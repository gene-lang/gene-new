#!/usr/bin/env gene run
# =============================================================================
# Gene agent gateway — milestone 8 of docs/ai-agent.md §12.
#
# One long-running process that owns every conversation. Sessions are actors
# (mailbox = per-session turn ordering; the scheduler runs sessions
# concurrently because model calls and tools ride os/exec-*-async on
# dedicated threads). Surfaces are thin HTTP+JSON clients:
#
#   POST /api/sessions                     -> {"id": "s1"}
#   GET  /api/sessions                     -> {"sessions": [...]}
#   POST /api/sessions/:id/messages        {"text": "..."} -> 202
#   GET  /api/sessions/:id/events?cursor=N -> long-poll {"events": [...], "cursor": M}
#   GET  /                                 -> embedded web chat page
#
# Config: GENE_GATEWAY_HOST (default 127.0.0.1), GENE_GATEWAY_PORT (8090),
# GENE_GATEWAY_TOKEN (optional bearer token; open when unset — bind localhost).
# Model/backend config is shared with examples/ai_agent.gene (OPENAI_* env);
# with no model token, sessions run the offline demo transport.
# =============================================================================

(mod agent-gateway
  @doc "multi-session gateway over the ai_agent turn loop (§12 milestone 8)")

(import os [get-env exec-async Env Exec])
(import json [parse stringify JsonError])
(import str [split trim join starts_with?])
(import std/stream [to_stream filter each into])
(import std/parse [parse_int])
(import net/http [Server serve Response])
(import [gene-system-prompt system-item user-item run-turn live-transport
         demo-transport-for max-tool-turns append model auth-token]
        from "./ai_agent")
(import serde [write-data read-data])
(import db/sqlite [open : sqlite-open])

(var gw-host (get-env Env "GENE_GATEWAY_HOST" "127.0.0.1"))
(var gw-port (parse_int (get-env Env "GENE_GATEWAY_PORT" "8090")))
(var gw-token (get-env Env "GENE_GATEWAY_TOKEN" ""))
# Optional persistence (docs/ai-agent.md §12 milestone 11): set GENE_GATEWAY_DB
# to a sqlite path and sessions survive restarts — transcripts and event logs
# are pure data, stored as serde text (docs/proposals/serialization.md §4).
(var gw-db-path (get-env Env "GENE_GATEWAY_DB" ""))

# Telegram channel (docs/ai-agent.md §12.6). Outbound HTTPS only: a getUpdates
# long-poll rides os/exec-async, so no inbound port, webhook, or TLS server.
(var tg-token (get-env Env "TELEGRAM_BOT_TOKEN" ""))
(var tg-base  (get-env Env "TELEGRAM_API_BASE" "https://api.telegram.org"))
(var tg-allowed (get-env Env "TELEGRAM_ALLOWED_CHAT_IDS" ""))

# -----------------------------------------------------------------------------
# Sessions. Each is an actor whose handler runs one user turn; the mailbox
# gives per-session ordering, the scheduler gives cross-session concurrency.
# Events are a versioned log (§12.3) that long-poll clients read by cursor.
# -----------------------------------------------------------------------------

(var sessions {})
(var session-seq (cell 0))

(var gw-db (cell nil))

(fn persist-session [id, items, events, next-v]
  (if (= (gw-db ~ Cell/get) nil)
    nil
    (try
      ((gw-db ~ Cell/get) ~ execute
        "insert or replace into sessions(id, data) values (?, ?)"
        id
        (write-data {^items (items ~ Cell/get)
                     ^events (events ~ Cell/get)
                     ^next-v (next-v ~ Cell/get)}))
    catch * (println $"persist failed for session ${id}"))))

# on-event: nil, or (fn [event] ...) called after each event is logged — how
# push surfaces (Telegram) mirror the log without polling it. It runs inside
# the session actor's turn fiber, so per-session ordering carries over.
# saved: nil, or a restored {^items ^events ^next-v} snapshot from the db.
(fn make-session [id, on-event, saved]
  (var events (cell (if (= saved nil) [] saved/events)))
  (var next-v (cell (if (= saved nil) 0 saved/next-v)))
  (var items (cell (if (= saved nil)
                     [(system-item gene-system-prompt)]
                     saved/items)))
  (fn push-event [type : Str, text : Str]
    (next-v ~ Cell/set (+ (next-v ~ Cell/get) 1))
    (var event {^v (next-v ~ Cell/get) ^type type ^text text})
    (events ~ Cell/set (append (events ~ Cell/get) event))
    (if (= on-event nil)
      nil
      (try (on-event event) catch * nil)))
  (var transport (if (= auth-token nil) (demo-transport-for) live-transport))
  (var turn-actor
    (actor/spawn ^init (fn [] 0)
      ^handle (fn [ctx, state, text]
        (push-event "user" text)
        (items ~ Cell/set
          (run-turn transport
                    (append (items ~ Cell/get) (user-item text))
                    (fn [t] (if (= t "") nil (push-event "text" t)))
                    (fn [d] (if (= d "") nil (push-event "text_delta" d)))
                    max-tool-turns))
        (push-event "turn_done" "")
        (persist-session id items events next-v)
        (actor/continue state))))
  {^id id ^actor turn-actor ^events events ^next-v next-v})

(fn events-after [s, cursor : Int]
  ((to_stream (s/events ~ Cell/get))
    ~ filter (fn [e] (> e/v cursor))
    ; ~ into []))

(fn max-event-v [evs, fallback : Int] : Int
  (var m (cell fallback))
  ((to_stream evs)
    ~ each (fn [e] (if (> e/v (m ~ Cell/get)) (m ~ Cell/set e/v) nil)))
  (m ~ Cell/get))

# -----------------------------------------------------------------------------
# Telegram channel (§12.6). An adapter task long-polls getUpdates; messages
# from allowlisted chats route into per-chat sessions; replies stream back by
# sendMessage plus size-throttled editMessageText, with a final edit on
# turn_done. Every Telegram call is curl over os/exec-async, so the poll and
# the sends never block other sessions or the HTTP listener.
# -----------------------------------------------------------------------------

(fn tg-call [method : Str, payload]
  (await (exec-async Exec ^cmd "curl"
            ^args ["-sS" "-X" "POST" $"${tg-base}/bot${tg-token}/${method}"
                   "-H" "Content-Type: application/json"
                   "-d" (stringify payload)]
            ^timeout-ms 30000 ^max-bytes 400000)))

(fn tg-send-message [chat-id, text : Str]
  # returns the sent message_id, or nil
  (if (= text "")
    nil
    (try
      (var r (tg-call "sendMessage" {^chat_id chat-id ^text text}))
      (var resp (parse r/stdout))
      (if (= resp/ok true) resp/result/message_id nil)
    catch * nil)))

(fn tg-edit-message [chat-id, message-id, text : Str]
  (if (|| (= message-id nil) (= text ""))
    nil
    (do
      (try (tg-call "editMessageText"
                    {^chat_id chat-id ^message_id message-id ^text text})
      catch * nil)
      nil)))

# Outbound path. Session events are mirrored to Telegram through a queue: the
# session's on-event hook does a non-blocking try-send (it may run inside a
# native render callback, where suspending is not allowed), and a dedicated
# sender fiber drains the queue and talks to Telegram — its awaits park
# properly, so a slow Telegram call never stalls a turn or another session.
# Entries cross the channel as JSON strings: channel items must be Send-safe
# (immutable), which mutable event maps are not.
(var tg-outbox (channel ^capacity 1024))

(fn make-telegram-sender [chat-id]
  (fn [event]
    (if (tg-outbox ~ Channel/try-send
          (stringify {^chat_id chat-id ^event event}))
      nil
      (println $"telegram: outbox full, dropped event for chat ${chat-id}"))))

# Per-chat streaming state for the sender fiber: deltas accumulate into one
# message edited every ~200 new characters (size-based throttle) and
# finalized on turn_done; non-streamed lines go out as individual messages.
(var tg-chat-state {})

(fn tg-state-for [chat-id]
  (var key $"${chat-id}")
  (var st (tg-chat-state ~ Map/get key))
  (if (= st void)
    (do
      (set st {^pending (cell "") ^sent-id (cell nil) ^sent-len (cell 0)})
      (tg-chat-state ~ Map/put! key st)
      st)
    st))

(fn tg-dispatch [raw : Str]
  (var entry (parse raw))
  (var chat-id entry/chat_id)
  (var event entry/event)
  (var st (tg-state-for chat-id))
  (match event/type
    (when "text_delta"
      (st/pending ~ Cell/set $"${(st/pending ~ Cell/get)}${event/text}")
      (var text (st/pending ~ Cell/get))
      (if (= (st/sent-id ~ Cell/get) nil)
        (do
          (st/sent-id ~ Cell/set (tg-send-message chat-id text))
          (st/sent-len ~ Cell/set text/~size))
        (if (>= (- text/~size (st/sent-len ~ Cell/get)) 200)
          (do
            (tg-edit-message chat-id (st/sent-id ~ Cell/get) text)
            (st/sent-len ~ Cell/set text/~size))
          nil)))
    (when "text"
      (tg-send-message chat-id event/text)
      nil)
    (when "turn_done"
      (var text (st/pending ~ Cell/get))
      (if (&& (! (= (st/sent-id ~ Cell/get) nil))
              (> text/~size (st/sent-len ~ Cell/get)))
        (tg-edit-message chat-id (st/sent-id ~ Cell/get) text)
        nil)
      (st/pending ~ Cell/set "")
      (st/sent-id ~ Cell/set nil)
      (st/sent-len ~ Cell/set 0))
    (else nil)))

(fn telegram-sender-loop []
  (var entry nil)
  (loop
    (set entry (tg-outbox ~ Channel/recv))
    (try
      (tg-dispatch entry)
    catch * nil)))

(fn tg-chat-allowed? [chat-id] : Bool
  (if (= tg-allowed "*")
    true
    (do
      (var key $"${chat-id}")
      (var found (cell false))
      ((to_stream (split tg-allowed ","))
        ~ each (fn [entry]
            (if (= (trim entry) key) (found ~ Cell/set true) nil)))
      (found ~ Cell/get))))

(fn tg-session-for [chat-id]
  (var id $"tg-${chat-id}")
  (var s (sessions ~ Map/get id))
  (if (= s void)
    (do
      (set s (make-session id (make-telegram-sender chat-id) nil))
      (sessions ~ Map/put! id s)
      s)
    s))

(fn tg-handle-update [u]
  (var msg u/message)
  (if (= msg void)
    nil
    (do
      (var chat-id msg/chat/id)
      (var text msg/text)
      (if (|| (= chat-id void) (= text void) (= text nil) (= text ""))
        nil
        (if (tg-chat-allowed? chat-id)
          (do
            (var s (tg-session-for chat-id))
            (s/actor ~ actor/send text))
          (println $"telegram: dropped message from unlisted chat ${chat-id} - add it to TELEGRAM_ALLOWED_CHAT_IDS to allow"))))))

# One getUpdates long-poll round. Loop-local state lives in the fn body (fresh
# scope per call) because re-`var` inside a loop body is a duplicate binding.
(fn telegram-poll-once [offset]
  (var r (await (exec-async Exec ^cmd "curl"
            ^args ["-sS" $"${tg-base}/bot${tg-token}/getUpdates?timeout=50&offset=${(offset ~ Cell/get)}"]
            ^timeout-ms 65000 ^max-bytes 1000000)))
  (if (= r/status 0)
    (do
      (var resp (parse r/stdout))
      (if (= resp/ok true)
        ((to_stream resp/result)
          ~ each (fn [u]
              (if (>= u/update_id (offset ~ Cell/get))
                (offset ~ Cell/set (+ u/update_id 1))
                nil)
              (tg-handle-update u)))
        (sleep 2000)))
    (sleep 2000)))

(fn telegram-loop []
  (var offset (cell 0))
  (loop
    (try
      (telegram-poll-once offset)
    catch * (sleep 2000))))

# -----------------------------------------------------------------------------
# HTTP API.
# -----------------------------------------------------------------------------

(fn json-response [status : Int, value]
  (Response ^status status
            ^headers {^content-type "application/json"}
            ^body (stringify value)))

(fn authorized? [req]
  (if (= gw-token "")
    true
    (do
      (var h req/headers/authorization)
      (if (= h void)
        false
        (= h $"Bearer ${gw-token}")))))

(fn create-session []
  (session-seq ~ Cell/set (+ (session-seq ~ Cell/get) 1))
  (var id $"s${(session-seq ~ Cell/get)}")
  (sessions ~ Map/put! id (make-session id nil nil))
  (json-response 200 {^id id}))

(fn list-sessions []
  (var out (cell []))
  (sessions/%to_pairs_stream
    ~ each (fn [pair]
        (var [k, s] pair)
        (out ~ Cell/set
          (append (out ~ Cell/get)
                  {^id k ^events (s/next-v ~ Cell/get)}))))
  (json-response 200 {^sessions (out ~ Cell/get)}))

(fn post-message [id : Str, req]
  (var s (sessions ~ Map/get id))
  (if (= s void)
    (json-response 404 {^error "no such session"})
    (try
      (var body (parse req/body))
      (if (|| (= body/text void) (= body/text nil) (= body/text ""))
        (json-response 400 {^error "missing text"})
        (do
          (s/actor ~ actor/send body/text)
          (json-response 202 {^ok true})))
    catch (JsonError ^message m)
      (json-response 400 {^error m}))))

# Long-poll: return events after ^cursor as soon as any exist, waiting up to
# ~20s. A handler parked in sleep does not stall other requests (task-per-
# request dispatch), so this works without streaming responses (§12.9 gap 2).
(fn get-events [id : Str, req]
  (var s (sessions ~ Map/get id))
  (if (= s void)
    (json-response 404 {^error "no such session"})
    (do
      (var cursor 0)
      (if (= req/params/cursor void)
        nil
        (try
          (set cursor (parse_int req/params/cursor))
        catch * nil))
      (var out (cell (events-after s cursor)))
      (var waited (cell 0))
      (while (&& (empty? (out ~ Cell/get)) (< (waited ~ Cell/get) 200))
        (sleep 100)
        (waited ~ Cell/set (+ (waited ~ Cell/get) 1))
        (out ~ Cell/set (events-after s cursor)))
      (var evs (out ~ Cell/get))
      (json-response 200 {^events evs
                          ^cursor (max-event-v evs cursor)}))))

(var web-page """<!doctype html>
<meta charset="utf-8">
<title>Gene Agent Gateway</title>
<style>
body { font-family: ui-monospace, monospace; max-width: 52rem; margin: 2rem auto; padding: 0 1rem; }
#log { white-space: pre-wrap; border: 1px solid #8884; padding: 1rem; min-height: 16rem; }
.user { color: #06c; } .text { color: inherit; } .muted { color: #888; }
form { display: flex; gap: .5rem; margin-top: .75rem; }
input { flex: 1; font: inherit; padding: .4rem; }
</style>
<h1>Gene Agent Gateway</h1>
<div id="log" class="muted">connecting...</div>
<form id="f"><input id="t" autofocus placeholder="message..."><button>send</button></form>
<script>
var tok = localStorage.gwToken || new URLSearchParams(location.search).get('token') || '';
if (tok) localStorage.gwToken = tok;
function hdrs(json) {
  var h = {};
  if (json) h['content-type'] = 'application/json';
  if (tok) h['authorization'] = 'Bearer ' + tok;
  return h;
}
var log = document.getElementById('log');
var sid = null, cursor = 0, streaming = false;
function show(cls, text) {
  if (log.classList.contains('muted')) { log.textContent = ''; log.classList.remove('muted'); }
  var span = document.createElement('span');
  span.className = cls;
  span.textContent = text;
  log.appendChild(span);
  log.scrollTop = log.scrollHeight;
}
function render(ev) {
  if (ev.type === 'user') { if (streaming) { show('text', '\n'); streaming = false; } show('user', 'you> ' + ev.text + '\n'); }
  else if (ev.type === 'text_delta') { if (!streaming) { show('text', 'agent> '); streaming = true; } show('text', ev.text); }
  else if (ev.type === 'text') { if (streaming) { show('text', '\n'); streaming = false; } show('text', 'agent> ' + ev.text + '\n'); }
  else if (ev.type === 'turn_done') { if (streaming) { show('text', '\n'); streaming = false; } }
}
function poll() {
  fetch('/api/sessions/' + sid + '/events?cursor=' + cursor, { headers: hdrs(false) })
    .then(function (r) { return r.json(); })
    .then(function (d) {
      (d.events || []).forEach(render);
      if (d.cursor > cursor) cursor = d.cursor;
      poll();
    })
    .catch(function () { setTimeout(poll, 1000); });
}
fetch('/api/sessions', { method: 'POST', headers: hdrs(false) })
  .then(function (r) { return r.json(); })
  .then(function (d) { sid = d.id; show('muted', 'session ' + sid + '\n'); poll(); });
document.getElementById('f').addEventListener('submit', function (e) {
  e.preventDefault();
  var t = document.getElementById('t');
  if (!t.value || !sid) return;
  fetch('/api/sessions/' + sid + '/messages',
        { method: 'POST', headers: hdrs(true), body: JSON.stringify({ text: t.value }) });
  t.value = '';
});
</script>
""")

(fn route [req]
  (var parts (split req/path "/"))
  (if (= req/path "/")
    (Response ^status 200
              ^headers {^content-type "text/html; charset=utf-8"}
              ^body web-page)
    (if (= req/path "/api/sessions")
      (if (= req/method "POST")
        (create-session)
        (list-sessions))
      (if (&& (>= parts/~size 5)
              (= parts/1 "api")
              (= parts/2 "sessions"))
        (match parts/4
          (when "messages"
            (if (= req/method "POST")
              (post-message parts/3 req)
              (json-response 405 {^error "method not allowed"})))
          (when "events" (get-events parts/3 req))
          (else (json-response 404 {^error "not found"})))
        (json-response 404 {^error "not found"})))))

(fn handle [req]
  (if (authorized? req)
    (route req)
    (json-response 401 {^error "unauthorized"})))

# -----------------------------------------------------------------------------
# Persistence bootstrap (§12 milestone 11). Sessions restore with their event
# log and transcript; Telegram sessions (tg-<chat-id>) reattach their sender
# hook so replies keep flowing after a restart. session-seq resumes past the
# highest restored s<N> id so new ids never collide.
# -----------------------------------------------------------------------------

(fn restore-session-id-seq [id : Str]
  (if (starts_with? id "s")
    (try
      (var n (parse_int ((split id "s") ~ join "")))
      (if (> n (session-seq ~ Cell/get))
        (session-seq ~ Cell/set n)
        nil)
    catch * nil)
    nil))

(fn restore-sessions []
  (var rows ((gw-db ~ Cell/get) ~ query "select id, data from sessions"))
  (var count (cell 0))
  (for row in rows
    (try
      (var id row/id)
      (var saved (read-data row/data))
      (var hook
        (if (starts_with? id "tg-")
          (make-telegram-sender ((split id "tg-") ~ join ""))
          nil))
      (sessions ~ Map/put! id (make-session id hook saved))
      (restore-session-id-seq id)
      (count ~ Cell/set (+ (count ~ Cell/get) 1))
    catch * (println $"failed to restore session ${row/id}")))
  (count ~ Cell/get))

(fn open-gateway-db []
  (if (= gw-db-path "")
    nil
    (do
      (gw-db ~ Cell/set (sqlite-open gw-db-path))
      ((gw-db ~ Cell/get) ~ exec
        "create table if not exists sessions (id text primary key, data text not null)")
      (var n (restore-sessions))
      (println $"Persistence enabled - ${gw-db-path} (${n} sessions restored)"))))

(fn main [args]
  (open-gateway-db)
  (println $"Gene agent gateway - http://${gw-host}:${gw-port} (model ${model})")
  (if (= auth-token nil)
    (println "No model API token set - sessions use the offline demo transport.")
    nil)
  (if (= gw-token "")
    (println "GENE_GATEWAY_TOKEN unset - API is open; keep the bind on localhost.")
    nil)
  (if (= tg-token "")
    (do
      (println "TELEGRAM_BOT_TOKEN unset - Telegram channel disabled.")
      (serve (Server ^host gw-host ^port gw-port) handle))
    (scope
      (spawn (telegram-loop))
      (spawn (telegram-sender-loop))
      (println $"Telegram channel enabled - long-polling ${tg-base}")
      (serve (Server ^host gw-host ^port gw-port) handle))))
