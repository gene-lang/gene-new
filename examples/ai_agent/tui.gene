#!/usr/bin/env gene run
# =============================================================================
# Gene AI coding agent — MVP (examples/ai_agent/design.md milestones 1-4).
#
#   * Talks to Codex's ChatGPT-account Responses backend by default, or to any
#     OpenAI-compatible Chat Completions endpoint (MiniMax, DeepSeek, vLLM,
#     api.openai.com, ...) configured entirely from the environment. Streaming
#     in both modes.
#   * Transport is native libcurl through net/http_client (curl(1) is a
#     discovery fallback), so model calls never block the scheduler.
#   * Tools: read_file / write_file / edit_file / list_dir / run_shell / grep,
#     each declared ONCE as a typed Tool value — the model-facing JSON schema,
#     argument validation, risk class, and handler all derive from that single
#     declaration (examples/ai_agent/design.md §6, slice A).
#   * §8.5 catastrophe guard: host-destroying commands (rm -rf of protected
#     roots, mkfs, fork bombs, shutdown, DROP DATABASE) are denied; destructive
#     git/db/infra commands take one explicit confirmation; file paths are
#     realpath-confined to the workspace; timeouts + output caps apply and
#     truncation is surfaced; known secrets are redacted everywhere. Routine
#     work runs without prompts. GENE_AGENT_GUARD=0 disables risk
#     classification, but not the mediated foreground-lifetime contract.
#   * Every action is appended to a versioned event log (§9.2): /trace queries
#     it, and /repl binds a stable `session` object with message-based
#     mutations (add_tool / remember / subscribe / trace / resume).
#   * Ncurses-backed prompt on TTY; paste and Shift+Enter/Alt+Enter keep newlines.
#
# Run live (Codex Responses backend, the default):
#   OPENAI_AUTH_TOKEN=... gene run examples/ai_agent/tui.gene
# Run live against any OpenAI-compatible chat-completions endpoint, e.g. MiniMax:
#   OPENAI_BASE_URL=https://api.minimax.io/v1 OPENAI_MODEL=MiniMax-M2 \
#   OPENAI_API_KEY=... gene run examples/ai_agent/tui.gene
# Wire shape is OPENAI_API=responses|chat; it defaults to responses for the
# Codex backend and chat for any custom OPENAI_BASE_URL.
# Tools auto-approve by default (single-user agent); set GENE_AGENT_APPROVE_ALL=0
# to be prompted before writes and shell commands.
# Local persistence: GENE_AGENT_STATE selects `fs:<path>` or
# `db:sqlite:<path>`. When it is unset or blank, GENE_AGENT_HOME supplies the
# filesystem path. Reusing the same store restores application/session state
# automatically.
# Run demo:   gene run examples/ai_agent/tui.gene         (no token -> offline demo
#             that drives the same loop with a scripted transport, incl. a
#             tool_call round trip — needs no network)
#
# Auth is a bearer token from `OPENAI_AUTH_TOKEN`, `OPENAI_API_KEY`, or
# `CODEX_ACCESS_TOKEN` (checked in that order).
# =============================================================================

(mod ai_agent
  @doc "a terminal coding agent over the OpenAI Responses API")

(import [AgentApplication FileViewController LogTailController
         OutputController ReplController ShellController StatsController
         TerminalController Tool Worker active_application active_turn_task
         after_prefix agent_artifacts agent_events agent_evidence
         agent_instruction_records agent_log agent_result_report
         agent_result_text agent_store api_flavor append
         append_agent_transcript! append_worker_transcript!
         application_acquire_workspace application_append_projection_output!
         application_attach_worker_pane application_attach_worker_pane_as
         application_begin_worker_operation! application_call_worker
         application_cancel_worker application_close_pane
         application_delete_artifact! application_emit
         application_find_agent application_find_pane
         application_find_pane_worker application_find_stopped_worker_kind
         application_find_worker application_find_worker_kind
         application_finish_agent_operation! application_new_worker
         application_new_worker_from application_open_pane
         application_pane_ids_for_worker application_pin_artifact!
         application_release_workspace application_request_worker_attention
         application_send_worker_input application_set_projection_output!
         application_shutdown application_spawn_agent application_stop_agent
         application_stop_worker approve_all artifact_content artifact_find
         artifacts_report auth_token base begin_turn! blank_line?
         bounded_list_tail bounded_worker_append! checkpoint_agent_state!
         checkpoint_local_application? classify_command
         client_surface_checkpoint_hook client_surface_record_loader
         close_agent_state context_stats current_turn
         demo_transport_for emit_event! event_echo event_matches?
         event_subscriptions file_changes file_diff_report flag_enabled?
         format_event_with_filters gateway_api gene_system_prompt
         guard_enabled? guard_shell ignore_stream_delta init_agent_state
         initial_items interactive_confirm interactive_resume_turn
         interactive_transport live_transport load_memory load_session
         make_application max_tool_rounds model open_client_store
         parse_trace_filters present?
         project_progress_report reasoning_effort
         reasoning_effort_levels_text redact redact_any
         refresh_system_memory
         register_tool! register_worker_operation! repl_restart_factory
         restore_application! restore_dynamic_registrations! restore_events
         restore_reasoning_effort! resume_enabled? run_repl_worker_command
         run_shell_worker_command run_shell_worker_command_unchecked
         run_turn_in run_turn_tracked run_turn_tracked_in safe_path
         save_agent_state save_agent_state_with_reason
         session_config_snapshot start_terminal_pump!
         start_workspace_heartbeat! state_display state_enabled?
         stats_worker_text surface_draft_max_bytes surface_history_max
         surface_history_recorder surface_overlay_max_items
         surface_snapshot system_item
         terminal_leader_code terminal_leader_label tool_names tool_registry
         trace_report transcript_max_bytes ui_escape_poll ui_refresh
         undo_with_workspace_lease user_item utf8_prefix
         valid_reasoning_effort? worker_history_push! worker_operation_for
         worker_operations_for_kind workspace_real workspace_root]
        from "./core")
(import [prepare_gateway serve_gateway stop_gateway run_gateway]
        from "./gateway_adapter")
(import [remote_transport ClientTransportError]
        from "./client_transport")
(import [Pane SurfaceAttachment create_surface emit_surface_event!]
        from "./surface")
(import os [get_env env? exec exec_async exec_stream_async
            exec_stdio_async
            executable_path
            begin_interrupt take_interrupt end_interrupt
            monotonic_ms process_id
            stdin_tty? read_line
            Env Exec Pty OsError])
(import terminal [open : terminal_open close : terminal_close
                  next_update : terminal_next_update
                  snapshot : terminal_snapshot
                  capture_text : terminal_capture_text
                  write : terminal_write key : terminal_key
                  paste : terminal_paste focus : terminal_focus
                  mouse : terminal_mouse
                  resize : terminal_resize
                  signal : terminal_signal stop : terminal_stop
                  request_stop : terminal_request_stop
                  Session : TerminalSession TerminalError])
(import curses [open : curses_open close : curses_close
                read_input : curses_read_input
                refresh_input : curses_refresh_input escape_pressed?
                draw : curses_draw next_event : curses_next_event
                Screen CursesError])
(import json [parse stringify JsonError])
(import crypto [sha256])
(import str [join split starts_with? ends_with? contains? lower trim byte_size
             slice_bytes])
(import std/stream [to_stream map filter take into each])
(import std/parse [parse_int read_all ParseError])
(import Fs [read_text write_text exists? remove list_dir real_path
            ReadDir WriteDir ReadWriteDir])
(import net/http_client [Http stream HttpClientError])
(import db/sqlite [open : sqlite_open DbError])
(import store/fs [open : store_fs_open StoreError])
(import store/sqlite [open : store_sqlite_open])
(import repl [run : run_repl_session open : repl_open
              eval_source : repl_eval
