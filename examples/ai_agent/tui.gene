              eval_guard_end : repl_eval_guard_end])
(import log [new_logger info! warn! error! debug! trace!])

(var user_screen (cell nil))
(var user_input_suspended (cell false))
(var active_editor (cell nil))
(var confirmation_active (cell false))
(var active_repaint_pending (cell false))
(var interactive_transcript (cell nil))
(var interactive_memory (cell []))
(fn pane_pending_marker [pane] : Str
  (if (pane/pending_visible ~ Cell/get)
    "assistant|...\n"
    (if (!= (pane/current_task ~ Cell/get) nil) "assistant|   \n" "")))

(fn main_pending_marker [app] : Str
  (if (|| (== app nil) (== app/local_surface nil))
    ""
    (if (app/local_surface/main_pending_visible ~ Cell/get)
      "agent> ...\n"
      (if (!= (app/main_agent/current_task ~ Cell/get) nil)
        "agent>    \n" ""))))

(fn output_with_pending_marker [output : Str, marker : Str] : Str
  (if (== marker "")
    (then output)
    (else
      (var separator
        (if (|| (== output "") (ends_with? output "\n")) "" "\n"))
      $"${output}${separator}${marker}")))

(fn main_presented_output [app, transcript] : Str
  (var notice
    (if (|| (== app nil) (== app/local_surface nil)) ""
      (app/local_surface/help_notice ~ Cell/get)))
  (var base (transcript ~ Cell/get))
  (var separator
    (if (|| (== base "") (ends_with? base "\n")) "" "\n"))
  (var presented
    (if (== notice "") base
      $"${base}${separator}\n${notice}"))
  (output_with_pending_marker
    presented (main_pending_marker app)))

(fn application_pane_views [app]
  (var surface app/local_surface)
  (var views (cell []))
  (for pane in (if (== surface nil) [] (surface/panes ~ Cell/get))
    (if_not (pane/hidden ~ Cell/get)
      (var marker
        (if (== (surface/focused_pane ~ Cell/get) pane/id) "*" ""))
      (var unread
        (if (== pane/kind "agent")
          (match (pane/worker/result ~ Cell/get)
            (when (m : Map) (if (== m/read false) "!" ""))
            (else ""))
          ""))
      ((views ~ Cell/get) ~ List/push!
        {^title $"[${pane/id}]${marker}${unread} ${pane/title} (${(pane/status ~ Cell/get)})"
         ^output
           (output_with_pending_marker
             (if (== pane/kind "terminal")
               (pane/worker/controller/restored_text ~ Cell/get)
               (pane/output ~ Cell/get))
             (pane_pending_marker pane))
         ^scroll (pane/scroll ~ Cell/get)
         ^terminal_id
           (if (&& (== pane/kind "terminal")
                    pane/worker/controller/session)
             pane/worker/controller/session/id 0)
         ^focused (== (surface/focused_pane ~ Cell/get) pane/id)
         ^maximized (== (surface/maximized_pane ~ Cell/get) pane/id)})))
  (views ~ Cell/get))

(fn application_scroll_target! [app, main_scroll, direction : Int,
                                amount : Int]
  (var surface app/local_surface)
  (var pane_id
    (if surface (surface/focused_pane ~ Cell/get)))
  (var pane
    (if pane_id (application_find_pane app pane_id)))
  (var target (if (== pane nil) main_scroll pane/scroll))
  (var current (target ~ Cell/get))
  (target ~ Cell/set
    (if (> direction 0)
      (+ current amount)
      (if (> current amount) (- current amount) 0)))
  (if pane pane/id))

(fn application_pane_page_rows [app, rows : Int] : Int
  (var surface app/local_surface)
  (var available (if (> rows 5) (- rows 5) 1))
  (var pane_count 0)
  (for pane in (if (== surface nil) [] (surface/panes ~ Cell/get))
    (if_not (pane/hidden ~ Cell/get)
      (set pane_count (+ pane_count 1))))
  (var page
    (if (|| (== surface nil) (== (surface/focused_pane ~ Cell/get) nil))
      available
      (if (> pane_count 0)
        (if (< available (* pane_count 7))
          (- available 1)
          (- (/ available pane_count) 1))
        available)))
  (if (> page 0) page 1))

(fn application_cycle_visible_pane! [app, direction : Int]
  (var surface app/local_surface)
  (if_not (== surface nil)
    (var ids [0])
    (for pane in (surface/panes ~ Cell/get)
      (if_not (pane/hidden ~ Cell/get) (ids ~ List/push! pane/id)))
    (var current
      (if (== (surface/focused_pane ~ Cell/get) nil)
        0 (surface/focused_pane ~ Cell/get)))
    (var index 0)
    (repeat i in ids/~size
      (if (== ids/%i current) (set index i)))
    (var next (+ index direction))
    (if (< next 0) (set next (- ids/~size 1)))
    (if (>= next ids/~size) (set next 0))
    (var target ids/%next)
    (surface/focused_pane ~ Cell/set (if (== target 0) nil target))
    (surface/maximized_pane ~ Cell/set nil)
    target))

(fn undo_command [line : Str]
  (var app (active_application ~ Cell/get))
  (var worker_id (if (== app nil) "main" app/main_agent/id))
  (if (== line "/undo")
    (undo_with_workspace_lease app worker_id nil)
    (try
      (undo_with_workspace_lease app worker_id
        (parse_int (trim (after_prefix line "/undo "))))
    catch _
      "usage: /undo [change-id]")))

# -----------------------------------------------------------------------------
# Offline demo transport: turn 1 asks to list the workspace, turn 2 answers.
# Proves the full tool_call loop with no network or key.
# -----------------------------------------------------------------------------

(fn run_demo []
  (println "No OPENAI_AUTH_TOKEN, OPENAI_API_KEY, or CODEX_ACCESS_TOKEN set — running the offline demo.")
  (println "user> what's in this directory?")
  (begin_turn!)
  (emit_event! "user_input" {^text "what's in this directory?"})
  (var items [(system_item gene_system_prompt)
              (user_item "what's in this directory?")])
  (run_turn_tracked (demo_transport_for) items
    (fn [text] (println $"agent> ${text}"))
    ignore_stream_delta
    max_tool_rounds
    emit_event!)
  (println "Demo complete. Set OPENAI_AUTH_TOKEN, OPENAI_API_KEY, or CODEX_ACCESS_TOKEN to go live."))

(fn run_one_shot [task : Str]
  (init_agent_state)
  (start_workspace_heartbeat!)
  (restore_reasoning_effort!)
  (restore_dynamic_registrations! nil)
  (println $"Gene AI agent - model ${model}")
  (println $"user> ${task}")
  (if (== auth_token nil)
    (println "No OPENAI_AUTH_TOKEN, OPENAI_API_KEY, or CODEX_ACCESS_TOKEN set - using offline demo transport."))
  (var streaming (cell false))
  (var transport (if (== auth_token nil) (demo_transport_for) live_transport))
  (var memory (load_memory))
  (begin_turn!)
  (emit_event! "user_input" {^text task})
  (var result_items
    (run_turn_tracked transport
              (append (initial_items memory) (user_item task))
              (fn [text]
                (if_yes (Cell/get streaming)
                  (println "")
                  (Cell/set streaming false))
                (if_not (== text "")
                  (println $"agent> ${text}")))
              (fn [text]
                (if_not (== text "")
                  (if_not (Cell/get streaming)
                    (print "agent> ")
                    (Cell/set streaming true))
                  (print text)))
              max_tool_rounds
              emit_event!))
  (save_agent_state result_items $"Gene AI agent - model ${model}\nuser> ${task}\n" memory)
  (if (Cell/get streaming)
    (println "")))

(fn exit_word? [line]
  (["exit" "quit"] ~ contains? line))

(fn append_transcript [transcript, text : Str]
  (var app (active_application ~ Cell/get))
  (if (&& (!= app nil) (== app/main_agent/transcript transcript))
    (then (append_agent_transcript! app/main_agent text))
    # Offline/demo callers without an application still stay bounded; shared
    # application snapshots always take the exact branch above.
    (else
      (var combined (join [(Cell/get transcript) text] ""))
      (var total (byte_size combined))
      (if (<= total transcript_max_bytes)
        (then (Cell/set transcript combined))
        (else
          (var marker "[older transcript rows were dropped]\n")
          (var budget (- transcript_max_bytes (byte_size marker)))
          (var start (- total budget))
          (var retained "")
          (var sliced (cell false))
          (while (&& (! (sliced ~ Cell/get)) (< start total))
            (try
              (set retained (slice_bytes combined start (- total start)))
              (sliced ~ Cell/set true)
            catch _ (set start (+ start 1))))
          (Cell/set transcript $"${marker}${retained}"))))))

(fn input_route_label []
  (var app (active_application ~ Cell/get))
  (if (|| (== app nil) (== app/local_surface nil))
    (then "[0 main]")
    (else
      (var pane_id (app/local_surface/focused_pane ~ Cell/get))
      (var pane
        (if pane_id (application_find_pane app pane_id)))
      (if (== pane nil) "[0 main]" $"[${pane/id} ${pane/kind}]"))))

(fn focused_terminal_pane [app]
  (var result nil)
  (if_not (|| (== app nil) (== app/local_surface nil))
    (var pane_id (app/local_surface/focused_pane ~ Cell/get))
    (var pane (if pane_id (application_find_pane app pane_id)))
    (if (&& pane (== pane/kind "terminal")) (set result pane)))
  result)

(fn terminal_pane_controlled? [pane] : Bool
  (var app (active_application ~ Cell/get))
  (if (&& pane app app/local_surface
          (== (app/local_surface/focused_pane ~ Cell/get) pane/id)
          (== (pane/worker/lifecycle ~ Cell/get) "running")
          (!= (pane/worker/status ~ Cell/get) "stopping")
          pane/worker/controller/session
          (== (pane/worker/controller/controller_surface_id ~ Cell/get)
              (app/local_surface/instance_id ~ Cell/get)))
    true false))

(fn editor_terminal_direct? [editor] : Bool
  (if (&& editor (editor/terminal_direct ~ Cell/get)
          (terminal_pane_controlled? editor/terminal_pane))
    true false))

(fn current_input_status []
  (var app (active_application ~ Cell/get))
  (var pane_id
    (if (|| (== app nil) (== app/local_surface nil)) nil
      (app/local_surface/focused_pane ~ Cell/get)))
  (var pane
    (if pane_id (application_find_pane app pane_id)))
  (if (== pane nil)
    (then
      (var progress (if app (app/progress ~ Cell/get)))
      (var progress_hint
        (if (|| (== progress nil) (== progress/objective "")) ""
          $" | ${progress/phase}/${progress/status}"))
      $"[0 main] Enter send | Tab complete | Ctrl-R history | Ctrl-E edit | /help | Esc cancel${progress_hint}")
    (else
      (var worker pane/worker)
      (var state
        (if (!= (worker/current_task ~ Cell/get) nil) "working"
          (worker/status ~ Cell/get)))
      (match pane/kind
        (when "agent"
          $"[${pane/id} agent ${worker/id}: ${state}] Enter send | /0 main | Esc cancel | PgUp/PgDn scroll")
        (when "shell"
          $"[${pane/id} shell ${worker/id}: ${state}] Enter run | /0 main | //literal slash | Ctrl-C cancel | PgUp/PgDn scroll")
        (when "repl"
          $"[${pane/id} repl ${worker/id}: ${state}] Enter eval | /0 main | //literal slash | Ctrl-C cancel | PgUp/PgDn scroll")
        (when "terminal"
          (if (editor_terminal_direct? (active_editor ~ Cell/get))
            $"[${pane/id} terminal ${worker/id}: direct/unmediated] ${terminal_leader_label} commands | Shift-PgUp scroll"
            (if (terminal_pane_controlled? pane)
              $"[${pane/id} terminal ${worker/id}: app commands] Esc direct | ${terminal_leader_label} literal | /help"
              $"[${pane/id} terminal ${worker/id}: ${state}] app commands | /worker ${worker/id} restart | /help")))
        (else
          $"[${pane/id} ${pane/kind} ${worker/id}: read-only] /0 main | PgUp/PgDn scroll | /close | /help")))))

(fn surface_route_input_capable? [app] : Bool
  (if (|| (== app nil) (== app/local_surface nil))
    (then true)
    (else
      (var pane_id (app/local_surface/focused_pane ~ Cell/get))
      (var pane (if pane_id (application_find_pane app pane_id)))
      (|| (== pane nil)
          (["agent" "shell" "repl" "log_tail"] ~ contains? pane/kind)))))

(fn editor_accepts_surface_text? [app, editor, text : Str] : Bool
  (|| (surface_route_input_capable? app)
      (starts_with? (editor_text (editor/values ~ Cell/get)) "/")
      (starts_with? text "/")))

(fn surface_route_history [app]
  (var surface app/local_surface)
  (var pane_id (surface/focused_pane ~ Cell/get))
  (var pane
    (if pane_id (application_find_pane app pane_id)))
  (var worker_id (if (== pane nil) app/main_agent/id pane/worker_id))
  (var histories (surface/input_histories ~ Cell/get))
  (var history (histories ~ Map/get worker_id))
  (if_yes (== history void)
    (set history (cell []))
    (histories ~ Map/put! worker_id history))
  history)

(fn surface_route_draft [app]
  (var surface app/local_surface)
  (var pane_id (surface/focused_pane ~ Cell/get))
  (var pane
    (if pane_id (application_find_pane app pane_id)))
  (var worker_id (if (== pane nil) app/main_agent/id pane/worker_id))
  (var drafts (surface/drafts ~ Cell/get))
  (var draft (drafts ~ Map/get worker_id))
  (if_yes (== draft void)
    (set draft (cell ""))
    (drafts ~ Map/put! worker_id draft))
  draft)

(fn surface_history_push! [history, value]
  ((history ~ Cell/get) ~ List/push! value)
  (if_yes (> ((history ~ Cell/get) ~ size) surface_history_max)
    (var current (history ~ Cell/get))
    (var first (- (current ~ size) surface_history_max))
    (var kept [])
    (repeat i in current/~size
      (if (>= i first) (kept ~ List/push! current/%i)))
    (history ~ Cell/set kept)))

(fn record_local_surface_history! [worker_id : Str, value : Str, surface_id]
  (var app (active_application ~ Cell/get))
  (if (&& app app/local_surface
          (|| (== surface_id nil)
              (== surface_id (app/local_surface/instance_id ~ Cell/get))))
    (then
      (var histories (app/local_surface/input_histories ~ Cell/get))
      (var history (histories ~ Map/get worker_id))
      (if (== history void)
        (then
          (set history (cell []))
          (histories ~ Map/put! worker_id history)))
      # Worker history stores the semantic input after routing. Surface recall
      # must restore the escape needed to submit a literal leading slash
      # through the command parser again.
      (surface_history_push! history
        (if (starts_with? value "/") $"/${value}" value)))))

(fn extension_views []
  (var app (active_application ~ Cell/get))
  (if (== app nil) [] (application_pane_views app)))

(fn find_extension [id : Int]
  (var app (active_application ~ Cell/get))
  (if app (application_find_pane app id)))

(fn ensure_user_screen []
  (if (== (user_screen ~ Cell/get) nil)
    (user_screen ~ Cell/set (curses_open)))
  (user_screen ~ Cell/get))

(fn close_user_input []
  (if_yes (!= (user_screen ~ Cell/get) nil)
    (curses_close (user_screen ~ Cell/get))
    (user_screen ~ Cell/set nil)))

(fn suspend_user_input []
  # Surface-local terminal handoffs must not let an event callback reopen
  # curses over the external editor or real shell while application fibers
  # continue progressing in the background.
  (user_input_suspended ~ Cell/set true)
  (close_user_input))

(fn resume_user_input []
  (user_input_suspended ~ Cell/set false))

(fn editor_chars [text : Str]
  # Graphemes are strings (unlike `chars`, whose Char values print as source
  # literals), and they keep combining sequences together during navigation.
  (graphemes text))

(fn editor_text [values]
  (join values ""))

(fn editor_cursor_byte [values, cursor : Int]
  (var prefix [])
  (repeat i in cursor
    (prefix ~ List/push! values/%i))
  (byte_size (editor_text prefix)))

(fn editor_insert! [editor, text : Str]
  (var values (editor/values ~ Cell/get))
  (var cursor (editor/cursor ~ Cell/get))
  (var current_text (editor_text values))
  (var remaining (- surface_draft_max_bytes (byte_size current_text)))
  (var accepted
    (if (<= remaining 0) ""
      (utf8_prefix text remaining)))
  (var additions (editor_chars accepted))
  (var updated [])
  (repeat i in values/~size
    (if (== i cursor)
      (for value in additions (updated ~ List/push! value)))
    (updated ~ List/push! values/%i))
  (if (== cursor values/~size)
    (for value in additions (updated ~ List/push! value)))
  (editor/values ~ Cell/set updated)
  (editor/cursor ~ Cell/set (+ cursor additions/~size))
  nil)

(fn editor_remove! [editor, index : Int]
  (var values (editor/values ~ Cell/get))
  (if (|| (< index 0) (>= index values/~size))
    (then false)
    (else
      (var updated [])
      (repeat i in values/~size
        (if (!= i index) (updated ~ List/push! values/%i)))
      (editor/values ~ Cell/set updated)
      true)))

(fn editor_set_text! [editor, text : Str]
  (var values (editor_chars text))
  (editor/values ~ Cell/set values)
  (editor/cursor ~ Cell/set values/~size)
  nil)

(fn editor_clear! [editor]
  (editor/values ~ Cell/set [])
  (editor/cursor ~ Cell/set 0)
  (editor/history_index ~ Cell/set editor/history/~size)
  (editor/draft ~ Cell/set "")
  nil)

(fn editor_history! [editor, direction : Int]
  (var history editor/history)
  (var index (editor/history_index ~ Cell/get))
  (if (&& (< direction 0) (> index 0))
    (then
      (if (== index history/~size)
        (editor/draft ~ Cell/set
          (editor_text (editor/values ~ Cell/get))))
      (set index (- index 1))
      (editor/history_index ~ Cell/set index)
      (editor_set_text! editor history/%index)
      true)
    (else
      (if (&& (> direction 0) (< index history/~size))
        (then
          (set index (+ index 1))
          (editor/history_index ~ Cell/set index)
          (editor_set_text! editor
            (if (== index history/~size)
              (editor/draft ~ Cell/get)
              history/%index))
          true)
        (else false)))))

(fn editor_home! [editor]
  (var values (editor/values ~ Cell/get))
  (var cursor (editor/cursor ~ Cell/get))
  (while (&& (> cursor 0) (!= values/%(- cursor 1) "\n"))
    (set cursor (- cursor 1)))
  (editor/cursor ~ Cell/set cursor))

(fn editor_end! [editor]
  (var values (editor/values ~ Cell/get))
  (var cursor (editor/cursor ~ Cell/get))
  (while (&& (< cursor values/~size) (!= values/%cursor "\n"))
    (set cursor (+ cursor 1)))
  (editor/cursor ~ Cell/set cursor))

(fn completion_item [value : Str, label : Str, detail : Str]
  {^value value ^label label ^detail detail})

(fn completion_labels [overlay]
  (var labels [])
  (if overlay
    (for item in overlay/items
      (labels ~ List/push!
        (if (== item/detail "") item/label
          $"${item/label}  ${item/detail}"))))
  labels)

(fn replace_last_token [text : Str, replacement : Str] : Str
  (var tokens (split text " "))
  (var rebuilt [])
  (repeat i in tokens/~size
    (if (< i (- tokens/~size 1))
      (rebuilt ~ List/push! tokens/%i)))
  (rebuilt ~ List/push! replacement)
  (rebuilt ~ join " "))

(fn worker_completion_items [app, prefix : Str, agents_only : Bool]
  (var out [])
  (for worker in (app/workers ~ Cell/get)
    (if_yes (|| (! agents_only) (== worker/kind "agent"))
      (var label (if worker/name worker/name worker/id))
      (if_yes (starts_with? label prefix)
        (out ~ List/push!
          (completion_item label label
            $"${worker/kind} ${(worker/status ~ Cell/get)}")))
      (if_yes (&& worker/name (starts_with? worker/id prefix))
        (out ~ List/push!
          (completion_item worker/id worker/id
            $"${worker/kind} ${(worker/status ~ Cell/get)}")))))
  out)

(fn pane_completion_items [app, prefix : Str, include_main : Bool]
  (var out [])
  (if (&& include_main (starts_with? "0" prefix))
    (out ~ List/push! (completion_item "0" "0" "main agent")))
  (for pane in (app/local_surface/panes ~ Cell/get)
    (var id $"${pane/id}")
    (if (starts_with? id prefix)
      (out ~ List/push!
        (completion_item id id
          $"${pane/kind} ${(pane/status ~ Cell/get)}"))))
  out)

(fn operation_visible_to_local? [operation] : Bool
  (&& (!= operation/enabled false)
      (operation/audience ~ contains? "local_user")))

(fn verb_completion_items [verbs, prefix : Str, base : Str]
  (var out [])
  (for verb in verbs
    (if (starts_with? verb prefix)
      (out ~ List/push! (completion_item $"${base}${verb} " verb "action"))))
  out)

(fn shell_completion_context [text : Str]
  # Lex only the current shell word. No expansion is executed; substitutions
  # and quote transitions in the middle of a token are intentionally
  # ambiguous and produce no candidates.
  (var values (editor_chars text))
  (var token [])
  (var token_start 0)
  (var state "plain")
  (var quote "")
  (var escaped false)
  (var ch "")
  (repeat i in values/~size
    (set ch values/%i)
    (if escaped
      (then
        (token ~ List/push! ch)
        (set escaped false))
      (else
        (match state
        (when "single"
          (if (== ch "'") (set state "plain")
            (token ~ List/push! ch)))
        (when "double"
          (if (== ch "\"")
            (set state "plain")
            (if (== ch "\\")
              (set escaped true)
              (if (|| (== ch "$") (== ch "`"))
                (return nil)
                (token ~ List/push! ch)))))
        (else
          (if (contains? " \t\n" ch)
            (then
              (set token [])
              (set token_start (+ i 1))
              (set quote ""))
            (else
              (if (== ch "\\")
                (set escaped true)
                (if (|| (== ch "$") (== ch "`"))
                  (return nil)
                  (if (|| (== ch "'") (== ch "\""))
                    (if (! (empty? token))
                      (then
                        (return nil))
                      (else
                        (set quote ch)
                        (set state (if (== ch "'") "single" "double"))))
                    (token ~ List/push! ch)))))))))))
  (if escaped (return nil))
  (var before [])
  (repeat j in token_start (before ~ List/push! values/%j))
  {^before (editor_text before) ^prefix (editor_text token) ^quote quote})

(fn shell_completion_path_parts [prefix : Str]
  (var parts (split prefix "/"))
  (var directories [])
  (repeat i in parts/~size
    (if (< i (- parts/~size 1))
      (directories ~ List/push! parts/%i)))
  (var last (- parts/~size 1))
  {^directory (directories ~ join "/")
   ^base (if (empty? parts) "" parts/%last)})

(fn shell_completion_render [context, candidate : Str]
  (var rendered candidate)
  (if (== context/quote "'")
    (if (contains? candidate "'") (return nil)
      (set rendered $"'${candidate}'"))
    (if (== context/quote "\"")
      (if (|| (contains? candidate "\"") (contains? candidate "\\"))
        (return nil)
        (set rendered $"\"${candidate}\""))
      (if (|| (contains? candidate " ") (contains? candidate "\t"))
        (if (contains? candidate "'") (return nil)
          (set rendered $"'${candidate}'")))))
  $"${context/before}${rendered}")

(fn workspace_path_completion_items [text : Str]
  (var out [])
  (var context (shell_completion_context text))
  (if (== context nil) (return out))
  (var path_parts (shell_completion_path_parts context/prefix))
  (var directory
    (if (== path_parts/directory "") "." path_parts/directory))
  (try
    (var checked_directory (safe_path directory))
    (for name in (list_dir ReadDir checked_directory)
      (if_yes (&& (< out/~size surface_overlay_max_items)
                  (starts_with? name path_parts/base))
        (var candidate
          (if (== path_parts/directory "") name
            $"${path_parts/directory}/${name}"))
        (var detail "workspace")
        (try
          (list_dir ReadDir (safe_path candidate))
          (set candidate $"${candidate}/")
          (set detail "workspace directory")
        catch _ nil)
        (var value (shell_completion_render context candidate))
        (if_yes value
          (out ~ List/push! (completion_item value candidate detail)))))
  catch _ nil)
  out)

(fn shell_route_completion_items [worker, text : Str]
  (var out (workspace_path_completion_items text))
  (var seen {})
  (for item in out (seen ~ Map/put! item/label true))
  (var context (shell_completion_context text))
  (if (== context nil) (return out))
  (for record in (worker/history ~ Cell/get)
    (for token in (split record/text " ")
      (if_yes (&& (< out/~size surface_overlay_max_items)
                  (!= token "")
                  (starts_with? token context/prefix)
                  (== (seen ~ Map/get token) void)
                  (! (contains? token "$")) (! (contains? token "`"))
                  (! (contains? token "'")) (! (contains? token "\""))
                  (! (contains? token "\\")))
        (var value (shell_completion_render context token))
        (if_yes value
          (seen ~ Map/put! token true)
          (out ~ List/push!
            (completion_item value token "shell history"))))))
  out)

(fn command_completion_items [text : Str]
  (var out [])
  (for spec in surface_command_specs
    (if (starts_with? spec/name text)
      (out ~ List/push!
        (completion_item spec/name spec/name spec/summary))))
  out)

(fn operation_argument_field [operation, parts]
  (var fields (operation/args ~ fields))
  (var index (- parts/~size 4))
  (if (&& (>= index 0) (< index fields/~size)) fields/%index))

(fn worker_command_completion_items [app, text : Str, parts]
  (var out [])
  (if (<= parts/~size 2)
    (then
      (var prefix (if (== parts/~size 2) parts/1 ""))
      (for item in (worker_completion_items app prefix false)
        (out ~ List/push!
          (completion_item $"/worker ${item/value} " item/label item/detail))))
    (else
      (var target parts/1)
      (var worker (application_find_worker app target))
      (if_yes worker
        (var operation_name parts/2)
        (if (<= parts/~size 3)
          (then
            (for operation in (worker_operations_for_kind worker/kind)
              (if_yes (&& (operation_visible_to_local? operation)
                          (starts_with? operation/name operation_name))
                (out ~ List/push!
                  (completion_item $"/worker ${target} ${operation/name} "
                    operation/name operation/summary)))))
          (else
            (var operation
              (worker_operation_for worker/kind operation_name))
            (if_yes (&& operation (operation_visible_to_local? operation))
              (var field (operation_argument_field operation parts))
              (if_yes (&& field (== field/name "path"))
                (set out (workspace_path_completion_items text)))
              (if_yes (&& field (== field/name "source"))
                (var last (- parts/~size 1))
                (var prefix parts/%last)
                (for item in (worker_completion_items app prefix false)
                  (out ~ List/push!
                    (completion_item
                      (replace_last_token text item/value)
                      item/label item/detail))))))))))
  out)

(fn agent_command_completion_items [app, parts]
  (var out [])
  (var target (if (> parts/~size 1) parts/1 ""))
  (if (<= parts/~size 2)
    (then
      (for item in (verb_completion_items ["list" "new"] target "/agent ")
        (out ~ List/push! item))
      (for item in (worker_completion_items app target true)
        (out ~ List/push!
          (completion_item $"/agent ${item/value} " item/label item/detail))))
    (else
      (var agent (application_find_agent app target))
      (if_yes agent
        (var prefix parts/2)
        (if_yes (starts_with? "open" prefix)
          (out ~ List/push!
            (completion_item $"/agent ${target} open " "open" "open pane")))
        (for operation in (worker_operations_for_kind "agent")
          (if_yes (&& (operation_visible_to_local? operation)
                      (starts_with? operation/name prefix))
            (out ~ List/push!
              (completion_item $"/agent ${target} ${operation/name} "
                operation/name operation/summary)))))))
  out)

(fn pane_command_completion_items [app, parts]
  (var out [])
  (var action (if (> parts/~size 1) parts/1 ""))
  (if (<= parts/~size 2)
    (then
      (for item in
          (verb_completion_items
            ["list" "new" "open" "focus" "show" "hide" "close" "max"]
            action "/pane ")
        (out ~ List/push! item))
      (for item in (pane_completion_items app action true)
        (out ~ List/push!
          (completion_item $"/pane ${item/value} " item/label item/detail))))
    (else
      (var prefix parts/2)
      (if_yes (== action "new")
        (for item in
            (verb_completion_items
              ["agent" "shell" "terminal" "repl" "tail" "output" "view" "stats"]
              prefix "/pane new ")
          (out ~ List/push! item)))
      (if_yes (== action "open")
        (for item in (worker_completion_items app prefix false)
          (out ~ List/push!
            (completion_item $"/pane open ${item/value} "
              item/label item/detail))))
      (if_yes (["focus" "show" "hide" "close" "max"] ~ contains? action)
        (for item in (pane_completion_items app prefix (== action "focus"))
          (out ~ List/push!
            (completion_item $"/pane ${action} ${item/value}"
              item/label item/detail))))
      (if_yes (!= (pane_command_id action) nil)
        (for item in
            (verb_completion_items ["focus" "show" "hide" "close" "max"]
              prefix $"/pane ${action} ")
          (out ~ List/push! item)))))
  out)

(fn trace_completion_items [text : Str, parts]
  (var out [])
  (var last (- parts/~size 1))
  (var prefix parts/%last)
  (for key in ["type=" "tool=" "path=" "turn=" "worker=" "agent="
               "task=" "from=" "to=" "--detail"]
    (if (starts_with? key prefix)
      (out ~ List/push!
        (completion_item (replace_last_token text key) key "trace filter"))))
  out)

(fn artifact_completion_items [text : Str, parts]
  (var out [])
  (var last (- parts/~size 1))
  (var prefix parts/%last)
  (for artifact in (agent_artifacts ~ Cell/get)
    (if (starts_with? artifact/id prefix)
      (out ~ List/push!
        (completion_item (replace_last_token text artifact/id)
          artifact/id artifact/kind))))
  out)

(fn editor_completion_items [editor]
  (var app (active_application ~ Cell/get))
  (var text (editor_text (editor/values ~ Cell/get)))
  (var parts (split text " "))
  (if (&& (starts_with? text "/") (== parts/~size 1))
    (return (command_completion_items text)))
  (if (starts_with? text "/worker ")
    (return (worker_command_completion_items app text parts)))
  (if (starts_with? text "/agent ")
    (return (agent_command_completion_items app parts)))
  (if (starts_with? text "/pane ")
    (return (pane_command_completion_items app parts)))
  (if (starts_with? text "/trace ")
    (return (trace_completion_items text parts)))
  (if (starts_with? text "/artifact ")
    (return (artifact_completion_items text parts)))
  (var pane_id (app/local_surface/focused_pane ~ Cell/get))
  (var pane (if pane_id (application_find_pane app pane_id)))
  (if (&& pane (== pane/worker/kind "shell"))
    (return (shell_route_completion_items pane/worker text)))
  (var out [])
  (if (&& pane (== pane/worker/kind "repl"))
    (for binding in ["session" "session/items" "session/events"
                     "session/workers" "session/main_agent"]
      (if (starts_with? binding text)
        (out ~ List/push! (completion_item binding binding "REPL binding")))))
  out)

(fn editor_show_completion! [editor, kind : Str]
  (var items (editor_completion_items editor))
  (if (empty? items)
    (editor/overlay ~ Cell/set nil)
    (editor/overlay ~ Cell/set
      {^kind kind ^title (if (== kind "palette") "commands" "completion")
       ^items items ^selected (cell 0) ^query (cell "")
       ^original (editor_text (editor/values ~ Cell/get))})))

(fn reverse_search_items [editor, query : Str]
  (var items [])
  (for value in editor/history
    (if (|| (== query "") (contains? value query))
      (items ~ List/push! (completion_item value value "history"))))
  (bounded_list_tail items surface_overlay_max_items))

(fn editor_begin_reverse_search! [editor]
  (var current (editor/overlay ~ Cell/get))
  (if (&& current (== current/kind "reverse_search"))
    (then
      (var selected (current/selected ~ Cell/get))
      (if_yes (> selected 0)
        (current/selected ~ Cell/set (- selected 1))))
    (else
      (var items (reverse_search_items editor ""))
      (editor/overlay ~ Cell/set
        {^kind "reverse_search" ^title "reverse history"
         ^items items ^selected (cell (if (empty? items) 0 (- items/~size 1)))
         ^query (cell "")
         ^original (editor_text (editor/values ~ Cell/get))}))))

(fn editor_refresh_reverse_search! [editor]
  (var overlay (editor/overlay ~ Cell/get))
  (var items (reverse_search_items editor (overlay/query ~ Cell/get)))
  (overlay ~ Map/put! "items" items)
  (overlay/selected ~ Cell/set (if (empty? items) 0 (- items/~size 1)))
  (overlay ~ Map/put! "title"
    $"reverse history: ${(overlay/query ~ Cell/get)}"))

(fn editor_overlay_move! [editor, direction : Int]
  (var overlay (editor/overlay ~ Cell/get))
  (if_yes overlay
    (var selected (overlay/selected ~ Cell/get))
    (var last (- overlay/items/~size 1))
    (if_yes (> last -1)
      (overlay/selected ~ Cell/set
        (if (< (+ selected direction) 0)
          0
          (if (> (+ selected direction) last) last
            (+ selected direction)))))))

(fn editor_accept_overlay! [editor] : Bool
  (var overlay (editor/overlay ~ Cell/get))
  (if (|| (== overlay nil) (empty? overlay/items))
    (then
      false)
    (else
      (var selected (overlay/selected ~ Cell/get))
      (editor_set_text! editor overlay/items/%selected/value)
      (editor/overlay ~ Cell/set nil)
      true)))

(fn editor_overlay_is_current_draft? [editor] : Bool
  (var overlay (editor/overlay ~ Cell/get))
  (if (|| (== overlay nil) (== overlay/kind "reverse_search")
          (empty? overlay/items))
    (then
      false)
    (else
      (var selected (overlay/selected ~ Cell/get))
      (== overlay/items/%selected/value
          (editor_text (editor/values ~ Cell/get))))))

(fn editor_dismiss_overlay! [editor, restore : Bool]
  (var overlay (editor/overlay ~ Cell/get))
  (if (&& restore overlay (== overlay/kind "reverse_search"))
    (editor_set_text! editor overlay/original))
  (editor/overlay ~ Cell/set nil))

(fn draw_editor [editor]
  (var values (editor/values ~ Cell/get))
  (var app (active_application ~ Cell/get))
  (var overlay (editor/overlay ~ Cell/get))
  (var terminal_direct (editor_terminal_direct? editor))
  (curses_draw (ensure_user_screen)
    ^prompt (input_route_label) ^status (current_input_status)
    ^output (main_presented_output app editor/transcript)
    ^input (if terminal_direct "" (editor_text values))
    ^cursor (if terminal_direct 0
              (editor_cursor_byte values (editor/cursor ~ Cell/get)))
    ^output_scroll (editor/output_scroll ~ Cell/get)
    ^panes (extension_views)
    ^terminal_direct terminal_direct
    ^overlay (if terminal_direct [] (completion_labels overlay))
    ^overlay_selected (if overlay (overlay/selected ~ Cell/get) 0)
    ^overlay_title (if overlay overlay/title "")))

(fn terminal_editor_enter_command! [editor]
  (editor/terminal_direct ~ Cell/set false)
  (editor_set_text! editor "/")
  (editor/overlay ~ Cell/set nil)
  (editor_show_completion! editor "palette"))

(fn terminal_editor_return_direct! [editor]
  (editor/terminal_direct ~ Cell/set true)
  (editor_clear! editor)
  (editor/overlay ~ Cell/set nil))

(fn terminal_editor_handle_leader! [editor, event] : Bool
  (if (&& editor/terminal_pane
          (terminal_pane_controlled? editor/terminal_pane)
          (== event/code terminal_leader_code)
          (! (editor/paste ~ Cell/get)))
    (then
      (if (editor_terminal_direct? editor)
        (terminal_editor_enter_command! editor)
        (if (== (editor_text (editor/values ~ Cell/get)) "/")
          (then
            (var session editor/terminal_pane/worker/controller/session)
            (terminal_key session ^key "control"
              ^code terminal_leader_code)
            (terminal_editor_return_direct! editor))))
      true)
    (else false)))

(fn editor_sync_focused_route! [editor]
  (var app (active_application ~ Cell/get))
  (if_yes (&& app app/local_surface)
    # Preserve the draft owned by the route that just lost focus before
    # retargeting the long-lived input editor to the newly focused route.
    (if_not (editor_terminal_direct? editor)
      (editor/draft ~ Cell/set
        (editor_text (editor/values ~ Cell/get))))
    (var pane (focused_terminal_pane app))
    (var draft (surface_route_draft app))
    (var history (surface_route_history app))
    (editor ~ Map/put! "terminal_pane" pane)
    (editor ~ Map/put! "draft" draft)
    (editor ~ Map/put! "history" (history ~ Cell/get))
    (editor/history_index ~ Cell/set editor/history/~size)
    (editor/paste ~ Cell/set false)
    (editor/overlay ~ Cell/set nil)
    (if (terminal_pane_controlled? pane)
      (then
        (editor/terminal_direct ~ Cell/set true)
        (editor/values ~ Cell/set [])
        (editor/cursor ~ Cell/set 0))
      (else
        (editor/terminal_direct ~ Cell/set false)
        (editor_set_text! editor (draft ~ Cell/get))))))

(fn terminal_editor_session [editor]
  (var pane editor/terminal_pane)
  (if (terminal_pane_controlled? pane)
    pane/worker/controller/session))

(fn terminal_editor_write! [editor, text : Str]
  (var session (terminal_editor_session editor))
  (if session
    (terminal_write session ^bytes text)))

(fn terminal_editor_key! [editor, key : Str]
  (var session (terminal_editor_session editor))
  (if session
    (terminal_key session ^key key)))

(fn terminal_editor_escape_sequence! [editor, sequence : Str]
  (var session (terminal_editor_session editor))
  (if session
    (terminal_key session ^key "escape_sequence" ^sequence sequence)))

(fn terminal_editor_mouse! [editor, event] : Bool
  (var session (terminal_editor_session editor))
  (var snapshot
    (if editor/terminal_pane
      (editor/terminal_pane/worker/controller/snapshot ~ Cell/get)))
  (if (&& session snapshot event/inside_terminal (! event/shift)
          (> snapshot/mouse_mode 0)
          (|| (== event/direction 1) (== event/direction -1)))
    (then
      (terminal_mouse session ^row event/row ^col event/col
        ^direction event/direction ^shift event/shift
        ^alt event/alt ^ctrl event/ctrl)
      true)
    (else false)))

(fn handle_running_terminal_event! [editor, event] : Bool
  (match event/type
        (when "text"
          (terminal_editor_write! editor event/text))
        (when "paste_start"
          (editor/paste ~ Cell/set true)
          (var session (terminal_editor_session editor))
          (if session (terminal_paste session ^active true)))
        (when "paste_end"
          (var session (terminal_editor_session editor))
          (if session (terminal_paste session ^active false))
          (editor/paste ~ Cell/set false))
        (when "focus_in"
          (var session (terminal_editor_session editor))
          (if session (terminal_focus session ^active true)))
        (when "focus_out"
          (var session (terminal_editor_session editor))
          (if session (terminal_focus session ^active false)))
        (when "newline" (terminal_editor_key! editor "enter"))
        (when "enter" (terminal_editor_key! editor "enter"))
        (when "eof" (terminal_editor_key! editor "eof"))
        (when "interrupt" (terminal_editor_key! editor "interrupt"))
        (when "escape" (terminal_editor_key! editor "escape"))
        (when "backspace" (terminal_editor_key! editor "backspace"))
        (when "delete" (terminal_editor_key! editor "delete"))
        (when "left" (terminal_editor_key! editor "left"))
        (when "right" (terminal_editor_key! editor "right"))
        (when "home" (terminal_editor_key! editor "home"))
        (when "end" (terminal_editor_key! editor "end"))
        (when "up" (terminal_editor_key! editor "up"))
        (when "down" (terminal_editor_key! editor "down"))
        (when "complete" (terminal_editor_key! editor "tab"))
        (when "reverse_search" (terminal_editor_key! editor "reverse_search"))
        (when "edit" (terminal_editor_key! editor "edit"))
        (when "page_up" (terminal_editor_key! editor "page_up"))
        (when "page_down" (terminal_editor_key! editor "page_down"))
        (when "function" (terminal_editor_key! editor event/key))
        (when "escape_sequence"
          (terminal_editor_escape_sequence! editor event/sequence))
        (when "scroll_page_up"
          (var app (active_application ~ Cell/get))
          (application_scroll_target! app editor/output_scroll 1
            (application_pane_page_rows app event/rows)))
        (when "scroll_page_down"
          (var app (active_application ~ Cell/get))
          (application_scroll_target! app editor/output_scroll -1
            (application_pane_page_rows app event/rows)))
        # Ctrl-PgUp/PgDown remain application-level pane cycling. Shift-wheel
        # is always local; an unmodified wheel inside the terminal is sent to
        # the child only when its VT mode requests mouse reports.
        (when "pane_previous"
          (application_cycle_visible_pane!
            (active_application ~ Cell/get) -1)
          (editor_sync_focused_route! editor))
        (when "pane_next"
          (application_cycle_visible_pane!
            (active_application ~ Cell/get) 1)
          (editor_sync_focused_route! editor))
        (when "scroll_up"
          (if_not (terminal_editor_mouse! editor event)
            (application_scroll_target!
              (active_application ~ Cell/get) editor/output_scroll 1 3)))
        (when "scroll_down"
          (if_not (terminal_editor_mouse! editor event)
            (application_scroll_target!
              (active_application ~ Cell/get) editor/output_scroll -1 3)))
    (else nil))
  true)

(fn handle_terminal_direct_event! [editor, event] : Bool
  (if (editor_terminal_direct? editor)
    (then
      (if (terminal_editor_session editor)
        (then (handle_running_terminal_event! editor event))
        (else
          (terminal_editor_enter_command! editor)
          false)))
    (else false)))

(fn handle_surface_escape! [editor]
  (var app (active_application ~ Cell/get))
  (if (== app nil)
    (then false)
    (else
      (var surface app/local_surface)
      (var pane_id (surface/focused_pane ~ Cell/get))
      (var pane
        (if pane_id (application_find_pane app pane_id)))
      (var worker (if (== pane nil) app/main_agent pane/worker))
      (var task (worker/current_task ~ Cell/get))
      (if (!= task nil)
        (then (application_cancel_worker app worker) true)
        (elif (&& (!= pane nil) (== pane/kind "repl")
                  (worker/controller/pending ~ Cell/get))
          # §7.1 ladder: discard a pending incomplete form before unmaximize.
          (repl_discard_pending worker/controller/session)
          (worker/controller/pending ~ Cell/set false)
          (append_worker_transcript! app worker "[discarded pending form]\n")
          true)
        (else
          (if (!= (surface/maximized_pane ~ Cell/get) nil)
            (then (surface/maximized_pane ~ Cell/set nil) true)
            (else
              (if (&& (== ((editor/values ~ Cell/get) ~ size) 0)
                      (!= pane_id nil))
                (then (surface/focused_pane ~ Cell/set nil) true)
                (else false)))))))))

(fn read_user_input [transcript, history]
  (if (stdin_tty?)
    (then
      # Keep editor state at Gene level and wait through cancellable
      # next_event tasks. This yields the scheduler between keystrokes, so
      # sub-agents, pane controllers, streams, and repaint callbacks continue
      # while the user is composing the next prompt.
      (var submitted (cell nil))
      (var done (cell false))
      (var app (active_application ~ Cell/get))
      (var route_draft (surface_route_draft app))
      (var terminal_pane (focused_terminal_pane app))
      (var terminal_direct
        (if (terminal_pane_controlled? terminal_pane)
          true false))
      (var initial_values
        (if terminal_direct []
          (editor_chars (route_draft ~ Cell/get))))
      (var editor
        {^values (cell initial_values)
         ^cursor (cell (initial_values ~ size)) ^history (history ~ Cell/get)
         ^history_index (cell ((history ~ Cell/get) ~ size))
         ^draft route_draft ^paste (cell false)
         ^terminal_pane terminal_pane
         ^terminal_direct (cell terminal_direct)
         ^overlay (cell nil)
         ^output_scroll app/local_surface/main_scroll
         ^transcript transcript})
      (active_editor ~ Cell/set editor)
      (try
        (draw_editor editor)
        # Hoisted because a `var` declaration inside a loop would attempt to
        # bind the same name again on the second key event.
        (var event nil)
        (var cursor 0)
        (var event_app nil)
        (while (! (done ~ Cell/get))
          (set event (await (curses_next_event (ensure_user_screen))))
          (if_not (terminal_editor_handle_leader! editor event)
            (if_not (handle_terminal_direct_event! editor event)
            (match event/type
              (when "text"
                (var overlay (editor/overlay ~ Cell/get))
                (if (&& overlay (== overlay/kind "reverse_search"))
                  (then
                    (overlay/query ~ Cell/set
                      $"${(overlay/query ~ Cell/get)}${event/text}")
                    (editor_refresh_reverse_search! editor))
                  (else
                    (if_yes
                      (editor_accepts_surface_text?
                        (active_application ~ Cell/get) editor event/text)
                      (editor_insert! editor event/text)
                      (var current
                        (editor_text (editor/values ~ Cell/get)))
                      (if (&& (starts_with? current "/")
                              (! (starts_with? current "//"))
                              (! (contains? current " ")))
                        (editor_show_completion! editor "palette")
                        (editor_dismiss_overlay! editor false))))))
              (when "paste_start" (editor/paste ~ Cell/set true))
              (when "paste_end" (editor/paste ~ Cell/set false))
              (when "focus_in"
                (var session (terminal_editor_session editor))
                (if session (terminal_focus session ^active true)))
              (when "focus_out"
                (var session (terminal_editor_session editor))
                (if session (terminal_focus session ^active false)))
              (when "newline"
                (if (surface_route_input_capable?
                      (active_application ~ Cell/get))
                  (editor_insert! editor "\n")))
              (when "enter"
                (if (editor/paste ~ Cell/get)
                  (then (editor_insert! editor "\n"))
                  (else
                    # An exact command should remain one-Enter interaction
                    # even while the discovery palette is visible. Partial
                    # completion and reverse-search still accept into the
                    # draft without submitting.
                    (if (editor_overlay_is_current_draft? editor)
                      (then
                        (editor_dismiss_overlay! editor false)
                        (submitted ~ Cell/set
                          (editor_text (editor/values ~ Cell/get)))
                        (done ~ Cell/set true))
                      (else
                        (if_not (editor_accept_overlay! editor)
                          (submitted ~ Cell/set
                            (editor_text (editor/values ~ Cell/get)))
                          (done ~ Cell/set true)))))))
              (when "eof" (done ~ Cell/set true))
              (when "interrupt" (editor_clear! editor))
              (when "escape"
                (if (&& editor/terminal_pane
                        (terminal_pane_controlled? editor/terminal_pane)
                        (|| (== (editor_text (editor/values ~ Cell/get)) "")
                            (== (editor_text (editor/values ~ Cell/get)) "/")))
                  (terminal_editor_return_direct! editor)
                (elif (editor/overlay ~ Cell/get)
                  (editor_dismiss_overlay! editor true))
                (elif (confirmation_active ~ Cell/get)
                  (then
                    (submitted ~ Cell/set "n")
                    (done ~ Cell/set true)))
                (else
                  (if (handle_surface_escape! editor)
                    (then
                      (editor_sync_focused_route! editor)
                      true)
                    (else false)))))
              (when "backspace"
                (var overlay (editor/overlay ~ Cell/get))
                (if (&& overlay (== overlay/kind "reverse_search"))
                  (then
                    (var query_values
                      (editor_chars (overlay/query ~ Cell/get)))
                    (if_not (empty? query_values)
                      (var shortened [])
                      (repeat i in (- query_values/~size 1)
                        (shortened ~ List/push! query_values/%i))
                      (set query_values shortened))
                    (overlay/query ~ Cell/set (editor_text query_values))
                    (editor_refresh_reverse_search! editor))
                  (else
                    (set cursor (editor/cursor ~ Cell/get))
                    (if_yes (> cursor 0)
                      (editor_remove! editor (- cursor 1))
                      (editor/cursor ~ Cell/set (- cursor 1))))))
              (when "delete"
                (editor_remove! editor (editor/cursor ~ Cell/get)))
              (when "left"
                (set cursor (editor/cursor ~ Cell/get))
                (if (> cursor 0) (editor/cursor ~ Cell/set (- cursor 1))))
              (when "right"
                (set cursor (editor/cursor ~ Cell/get))
                (if (< cursor ((editor/values ~ Cell/get) ~ size))
                  (editor/cursor ~ Cell/set (+ cursor 1))))
              (when "home" (editor_home! editor))
              (when "end" (editor_end! editor))
              (when "up"
                (if (editor/overlay ~ Cell/get)
                  (editor_overlay_move! editor -1)
                  (editor_history! editor -1)))
              (when "down"
                (if (editor/overlay ~ Cell/get)
                  (editor_overlay_move! editor 1)
                  (editor_history! editor 1)))
              (when "complete"
                (var overlay (editor/overlay ~ Cell/get))
                (if (&& overlay (== overlay/kind "palette"))
                  (then
                    (overlay ~ Map/put! "kind" "completion")
                    (overlay ~ Map/put! "title" "completion"))
                  (else
                    (if (&& overlay (!= overlay/kind "reverse_search"))
                      (editor_overlay_move! editor 1)
                      (editor_show_completion! editor "completion")))))
              (when "reverse_search"
                (editor_begin_reverse_search! editor))
              (when "edit"
                (editor_dismiss_overlay! editor false)
                (try
                  (editor_set_text! editor
                    (external_editor_draft
                      (editor_text (editor/values ~ Cell/get))))
                catch {^message message}
                  (var app (active_application ~ Cell/get))
                  (if app
                    (app/local_surface/help_notice ~ Cell/set
                      $"external editor failed: ${message}"))))
              (when "scroll_up"
                (application_scroll_target!
                  (active_application ~ Cell/get) editor/output_scroll 1 3))
              (when "scroll_down"
                (application_scroll_target!
                  (active_application ~ Cell/get) editor/output_scroll -1 3))
              (when "page_up"
                (set event_app (active_application ~ Cell/get))
                (application_scroll_target! event_app editor/output_scroll 1
                  (application_pane_page_rows event_app event/rows)))
              (when "page_down"
                (set event_app (active_application ~ Cell/get))
                (application_scroll_target! event_app editor/output_scroll -1
                  (application_pane_page_rows event_app event/rows)))
              (when "scroll_page_up"
                (set event_app (active_application ~ Cell/get))
                (application_scroll_target! event_app editor/output_scroll 1
                  (application_pane_page_rows event_app event/rows)))
              (when "scroll_page_down"
                (set event_app (active_application ~ Cell/get))
                (application_scroll_target! event_app editor/output_scroll -1
                  (application_pane_page_rows event_app event/rows)))
              (when "pane_previous"
                (application_cycle_visible_pane!
                  (active_application ~ Cell/get) -1)
                (editor_sync_focused_route! editor))
              (when "pane_next"
                (application_cycle_visible_pane!
                  (active_application ~ Cell/get) 1)
                (editor_sync_focused_route! editor))
              (else nil))))
          (if (! (done ~ Cell/get)) (draw_editor editor)))
        (if (== (submitted ~ Cell/get) nil)
          (editor/draft ~ Cell/set
            (editor_text (editor/values ~ Cell/get)))
          (editor/draft ~ Cell/set ""))
        (submitted ~ Cell/get)
      ensure
        (active_editor ~ Cell/set nil)))
    (else
      (print "you> ")
      (read_line))))

(fn confirmation_answer [prompt : Str] : Bool
  (var transcript (interactive_transcript ~ Cell/get))
  (if (&& (stdin_tty?) (!= transcript nil))
    (then
      (if (!= (active_editor ~ Cell/get) nil)
      # A background worker must not steal the terminal or replace a composed
      # draft. Until the optional multi-surface confirmation inbox lands,
      # default-deny this rare collision without blocking the scheduler.
        (then false)
        (else
          (append_transcript transcript $"${prompt}\n")
          (refresh_user_input transcript)
          (confirmation_active ~ Cell/set true)
          (var answer nil)
          (try
            (set answer (read_user_input transcript (cell [])))
          ensure
            (confirmation_active ~ Cell/set false))
          (if (== answer nil)
            (then false)
            (else
              (set answer (lower (trim answer)))
              (|| (== answer "y") (== answer "yes")))))))
    (else
      # Scripted/one-shot callers have no live curses surface. Preserve the
      # ordinary stdin contract; EOF remains default deny.
      (close_user_input)
      (print prompt)
      (var answer (read_line))
      (if (== answer nil)
        (then false)
        (else
          (set answer (lower (trim answer)))
          (|| (== answer "y") (== answer "yes")))))))

(fn refresh_user_input [transcript]
  (if_yes (&& (stdin_tty?) (! (user_input_suspended ~ Cell/get)))
    (var editor (active_editor ~ Cell/get))
    (if (== editor nil)
      (curses_refresh_input (ensure_user_screen)
                            ^prompt (input_route_label)
                            ^output
                              (main_presented_output
                                (active_application ~ Cell/get) transcript)
                            ^panes (extension_views)
                            ^status (current_input_status))
      (draw_editor editor))))

(fn refresh_active_input []
  # Background invalidations already run on the single UI/scheduler lane.
  # Draw synchronously there: a detached/timer repaint can remain parked while
  # the root fiber awaits curses input, leaving PTY output one key behind.
  # The guard prevents nested callbacks from recursively redrawing.
  (if_not (active_repaint_pending ~ Cell/get)
    (active_repaint_pending ~ Cell/set true)
    (try
      (var transcript (interactive_transcript ~ Cell/get))
      (if (!= transcript nil) (refresh_user_input transcript))
    ensure
      (active_repaint_pending ~ Cell/set false))))

# A pending turn owns the final transcript line until it produces visible
# output. The pulse task alternates the dots and spaces while the scheduler is
# waiting on a model or tool task; the first real output restores the saved
# transcript and replaces that line.
(fn refresh_agent_pending [transcript pending dots_visible]
  (if_yes (pending ~ Cell/get)
    (var app (active_application ~ Cell/get))
    (if (&& (!= app nil) (!= app/local_surface nil))
      (app/local_surface/main_pending_visible ~ Cell/set
        (dots_visible ~ Cell/get)))
    (if (stdin_tty?)
      (refresh_user_input transcript)
      (print (if (dots_visible ~ Cell/get) "\ragent> ..." "\ragent>    ")))))

# Remove the currently drawn placeholder before appending output, but retain
# the pending state: the placeholder is redrawn beneath that output until the
# whole turn completes.
(fn advance_agent_pending [transcript pending]
  (if_yes (pending ~ Cell/get)
    (var app (active_application ~ Cell/get))
    (if (&& (!= app nil) (!= app/local_surface nil))
      (app/local_surface/main_pending_visible ~ Cell/set false))
    (if (stdin_tty?)
      (refresh_user_input transcript)
      (print "\r"))))

(fn stop_agent_pending [transcript pending]
  (if_yes (pending ~ Cell/get)
    (pending ~ Cell/set false)
    (var app (active_application ~ Cell/get))
    (if (&& (!= app nil) (!= app/local_surface nil))
      (app/local_surface/main_pending_visible ~ Cell/set false))
    (if (stdin_tty?)
      (refresh_user_input transcript)
      (print "\r"))))

(fn output_with_pending [transcript pending dots_visible render]
  (if (stdin_tty?)
    (then
      # The marker is virtual terminal state, not transcript text. Appending
      # and drawing new output naturally leaves it last, so hiding and
      # redrawing it around every stream delta only creates redundant frames.
      (render))
    (else
      (advance_agent_pending transcript pending)
      (render)
      (if (pending ~ Cell/get)
        (refresh_agent_pending transcript pending dots_visible)))))

(fn start_agent_pending [transcript]
  (var pending (cell true))
  (var dots_visible (cell true))
  (refresh_agent_pending transcript pending dots_visible)
  {^pending pending ^dots_visible dots_visible
   ^task (spawn ^lane root
     (while (pending ~ Cell/get)
       (sleep 400)
       (if_yes (pending ~ Cell/get)
         (dots_visible ~ Cell/set (! (dots_visible ~ Cell/get)))
         (refresh_agent_pending transcript pending dots_visible))))})

(fn run_interactive_turn [transcript streaming transport input_items]
  (var placeholder (start_agent_pending transcript))
  (var app (active_application ~ Cell/get))
  (var context
    (if app {^app app ^agent app/main_agent ^pane nil}))
  (var turn_emit
    (if (== app nil)
      emit_event!
      (fn [type props]
        (var tagged {^worker_id app/main_agent/id
                     ^agent_id app/main_agent/id})
        (for [key value] in props
          (tagged ~ Map/put! key value))
        (application_emit app type tagged))))
  (try
    (run_turn_tracked_in transport input_items
      (fn [text]
        (output_with_pending transcript placeholder/pending placeholder/dots_visible
          (fn [] (render_agent_text transcript streaming text))))
      (fn [text]
        (output_with_pending transcript placeholder/pending placeholder/dots_visible
          (fn [] (render_agent_delta transcript streaming text))))
      max_tool_rounds
      turn_emit
      context)
  ensure
    (stop_agent_pending transcript placeholder/pending)
    (finish_agent_stream transcript streaming)
    (placeholder/task ~ Task/cancel)))

(fn render_agent_delta [transcript streaming text]
  (if_not (== text "")
    (if_not (Cell/get streaming)
      (append_transcript transcript "agent> ")
      (if_not (stdin_tty?)
        (print "agent> "))
      (Cell/set streaming true))
    (append_transcript transcript text)
    (if (stdin_tty?)
      (refresh_active_input)
      (print text))))

(fn finish_agent_stream [transcript streaming]
  (if_yes (Cell/get streaming)
    (append_transcript transcript "\n")
    (if (stdin_tty?)
      (refresh_user_input transcript)
      (println ""))
    (Cell/set streaming false)))

(fn render_agent_text [transcript streaming text]
  (finish_agent_stream transcript streaming)
  (if_not (== text "")
    (append_transcript transcript $"agent> ${text}\n")
    (if (stdin_tty?)
      (refresh_user_input transcript)
      (println $"agent> ${text}"))))

# Convenience helpers over the native application registries. Creating an
# agent and opening its pane is a surface composite; their identities and
# lifecycles remain independent underneath.
(fn open_extension_pane [title : Str, memory]
  (var app (active_application ~ Cell/get))
  (if_yes app
    (var label (if (== (trim title) "") "sub-agent" (trim title)))
    (var transcript (cell "ready\n"))
    (var agent
      (application_spawn_agent app label "awaiting assignment"
        (cell
          (append (initial_items memory)
            (system_item
              $"You are ${label}, a supervised sub-agent in the same workspace. Work only on assignments delegated by the main agent or user. Report a concise result; your private tool transcript is not copied into the main context.")))
        transcript))
    (if_yes agent
      (var pane
        (application_open_pane app "agent" agent/id agent/title
                               transcript agent "detach"))
      (refresh_active_input)
      pane)))

(fn open_output_pane [title : Str]
  (var app (active_application ~ Cell/get))
  (if_yes app
    (var label (if (== (trim title) "") "output" (trim title)))
    (application_open_pane app "output" nil label
      (cell "ready\n")
      (OutputController ^source "manual" ^following (cell [])) "detach")))

(fn open_stats_pane []
  (var app (active_application ~ Cell/get))
  (var worker (application_find_worker_kind app "stats"))
  (if_yes (== worker nil)
    (set worker
      (application_new_worker app "stats" "stats"
        (cell "") (StatsController)))
    (if_yes worker
      (application_set_projection_output!
        app worker (stats_worker_text app) "stats")
      ((app/event_observers ~ Cell/get) ~ List/push!
        {^worker_id worker/id
         ^handler (fn [event]
           (if_not (== event/projection true)
             (application_set_projection_output!
               app worker (stats_worker_text app) "stats")
             (refresh_active_input)))})))
  (if_yes worker
    (var pane (application_find_pane_worker app worker/id))
    (if (== pane nil)
      (set pane (application_attach_worker_pane app worker nil "detach")))
    (if pane (application_focus_pane! app pane/id))
    pane))

(fn open_log_tail_pane [filter_text : Str]
  (var app (active_application ~ Cell/get))
  (var filters (parse_trace_filters filter_text))
  (var worker
    (application_new_worker app "log_tail" "event tail"
      (cell "") (LogTailController ^filter (cell filters))))
  (if_yes worker
    # Seed the local TUI projection from retained events; headless sessions
    # begin at their creation cursor and receive subsequent app events.
    (for event in (if (== app/local_surface nil) []
                    (agent_events ~ Cell/get))
      (if (event_matches? event filters)
        (bounded_worker_append! worker
          $"${(format_event_with_filters event filters)}\n")))
    ((app/event_observers ~ Cell/get) ~ List/push!
      {^worker_id worker/id
       ^handler (fn [event]
         (var current (worker/controller/filter ~ Cell/get))
         (if_yes (&& (!= event/projection true)
                 (event_matches? event current))
             (application_append_projection_output!
               app worker
               $"${(format_event_with_filters event current)}\n" "log_tail")
             (refresh_active_input)))})
    (application_attach_worker_pane app worker nil "detach")))

(fn open_file_view_pane [requested_path : Str]
  (var app (active_application ~ Cell/get))
  (try
    # A file-view worker is shared session state and may be exposed through
    # gateway snapshots, so even a user-originated local view stays within
    # the workspace. Arbitrary host inspection remains available via /tty
    # or an external editor without entering shared state.
    (var path (safe_path requested_path))
    (if_yes (exists? ReadDir path)
      (var worker
        (application_new_worker app "file_view" $"view ${path}"
          (cell "") (FileViewController ^path path)))
      (if_yes worker
        (application_append_projection_output!
          app worker (read_text ReadDir path) "file_view")
        (application_attach_worker_pane app worker nil "detach")))
    catch _ nil))

(fn open_terminal_pane [command, args]
  (var app (active_application ~ Cell/get))
  (if_yes app
    (var worker (application_find_worker_kind app "terminal"))
    (var existing
      (if worker (application_find_pane_worker app worker/id)))
    (if existing
      (then
        (application_focus_pane! app existing/id)
        existing)
      (else
        (if_yes (== worker nil)
          (var executable
            (if (|| (== command nil) (== command ""))
              (get_env Env "SHELL" "/bin/sh") command))
          (var child_args (if (== args nil) [] args))
          (var session
            (terminal_open Pty ^cmd executable ^args child_args
              ^dir workspace_real ^rows 24 ^cols 80
              ^scrollback_lines 2000))
          (var controller
            (TerminalController
              ^session session ^snapshot (cell (terminal_snapshot session))
              ^restored_text (cell "")
              ^pump_task (cell nil)
              ^controller_surface_id
                (cell (app/local_surface/instance_id ~ Cell/get))
              ^command executable ^args child_args
              ^cwd workspace_real))
          (set worker
            (application_new_worker app "terminal" "terminal"
              (cell "interactive terminal (local/unmediated)\n") controller))
          (if_yes worker (start_terminal_pump! app worker)))
        (if worker
          (application_attach_worker_pane app worker "user" "detach"))))))

(fn open_shell_pane []
  (var app (active_application ~ Cell/get))
  (if_yes app
    (var worker (application_find_worker_kind app "shell"))
    (var previous
      (if (== worker nil)
        (application_find_stopped_worker_kind app "shell")))
    (var existing
      (if worker
        (application_find_pane_worker app worker/id)))
    (if (!= existing nil)
      (then
        (application_focus_pane! app existing/id)
        existing)
      (else
        (if (== worker nil)
          (set worker
            (application_new_worker_from app "shell" "shell"
              (cell $"cwd: ${workspace_root}\n")
              (ShellController ^cwd (cell workspace_root)
                               ^environment (cell {})) previous)))
        (application_attach_worker_pane app worker "user" "detach")))))

(fn run_shell_pane_command_unchecked [pane, command : Str]
  (var app (active_application ~ Cell/get))
  (var result
    (run_shell_worker_command_unchecked app pane/worker command nil "local_tui"
      (if app/local_surface
        (app/local_surface/instance_id ~ Cell/get))
      $"pane ${pane/id}" (stdin_tty?)))
  (if (== result "accepted")
    $"shell command started in pane ${pane/id}" result))

(fn run_shell_pane_command [pane, command : Str]
  # A visible shell pane is attributable application input, not the raw /tty
  # escape hatch. Classify it on TTY and pipe surfaces alike.
  (var app (active_application ~ Cell/get))
  (var result
    (run_shell_worker_command app pane/worker command nil "local_tui"
      (if app/local_surface
        (app/local_surface/instance_id ~ Cell/get))
      $"pane ${pane/id}" (stdin_tty?) false))
  (if (== result "accepted")
    $"shell command started in pane ${pane/id}" result))

(fn run_repl_pane_command [pane, source : Str]
  (var app (active_application ~ Cell/get))
  (var result
    (run_repl_worker_command app pane/worker source "local_tui"
      (if app/local_surface
        (app/local_surface/instance_id ~ Cell/get))
      $"pane ${pane/id}" (stdin_tty?)))
  (if (== result "accepted")
    $"REPL evaluation started in pane ${pane/id}" result))

(fn close_extension_pane [id : Int] : Bool
  (var app (active_application ~ Cell/get))
  (if (== app nil)
    (then false)
    (else
      (var removed (application_close_pane app id))
      (refresh_active_input)
      removed)))

(fn handle_close_command [line : Str, transcript, streaming]
  (var app (active_application ~ Cell/get))
  (var rest (trim (after_prefix line "/close")))
  (var id
    (if (== rest "")
      (app/local_surface/focused_pane ~ Cell/get)
      (pane_command_id rest)))
  (if (&& (!= rest "") (== id nil))
    (render_agent_text transcript streaming "usage: /close [N]")
    (if (|| (== id nil) (== id 0))
      (render_agent_text transcript streaming "pane 0 cannot be closed")
      (render_agent_text transcript streaming
        (if (application_close_pane app id)
          $"closed pane ${id}" $"pane ${id} is not open")))))

(fn append_extension_transcript [pane, text : Str]
  (append_worker_transcript!
    (active_application ~ Cell/get) pane/worker text))

(fn refresh_extension_pending [pane, pending, dots_visible]
  (if_yes (pending ~ Cell/get)
    (pane/pending_visible ~ Cell/set (dots_visible ~ Cell/get))
    (refresh_active_input)))

(fn start_extension_pending [pane]
  (var pending (cell true))
  (var dots_visible (cell true))
  (refresh_extension_pending pane pending dots_visible)
  {^pending pending ^dots_visible dots_visible
   ^task (spawn ^lane root
     (while (pending ~ Cell/get)
       (sleep 400)
       (if_yes (pending ~ Cell/get)
         (dots_visible ~ Cell/set (! (dots_visible ~ Cell/get)))
         (refresh_extension_pending pane pending dots_visible))))})

(fn advance_extension_pending [pane, pending]
  (if_yes (pending ~ Cell/get)
    (pane/pending_visible ~ Cell/set false)
    (refresh_active_input)))

(fn stop_extension_pending [pane, pending]
  (if_yes (pending ~ Cell/get)
    (pending ~ Cell/set false)
    (pane/pending_visible ~ Cell/set false)
    (refresh_active_input)))

(fn render_extension_delta [pane, text : Str]
  (if_not (== text "")
    (if_not (pane/controller/streaming ~ Cell/get)
      (append_extension_transcript pane "assistant|")
      (pane/controller/streaming ~ Cell/set true))
    (append_extension_transcript pane text)))

(fn finish_extension_stream [pane]
  (if_yes (pane/controller/streaming ~ Cell/get)
    (append_extension_transcript pane "\n")
    (pane/controller/streaming ~ Cell/set false)))

(fn render_extension_text [pane, text : Str]
  (finish_extension_stream pane)
  (if_not (== text "")
    (append_extension_transcript pane $"assistant|${text}\n")))

(fn output_with_extension_pending [pane, placeholder, render]
  (advance_extension_pending pane placeholder/pending)
  (render)
  (if (placeholder/pending ~ Cell/get)
    (refresh_extension_pending pane placeholder/pending placeholder/dots_visible)))

(fn extension_emit [pane, type : Str, props]
  (var app (active_application ~ Cell/get))
  (var agent pane/controller)
  (var tagged {^pane_id pane/id ^worker_id agent/id ^agent_id agent/id
               ^parent_agent_id agent/parent_id})
  (for [key value] in props
    (tagged ~ Map/put! key value))
  (if (== app nil)
    (emit_event! type tagged)
    (application_emit app type tagged)))

(fn run_extension_prompt [pane, prompt : Str, tracked : Bool]
  (var app (active_application ~ Cell/get))
  (var agent pane/controller)
  (if (== (agent/lifecycle ~ Cell/get) "stopped")
    $"agent ${agent/id} is stopped"
    (if (|| (agent/input_reserved ~ Cell/get)
            (!= (agent/current_task ~ Cell/get) nil))
      (then $"agent ${agent/id} is already working")
      (else
        (worker_history_push! agent prompt "local_tui"
          (if app/local_surface
            (app/local_surface/instance_id ~ Cell/get)))
        (append_extension_transcript pane $"user|› ${prompt}\n")
        (application_emit app "agent_status"
          {^worker_id agent/id ^agent_id agent/id
           ^parent_agent_id agent/parent_id
           ^pane_id pane/id ^status "working"})
        (var task
          (spawn ^lane root
            (do
              (var placeholder (start_extension_pending pane))
              (var result (cell (agent/items ~ Cell/get)))
              (var final_text (cell ""))
              (var outcome (cell "cancelled"))
              (var error_kind (cell "cancelled"))
              (var error_text (cell "agent operation cancelled"))
              (var render
                (fn [text]
                  (output_with_extension_pending pane placeholder
                    (fn [] (render_extension_text pane text)))))
              (var render_stream
                (fn [text]
                  (output_with_extension_pending pane placeholder
                    (fn [] (render_extension_delta pane text)))))
              (var emit
                (fn [type props]
                  (if (&& (== type "agent_text") (present? props/text))
                    (final_text ~ Cell/set props/text))
                  (extension_emit pane type props)))
              (try
                (result ~ Cell/set
                (run_turn_in (interactive_transport)
                  (append (agent/items ~ Cell/get) (user_item prompt))
                  render render_stream max_tool_rounds emit
                  {^app app ^agent agent ^pane pane}))
                (outcome ~ Cell/set "completed")
              catch {^message message}
                (outcome ~ Cell/set "failed")
                (error_kind ~ Cell/set "AgentError")
                (error_text ~ Cell/set message)
                (render_extension_text pane $"[agent failed: ${message}]")
              catch _
                (outcome ~ Cell/set "failed")
                (error_kind ~ Cell/set "AgentError")
                (error_text ~ Cell/set "agent operation failed")
                (render_extension_text pane "[agent failed]")
              ensure
                (stop_extension_pending pane placeholder/pending)
                (finish_extension_stream pane)
                (placeholder/task ~ Task/cancel)
                (agent/items ~ Cell/set (result ~ Cell/get))
                (application_finish_agent_operation!
                  app agent (outcome ~ Cell/get) (final_text ~ Cell/get)
                  (error_kind ~ Cell/get) (error_text ~ Cell/get) pane/id)))))
        (application_begin_worker_operation! app agent task "agent_turn")
        (task ~ Task/detach)
        (if tracked
          (then $"agent ${agent/id} started in pane ${pane/id}")
          (else
            # `open_extension` predates first-class spawn/send/wait tools and
            # promises one delegated result to the calling model. Preserve that
            # compatibility contract while the child runs in its own Task; the
            # scheduler remains free to serve input and other agents.
            (await task)
            (var completed_text
              (agent_result_text (agent/result ~ Cell/get)))
            (if (== (agent/last_outcome ~ Cell/get) "completed")
              $"extension ${pane/id} completed: ${completed_text}"
              $"extension ${pane/id} ${(agent_result_report agent)}")))))))

# Model-facing supervision primitives use the same AgentApplication services as
# slash commands, but do not require a visible pane. This is intentionally
# separate from `open_extension`: spawning an agent, opening a view, and
# sending work are independent capabilities (§7.1/§10.4).
(fn extension_command_id [line : Str]
  (var parts (split line " "))
  (var selector parts/0)
  (if (&& (starts_with? selector "/") (> (byte_size selector) 1))
    (try
      (parse_int (after_prefix selector "/"))
    catch _ nil)))

(fn handle_extension_command [line : Str, transcript, memory, streaming]
  (var parts (split line " "))
  (var selector parts/0)
  (var id (extension_command_id line))
  (var pane (find_extension id))
  (var command (trim (after_prefix line selector)))
  (if (== pane nil)
    (render_agent_text transcript streaming $"pane ${id} is not open")
  (match command
    (when "close"
      (close_extension_pane id)
      (render_agent_text transcript streaming $"closed pane ${id}"))
      (when ""
        (var app (active_application ~ Cell/get))
        (application_focus_pane! app id)
        (render_agent_text transcript streaming $"focused pane ${id}"))
    (when "cancel"
      (var app (active_application ~ Cell/get))
      (var response
        (application_call_worker app pane/worker/id "cancel" {}
          {^origin "user" ^adapter "local_tui"
           ^caller_worker_id app/main_agent/id
           ^surface_id (app/local_surface/instance_id ~ Cell/get)}))
      (render_agent_text transcript streaming
        (worker_operation_cli_text pane/worker "cancel" response)))
    (when "stop"
      (var app (active_application ~ Cell/get))
      (var response
        (application_call_worker app pane/worker/id "stop" {}
          {^origin "user" ^adapter "local_tui"
           ^caller_worker_id app/main_agent/id
           ^surface_id (app/local_surface/instance_id ~ Cell/get)}))
      (render_agent_text transcript streaming
        (worker_operation_cli_text pane/worker "stop" response)))
    (when "focus"
      (var app (active_application ~ Cell/get))
      (application_focus_pane! app id)
      (render_agent_text transcript streaming $"focused pane ${id}"))
    (when "max"
      (var app (active_application ~ Cell/get))
      (var surface app/local_surface)
      (surface/maximized_pane ~ Cell/set
        (if_not (== (surface/maximized_pane ~ Cell/get) id) id))
      (render_agent_text transcript streaming
        (if (== (surface/maximized_pane ~ Cell/get) id)
          $"maximized pane ${id}" "restored split layout")))
    (else
      (var routed
        (if (starts_with? command "-- ")
          (after_prefix command "-- ") command))
      (match pane/kind
        (when "agent"
          (interactive_memory ~ Cell/set (memory ~ Cell/get))
          (begin_turn!)
          (emit_event! "user_input"
            {^text routed ^worker_id pane/worker_id
             ^pane_id id ^agent_id pane/controller/id})
          (render_agent_text transcript streaming
            (application_send_worker_input
              (active_application ~ Cell/get) pane/worker routed "local_tui")))
        (when "shell"
          (var response (application_send_worker_input
            (active_application ~ Cell/get) pane/worker routed "local_tui"))
          (if (== response "accepted")
            (refresh_user_input transcript)
            (render_agent_text transcript streaming response)))
        (when "repl"
          (var response (application_send_worker_input
            (active_application ~ Cell/get) pane/worker routed "local_tui"))
          (if (== response "accepted")
            (refresh_user_input transcript)
            (render_agent_text transcript streaming response)))
        (when "terminal"
          (if (starts_with? routed "send ")
            (then
              (var line_text (after_prefix routed "send "))
              (var app (active_application ~ Cell/get))
              (var response
                (application_call_worker app pane/worker/id "write"
                  {^bytes $"${line_text}\n"}
                  {^origin "user" ^adapter "local_tui"
                   ^caller_worker_id app/main_agent/id
                   ^surface_id
                     (app/local_surface/instance_id ~ Cell/get)}))
              (if response/ok
                (refresh_user_input transcript)
                (render_agent_text transcript streaming
                  (worker_operation_cli_text
                    pane/worker "write" response))))
            (else
              (render_agent_text transcript streaming
                $"terminal pane ${id} is direct; use /${id} send <line> or focus it"))))
        (when "log_tail"
          (var response (application_send_worker_input
            (active_application ~ Cell/get) pane/worker routed "local_tui"))
          (if (== response "accepted")
            (refresh_user_input transcript)
            (render_agent_text transcript streaming response)))
        (when "output"
          (if (starts_with? routed "append ")
            (then
              (var text (after_prefix routed "append "))
              (var response
                (application_call_worker (active_application ~ Cell/get)
                  pane/worker/id "append" {^text text}
                  {^origin "user" ^caller_worker_id "main"}))
              (render_agent_text transcript streaming
                (if response/ok $"appended to pane ${id}"
                  (worker_operation_cli_text pane/worker "append" response))))
            (else
              (render_agent_text transcript streaming
                $"pane ${id} is read-only; use /${id} append <text>"))))
        (else
          (render_agent_text transcript streaming
            $"pane ${id} (${pane/kind}) does not accept input")))))))

(fn handle_open_extension [transcript, memory, streaming]
  (var pane (open_extension_pane "" (memory ~ Cell/get)))
  (if (== pane nil)
    (render_agent_text transcript streaming "sub-agent limit reached")
    (render_agent_text transcript streaming
      $"opened agent ${pane/controller/id} in pane ${pane/id}; use /${pane/id} <prompt> or /close")))

(fn worker_result_unread? [worker] : Bool
  (if (!= worker/kind "agent") false
    (match (worker/result ~ Cell/get)
      (when (m : Map) (== m/read false))
      (else false))))

(fn agents_report []
  (var app (active_application ~ Cell/get))
  (if (== app nil)
    (then "application is not running")
    (else
      (var lines [])
      (for agent in (app/agents ~ Cell/get)
        (var unread (worker_result_unread? agent))
        (var last (agent/last_outcome ~ Cell/get))
        (var last_text (if (== last nil) "none" last))
        (var address
          (if (present? agent/name) $"${agent/name} (${agent/id})" agent/id))
        (lines ~ List/push!
          $"${address} lifecycle=${(agent/lifecycle ~ Cell/get)} availability=${(agent/status ~ Cell/get)} last=${last_text} unread=${unread} panes=${(application_pane_ids_for_worker app agent/id)} ${agent/title}"))
      (join lines "\n"))))

(fn workers_report []
  (var app (active_application ~ Cell/get))
  (if (== app nil)
    (then "application is not running")
    (else
      (var lines [])
      (for worker in (app/workers ~ Cell/get)
        (var pane_refs [])
        (for candidate in (app/local_surface/panes ~ Cell/get)
          (if (== candidate/worker_id worker/id)
            (pane_refs ~ List/push!
              (if (candidate/hidden ~ Cell/get)
                $"${candidate/id}:hidden" $"${candidate/id}"))))
        (var operation (worker/current_operation ~ Cell/get))
        (var state
          (if (== (worker/lifecycle ~ Cell/get) "stopped")
            "stopped"
            (if (worker/input_reserved ~ Cell/get)
              "confirming"
              (if (== operation nil) "idle" "busy"))))
        (var location
          (if (== worker/id "main") "pane=0"
            (if (empty? pane_refs) "headless"
              (if (== pane_refs/~size 1)
                $"pane=${pane_refs/0}" $"panes=${pane_refs}"))))
        (var last (worker/last_outcome ~ Cell/get))
        (var last_text (if (== last nil) "none" last))
        (var unread (worker_result_unread? worker))
        (var address
          (if (present? worker/name) $"${worker/name} (${worker/id})" worker/id))
        (lines ~ List/push!
          $"${address} ${worker/kind} ${state} ${location} ${worker/title} last=${last_text} unread=${unread}"))
      (join lines "\n"))))

(fn panes_report []
  (var app (active_application ~ Cell/get))
  (if (|| (== app nil) (== app/local_surface nil))
    (then "this session has no local layout surface")
    (else
      (var surface app/local_surface)
      (var main_outcome (app/main_agent/last_outcome ~ Cell/get))
      (var main_outcome_text
        (if (== main_outcome nil) "none" main_outcome))
      (var lines [
        $"0 main agent visible lifecycle=${(app/main_agent/lifecycle ~ Cell/get)} ${(app/main_agent/status ~ Cell/get)} last=${main_outcome_text} unread=${(worker_result_unread? app/main_agent)} main"])
      (for pane in (surface/panes ~ Cell/get)
        (var worker pane/worker)
        (var operation (worker/current_operation ~ Cell/get))
        (var operation_text
          (if (== operation nil) "idle"
            $"busy:${operation/kind}:${operation/task_id}"))
        (var outcome (worker/last_outcome ~ Cell/get))
        (var outcome_text (if (== outcome nil) "none" outcome))
        (var visibility
          (if (pane/hidden ~ Cell/get) "hidden" "visible"))
        (var unread (worker_result_unread? worker))
        (lines ~ List/push!
          $"${pane/id} ${pane/worker_id} ${pane/kind} ${visibility} lifecycle=${(worker/lifecycle ~ Cell/get)} ${operation_text} last=${outcome_text} unread=${unread} ${pane/title}"))
      (join lines "\n"))))

(fn application_focus_pane! [app, id : Int] : Bool
  (var surface app/local_surface)
  (if (== surface nil)
    (then false)
    (else
      (if (== id 0)
        (then
          (surface/focused_pane ~ Cell/set nil)
          (surface/maximized_pane ~ Cell/set nil)
          true)
        (else
          (var pane (application_find_pane app id))
          (if (== pane nil)
            (then false)
            (else
              (pane/hidden ~ Cell/set false)
              (surface/focused_pane ~ Cell/set id)
              true)))))))

(fn application_hide_pane! [app, id : Int] : Bool
  (var pane (application_find_pane app id))
  (if (== pane nil)
    (then false)
    (else
      (pane/hidden ~ Cell/set true)
      (if (== (app/local_surface/focused_pane ~ Cell/get) id)
        (app/local_surface/focused_pane ~ Cell/set nil))
      (if (== (app/local_surface/maximized_pane ~ Cell/get) id)
        (app/local_surface/maximized_pane ~ Cell/set nil))
      true)))

(fn application_show_pane! [app, id : Int] : Bool
  (var pane (application_find_pane app id))
  (if (== pane nil)
    (then false)
    (else
      (pane/hidden ~ Cell/set false)
      true)))

(fn pane_command_id [text : Str]
  (try (parse_int (trim text)) catch _ nil))

(fn handle_pane_command [line : Str, items, transcript, memory, streaming]
  (var app (active_application ~ Cell/get))
  (var rest (trim (after_prefix line "/pane")))
  # Preserve the shipped `/pane output [title]` spelling as a concise alias.
  (if (|| (== rest "output") (starts_with? rest "output "))
    (then
      (var output_suffix
        (if (== rest "output") "" (after_prefix rest "output")))
      (set rest $"new output${output_suffix}")))
  (if (|| (== rest "") (== rest "list"))
    (render_agent_text transcript streaming (panes_report))
    (if (starts_with? rest "new ")
      (then
        (var create_rest (trim (after_prefix rest "new ")))
        (var parts (split create_rest " "))
        (var kind (if (empty? parts) "" parts/0))
        (var args (trim (after_prefix create_rest kind)))
        (match kind
          (when "agent"
            (handle_agent_command
              (if (== args "") "/agent new" $"/agent new ${args}")
              transcript memory streaming))
          (when "shell" (handle_shell_pane transcript streaming))
          (when "terminal"
            (var pane (open_terminal_pane nil []))
            (render_agent_text transcript streaming
              (if pane $"opened terminal pane ${pane/id}"
                "worker limit reached")))
          (when "repl" (handle_repl_pane items transcript memory streaming))
          (when "tail"
            (var pane (open_log_tail_pane args))
            (render_agent_text transcript streaming
              (if pane $"opened event tail pane ${pane/id}"
                "worker limit reached")))
          (when "output"
            (var pane (open_output_pane args))
            (render_agent_text transcript streaming
              (if pane $"opened output pane ${pane/id}"
                "worker limit reached")))
          (when "view"
            (if (== args "")
              (then
                (render_agent_text transcript streaming
                  "usage: /pane new view <workspace-path>"))
              (else
                (var pane (open_file_view_pane args))
                (render_agent_text transcript streaming
                  (if pane $"opened ${args} in pane ${pane/id}"
                    $"cannot open ${args}")))))
          (when "stats"
            (var pane (open_stats_pane))
            (render_agent_text transcript streaming
              (if pane $"opened stats pane ${pane/id}"
                "worker limit reached")))
          (else
            (render_agent_text transcript streaming
              "usage: /pane new <agent|shell|terminal|repl|tail|output|view|stats> [args]"))))
      (else
        (if (starts_with? rest "open ")
          (then
            (var open_rest (trim (after_prefix rest "open ")))
            (var parts (split open_rest " "))
            (var worker_id (if (empty? parts) "" parts/0))
            (var pane_title (trim (after_prefix open_rest worker_id)))
            (var worker (application_find_worker app worker_id))
            (if (== worker nil)
              (then
                (render_agent_text transcript streaming
                  $"worker ${worker_id} not found"))
              (else
                (var pane
                  (application_attach_worker_pane_as app worker
                    (if (== worker/kind "agent") worker/id "user") "detach"
                    pane_title))
                (render_agent_text transcript streaming
                  (if pane $"opened worker ${worker/id} in pane ${pane/id}"
                    "pane limit reached")))))
          (else
            (var parts (split rest " "))
            (var action (if (empty? parts) "" parts/0))
            (var id_text (trim (after_prefix rest action)))
            (var id nil)
            # Accept both canonical action-first `/pane max 1` and natural
            # id-first `/pane 1 max`. Short `/1 max` remains available too.
            (var leading_id (pane_command_id action))
            (if (&& (!= leading_id nil)
                    (["focus" "show" "hide" "close" "max"] ~ contains? id_text))
              (then
                (set action id_text)
                (set id leading_id))
              (else
                (set id (pane_command_id id_text))))
            (if (== id nil)
              (then
                (var literal_help
                  (if (surface_route_input_capable? app)
                    "\nto send literal leading-slash input, use //text or /N -- text"
                    ""))
                (render_agent_text transcript streaming
                  $"usage: /pane list | /pane new ... | /pane open W | /pane focus|show|hide|close|max N${literal_help}"))
              (else
                (match action
                (when "focus"
                  (render_agent_text transcript streaming
                    (if (application_focus_pane! app id)
                      (if (== id 0) "focused main agent" $"focused pane ${id}")
                      $"pane ${id} is not open")))
                (when "show"
                  (render_agent_text transcript streaming
                    (if (application_show_pane! app id)
                      $"showing pane ${id}" $"pane ${id} is not open")))
                (when "hide"
                  (render_agent_text transcript streaming
                    (if (application_hide_pane! app id)
                      $"hid pane ${id}" $"pane ${id} is not open")))
                (when "close"
                  (render_agent_text transcript streaming
                    (if (== id 0) "pane 0 cannot be closed"
                      (if (application_close_pane app id)
                        $"closed pane ${id}" $"pane ${id} is not open"))))
                (when "max"
                  (var pane (application_find_pane app id))
                  (if (== pane nil)
                    (then
                      (render_agent_text transcript streaming
                        $"pane ${id} is not open"))
                    (else
                      (pane/hidden ~ Cell/set false)
                      (app/local_surface/focused_pane ~ Cell/set id)
                      (app/local_surface/maximized_pane ~ Cell/set
                        (if_not (== (app/local_surface/maximized_pane ~ Cell/get)
                                   id) id))
                      (render_agent_text transcript streaming
                        (if (== (app/local_surface/maximized_pane ~ Cell/get) id)
                          $"maximized pane ${id}" "restored split layout")))))
                (else
                  (render_agent_text transcript streaming
                    "usage: /pane list | /pane new ... | /pane open W | /pane focus|show|hide|close|max N")))))))))))

(fn worker_operation_cli_text [worker, operation_name : Str, response] : Str
  (if response/ok
    (match operation_name
      (when "status"
        (var value response/result)
        $"${value/worker_id} ${value/kind} ${value/lifecycle}/${value/status} busy=${value/busy}")
      (when "tail" response/result/text)
      (when "result" (agent_result_report worker))
      (when "info"
        $"${response/result/path}: ${response/result/bytes} bytes")
      (when "snapshot" (stringify response/result/snapshot))
      (else
        (var text response/result/text)
        (if (|| (== text nil) (== text void))
          (stringify response/result) text)))
    $"${response/error/kind}: ${response/error/message}"))

(fn worker_operations_usage [worker] : Str
  (var entries [])
  (for operation in (worker_operations_for_kind worker/kind)
    (entries ~ List/push! operation/usage))
  (var joined (entries ~ join " | "))
  $"operations: ${joined}")

(fn handle_worker_command [line : Str, transcript, streaming]
  (var app (active_application ~ Cell/get))
  (var rest (trim (after_prefix line "/worker")))
  (var parts (split rest " "))
  (var worker_ref (if (empty? parts) "" parts/0))
  (var operation_text (trim (after_prefix rest worker_ref)))
  (var worker (application_find_worker app worker_ref))
  (if (== rest "list")
    (then (render_agent_text transcript streaming (workers_report)))
    (elif (|| (== worker_ref "") (== operation_text ""))
      (render_agent_text transcript streaming
        "usage: /worker list | /worker W open | /worker W <operation> [args]"))
    (elif (== worker nil)
      (render_agent_text transcript streaming $"worker ${worker_ref} not found"))
    (elif (== operation_text "open")
      (var pane (application_find_pane_worker app worker/id))
      (if (== pane nil)
        (set pane
          (application_attach_worker_pane app worker
            (if (== worker/kind "agent") worker/id "user") "detach")))
      (if pane (application_focus_pane! app pane/id))
      (render_agent_text transcript streaming
        (if pane $"opened worker ${worker/id} in pane ${pane/id}"
          "this session has no local layout surface")))
    (else
      (var op_parts (split operation_text " "))
      (var operation_name (if (empty? op_parts) "" op_parts/0))
      (var cli_args (trim (after_prefix operation_text operation_name)))
      (var operation (worker_operation_for worker/kind operation_name))
      (if (== operation nil)
        (then
          (var response
            (application_call_worker app worker/id operation_name {}
              {^origin "user" ^adapter "local_tui" ^detached (stdin_tty?)
               ^caller_worker_id app/main_agent/id
               ^surface_id (app/local_surface/instance_id ~ Cell/get)}))
          (render_agent_text transcript streaming
            $"${response/error/kind}: ${response/error/message}; ${(worker_operations_usage worker)}"))
        (else
          (try
            (var raw_args (operation/parse_cli cli_args))
            (var response
              (application_call_worker app worker/id operation_name raw_args
                {^origin "user" ^adapter "local_tui" ^detached (stdin_tty?)
                 ^caller_worker_id app/main_agent/id
                 ^surface_id (app/local_surface/instance_id ~ Cell/get)}))
            (render_agent_text transcript streaming
              (worker_operation_cli_text worker operation_name response))
          catch {^message message}
            (render_agent_text transcript streaming
              $"usage: /worker ${worker_ref} ${operation/usage}\n${message}")))))))

(fn handle_agent_command [line : Str, transcript, memory, streaming]
  (var app (active_application ~ Cell/get))
  (var rest (trim (after_prefix line "/agent")))
  (if (== rest "list")
    (then (render_agent_text transcript streaming (agents_report)))
    (elif (|| (== rest "") (== rest "new"))
      (handle_open_extension transcript memory streaming))
    (elif (starts_with? rest "new ")
      (var prompt (trim (after_prefix rest "new ")))
      (var pane (open_extension_pane "" (memory ~ Cell/get)))
      (if (== pane nil)
        (then
          (render_agent_text transcript streaming "sub-agent limit reached"))
        (else
          (var response
            (application_call_worker app pane/worker/id "send" {^prompt prompt}
              {^origin "user" ^adapter "local_tui"
               ^detached (stdin_tty?)
               ^caller_worker_id app/main_agent/id}))
          (render_agent_text transcript streaming
            (if (&& response/ok (! (stdin_tty?)))
              $"extension ${pane/id} completed: ${response/result/text}"
              (worker_operation_cli_text pane/worker "send" response))))))
    (else
      (var parts (split rest " "))
      (var agent_id parts/0)
      (var action (trim (after_prefix rest agent_id)))
      (var agent (application_find_agent app agent_id))
      (if (== agent nil)
        (then
          (render_agent_text transcript streaming $"agent ${agent_id} not found"))
        (elif (starts_with? action "send ")
          (var prompt (after_prefix action "send "))
          (var response
            (application_call_worker app agent/id "send" {^prompt prompt}
              {^origin "user" ^adapter "local_tui"
               ^detached (stdin_tty?)
               ^caller_worker_id app/main_agent/id}))
          (render_agent_text transcript streaming
            (worker_operation_cli_text agent "send" response)))
        (else
          (match action
            (when "open"
              (var pane (application_find_pane_worker app agent/id))
              (if (== pane nil)
                (set pane
                  (application_open_pane app "agent" agent/id agent/title
                    agent/transcript agent "detach"))
                (application_focus_pane! app pane/id))
              (render_agent_text transcript streaming
                (if pane
                  $"opened agent ${agent/id} in pane ${pane/id}"
                  "pane limit reached")))
            (when "cancel"
              (var response
                (application_call_worker app agent/id "cancel" {}
                  {^origin "user" ^caller_worker_id app/main_agent/id}))
              (render_agent_text transcript streaming
                (worker_operation_cli_text agent "cancel" response)))
            (when "stop"
              (var response
                (application_call_worker app agent/id "stop" {}
                  {^origin "user" ^caller_worker_id app/main_agent/id}))
              (render_agent_text transcript streaming
                (worker_operation_cli_text agent "stop" response)))
            (when "result"
              (var observed
                (application_call_worker app agent/id "result" {}
                  {^origin "user" ^caller_worker_id app/main_agent/id}))
              (var text (worker_operation_cli_text agent "result" observed))
              (if observed/ok
                (application_call_worker app agent/id "mark_result_read" {}
                  {^origin "user" ^caller_worker_id app/main_agent/id}))
              (render_agent_text transcript streaming text))
            (when "incorporate"
              (var response
                (application_call_worker app agent/id "incorporate" {}
                  {^origin "user" ^caller_worker_id app/main_agent/id}))
              (render_agent_text transcript streaming
                (worker_operation_cli_text agent "incorporate" response)))
            (else
              (render_agent_text transcript streaming
                "usage: /agent list | /agent new [prompt] | /agent A send <prompt>|open|result|incorporate|cancel|stop"))))))))

(fn handle_output_pane_command [line : Str, transcript, streaming]
  (var title
    (if (== line "/pane output")
      ""
      (trim (after_prefix line "/pane output "))))
  (var pane (open_output_pane title))
  (render_agent_text transcript streaming
    (if (== pane nil)
      "application is not running"
      $"opened output pane ${pane/id}")))

(fn handle_shell_pane [transcript, streaming]
  (var pane (open_shell_pane))
  (if (== pane nil)
    (then (render_agent_text transcript streaming "application is not running"))
    (else
      (var app (active_application ~ Cell/get))
      (application_focus_pane! app pane/id)
      (render_agent_text transcript streaming
        $"shell pane ${pane/id}; use /${pane/id} <command>"))))

(fn handle_terminal_pane [line : Str, transcript, streaming]
  (var command nil)
  (var args [])
  (var words [])
  (if_yes (starts_with? line "/sh -- ")
    (set words (split (trim (after_prefix line "/sh -- ")) " "))
    (if_not (empty? words)
      (set command words/0)
      (repeat i in words/~size
        (if (> i 0) (args ~ List/push! words/%i)))))
  (var pane (open_terminal_pane command args))
  (if (== pane nil)
    (render_agent_text transcript streaming "application is not running")
    (render_agent_text transcript streaming
      $"terminal pane ${pane/id}; keys go directly to the child, ${terminal_leader_label} opens agent commands")))

(fn agent_status_report [items, memory] : Str
  (var state_label
    (if (== (agent_store ~ Cell/get) nil) "off" (state_display)))
  (var context (context_stats (items ~ Cell/get) (memory ~ Cell/get)))
  (var item_count context/items)
  (var memory_count context/memory_items)
  (var event_count ((agent_events ~ Cell/get) ~ size))
  (var instruction_count ((agent_instruction_records ~ Cell/get) ~ size))
  (var guard_label (if (guard_enabled?) "on" "off"))
  (var app (active_application ~ Cell/get))
  (var agent_count (if (== app nil) 1 ((app/agents ~ Cell/get) ~ size)))
  (var pane_count
    (if (|| (== app nil) (== app/local_surface nil))
      0
      ((app/local_surface/panes ~ Cell/get) ~ size)))
  $"state: ${state_label}\nmodel: ${model}\napi: ${api_flavor}\neffort: ${(reasoning_effort ~ Cell/get)}\ntool rounds: max ${max_tool_rounds}\ncontext: ${context/bytes} bytes (~${context/approx_tokens} tokens), ${item_count} items, ${context/retained_turns} turns\ncontext limits: ${context/max_bytes} bytes, ${context/max_items} items, keep ${context/keep_turns} turns\nmemory: ${memory_count} items, ${context/memory_bytes} bytes\nevents: ${event_count}\ninstructions: ${instruction_count}\nagents: ${agent_count}\npanes: ${pane_count}\nguard: ${guard_label}")

(fn run_shell_session []
  (suspend_user_input)
  (var shell (get_env Env "SHELL" "sh"))
  (println $"Entering shell (${shell}). Ctrl-C stops the running command or clears the line; exit/quit or Ctrl-D returns.")
  (if (stdin_tty?)
    (then
      # Ctrl-C: the trap marks the interrupt, so a failed read reprompts
      # (cleared line) instead of exiting; a running command just dies and the
      # loop continues. EOF (read fails without the mark) exits the session.
      (var script "intr=0; trap 'intr=1; printf \"\\n\"' INT; while true; do printf 'sh> '; intr=0; IFS= read -r line; rc=$?; if [ $rc -ne 0 ]; then if [ $intr -eq 1 ]; then continue; fi; break; fi; case \"$line\" in exit|quit) break;; *) eval \"$line\";; esac; done")
      (await (exec_stdio_async Exec ^cmd shell ^args ["-c" script]
                               ^dir workspace_root))
      (println "")
      nil)
    (else
      # Scripted (piped) /sh: unlike the interactive TTY loop, we read each
      # line in Gene, so route it through the same catastrophe guard as
      # model-issued run_shell (§8.5) before executing.
      (var running (cell true))
      (var line nil)
      (var r nil)
      # Hoisted: re-`var` inside a while body is a duplicate binding on the
      # second iteration, so allocate loop state once and `set` it.
      (var denial nil)
      (while (Cell/get running)
        (print "sh> ")
        (set line (read_line))
        (if (== line nil)
          (Cell/set running false)
          (if (exit_word? line)
            (then (Cell/set running false))
            (else
              (set denial (guard_shell line))
              (if (present? denial)
                (then (println denial))
                (else
                  (set r (exec Exec ^cmd shell ^args ["-lc" line] ^dir workspace_root
                             ^timeout_ms 60000 ^max_bytes 400000))
                  (print (redact r/stdout))
                  (print (redact r/stderr))
                  (if r/timed_out
                    (println "[timed out]"))))))))
      (println ""))))

# Stable live session object (§9.1). Projections are props holding the live
# cells and registry; mutations go through messages so the session can keep
# invariants (system-prompt memory refresh, persistence) and append an audit
# event. `evidence` arrives with the later slice-B evidence work.
(type Session
  ^props {^items Any ^transcript Any ^memory Any ^tools Any ^events Any
          ^changes Any ^evidence Any ^instructions Any ^config Any ^workspace Any
          ^current_task Any ^resume_requested Any ^application Any
          ^main_agent Any ^agents Any ^workers Any ^panes Any}

  # Register (or replace) a typed Tool; it reaches the next model call.
  (message add_tool [self, t]
    (register_tool! t)
    $"tool ${t/name} registered")

  (message add_operation [self, kind : Str, operation]
    (register_worker_operation! kind operation)
    $"worker operation ${kind}/${operation/name} registered")

  # Durable note: memory list + system prompt + persisted state stay in sync.
  (message remember [self, note : Str]
    (self/memory ~ Cell/set (append (self/memory ~ Cell/get) note))
    (self/items ~ Cell/set
      (refresh_system_memory (self/items ~ Cell/get) (self/memory ~ Cell/get)))
    (emit_event! "memory" {^text note})
    (save_agent_state (self/items ~ Cell/get)
                      (self/transcript ~ Cell/get)
                      (self/memory ~ Cell/get))
    $"remembered: ${note}")

  # Echo future events of this type into the transcript as they are emitted.
  (message subscribe [self, type]
    (var t $"${type}")
    (event_subscriptions ~ Cell/set
      (append (event_subscriptions ~ Cell/get) t))
    $"subscribed to ${t} events")

  # Query the event log with the same filters as /trace.
  (message trace [self, filters : Str]
    (trace_report filters))

  (message diff [self]
    (file_diff_report))

  (message undo [self, id : Int?]
    (undo_with_workspace_lease self/application self/main_agent/id id))

  (message spawn_agent [self, assignment : Str]
    (var app self/application)
    (var child_transcript (cell "ready\n"))
    (var agent
      (application_spawn_agent app "sub-agent" assignment
        (cell
          (append (initial_items (self/memory ~ Cell/get))
            (system_item
              $"You are a supervised sub-agent. Assignment: ${assignment}\nKeep private tool chatter out of the main context and return a concise result.")))
        child_transcript))
    (if agent agent/id))

  (message stop_agent [self, agent_id : Str]
    (var agent (application_find_agent self/application agent_id))
    (if (== agent nil)
      false
      (application_stop_agent self/application agent)))

  (message stop_worker [self, worker_id : Str]
    (var worker (application_find_worker self/application worker_id))
    (if (== worker nil)
      false
      (application_stop_worker self/application worker)))

  # REPL scripts and embedded callers share the exact declaration-backed
  # validation/admission path used by slash commands, the model tool, and the
  # gateway. A live REPL is local-user authority; it does not inherit model
  # access merely because the main agent owns the session.
  (message call_worker [self, worker_id : Str, operation : Str, args]
    (application_call_worker self/application worker_id operation args
      {^origin "user" ^caller_worker_id self/main_agent/id}))

  (message pin_artifact [self, source : Str, worker_id : Str]
    (var app self/application)
    (match source
      (when "result"
        (var agent (application_find_agent app worker_id))
        (var result (if agent (agent/result ~ Cell/get)))
        (if (== result nil)
          {^ok false ^error "agent result not found"}
          (application_pin_artifact! app "result"
            (agent_result_text result) agent/id result/task_id)))
      (when "tail"
        (var worker (application_find_worker app worker_id))
        (if (== worker nil)
          {^ok false ^error "worker not found"}
          (then
            (var operation (worker/current_operation ~ Cell/get))
            (application_pin_artifact! app "capture"
              (worker/output ~ Cell/get) worker/id
              (if operation operation/task_id nil)))))
      (else
        {^ok false ^error "source must be result or tail"})))

  (message open_pane [self, kind : Str, owner_id, title : Str]
    (match kind
      (when "agent"
        (var agent (application_find_agent self/application $"${owner_id}"))
        (if_yes agent
          (application_request_worker_attention self/application agent title)
          agent/id))
      (when "output"
        (var worker
          (application_new_worker self/application "output" title
            (cell "ready\n")
            (OutputController ^source "session" ^following (cell []))))
        (if_yes worker
          (application_request_worker_attention self/application worker title)
          worker/id))
      (when "shell" (open_shell_pane))
      (when "terminal" (open_terminal_pane nil []))
      (when "repl" (open_repl_pane self/items self/transcript self/memory))
      (else nil)))

  (message close_pane [self, pane_id : Int]
    (application_close_pane self/application pane_id))

  (message send_pane [self, pane_id : Int, text : Str]
    (var pane (application_find_pane self/application pane_id))
    (if (== pane nil)
      "pane not found"
      (application_send_worker_input
        self/application pane/worker text "local_tui")))

  # Cancel the active model/tool turn. The embedded CLI currently exposes
  # this through the programmable session; gateway.gene also maps it to HTTP.
  (message cancel [self]
    (var task (self/current_task ~ Cell/get))
    (if (== task nil)
      (then "no turn in flight")
      (else
        (task ~ Task/cancel)
        "cancellation requested")))

  # Ask the agent to run another model turn on the current items (no new user
  # input) right after the REPL exits — the add-a-tool-and-continue flow.
  (message resume [self]
    (self/resume_requested ~ Cell/set true)
    "resume requested: exit the REPL (exit/quit) to continue the current turn"))

(fn make_live_session [items, transcript, memory, resume_flag]
  (var app (active_application ~ Cell/get))
  (Session ^items items ^transcript transcript ^memory memory
           ^tools tool_registry ^events agent_events ^changes file_changes
           ^evidence agent_evidence ^instructions agent_instruction_records
           ^config (session_config_snapshot (items ~ Cell/get)
                                            (memory ~ Cell/get))
           ^workspace workspace_real ^current_task active_turn_task
           ^resume_requested resume_flag ^application app
           ^main_agent app/main_agent ^agents app/agents ^workers app/workers
           ^panes (if (== app/local_surface nil)
                    (cell []) app/local_surface/panes)))

(fn live_session_env [items, transcript, memory, resume_flag]
  (env ^bindings
    {^session (make_live_session items transcript memory resume_flag)
     ^Tool Tool ^classify_command classify_command}))

(fn open_repl_pane [items, transcript, memory]
  (var app (active_application ~ Cell/get))
  (var worker (application_find_worker_kind app "repl"))
  (var previous
    (if (== worker nil)
      (application_find_stopped_worker_kind app "repl")))
    (var existing
      (if worker
        (application_find_pane_worker app worker/id)))
    (if (!= existing nil)
      (then
        (application_focus_pane! app existing/id)
        existing)
      (else
        (if_yes (== worker nil)
          (var resume_flag (cell false))
          (var session
            (repl_open (live_session_env items transcript memory resume_flag)))
          (set worker
            (application_new_worker_from app "repl" "Gene REPL"
              (cell "session is bound; type Gene forms (multi-form ok); Esc discards a pending form\n")
              (ReplController ^session session ^items items
                              ^transcript transcript ^memory memory
                              ^streaming app/main_agent/streaming
                              ^resume_requested resume_flag
                              ^pending (cell false))
              previous)))
        (application_attach_worker_pane app worker "user" "detach"))))

(fn handle_repl_pane [items, transcript, memory, streaming]
  (var pane (open_repl_pane items transcript memory))
  (var app (active_application ~ Cell/get))
  (application_focus_pane! app pane/id)
  (render_agent_text transcript streaming
    $"REPL pane ${pane/id}; use /${pane/id} <Gene form>"))

# Returns true when the user asked to continue the turn after the REPL.
(fn run_session_repl [items, transcript, memory]
  (close_user_input)
  (var resume_flag (cell false))
  # classify_command is bound so the guard's classification of dangerous
  # strings can be inspected (and tested) without ever executing them.
  (var repl_env (live_session_env items transcript memory resume_flag))
  (println "Entering Gene REPL. `session` is bound: session/items session/events session/evidence session/instructions session/changes session/current_task (session ~ diff) (session ~ undo nil) (session ~ add_tool (Tool ...)) (session ~ remember \"...\") (session ~ trace \"type=tool_call\") (session ~ cancel) (session ~ resume). Ctrl-C stops the running eval or clears the line; exit/quit or Ctrl-D returns.")
  (run_repl_session repl_env ^interactive true)
  (resume_flag ~ Cell/get))

(fn handle_main_input [app, input : Str, items, transcript, memory, streaming]
  (if (|| (app/main_agent/input_reserved ~ Cell/get)
          (!= (app/main_agent/current_task ~ Cell/get) nil))
    (then
      (render_agent_text transcript streaming
        "main agent is already working; press Esc to cancel it or send this input after it finishes"))
    (else
      (worker_history_push! app/main_agent input "local_tui"
        (if app/local_surface
          (app/local_surface/instance_id ~ Cell/get)))
      (Cell/set streaming false)
      (begin_turn!)
      (application_emit app "user_input"
        {^worker_id app/main_agent/id ^agent_id app/main_agent/id ^text input})
      (Cell/set items
        (run_interactive_turn transcript streaming (interactive_transport)
          (append (Cell/get items) (user_item input))))
      (save_agent_state (items ~ Cell/get)
                        (transcript ~ Cell/get)
                        (memory ~ Cell/get)))))

(fn editor_command_words [command : Str]
  (var words [])
  (var current (cell ""))
  # `quote` is a reader/compiler form name; keeping parser state under a
  # normal identifier avoids it being resolved as syntax in deferred code.
  (var quote_char (cell ""))
  (var escaped (cell false))
  (for ch in (graphemes command)
    (if (escaped ~ Cell/get)
      (then
        (current ~ Cell/set $"${(current ~ Cell/get)}${ch}")
        (escaped ~ Cell/set false))
      (else
        (if (== ch "\\")
          (escaped ~ Cell/set true)
          (if (!= (quote_char ~ Cell/get) "")
            (if (== ch (quote_char ~ Cell/get))
              (quote_char ~ Cell/set "")
              (current ~ Cell/set $"${(current ~ Cell/get)}${ch}"))
            (if (|| (== ch "\"") (== ch "'"))
              (quote_char ~ Cell/set ch)
              (if (|| (== ch " ") (== ch "\t"))
                (if_not (== (current ~ Cell/get) "")
                  (words ~ List/push! (current ~ Cell/get))
                  (current ~ Cell/set ""))
                (current ~ Cell/set $"${(current ~ Cell/get)}${ch}"))))))))
  (if (escaped ~ Cell/get)
    (current ~ Cell/set $"${(current ~ Cell/get)}\\"))
  (if (!= (quote_char ~ Cell/get) "")
    (fail (OsError ^message "unterminated quote in $VISUAL/$EDITOR")))
  (if (!= (current ~ Cell/get) "")
    (words ~ List/push! (current ~ Cell/get)))
  words)

(fn external_editor_draft [draft : Str]
  (var configured (env? Env "VISUAL"))
  # Empty environment values mean “unset”. This matters in an embedding (and
  # in the combined test process), where restoring a previously absent value
  # may leave VISUAL="" while EDITOR is valid.
  (if (|| (== configured nil) (== (trim configured) ""))
    (set configured (env? Env "EDITOR")))
  (if (|| (== configured nil) (== (trim configured) ""))
    (set configured "vi"))
  (var words (editor_command_words configured))
  (if (empty? words)
    (fail (OsError ^message "$VISUAL/$EDITOR resolved to an empty command")))
  (var executable words/0)
  (var args [])
  (repeat i in words/~size
    (if (> i 0) (args ~ List/push! words/%i)))
  (var path $".gene-agent-draft-${(monotonic_ms)}.tmp")
  (write_text WriteDir path draft)
  (suspend_user_input)
  (try
    (args ~ List/push! path)
    (var status
      (await (exec_stdio_async Exec ^cmd executable ^args args
                               ^dir workspace_root)))
    (if (== status 0)
      (then
        (var composed (read_text ReadDir path))
        (if (> (byte_size composed) surface_draft_max_bytes)
          (fail (OsError
            ^message $"editor draft exceeds ${surface_draft_max_bytes} bytes"))
          composed))
      (else draft))
  ensure
    (resume_user_input)
    (if (exists? ReadDir path) (remove WriteDir path))))

(fn run_gene_view [app, path : Str] : Int
  (var owner app/main_agent/id)
  (if_not (application_acquire_workspace app owner "view")
    (fail (OsError
      ^message "workspace is busy; stop the mutating worker and retry /view")))
  (try
    (suspend_user_input)
    (await (exec_stdio_async Exec ^cmd (executable_path)
                             ^args ["view" path] ^dir workspace_root))
  ensure
    (resume_user_input)
    (application_release_workspace app owner "view")))

# One registry drives command recognition and comprehensive help. Handlers stay
# ordinary Gene functions, but a command cannot be accepted by the surface
# without a matching entry here; this keeps typo rejection and documentation
# aligned while the command dispatcher is incrementally flattened.
(var surface_command_specs [
  {^name "/help" ^section "input" ^usage "/help [topic|command|worker <kind>|search <text>|all]"
   ^summary "show comprehensive help in pane 0"}
  {^name "/?" ^section "input" ^usage "/? [topic]"
   ^summary "exact alias for /help"}
  {^name "/0" ^section "input" ^usage "/0 [prompt]"
   ^summary "focus main, or send an explicit main prompt"}
  {^name "/focus" ^section "input" ^usage "/focus <0|N>"
   ^summary "focus main or an extension pane"}
  {^name "/close" ^section "pane" ^usage "/close [N]"
   ^summary "close the focused pane, or pane N; pane 0 is protected"}
  {^name "/pane" ^section "pane" ^usage "/pane list | /pane new <agent|shell|terminal|repl|tail|output|view|stats> [args] | /pane open <W> [title] | /pane focus <0|N> | /pane show|hide|close|max <N> | /pane <N> focus|show|hide|close|max"
   ^summary "create and manage surface-local panes"}
  {^name "/agent" ^section "agent" ^usage "/agent list | /agent new [prompt] | /agent <A> send <prompt> | /agent <A> open|result|incorporate|cancel|stop"
   ^summary "create and supervise sub-agents"}
  {^name "/agents" ^section "agent" ^usage "/agents"
   ^summary "list agent lifecycle, outcome, result, and pane state"}
  {^name "/worker" ^section "worker" ^usage "/worker list | /worker <W> open | /worker <W> <operation> [args]"
   ^summary "invoke the target kind's declared operation table by id or name"}
  {^name "/workers" ^section "worker" ^usage "/workers"
   ^summary "list workers with pane ids and operation state"}
  {^name "/sh" ^section "pane" ^usage "/sh [-- argv...]"
   ^summary "open or focus the local interactive PTY terminal"}
  {^name "/repl" ^section "pane" ^usage "/repl"
   ^summary "open or focus the persistent Gene REPL"}
  {^name "/tail" ^section "pane" ^usage "/tail [filter]"
   ^summary "open an authoritative event-tail projection"}
  {^name "/stats" ^section "pane" ^usage "/stats"
   ^summary "open the live application-stats projection"}
  {^name "/view" ^section "pane" ^usage "/view <file>"
   ^summary "suspend the TUI and run gene view; quitting returns here"}
  {^name "/status" ^section "session" ^usage "/status"
   ^summary "show application and context status"}
  {^name "/effort" ^section "session" ^usage "/effort [default|none|minimal|low|medium|high|xhigh|max]"
   ^summary "show or set model reasoning effort"}
  {^name "/progress" ^section "session" ^usage "/progress"
   ^summary "show the main project-progress record"}
  {^name "/pin" ^section "session" ^usage "/pin result [A] | /pin worker <W> tail"
   ^summary "promote redacted live output to a durable content-addressed artifact"}
  {^name "/artifacts" ^section "session" ^usage "/artifacts"
   ^summary "list durable artifact provenance records"}
  {^name "/artifact" ^section "session" ^usage "/artifact <id> | /artifact delete <id>"
   ^summary "read or explicitly delete a durable artifact"}
  {^name "/trace" ^section "trace" ^usage "/trace [filters] [--detail]"
   ^summary "query redacted authoritative events"}
  {^name "/diff" ^section "session" ^usage "/diff"
   ^summary "show attributable application file changes"}
  {^name "/undo" ^section "session" ^usage "/undo [change-id]"
   ^summary "undo an attributable change after validation"}
  {^name "/remember" ^section "session" ^usage "/remember <note>"
   ^summary "add durable user memory"}
  {^name "/memory" ^section "session" ^usage "/memory"
   ^summary "show durable user memory"}
  {^name "/forget-memory" ^section "session" ^usage "/forget-memory"
   ^summary "clear durable user memory"}
  {^name "/edit" ^section "input" ^usage "/edit [initial text]"
   ^summary "compose the focused draft in VISUAL or EDITOR"}
  {^name "/tty" ^section "session" ^usage "/tty"
   ^summary "temporarily hand the terminal to an interactive shell"}
  {^name "/quit" ^section "session" ^usage "/quit"
   ^summary "save state and exit"}
  {^name "/exit" ^section "session" ^usage "/exit"
   ^summary "alias for /quit"}
])

(fn help_command? [line : Str] : Bool
  (|| (== line "/help") (starts_with? line "/help ")
      (== line "/?") (starts_with? line "/? ")))

(fn help_command_topic [line : Str] : Str
  (if (|| (== line "/help") (== line "/?")) ""
    (trim
      (if (starts_with? line "/help ")
        (after_prefix line "/help ")
        (after_prefix line "/? ")))))

(fn surface_command_head [line : Str] : Str
  (var parts (split line " "))
  (if (empty? parts) "" parts/0))

(fn registered_surface_command? [line : Str] : Bool
  (var head (surface_command_head line))
  (var found (cell false))
  (for spec in surface_command_specs
    (if (== spec/name head) (found ~ Cell/set true)))
  (found ~ Cell/get))

(fn unregistered_surface_command? [line : Str] : Bool
  (&& (starts_with? line "/")
      (! (starts_with? line "//"))
      (== (extension_command_id line) nil)
      (! (registered_surface_command? line))))

(fn worker_kind_help [kind : Str] : Str
  (var known
    ["agent" "shell" "terminal" "repl" "output" "log_tail"
     "file_view" "stats"])
  (var known_text (known ~ join ", "))
  (if_not (known ~ contains? kind)
    (return $"unknown worker kind '${kind}'\nworker kinds: ${known_text}"))
  (var lines [$"${kind} worker operations"])
  (for operation in (worker_operations_for_kind kind)
    (var effects (operation/effects ~ join "+"))
    (var audience (operation/audience ~ join ","))
    (lines ~ List/push!
      $"${operation/usage}\n    ${operation/summary} [${effects}; ${operation/admission}; ${operation/audit}; ${audience}]"))
  (lines ~ join "\n"))

(fn surface_command_spec [name : Str]
  (var requested (if (starts_with? name "/") name $"/${name}"))
  (var found (cell nil))
  (for spec in surface_command_specs
    (if (== spec/name requested) (found ~ Cell/set spec)))
  (found ~ Cell/get))

(fn command_help_page [spec] : Str
  $"${spec/name}\nusage: ${spec/usage}\n${spec/summary}\nsection: ${spec/section}")

(fn help_search [term : Str] : Str
  (var query (lower term))
  (var lines [$"help search: ${term}"])
  (for spec in surface_command_specs
    (var haystack
      (lower $"${spec/name} ${spec/usage} ${spec/summary} ${spec/section}"))
    (if (contains? haystack query)
      (lines ~ List/push! $"${spec/usage}\n    ${spec/summary}")))
  (if (== (lines ~ size) 1)
    $"no help matches '${term}'"
    (lines ~ join "\n")))

(fn common_prefix_size [a : Str, b : Str] : Int
  (var aa (editor_chars a))
  (var bb (editor_chars b))
  (var limit (if (< aa/~size bb/~size) aa/~size bb/~size))
  (var count 0)
  (while (&& (< count limit) (== aa/%count bb/%count))
    (set count (+ count 1)))
  count)

(fn surface_command_suggestion [name : Str] : Str
  (var best "")
  (var best_score 0)
  (for spec in surface_command_specs
    (var score (common_prefix_size name spec/name))
    (if_yes (> score best_score)
      (set best spec/name)
      (set best_score score)))
  (if (>= best_score 2) $"; did you mean '${best}'?" ""))

(fn comprehensive_help [topic : Str] : Str
  (if (starts_with? topic "worker ")
    (return (worker_kind_help (trim (after_prefix topic "worker ")))))
  (if (starts_with? topic "search ")
    (return (help_search (trim (after_prefix topic "search ")))))
  (var command_spec
    (if (|| (starts_with? topic "/")
            (&& (!= topic "")
                (! (["pane" "agent" "worker" "input" "session" "trace"
                      "all"] ~ contains? topic))))
      (surface_command_spec topic)))
  (if command_spec (return (command_help_page command_spec)))
  (if (== topic "all") (set topic ""))
  (var valid_topics ["pane" "agent" "worker" "input" "session" "trace"])
  (if (&& (!= topic "") (! (valid_topics ~ contains? topic)))
    (then
      (var topic_separator ", ")
      (var topics_text (join valid_topics topic_separator))
      $"unknown help topic '${topic}'\ntopics: ${topics_text}\n")
    (else
      (var lines ["Gene agent help" "topics: pane, agent, worker, input, session, trace" ""])
      (for spec in surface_command_specs
        (if (|| (== topic "") (== spec/section topic))
          (lines ~ List/push! $"${spec/usage}\n    ${spec/summary}")))
      (if (|| (== topic "") (== topic "input"))
        (then
          (lines ~ List/push! "")
          (lines ~ List/push! "keys: Up/Down history | Tab complete | Ctrl-R search | Ctrl-E edit | PgUp/PgDn or wheel scroll | Ctrl-PgUp/PgDn cycle panes | Esc cancel/back | Ctrl-C clear | Ctrl-D exit")
          (lines ~ List/push! "literal leading slash: //text for focused input | /N -- /absolute/path for pane N")))
      (lines ~ List/push! "")
      (lines ~ List/push! "pane shortcuts: /N focus | /close [N] | /N cancel|stop|max | /N <input> | /0 main")
      (var line_separator "\n")
      (var help_text (join lines line_separator))
      $"${help_text}\n")))

(fn show_surface_help! [app, transcript, line : Str]
  (var surface app/local_surface)
  (var text (comprehensive_help (help_command_topic line)))
  (if surface
    (then
      (surface/focused_pane ~ Cell/set nil)
      (surface/maximized_pane ~ Cell/set nil)
      (surface/main_scroll ~ Cell/set 0)
      (surface/help_notice ~ Cell/set text)
      (if (stdin_tty?)
        (refresh_user_input transcript)
        (println text)))
    (else (println text)))
  text)

(fn effort_report [] : Str
  $"reasoning effort levels: ${reasoning_effort_levels_text}\ncurrent effort: ${(reasoning_effort ~ Cell/get)}\navailability depends on the selected model")

(fn latest_subagent [app]
  (var found nil)
  (for agent in (app/agents ~ Cell/get)
    (if (!= agent/id "main") (set found agent)))
  found)

(fn handle_pin_command [line : Str, app, transcript, streaming]
  (var rest (trim (after_prefix line "/pin")))
  (if (starts_with? rest "result")
    (then
      (var agent_ref (trim (after_prefix rest "result")))
      (var agent
        (if (== agent_ref "") (latest_subagent app)
          (application_find_agent app agent_ref)))
      (if (== agent nil)
        (then
          (render_agent_text transcript streaming "agent result not found"))
        (else
          (var result (agent/result ~ Cell/get))
          (if (== result nil)
            (then
              (render_agent_text transcript streaming $"agent ${agent/id} has no result"))
            (else
              (var pinned
                (application_pin_artifact! app "result"
                  (agent_result_text result) agent/id result/task_id))
              (render_agent_text transcript streaming
                (if pinned/ok
                  $"pinned ${pinned/artifact/id} ${pinned/artifact/blob_id}"
                  pinned/error)))))))
    (elif (starts_with? rest "worker ")
      (var worker_rest (trim (after_prefix rest "worker ")))
      (var parts (split worker_rest " "))
      (var worker_ref (if (empty? parts) "" parts/0))
      (var action (trim (after_prefix worker_rest worker_ref)))
      (var worker (application_find_worker app worker_ref))
      (if (|| (== worker nil) (!= action "tail"))
        (then
          (render_agent_text transcript streaming
            "usage: /pin worker <W> tail"))
        (else
          (var operation (worker/current_operation ~ Cell/get))
          (var pinned
            (application_pin_artifact! app "capture"
              (worker/output ~ Cell/get) worker/id
              (if operation operation/task_id nil)))
          (render_agent_text transcript streaming
            (if pinned/ok
              $"pinned ${pinned/artifact/id} ${pinned/artifact/blob_id}"
              pinned/error)))))
    (else
      (render_agent_text transcript streaming
        "usage: /pin result [A] | /pin worker <W> tail"))))

(fn handle_artifact_command [line : Str, app, transcript, streaming]
  (var rest (trim (after_prefix line "/artifact")))
  (if (starts_with? rest "delete ")
    (then
      (var id (trim (after_prefix rest "delete ")))
      (var deleted (application_delete_artifact! app id))
      (render_agent_text transcript streaming
        (if deleted/ok $"deleted ${id}" deleted/error)))
    (else
      (var artifact (artifact_find rest))
      (if (== artifact nil)
        (then
          (render_agent_text transcript streaming $"artifact ${rest} not found"))
        (else
          (var content (artifact_content artifact))
          (render_agent_text transcript streaming
            (if (== content nil)
              $"artifact ${rest}: content missing"
              $"${artifact/id} ${artifact/kind} (${artifact/size} bytes)\n${content}")))))))

(fn handle_effort_command [line : Str, app, transcript, streaming]
  (var requested (trim (after_prefix line "/effort")))
  (if (== requested "")
    (then
      (render_agent_text transcript streaming (effort_report)))
    (else
      (var level (lower requested))
      (if (! (valid_reasoning_effort? level))
        (then
          (render_agent_text transcript streaming
            $"invalid reasoning effort '${requested}'\n${(effort_report)}"))
        (else
          (reasoning_effort ~ Cell/set level)
          (application_emit app "config_changed"
            {^setting "reasoning_effort" ^value level})
          (render_agent_text transcript streaming
            $"reasoning effort set to ${level}"))))))

(fn handle_surface_global_command [line : Str, app, items, transcript, memory,
                                   streaming] : Bool
  (if (starts_with? line "/pin ")
    (then
      (handle_pin_command line app transcript streaming)
      true)
    (elif (== line "/artifacts")
      (render_agent_text transcript streaming (artifacts_report))
      true)
    (elif (starts_with? line "/artifact ")
      (handle_artifact_command line app transcript streaming)
      true)
    (elif (|| (== line "/effort") (starts_with? line "/effort "))
      (handle_effort_command line app transcript streaming)
      true)
    (elif (help_command? line)
      (show_surface_help! app transcript line)
      true)
    (elif (starts_with? line "/focus ")
      (var focus_id_text (trim (after_prefix line "/focus ")))
      (handle_pane_command
        $"/pane focus ${focus_id_text}"
        items transcript memory streaming)
      true)
    (elif (|| (== line "/pane") (starts_with? line "/pane "))
      (handle_pane_command line items transcript memory streaming)
      true)
    (elif (== line "/0")
      (app/local_surface/focused_pane ~ Cell/set nil)
      (render_agent_text transcript streaming "focused main agent")
      true)
    (elif (starts_with? line "/0 ")
      (app/local_surface/focused_pane ~ Cell/set nil)
      (var main_input (after_prefix line "/0 "))
      (if (blank_line? main_input)
        (render_agent_text transcript streaming "focused main agent")
        (handle_main_input app main_input items transcript memory streaming))
      true)
    (elif (== line "/workers")
      (render_agent_text transcript streaming (workers_report))
      true)
    (elif (== line "/stats")
      (var pane (open_stats_pane))
      (render_agent_text transcript streaming
        (if (== pane nil)
          "worker limit reached"
          $"opened stats pane ${pane/id}"))
      true)
    (elif (|| (== line "/tail") (starts_with? line "/tail "))
      (var filter_text
        (if (== line "/tail") "" (after_prefix line "/tail ")))
      (var pane (open_log_tail_pane filter_text))
      (render_agent_text transcript streaming
        (if (== pane nil)
          "worker limit reached"
          $"opened event tail pane ${pane/id}"))
      true)
    (elif (starts_with? line "/view ")
      (var path (trim (after_prefix line "/view ")))
      (try
        (var status (run_gene_view app path))
        (render_agent_text transcript streaming
          (if (== status 0)
            "returned from gene view"
            $"gene view exited with status ${status}"))
      catch {^message message}
        (render_agent_text transcript streaming
          $"cannot run gene view: ${message}"))
      true)
    (elif (|| (== line "/edit") (starts_with? line "/edit "))
      (var draft (surface_route_draft app))
      (var initial
        (if (== line "/edit")
          (draft ~ Cell/get)
          (after_prefix line "/edit ")))
      (try
        (draft ~ Cell/set (external_editor_draft initial))
        (render_agent_text transcript streaming
          "external editor draft loaded; Enter submits it")
      catch {^message message}
        (render_agent_text transcript streaming
          $"external editor failed: ${message}"))
      true)
    (elif (== line "/tty")
      (var acquired
        (application_acquire_workspace app app/main_agent/id "tty"))
      (if acquired
        (try
          (run_shell_session)
        ensure
          (resume_user_input)
          (application_release_workspace app app/main_agent/id "tty"))
        (render_agent_text transcript streaming
          "application is shutting down"))
      (refresh_user_input transcript)
      true)
    (elif (|| (== line "/worker") (starts_with? line "/worker "))
      (handle_worker_command line transcript streaming)
      true)
    (else false)))

(fn route_surface_input [app, line : Str, items, transcript, memory, streaming]
  (if (&& (starts_with? line "/") (! (starts_with? line "//")))
    (then
      (var literal_hint
        (if (surface_route_input_capable? app)
          "; to send a literal leading slash use //text or /N -- text" ""))
      (render_agent_text transcript streaming
        (if (registered_surface_command? line)
          $"invalid command form: ${line}\nuse /help or /? for syntax${literal_hint}"
          $"unknown command: ${(surface_command_head line)}${(surface_command_suggestion (surface_command_head line))}\nuse /help or /?${literal_hint}")))
    (else
      (var pane_id (app/local_surface/focused_pane ~ Cell/get))
      (var routed_line
        (if (starts_with? line "//") (after_prefix line "/") line))
      (if (!= pane_id nil)
        (handle_extension_command $"/${pane_id} -- ${routed_line}"
                                  transcript memory streaming)
        (handle_main_input app routed_line items transcript memory streaming)))))

(fn run_repl []
  (init_agent_state)
  (start_workspace_heartbeat!)
  (restore_reasoning_effort!)
  (println $"Started Gene AI agent - model ${model}.")
  (var memory (cell (load_memory)))
  (var saved (load_session))
  (if saved
    (restore_events))
  (var items
    (cell
      (if (== saved nil)
        (initial_items (memory ~ Cell/get))
        (refresh_system_memory saved/items (memory ~ Cell/get)))))
  (var transcript
    (cell
      (if (== saved nil)
        $"Gene AI agent - model ${model}\n"
        saved/transcript)))
  (var running (cell true))
  (var line nil)
  (var input_history nil)
  (var streaming (cell false))
  (var app (make_application items transcript memory emit_event!))
  (active_application ~ Cell/set app)
  (restore_dynamic_registrations! app)
  (restore_application! app)
  (interactive_transcript ~ Cell/set transcript)
  (interactive_memory ~ Cell/set (memory ~ Cell/get))
  # Subscribed event types echo into the transcript as they are emitted.
  (event_echo ~ Cell/set
    (fn [text] (render_agent_text transcript streaming $"[event] ${text}")))
  (if_yes saved
    (append_transcript transcript $"[restored session from ${(state_display)}]\n")
    (refresh_user_input transcript))
  (while (Cell/get running)
    (interactive_memory ~ Cell/set (memory ~ Cell/get))
    (set input_history (surface_route_history app))
    (set line (read_user_input transcript input_history))
    (if (== line nil)
      (then
        (close_user_input)
        (save_agent_state (items ~ Cell/get)
                          (transcript ~ Cell/get)
                          (memory ~ Cell/get))
        (interactive_transcript ~ Cell/set nil)
        (Cell/set running false))
      (else
        (if_not (blank_line? line)
          (if_not (help_command? line)
            # Keep ordinary submitted commands in the visible/persisted
            # transcript. Help is a replaceable surface notice and deliberately
            # bypasses both transcript and checkpoint state.
            (if app/local_surface
              (app/local_surface/help_notice ~ Cell/set ""))
            # Routed bare input echoes once at its destination pane (§C7);
            # commands and main-agent prompts keep the main-transcript echo.
            (if (|| (starts_with? line "/")
                    (== app/local_surface nil)
                    (== (app/local_surface/focused_pane ~ Cell/get) nil))
              (append_transcript transcript $"──────\n${line}\n")
              (refresh_user_input transcript))
            (checkpoint_agent_state! app "input_submitted"))
          (refresh_user_input transcript)
          # Registry recognition is the gate in front of every static slash
          # handler. Dynamic /N routes are parsed separately; nothing else can
          # become a control command unless its metadata/help entry exists.
          (if (unregistered_surface_command? line)
            (route_surface_input app line items transcript memory streaming)
            (if_not (handle_surface_global_command line app items transcript memory streaming)
              (if (|| (== line "/quit") (== line "/exit"))
                (then
                  (close_user_input)
                  (save_agent_state (items ~ Cell/get)
                                    (transcript ~ Cell/get)
                                    (memory ~ Cell/get))
                  (interactive_transcript ~ Cell/set nil)
                  (Cell/set running false))
                (elif (== line "/agents")
                  (render_agent_text transcript streaming (agents_report)))
                (elif (|| (== line "/agent") (starts_with? line "/agent "))
                  (handle_agent_command line transcript memory streaming))
                (elif (|| (== line "/pane output")
                        (starts_with? line "/pane output "))
                  (handle_output_pane_command line transcript streaming))
                (elif (|| (== line "/close") (starts_with? line "/close "))
                  (handle_close_command line transcript streaming))
                (elif (|| (== line "/sh")
                          (starts_with? line "/sh -- "))
                  (handle_terminal_pane line transcript streaming))
                (elif (== line "/repl")
                  (handle_repl_pane items transcript memory streaming))
                (elif (== line "/memory")
                  (var sep "\n")
                  (render_agent_text transcript streaming
                    (if (empty? (memory ~ Cell/get))
                      "memory is empty"
                      $"memory:\n${(join (memory ~ Cell/get) sep)}")))
                (elif (== line "/forget-memory")
                  (memory ~ Cell/set [])
                  (items ~ Cell/set
                    (refresh_system_memory (items ~ Cell/get)
                                          (memory ~ Cell/get)))
                  (emit_event! "memory" {^action "clear" ^text "memory cleared"})
                  (save_agent_state (items ~ Cell/get)
                                    (transcript ~ Cell/get)
                                    (memory ~ Cell/get))
                  (render_agent_text transcript streaming "memory cleared"))
                (elif (starts_with? line "/remember ")
                  (var note (trim (after_prefix line "/remember ")))
                  (if (== note "")
                    (then
                      (render_agent_text transcript streaming
                        "usage: /remember <note>"))
                    (else
                      (memory ~ Cell/set (append (memory ~ Cell/get) note))
                      (items ~ Cell/set
                        (refresh_system_memory (items ~ Cell/get)
                                              (memory ~ Cell/get)))
                      (emit_event! "memory" {^action "remember" ^text note})
                      (save_agent_state (items ~ Cell/get)
                                        (transcript ~ Cell/get)
                                        (memory ~ Cell/get))
                      (render_agent_text transcript streaming
                        $"remembered: ${note}"))))
                (elif (== line "/status")
                  (render_agent_text transcript streaming
                    (agent_status_report items memory)))
                (elif (== line "/progress")
                  (render_agent_text transcript streaming
                    (project_progress_report app)))
                (elif (== line "/diff")
                  (render_agent_text transcript streaming (file_diff_report)))
                (elif (|| (== line "/undo") (starts_with? line "/undo "))
                  (render_agent_text transcript streaming (undo_command line)))
                (elif (|| (== line "/trace") (starts_with? line "/trace "))
                  (render_agent_text transcript streaming
                    (trace_report
                      (if (== line "/trace")
                        ""
                        (after_prefix line "/trace ")))))
                (elif (!= (extension_command_id line) nil)
                  (handle_extension_command line transcript
                                            memory streaming))
                (else
                  (route_surface_input app line items transcript
                                        memory streaming))))))))))

# Project a remotely initiated turn into an attached transcript without giving
# the adapter any curses knowledge. In headless/remote-only applications these
# cells are still the canonical transcript projection, just with no screen to
# refresh.

(fn parse_launch_options [raw : Str]
  (var gateway (cell false))
  (var headless (cell false))
  (var port (cell void))
  (var connect (cell nil))
  (var session (cell nil))
  (var pending_option (cell nil))
  (var task_parts [])
  (for token in (split (trim raw) " ")
    (if_not (== token "")
      (var pending (pending_option ~ Cell/get))
      (if pending
        (then
          (if (== pending "connect")
            (connect ~ Cell/set token)
            (session ~ Cell/set token))
          (pending_option ~ Cell/set nil))
        (else
          (if (== token "--gateway")
            (gateway ~ Cell/set true)
            (if (starts_with? token "--gateway=")
              (then
                (gateway ~ Cell/set true)
                (port ~ Cell/set
                  (parse_int (after_prefix token "--gateway="))))
              (else
                (match token
                  (when "--headless" (headless ~ Cell/set true))
                  (when "--connect" (pending_option ~ Cell/set "connect"))
                  (when "--session" (pending_option ~ Cell/set "session"))
                  (else
                    (if (starts_with? token "--connect=")
                      (connect ~ Cell/set
                        (after_prefix token "--connect="))
                      (if (starts_with? token "--session=")
                        (session ~ Cell/set
                          (after_prefix token "--session="))
                        (task_parts ~ List/push! token))))))))))))
  (if (pending_option ~ Cell/get)
    (fail (OsError
      ^message $"--${(pending_option ~ Cell/get)} requires a value")))
  (if (&& (headless ~ Cell/get) (! (gateway ~ Cell/get)))
    (fail (OsError ^message "--headless requires --gateway")))
  (if (&& (connect ~ Cell/get)
          (|| (gateway ~ Cell/get) (headless ~ Cell/get)))
    (fail (OsError
      ^message "--connect cannot be combined with --gateway or --headless")))
  (if (&& (!= (port ~ Cell/get) void)
          (|| (< (port ~ Cell/get) 1) (> (port ~ Cell/get) 65535)))
    (fail (OsError ^message "--gateway port must be between 1 and 65535")))
  {^gateway (gateway ~ Cell/get) ^headless (headless ~ Cell/get)
   ^port (port ~ Cell/get) ^connect (connect ~ Cell/get)
   ^session (session ~ Cell/get) ^task (join task_parts " ")})

(fn remote_confirmation_decision [event, interactive : Bool] : Str
  (if_not interactive (return "deny"))
  (print
    $"confirm ${event/risk}: ${event/target}\nallow once? [y/N] ")
  (var answer (read_line))
  (if (&& answer (["y" "yes"] ~ contains? (lower (trim answer))))
    "allow" "deny"))

(fn run_remote_turn [client, text : Str, interactive : Bool]
  (client/send_message text)
  (var streaming (cell false))
  (var done (cell false))
  (while (! (done ~ Cell/get))
    (var batch (client/poll))
    (for event in batch/events
      (match event/type
        (when "text_delta"
          (if_not (streaming ~ Cell/get)
            (print "agent> ")
            (streaming ~ Cell/set true))
          (print event/text))
        (when "agent_text"
          (if_not (streaming ~ Cell/get)
            (println $"agent> ${event/text}")))
        (when "confirmation_requested"
          (if_yes (streaming ~ Cell/get)
            (println "")
            (streaming ~ Cell/set false))
          (var decision
            (remote_confirmation_decision event interactive))
          (client/resolve_confirmation event/confirmation_id decision)
          (println $"confirmation ${decision}"))
        (when "turn_done"
          (if_yes (streaming ~ Cell/get)
            (println "")
            (streaming ~ Cell/set false))
          (done ~ Cell/set true))
        (else nil)))
    (client/acknowledge batch/cursor)))

# Remote parity (§10.12 stage 3): the operation registry served by
# /api/operations drives the remote /worker command exactly as the local
# declarations drive the local one. A single-placeholder usage string
# ("run <command>", "tail [n]") maps the rest of the line onto that field;
# anything richer takes literal JSON args. In-process-only operations reach
# the gateway and come back as typed local_only errors — never hidden here.
(fn remote_usage_placeholder [usage : Str]
  (var parts (split (trim usage) " "))
  (if (== parts/~size 2)
    (then
      (var token parts/1)
      (if (&& (starts_with? token "<") (ends_with? token ">"))
        {^field (slice_bytes token 1 (- (byte_size token) 2)) ^optional false}
        (if (&& (starts_with? token "[") (ends_with? token "]"))
          {^field (slice_bytes token 1 (- (byte_size token) 2)) ^optional true})))))

(fn remote_operation_args [metadata, kind : Str, op : Str, rest : Str]
  (if (== (trim rest) "") (return {}))
  (if (starts_with? (trim rest) "{")
    (return (parse (trim rest))))
  (var descriptor (cell nil))
  (for operation in metadata/operations
    (if (&& (== operation/name op)
            (|| (== operation/worker_kind kind)
                (== operation/worker_kind "*"))
            (|| (== (descriptor ~ Cell/get) nil)
                (== operation/worker_kind kind)))
      (descriptor ~ Cell/set operation)))
  (var found (descriptor ~ Cell/get))
  (if (== found nil)
    (fail (ClientTransportError
      ^kind "unknown_operation"
      ^message $"no ${kind} operation named ${op}; see /operations")))
  (var placeholder (remote_usage_placeholder found/usage))
  (if (== placeholder nil)
    (fail (ClientTransportError
      ^kind "invalid_arguments"
      ^message $"${op} takes JSON args here: /worker <id> ${op} {...}")))
  (var value
    (if placeholder/optional
      (try (parse_int (trim rest)) catch _ (trim rest))
      (trim rest)))
  (var args {})
  (args ~ Map/put! placeholder/field value)
  args)

(fn remote_worker_kind [client, worker_ref : Str]
  (var listing (client/workers))
  (var kind (cell nil))
  (for worker in listing/workers
    (if (|| (== worker/worker_id worker_ref)
            (== worker/name worker_ref))
      (kind ~ Cell/set worker/kind)))
  (kind ~ Cell/get))

(fn remote_workers_report [client]
  (var listing (client/workers))
  (for worker in listing/workers
    (println
      $"${worker/worker_id} ${worker/kind} ${worker/lifecycle} ${worker/title}")))

(fn remote_worker_command [client, line : Str]
  (var rest (trim (after_prefix line "/worker")))
  (var parts (split rest " "))
  (if (< parts/~size 2)
    (return (println "usage: /worker <id> <op> [args]")))
  (var worker_ref parts/0)
  (var op parts/1)
  (var arg_rest (trim (after_prefix (trim (after_prefix rest worker_ref)) op)))
  (var kind (remote_worker_kind client worker_ref))
  (if (== kind nil)
    (return (println $"worker ${worker_ref} not found")))
  (var args (remote_operation_args (client/operations) kind op arg_rest))
  (var response (client/call_worker worker_ref op args))
  (println (stringify response/result)))

(fn remote_pin_command [client, line : Str]
  (var rest (trim (after_prefix line "/pin")))
  (if (starts_with? rest "result")
    (then
      (var agent_ref (trim (after_prefix rest "result")))
      (var pinned (client/pin "result" agent_ref))
      (println $"pinned ${pinned/artifact/id} ${pinned/artifact/blob_id}"))
    (elif (starts_with? rest "worker ")
      (var worker_rest (trim (after_prefix rest "worker ")))
      (var parts (split worker_rest " "))
      (if (&& (== parts/~size 2) (== parts/1 "tail"))
        (then
          (var pinned (client/pin "tail" parts/0))
          (println $"pinned ${pinned/artifact/id} ${pinned/artifact/blob_id}"))
        (println "usage: /pin worker <id> tail")))
    (else
      (println "usage: /pin result <agent_id> | /pin worker <id> tail"))))

(fn remote_artifacts_report [client]
  (var listing (client/artifacts))
  (if (empty? listing/artifacts)
    (println "no artifacts")
    (for artifact in listing/artifacts
      (println
        $"${artifact/id} ${artifact/kind} source=${artifact/source_worker} bytes=${artifact/size} blob=${artifact/blob_id}"))))

(fn run_remote_entry [launch, task : Str]
  (var gateway_token (get_env Env "GENE_GATEWAY_TOKEN" ""))
  (var client (remote_transport launch/connect gateway_token))
  (try
    (var attached (client/connect launch/session "gene-tui"))
    (println
      $"Gene AI agent - remote session ${(client/session_id ~ Cell/get)} at ${launch/connect}")
    (if_not (blank_line? task)
      (println $"user> ${task}")
      (run_remote_turn client task false)
      (return nil))
    (var line nil)
    (var metadata nil)
    (var snapshot nil)
    (loop
      (print "user> ")
      (set line (read_line))
      (if (== line nil) (return nil))
      (set line (trim line))
      (try
        (match line
          (when "/quit" (return nil))
          (when "/exit" (return nil))
          (when "/help"
            (println
              (join
                ["/workers                  list session workers"
                 "/worker <id> <op> [args]  invoke a declared operation"
                 "/pin result <agent_id>    pin an agent result"
                 "/pin worker <id> tail     pin a worker tail capture"
                 "/artifacts                list pinned artifacts"
                 "/snapshot                 show the bounded session snapshot"
                 "/operations               list declared operations"
                 "/quit                     detach and exit"
                 "Other input is sent to the remote main agent."] "\n")))
          (when "/operations"
            (set metadata (client/operations))
            (for operation in metadata/operations
              (println
                $"${operation/worker_kind}/${operation/name} - ${operation/summary}")))
          (when "/workers" (remote_workers_report client))
          (when "/artifacts" (remote_artifacts_report client))
          (when "/snapshot"
            (set snapshot (client/snapshot))
            (println
              $"session ${snapshot/session_id} cursor ${snapshot/cursor} workers ${(snapshot/workers ~ size)}"))
          (else
            (if (starts_with? line "/worker ")
              (remote_worker_command client line)
              (if (starts_with? line "/pin")
                (remote_pin_command client line)
                (if_not (== line "")
                  (run_remote_turn client line true))))))
      catch (ClientTransportError ^kind kind ^message message)
        (println $"remote ${kind}: ${message}")))
  catch (ClientTransportError ^kind kind ^message message)
    (println $"remote ${kind}: ${message}")
  ensure
    (try (client/detach) catch _ nil)))

(fn run_local_entry [launch, task : Str]
  (if (blank_line? task)
    (if (&& (== auth_token nil) (! launch/gateway))
      (run_demo)
      (try
        (run_repl)
      ensure
        (close_user_input)))
    (run_one_shot task)))

# `gene run` auto-invokes a top-level `main` (src/gene.nim), so no explicit call.
(fn main [args]
  (var launch (parse_launch_options args/raw))
  (var task launch/task)
  (var run_mode
    (if launch/connect
      "remote_client"
    (if launch/headless
      "gateway_headless"
      (if launch/gateway
        "gateway_tui"
        (if (blank_line? task)
      (if (== auth_token nil) "offline_demo" "interactive")
          "one_shot")))))
  (info! agent_log "agent starting"
    ^payload {^run_mode run_mode ^api_flavor api_flavor ^model_name model
              ^live_auth (present? auth_token) ^state_enabled (state_enabled?)
              ^resume_enabled (resume_enabled?) ^guard_enabled (guard_enabled?)
              ^approve_all (flag_enabled? approve_all)
              ^max_tool_rounds max_tool_rounds
              ^tool_count ((tool_names ~ Cell/get) ~ size)})
  (var gateway_server (cell nil))
  (var gateway_task (cell nil))
  (try
    (if launch/connect
      (run_remote_entry launch task)
    (if launch/headless
      (then (run_gateway (gateway_api) {^port launch/port}))
      (else
        (if launch/gateway
          (then
            (gateway_server ~ Cell/set
              (prepare_gateway (gateway_api)
                {^port launch/port ^quiet true}))
            # `net/http/serve` is itself the scheduler-driving root loop. Keep
            # it at the root and make the local entrypoint a sibling Task;
            # spawning `serve` from inside the TUI fiber would recursively pump
            # the scheduler and starve curses input in combined mode.
            (gateway_task ~ Cell/set
              (spawn ^lane root
                (try
                  (run_local_entry launch task)
                ensure
                  (stop_gateway (gateway_server ~ Cell/get)))))
            ((gateway_task ~ Cell/get) ~ Task/detach)
            (serve_gateway (gateway_server ~ Cell/get))
            (try (await (gateway_task ~ Cell/get)) catch _ nil)
            # The local task requested and completed gateway shutdown. Clear
            # both handles so the outer failure-cleanup path does not stop the
            # already-dropped native listener a second time.
            (gateway_task ~ Cell/set nil)
            (gateway_server ~ Cell/set nil))
          (else (run_local_entry launch task))))))
  ensure
    (if_yes (gateway_server ~ Cell/get)
      (var task (gateway_task ~ Cell/get))
      (if_yes task
        (task ~ Task/cancel)
        (try (await task) catch _ nil))
      # An interrupted local task normally stops the server in its own
      # ensure. The fallback is intentionally idempotent at this boundary.
      (try (stop_gateway (gateway_server ~ Cell/get)) catch _ nil))
    (var app (active_application ~ Cell/get))
    (if_yes app
      (application_shutdown app)
      # The ordinary /exit checkpoint precedes process teardown. Publish one
      # final generation after terminal sessions have been stopped, captured,
      # and closed so restore never sees a fake live PTY.
      (save_agent_state_with_reason
        (app/main_agent/items ~ Cell/get)
        (app/main_agent/transcript ~ Cell/get)
        (app/memory ~ Cell/get) "application_stopped"))
    (active_application ~ Cell/set nil)
    (close_agent_state)
    (close_user_input)
    (info! agent_log "agent stopped"
      ^payload {^run_mode run_mode
                ^turns (current_turn ~ Cell/get)
                ^events ((agent_events ~ Cell/get) ~ size)})))

# -----------------------------------------------------------------------------
# Surface hook installation (slice C9): the core stays UI-free; this TUI
# provides the curses confirmation prompt, repaint, Escape polling, and the
# interactive repl-worker restart factory.
# -----------------------------------------------------------------------------
(interactive_confirm ~ Cell/set confirmation_answer)
(ui_refresh ~ Cell/set refresh_active_input)
(surface_history_recorder ~ Cell/set record_local_surface_history!)
(interactive_resume_turn ~ Cell/set
  (fn [transcript, streaming, items]
    (run_interactive_turn transcript streaming (interactive_transport) items)))
(ui_escape_poll ~ Cell/set
  (fn []
    (&& (!= (user_screen ~ Cell/get) nil)
        (escape_pressed? (user_screen ~ Cell/get)))))
(repl_restart_factory ~ Cell/set
  (fn [app, previous]
    (var resume_flag (cell false))
    (var session
      (repl_open
        (live_session_env app/main_agent/items
          app/main_agent/transcript interactive_memory resume_flag)))
    (application_new_worker_from app "repl" previous/title
      (cell "session is bound; type Gene forms (multi-form ok); Esc discards a pending form\n")
      (ReplController ^session session ^items app/main_agent/items
                      ^transcript app/main_agent/transcript
                      ^memory interactive_memory
                      ^streaming app/main_agent/streaming
                      ^resume_requested resume_flag
                      ^pending (cell false))
      previous)))

# This TUI's pane/layout state persists in its own client store (invariant
# §0.13): a `surface_local_tui` sibling of the session store. The session
# checkpoints never carry it.
(var tui_surface_store (cell nil))

(fn tui_surface_store_now []
  (if (== (tui_surface_store ~ Cell/get) nil)
    (tui_surface_store ~ Cell/set (open_client_store "surface_local_tui")))
  (tui_surface_store ~ Cell/get))

(client_surface_checkpoint_hook ~ Cell/set
  (fn [app, _reason]
    (var store (tui_surface_store_now))
    (if_yes (&& (!= store nil) (checkpoint_local_application? app))
      (try
        (store ~ put "surface"
          {^schema 1 ^kind "surface" ^data (surface_snapshot app)})
      catch _ nil))))

(client_surface_record_loader ~ Cell/set
  (fn []
    (var store (tui_surface_store_now))
    (if_yes (!= store nil)
      (try
        (var record (store ~ get "surface" ^default nil))
        (if_yes (present? record)
          (if (present? record/data) (redact_any record/data)))
      catch _ nil))))
