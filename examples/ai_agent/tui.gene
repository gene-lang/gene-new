#!/usr/bin/env gene run
# =============================================================================
# Gene AI coding agent — MVP (examples/ai_agent/design.md milestones 1-4).
#
#   * Talks to Codex's ChatGPT-account Responses backend by default, or to any
#     OpenAI-compatible Chat Completions endpoint (MiniMax, DeepSeek, vLLM,
#     api.openai.com, ...) configured entirely from the environment. Streaming
#     in both modes.
#   * Transport is native libcurl through net/http_client (curl(1) is a
#     discovery fallback), so model calls never block the scheduler.
#   * Tools: read_file / write_file / edit_file / list_dir / run_shell / grep,
#     each declared ONCE as a typed Tool value — the model-facing JSON schema,
#     argument validation, risk class, and handler all derive from that single
#     declaration (examples/ai_agent/design.md §6, slice A).
#   * §8.5 catastrophe guard: host-destroying commands (rm -rf of protected
#     roots, mkfs, fork bombs, shutdown, DROP DATABASE) are denied; destructive
#     git/db/infra commands take one explicit confirmation; file paths are
#     realpath-confined to the workspace; timeouts + output caps apply and
#     truncation is surfaced; known secrets are redacted everywhere. Routine
#     work runs without prompts. GENE_AGENT_GUARD=0 disables risk
#     classification, but not the mediated foreground-lifetime contract.
#   * Every action is appended to a versioned event log (§9.2): /trace queries
#     it, and /repl binds a stable `session` object with message-based
#     mutations (add_tool / remember / subscribe / trace / resume).
#   * Ncurses-backed prompt on TTY; paste and Shift+Enter/Alt+Enter keep newlines.
#
# Run live (Codex Responses backend, the default):
#   OPENAI_AUTH_TOKEN=... gene run examples/ai_agent/tui.gene
# Run live against any OpenAI-compatible chat-completions endpoint, e.g. MiniMax:
#   OPENAI_BASE_URL=https://api.minimax.io/v1 OPENAI_MODEL=MiniMax-M2 \
#   OPENAI_API_KEY=... gene run examples/ai_agent/tui.gene
# Wire shape is OPENAI_API=responses|chat; it defaults to responses for the
# Codex backend and chat for any custom OPENAI_BASE_URL.
# Tools auto-approve by default (single-user agent); set GENE_AGENT_APPROVE_ALL=0
# to be prompted before writes and shell commands.
# Local persistence: GENE_AGENT_STATE selects `fs:<path>` or
# `db:sqlite:<path>`. When it is unset or blank, GENE_AGENT_HOME supplies the
# filesystem path. Reusing the same store restores application/session state
# automatically.
# Run demo:   gene run examples/ai_agent/tui.gene         (no token -> offline demo
#             that drives the same loop with a scripted transport, incl. a
#             tool_call round trip — needs no network)
#
# Auth is a bearer token from `OPENAI_AUTH_TOKEN`, `OPENAI_API_KEY`, or
# `CODEX_ACCESS_TOKEN` (checked in that order).
# =============================================================================

(mod ai_agent
  @doc "a terminal coding agent over the OpenAI Responses API")

(import os [get_env env? exec exec_async exec_stream_async
            exec_stdio_async
            executable_path
            begin_interrupt take_interrupt end_interrupt
            monotonic_ms process_id
            stdin_tty? read_line
            Env Exec OsError])
(import curses [open : curses_open close : curses_close
                read_input : curses_read_input
                refresh_input : curses_refresh_input escape_pressed?
                draw : curses_draw next_event : curses_next_event
                Screen CursesError])
(import json [parse stringify JsonError])
(import crypto [sha256])
(import str [join split starts_with? ends_with? contains? lower trim byte_size
             slice_bytes])
(import std/stream [to_stream map filter take into each])
(import std/parse [parse_int read_all ParseError])
(import Fs [read_text write_text exists? remove list_dir real_path
            ReadDir WriteDir ReadWriteDir])
(import net/http_client [Http stream HttpClientError])
(import db/sqlite [open : sqlite_open DbError])
(import store/fs [open : store_fs_open StoreError])
(import store/sqlite [open : store_sqlite_open])
(import repl [run : run_repl_session open : repl_open
              eval_source : repl_eval
              close : repl_close])
(import log [new_logger info! warn! error! debug! trace!])
(import [prepare_gateway serve_gateway stop_gateway run_gateway]
        from "./gateway_adapter")

# Diagnostic logging is intentionally separate from the authoritative event
# log below. It records lifecycle, routing, sizes, durations, and outcomes, but
# never prompt/model text, tool arguments/output, shell commands, or auth
# material. Enable the detailed JSONL profile with
# `--log-config examples/ai_agent/logging.gene` (README.md).
(var agent_log
  (new_logger "app/ai_agent" ^payload {^component "tui"}))
(var turn_log       (agent_log ~ child "turn"))
(var model_log      (agent_log ~ child "model"))
(var transport_log  (agent_log ~ child "transport"))
(var tool_log       (agent_log ~ child "tool"))
(var guard_log      (agent_log ~ child "guard"))
(var state_log      (agent_log ~ child "state"))
(var context_log    (agent_log ~ child "context"))
(var event_log      (agent_log ~ child "event"))
(var instruction_log (agent_log ~ child "instructions"))

# -----------------------------------------------------------------------------
# Config (all from the environment; nothing hard-coded).
# -----------------------------------------------------------------------------

(var auth_token (env? Env "OPENAI_AUTH_TOKEN"))
(if (== auth_token nil)
  (set auth_token (env? Env "OPENAI_API_KEY")))
(if (== auth_token nil)
  (set auth_token (env? Env "CODEX_ACCESS_TOKEN")))
(var codex_base "https://chatgpt.com/backend-api/codex")
(var base    (get_env Env "OPENAI_BASE_URL" codex_base))
(var model   (get_env Env "OPENAI_MODEL" "gpt-5.6-terra"))
# Wire shape: the Codex backend speaks the Responses API; generic
# OpenAI-compatible endpoints (MiniMax, DeepSeek, vLLM, ...) speak Chat
# Completions. Default follows the backend; override with
# OPENAI_API=responses|chat.
(var api_flavor
  (get_env Env "OPENAI_API" (if (== base codex_base) "responses" "chat")))
(var reasoning_effort_levels
  ["default" "none" "minimal" "low" "medium" "high" "xhigh" "max"])
(var reasoning_effort_levels_text (join reasoning_effort_levels ", "))
(var configured_reasoning_effort (env? Env "OPENAI_REASONING_EFFORT"))
(var initial_reasoning_effort
  (if configured_reasoning_effort
    (lower (trim configured_reasoning_effort))
    "default"))

(fn valid_reasoning_effort? [level] : Bool
  (reasoning_effort_levels ~ contains? level))

(if (! (valid_reasoning_effort? initial_reasoning_effort))
  (fail (OsError
    ^message $"OPENAI_REASONING_EFFORT must be one of ${reasoning_effort_levels_text}")))
(var reasoning_effort (cell initial_reasoning_effort))
(var workspace_root ".")
(var approve_all (get_env Env "GENE_AGENT_APPROVE_ALL" "1"))
(var agent_home (get_env Env "GENE_AGENT_HOME" ""))
(var configured_agent_state (env? Env "GENE_AGENT_STATE"))
(var agent_state_spec
  (if (&& configured_agent_state
          (!= (trim configured_agent_state) ""))
    configured_agent_state
    (if_not (== (trim agent_home) "") $"fs:${agent_home}")))
(var agent_resume (get_env Env "GENE_AGENT_RESUME" "1"))
(var guard_flag (get_env Env "GENE_AGENT_GUARD" "1"))

(fn present? [v]
  (! (|| (== v void) (== v nil))))

(fn flag_enabled? [value : Str]
  (["1" "true" "yes" "on"] ~ contains? (lower (trim value))))

(fn positive_env_int [name : Str, fallback : Int] : Int
  (try
    (var parsed (parse_int (get_env Env name $"${fallback}")))
    (if (> parsed 0) parsed fallback)
  catch _ fallback))

# Context limits are deliberately wire-size approximations rather than
# provider-specific tokenizers. Four JSON bytes per token is shown as a rough
# planning number; compaction itself is deterministic and item-structural.
(var context_max_bytes
  (positive_env_int "GENE_AGENT_CONTEXT_MAX_BYTES" 750000))
(var context_max_items
  (positive_env_int "GENE_AGENT_CONTEXT_MAX_ITEMS" 200))
(var context_keep_turns
  (positive_env_int "GENE_AGENT_CONTEXT_KEEP_TURNS" 8))
(var max_tool_rounds
  (positive_env_int "GENE_AGENT_MAX_TOOL_ROUNDS" 12))
(var configured_worker_output_max_bytes
  (positive_env_int "GENE_AGENT_WORKER_OUTPUT_MAX_BYTES" 262144))
# The compact loss marker needs room to retain an exact byte count.
(var worker_output_max_bytes
  (if (< configured_worker_output_max_bytes 32)
    32 configured_worker_output_max_bytes))
(var configured_transcript_max_bytes
  (positive_env_int "GENE_AGENT_TRANSCRIPT_MAX_BYTES" 1048576))
(var transcript_max_bytes
  (if (< configured_transcript_max_bytes 64)
    64 configured_transcript_max_bytes))
(var worker_history_max
  (positive_env_int "GENE_AGENT_WORKER_HISTORY_MAX" 200))
(var surface_history_max
  (positive_env_int "GENE_AGENT_SURFACE_HISTORY_MAX" 200))
(var surface_draft_max_bytes
  (positive_env_int "GENE_AGENT_DRAFT_MAX_BYTES" 262144))
(var surface_overlay_max_items 100)
(var surface_pane_max_count
  (positive_env_int "GENE_AGENT_PANE_MAX_COUNT" 16))
(var stopped_worker_max_count
  (positive_env_int "GENE_AGENT_STOPPED_WORKER_MAX_COUNT" 64))
(var live_agent_max_count
  (positive_env_int "GENE_AGENT_LIVE_AGENT_MAX_COUNT" 8))
(var live_worker_max_count
  (positive_env_int "GENE_AGENT_LIVE_WORKER_MAX_COUNT" 32))
(var supervisor_inbox_max_count
  (positive_env_int "GENE_AGENT_SUPERVISOR_INBOX_MAX_COUNT" 64))
(var agent_attachment_max_count
  (positive_env_int "GENE_AGENT_ATTACHMENT_MAX_COUNT" 16))
(var agent_attachment_max_bytes
  (positive_env_int "GENE_AGENT_ATTACHMENT_MAX_BYTES" 65536))
(var agent_result_max_bytes
  (positive_env_int "GENE_AGENT_RESULT_MAX_BYTES" 65536))

(fn append_all [xs, ys]
  ((to_stream ys) ~ into xs))

(fn append [xs, x]
  ((to_stream [x]) ~ into xs))

(fn utf8_prefix [text : Str, max_bytes : Int] : Str
  (var total (byte_size text))
  (if (<= total max_bytes)
    text
    (if (<= max_bytes 0)
      (then "")
      (else
        (var finish max_bytes)
        (var out "")
        (var sliced (cell false))
        # A UTF-8 scalar is at most four bytes, so backing up at most three
        # bytes reaches a valid boundary without scanning or copying twice.
        (while (&& (! (sliced ~ Cell/get)) (> finish 0))
          (try
            (set out (slice_bytes text 0 finish))
            (sliced ~ Cell/set true)
          catch _ (set finish (- finish 1))))
        out))))

(fn bounded_list_tail [values, max_count : Int]
  (if (<= values/~size max_count)
    (then values)
    (else
      (var kept [])
      (var first (- values/~size max_count))
      (repeat i in values/~size
        (if (>= i first) (kept ~ List/push! values/%i)))
      kept)))

# -----------------------------------------------------------------------------
# §8.5 catastrophe guard. Posture: single-user power tool — routine work runs
# without prompts; narrow hard stops for catastrophic, hard-to-recover actions;
# one explicit confirmation for destructive-but-plausibly-intentional commands.
# GENE_AGENT_GUARD=0 (set outside the session) disables classification.
# -----------------------------------------------------------------------------

(fn replace_all [s : Str, from : Str, to : Str] : Str
  ((split s from) ~ join to))

# Never let the API token surface in transcript, logs, events, or errors.
(fn redact [s : Str] : Str
  (if (== auth_token nil)
    s
    (replace_all s auth_token "auth-***REDACTED***")))

(fn guard_enabled? []
  (flag_enabled? guard_flag))

# The workspace root as a real (symlink-resolved, absolute) path; every file
# tool path must resolve inside it.
(var workspace_real (real_path ReadDir workspace_root))

# Confine every file path to the workspace root: reject absolute paths and
# `..` segments up front, then realpath the target so a symlink inside the
# workspace cannot point writes/reads outside it (§8.5).
(fn confined_real_path [p : Str] : Str
  (if (starts_with? p "/")
    (fail (OsError ^message $"unsafe path rejected (absolute): ${p}"))
    (if ((split p "/") ~ contains? "..")
      (then
        (fail (OsError ^message $"unsafe path rejected (escapes workspace): ${p}")))
      (else
        (var rp (real_path ReadDir p))
        (if (|| (== rp workspace_real)
                (starts_with? rp $"${workspace_real}/"))
          rp
          (fail (OsError
            ^message $"unsafe path rejected (resolves outside workspace): ${p}")))))))

(fn safe_path [p : Str] : Str
  (confined_real_path p)
  p)

(fn confined_path? [p] : Bool
  (match p
    (when (candidate : Str)
      (try
        (safe_path candidate)
        true
      catch _ false))
    (else false)))

# --- raw-command classification: normal | destructive | catastrophic ---------
# High-confidence substring/segment heuristics only; parsing arbitrary shell is
# necessarily incomplete and this is not an OS sandbox (§8.5).

(fn rm_recursive? [c : Str]
  (|| (contains? c "rm -rf")
      (contains? c "rm -fr")
      (contains? c "rm -r ")
      (contains? c "rm -f -r")))

(var protected_root_tokens ["/" "/*" "~" "~/" "$HOME" "${HOME}" "." ".." ".git" ".git/"])

(fn protected_target? [tok : Str]
  (|| (protected_root_tokens ~ contains? tok)
      ([workspace_real $"${workspace_real}/"] ~ contains? tok)))

# A recursive rm is at least destructive; targeting a protected root or a
# top-level absolute directory (/usr, /etc, ...) is catastrophic.
(fn classify_rm [cmd : Str] : Str
  (var worst (cell "destructive"))
  ((to_stream (split cmd " "))
    ~ each (fn [raw]
        (var tok (trim raw))
        (if_not (== tok "")
          (if (protected_target? tok)
            (Cell/set worst "catastrophic")
            (if (&& (starts_with? tok "/")
                    (<= ((split tok "/") ~ size) 2))
              (Cell/set worst "catastrophic"))))))
  (Cell/get worst))

# Split a command line on `&&`, `;`, and `|` so command-name patterns anchor at
# the start of each simple command instead of matching anywhere (a `grep
# shutdown src/` must stay normal).
(fn command_segments [cmd : Str]
  (var segs (cell []))
  ((to_stream (split cmd "&&"))
    ~ each (fn [a]
        ((to_stream (split a ";"))
          ~ each (fn [b]
              ((to_stream (split b "|"))
                ~ each (fn [c]
                    ((segs ~ Cell/get) ~ List/push! (trim c))))))))
  (Cell/get segs))

# The workspace lease can cover only subprocesses whose lifetime the
# application can observe. Reject high-confidence shell syntax which is meant
# to outlive the invoking shell; `/tty` is the explicit user-driven escape.
# This is a lifecycle contract, not part of the optional catastrophe guard.
(fn unquoted_background_operator? [cmd : Str] : Bool
  (var values (graphemes cmd))
  (var quoted_by (cell ""))
  (var escaped (cell false))
  (var found (cell false))
  (var c nil)
  (var previous "")
  (var following "")
  (var previous_index 0)
  (var following_index 0)
  (repeat i in values/~size
    (set c values/%i)
    (if (escaped ~ Cell/get)
      (escaped ~ Cell/set false)
      (match (quoted_by ~ Cell/get)
        (when "'"
          (if (== c "'") (quoted_by ~ Cell/set "")))
        (when "\""
          (if (== c "\\")
            (escaped ~ Cell/set true)
            (if (== c "\"") (quoted_by ~ Cell/set ""))))
        (else
          (if (== c "\\")
            (escaped ~ Cell/set true)
            (if (|| (== c "'") (== c "\""))
              (quoted_by ~ Cell/set c)
              (if_yes (== c "&")
                (set previous_index (- i 1))
                (set following_index (+ i 1))
                (set previous (if (== i 0) "" values/%previous_index))
                (set following
                  (if (== following_index values/~size)
                    "" values/%following_index))
                # `&&`, `&>`, and `>&` are not background operators.
                (if (! (|| (== previous "&") (== following "&")
                           (== previous ">") (== following ">")))
                  (found ~ Cell/set true)))))))))
  (found ~ Cell/get))

(fn segment_detaching_launcher? [segment : Str] : Bool
  (var s (lower (trim segment)))
  (|| (== s "daemon") (starts_with? s "daemon ")
      (== s "daemonize") (starts_with? s "daemonize ")
      (&& (starts_with? s "setsid ")
          (|| (contains? s " -f ") (ends_with? s " -f")
              (contains? s " --fork")))
      (&& (|| (== s "systemd-run") (starts_with? s "systemd-run "))
          (! (contains? s " --wait")))
      (&& (starts_with? s "start-stop-daemon ")
          (|| (contains? s " --background") (contains? s " -b ")
              (ends_with? s " -b")))
      (&& (starts_with? s "tmux new-session ")
          (|| (contains? s " -d ") (ends_with? s " -d")))
      (|| (starts_with? s "screen -dm")
          (starts_with? s "screen -d -m"))))

(fn mediated_shell_detach_reason [cmd : Str]
  (if (unquoted_background_operator? cmd)
    (then "background operator '&'")
    (else
      (var reason (cell nil))
      ((to_stream (command_segments cmd))
        ~ each (fn [segment]
            (if (segment_detaching_launcher? segment)
              (reason ~ Cell/set "detaching process launcher"))))
      (reason ~ Cell/get))))

(var catastrophic_command_starts
  ["mkfs" "shutdown" "reboot" "poweroff" "halt" "init 0"])

(fn segment_catastrophic? [seg : Str]
  (var s (lower seg))
  (var hit (cell false))
  ((to_stream catastrophic_command_starts)
    ~ each (fn [p] (if (starts_with? s p) (Cell/set hit true))))
  (|| (Cell/get hit)
      (contains? s ":(){")
      (contains? s " of=/dev/")
      (contains? s "drop database")))

# A SQL DELETE/UPDATE with no WHERE clause rewrites the whole table.
(fn sql_unbounded? [s : Str]
  (&& (! (contains? s "where"))
      (|| (contains? s "delete from")
          (&& (contains? s "update ") (contains? s " set ")))))

(fn segment_destructive? [seg : Str]
  (var s (lower seg))
  (|| (contains? s "git reset --hard")
      (contains? s "git clean -fd")
      (contains? s "git push --force")
      (contains? s "git push -f")
      (contains? seg "git branch -D")
      (contains? s "drop table")
      (contains? s "truncate table")
      (contains? s "terraform destroy")
      (contains? s "kubectl delete namespace")
      (contains? s "kubectl delete ns ")
      (contains? s "kubectl delete cluster")
      (sql_unbounded? s)))

(fn classify_command [cmd : Str] : Str
  (var worst (cell "normal"))
  (fn bump [level : Str]
    (if (== level "catastrophic")
      (Cell/set worst "catastrophic")
      (if (&& (== level "destructive") (!= (Cell/get worst) "catastrophic"))
        (Cell/set worst "destructive"))))
  (if (rm_recursive? cmd) (bump (classify_rm cmd)))
  ((to_stream (command_segments cmd))
    ~ each (fn [seg]
        (if (segment_catastrophic? seg)
          (bump "catastrophic")
          (if (segment_destructive? seg) (bump "destructive")))))
  (Cell/get worst))

(fn approve? [tool : Str, detail : Str]
  (if (flag_enabled? approve_all)
    true
    (confirmation_answer
      $"approve ${tool}: ${(redact detail)}? [y/N] ")))

# One explicit confirmation for a destructive command. EOF (no stdin, scripted
# runs) denies — a destructive command never auto-approves.
(fn confirm_destructive? [cmd : Str]
  (confirmation_answer
    $"destructive command: ${(redact cmd)}\nrun it once? [y/N] "))

# Injectable guard strategy. The CLI's defaults are the stdin confirmation and
# the process-global event log; an embedding host (the gateway) must override
# them — it has no terminal, so a synchronous stdin read would stall the
# scheduler, and its confirmation/audit events belong in the per-session log.
# run_tool_call points guard_emit at the current turn's sink around each
# handler call; the guard runs synchronously before the handler's first await,
# so concurrent session actors cannot interleave between set and use.
(var guard_confirm (cell nil))   # nil -> confirm_destructive? (CLI stdin)
(var guard_emit (cell nil))      # nil -> emit_event! (CLI global log)

(fn set_guard_confirm [f]
  (guard_confirm ~ Cell/set f))

(fn guard_confirmed? [cmd : Str]
  (var f (guard_confirm ~ Cell/get))
  (if (present? f)
    (f cmd)
    (confirm_destructive? cmd)))

(fn guard_emit! [type : Str, props]
  (var f (guard_emit ~ Cell/get))
  (if (present? f)
    (f type props)
    (emit_event! type props)))

# -----------------------------------------------------------------------------
# Authoritative event log (§9.2). Append-only, versioned, redacted at append.
# One vocabulary shared by the transcript, /trace, the /repl session object,
# tests, and the gateway: user_input model_item tool_call tool_result
# agent_text text_delta turn_done tool_registered file_change check
# context_compacted confirmation memory error.
# -----------------------------------------------------------------------------

(var agent_events (cell []))
(var agent_evidence (cell []))
(var agent_event_bytes (cell 0))
(var next_event_v (cell 1))
(var event_dropped_before (cell 0))
(var event_max_count (positive_env_int "GENE_AGENT_EVENT_MAX_COUNT" 4096))
(var configured_event_max_bytes
  (positive_env_int "GENE_AGENT_EVENT_MAX_BYTES" 2097152))
# A loss-summary event itself needs a small atomic envelope. Values below this
# floor would make the configured contract impossible to represent.
(var event_max_bytes
  (if (< configured_event_max_bytes 1024) 1024 configured_event_max_bytes))
(var current_turn (cell 0))
(var event_subscriptions (cell []))
(var event_echo (cell nil))     # (fn [line]) hook installed by the REPL loop
# This process-global log is the embedded-CLI surface's own event log. The
# gateway imports run_turn but owns a per-session log in the same vocabulary
# (§12.1/§12.3), so it disables this one to avoid accumulating every session's
# events in a single shared list across concurrent actor turns.
(var events_enabled (cell true))
(var active_turn_task (cell nil))
(var user_screen (cell nil))
(var user_input_suspended (cell false))
(var active_application (cell nil))
(var active_editor (cell nil))
(var confirmation_active (cell false))
(var active_repaint_pending (cell false))
(var interactive_transcript (cell nil))
(var interactive_memory (cell []))
(var agent_checkpoint_suspended (cell false))
(var agent_checkpoint_writing (cell false))
(var agent_checkpoint_last_ms (cell 0))
(var agent_checkpoint_seq (cell 0))
(var agent_checkpoint_interval_ms
  (positive_env_int "GENE_AGENT_CHECKPOINT_INTERVAL_MS" 1000))
(var workspace_coordinators {})
(var next_surface_instance (cell 1))
(var next_application_instance (cell 1))

# Slice C application model. Agents and panes are independent values: an
# agent may continue without a visible pane, while output/shell/REPL panes do
# not imply a model conversation. All mutable collections remain behind cells
# so the stable Session surface can expose the values without exposing TUI
# implementation arrays.
(type Worker
  ^props {^id Str ^name Any ^kind Str ^title Str ^output Any ^current_task Any
          ^current_operation Any ^lifecycle Any ^last_outcome Any
          ^status Any ^history Any ^controller Any ^next_output_seq Any
          ^dropped_bytes Any ^dropped_before Any ^history_dropped Any
          ^retained_output Any ^input_reserved Any ^streamed_output Any
          ^last_finish_event Any ^pending_invocation Any})

(type Agent ^is Worker
  ^props {^parent_id Any ^assignment Str ^items Any ^transcript Any
          ^streaming Any ^result Any ^attachments Any
          ^transcript_seq Any ^transcript_dropped_bytes Any
          ^transcript_dropped_before Any ^transcript_retained Any})

(type Pane
  ^props {^id Int ^worker_id Str ^worker Any
          ^kind Str ^owner_id Any ^title Str ^output Any
          ^status Any ^current_task Any ^history Any ^scroll Any ^controller Any
          ^pending_visible Any ^hidden Any ^close_policy Str})

(type SurfaceAttachment
  ^props {^id Str ^instance_id Any ^panes Any ^next_pane_id Any
          ^focused_pane Any ^maximized_pane Any ^main_scroll Any
          ^main_pending_visible Any ^help_notice Any
          ^drafts Any ^input_histories Any ^max_panes Int})

(type WorkspaceCoordinator
  ^props {^root Str ^owner Any ^waiters Any ^next_request Any})

(type ShellController
  ^props {^cwd Any ^environment Any})

(type OutputController
  ^props {^source Str ^following Any})

(type LogTailController
  ^props {^filter Any})

(type FileViewController
  ^props {^path Str})

(type StatsController
  ^props {})

(type Artifact
  ^props {^id Str ^blob_id Str ^kind Str ^mime Str ^source_worker Any
          ^source_task Any ^created_v Int ^size Int})

(type HandlerRef
  ^props {^module Str ^path Str ^version Str})

# One declaration is the functional surface for a worker operation. `args`
# and `result` are real Gene Type values; every adapter calls the same
# validator and policy gate before invoking `handler`.
(type Operation
  ^props {^name Str ^summary Str ^usage Str ^args Any ^result Any
          ^errors Any ^effects Any ^audience Any ^admission Str ^audit Str
          ^cancellable Bool ^idempotent Bool ^task_managed Bool ^handler Any
          ^primary_input Bool ^parse_cli Any ^handler_ref Any? ^enabled Bool?})

(var registration_capture_enabled (cell false))
(var restoring_registrations (cell false))
(var dynamic_registration_records (cell []))

(type EmptyArgs ^props {})
(type TailArgs ^props {^n Int?})
(type AgentSendArgs ^props {^prompt Str})
(type ShellRunArgs ^props {^command Str ^timeout_ms Int?})
(type ShellChdirArgs ^props {^path Str})
(type EnvironmentSetArgs ^props {^name Str ^value Str})
(type EnvironmentUnsetArgs ^props {^name Str})
(type ReplEvalArgs ^props {^form Str})
(type OutputAppendArgs ^props {^text Str})
(type WorkerSourceArgs ^props {^source Str})
(type LogFilterArgs ^props {^expr Str})
(type FileViewArgs ^props {^path Str})

# Model-tool argument types share the same closed-schema validation path as
# worker operations. Optional ^params below carry documentation/enums only.
(type CallWorkerToolArgs ^props {^worker_id Str ^op Str ^args Map?})
(type PinArtifactToolArgs ^props {^source Str ^worker_id Str})
(type SpawnAgentToolArgs ^props {^assignment Str ^title Str? ^name Str?})
(type SendAgentToolArgs ^props {^agent_id Str ^prompt Str})
(type AgentIdToolArgs ^props {^agent_id Str})
(type UpdateProgressToolArgs
  ^props {^objective Str ^phase Str ^status Str ^summary Str
          ^blocked_reason Str? ^required_action Str?})
(type OpenPaneToolArgs
  ^props {^kind Str ^owner_id Str? ^title Str? ^text Str?})
(type AppendPaneToolArgs ^props {^pane_id Int ^text Str})
(type AppendWorkerToolArgs ^props {^worker_id Str ^text Str})
(type ClosePaneToolArgs ^props {^pane_id Int})
(type OpenExtensionToolArgs ^props {^title Str? ^prompt Str?})

(type OperationAck
  ^props {^accepted Bool? ^text Str? ^worker_id Str? ^task_id Str?})
(type WorkerStatusResult
  ^props {^worker_id Str ^name Any ^kind Str ^lifecycle Str ^status Str
          ^busy Bool ^current_operation Any ^last_outcome Any})
(type WorkerTailResult
  ^props {^worker_id Str ^text Str ^requested Int ^dropped_bytes Int
          ^dropped_before Any ^history_dropped Int})
(type AgentResultValue
  ^props {^worker_id Str ^available Bool ^result Any ^read Bool
          ^incorporated Bool})
(type FileInfoResult
  ^props {^worker_id Str ^path Str ^bytes Int ^loaded Bool})
(type StatsSnapshotResult ^props {^worker_id Str ^snapshot Any})

(type ProjectProgress
  ^props {^objective Str ^phase Str ^status Str ^summary Str
          ^blocked_reason Any ^required_action Any ^updated_v Any
          ^agent_ids Any ^worker_ids Any ^evidence_v Any})

(type ReplController
  ^props {^session Any ^items Any ^transcript Any ^memory Any
          ^streaming Any ^resume_requested Any})

(type AgentApplication
  ^props {^coordinator_id Str
          ^main_agent Any ^agents Any ^workers Any ^local_surface Any
          ^next_agent_id Any ^next_worker_id Any ^next_task_id Any ^memory Any
          ^event_sink Any ^event_observers Any ^workspace_coordinator Any
          ^supervisor_inbox Any ^progress Any ^max_agents Int ^max_workers Int
          ^shutting_down Any})

(fn make_surface_attachment [id : Str]
  (var seq (next_surface_instance ~ Cell/get))
  (next_surface_instance ~ Cell/set (+ seq 1))
  (SurfaceAttachment
    ^id id ^instance_id (cell $"${id}:${seq}")
    ^panes (cell []) ^next_pane_id (cell 1)
    ^focused_pane (cell nil) ^maximized_pane (cell nil)
    ^main_scroll (cell 0) ^main_pending_visible (cell false)
    ^help_notice (cell "")
    ^drafts (cell {}) ^input_histories (cell {})
    ^max_panes surface_pane_max_count))

(fn workspace_coordinator_for [root : Str]
  (var existing (workspace_coordinators ~ Map/get root))
  (if (!= existing void)
    (then existing)
    (else
      (var coordinator
        (WorkspaceCoordinator ^root root ^owner (cell nil)
                              ^waiters (cell []) ^next_request (cell 1)))
      (workspace_coordinators ~ Map/put! root coordinator)
      coordinator)))

(fn make_worker [id : Str, kind : Str, title : Str, output, controller]
  (Worker ^id id ^name nil ^kind kind ^title title ^output output
          ^current_task (cell nil) ^current_operation (cell nil)
          ^lifecycle (cell "running") ^last_outcome (cell nil)
          ^status (cell "idle")
          ^history (cell []) ^controller controller
          ^next_output_seq (cell 1) ^dropped_bytes (cell 0)
          ^dropped_before (cell nil) ^history_dropped (cell 0)
          ^retained_output (cell (output ~ Cell/get))
          ^input_reserved (cell false) ^streamed_output (cell false)
          ^last_finish_event (cell nil) ^pending_invocation (cell nil)))

(fn make_agent [id : Str, parent_id, title : Str, assignment : Str,
                items, transcript, current_task]
  (Agent ^id id ^name nil ^kind "agent" ^title title ^output transcript
         ^current_task current_task ^current_operation (cell nil)
         ^lifecycle (cell "running") ^last_outcome (cell nil)
         ^status (cell "idle")
         ^history (cell []) ^controller nil ^next_output_seq (cell 1)
         ^dropped_bytes (cell 0) ^dropped_before (cell nil)
         ^history_dropped (cell 0) ^retained_output (cell (transcript ~ Cell/get))
         ^input_reserved (cell false) ^streamed_output (cell false)
         ^last_finish_event (cell nil) ^pending_invocation (cell nil)
         ^parent_id parent_id ^assignment assignment ^items items
         ^transcript transcript ^streaming (cell false) ^result (cell nil)
         ^attachments (cell [])
         ^transcript_seq (cell 1) ^transcript_dropped_bytes (cell 0)
         ^transcript_dropped_before (cell nil)
         ^transcript_retained (cell (transcript ~ Cell/get))))

(fn make_application_core_with_task [main_items, main_transcript, memory,
                                     event_sink, main_task, local_surface]
  (var application_seq (next_application_instance ~ Cell/get))
  (next_application_instance ~ Cell/set (+ application_seq 1))
  (var main_agent
    (make_agent "main" nil "main" "primary user conversation"
                main_items main_transcript main_task))
  (AgentApplication
    ^coordinator_id $"app${application_seq}"
    ^main_agent main_agent ^agents (cell [main_agent])
    ^workers (cell [main_agent]) ^local_surface local_surface
    ^next_agent_id (cell 1) ^next_worker_id (cell 1)
    ^next_task_id (cell 1) ^memory memory
    ^event_sink event_sink ^event_observers (cell [])
    ^workspace_coordinator (workspace_coordinator_for workspace_real)
    ^supervisor_inbox (cell [])
    ^progress (cell
      {^objective "" ^phase "planning" ^status "active"
       ^summary "" ^blocked_reason nil ^required_action nil ^updated_v nil
       ^agent_ids [] ^worker_ids [] ^evidence_v []})
    ^max_agents live_agent_max_count ^max_workers live_worker_max_count
    ^shutting_down (cell false)))

(fn make_application_with_task [main_items, main_transcript, memory, event_sink,
                                main_task]
  (make_application_core_with_task
    main_items main_transcript memory event_sink main_task
    (make_surface_attachment "local_tui")))

(fn make_headless_application_with_task [main_items, main_transcript, memory,
                                         event_sink, main_task]
  (make_application_core_with_task
    main_items main_transcript memory event_sink main_task nil))

(fn make_application [main_items, main_transcript, memory, event_sink]
  (make_application_with_task main_items main_transcript memory event_sink
                              active_turn_task))

(fn application_emit [app, type : Str, props]
  (var sink app/event_sink)
  (var emitted (sink type props))
  (var event
    (match emitted
      (when (m : Map) m)
      (else
        (var fallback {^type type})
        (for [key value] in props
          (fallback ~ Map/put! key value))
        fallback)))
  (for observer in (app/event_observers ~ Cell/get)
    (var handler observer/handler)
    (handler event))
  # Agent protocol events remain additive compatibility events. The worker
  # event is the pane-independent producer boundary consumed by headless and
  # remote surfaces.
  (if_yes (&& (["text_delta" "agent_text"] ~ contains? type)
              (!= props/worker_id void) (!= props/text void)
              (!= props/text ""))
      (var source_worker nil)
      (for candidate in (app/workers ~ Cell/get)
        (if (== candidate/id props/worker_id)
          (set source_worker candidate)))
      (if source_worker
        # The complete agent_text after streamed deltas is terminal
        # metadata, not a second output chunk. Non-streamed turns still use
        # agent_text as their one canonical chunk.
        (if_not (&& (== type "agent_text")
                    (source_worker/streamed_output ~ Cell/get))
          (if (== type "text_delta")
            (source_worker/streamed_output ~ Cell/set true))
          (var seq (source_worker/next_output_seq ~ Cell/get))
          (source_worker/next_output_seq ~ Cell/set (+ seq 1))
          (var operation (source_worker/current_operation ~ Cell/get))
          (application_emit app "worker_output"
            {^worker_id source_worker/id ^kind source_worker/kind
             ^task_id (if operation operation/task_id)
             ^seq seq
             # During the additive compatibility window generic consumers
             # render this record and agent-specific consumers render the
             # source event. The cursor link makes deduplication structural.
             ^source_v (if (present? emitted/v) emitted/v)
             ^stream (if (== type "text_delta")
                       "assistant_delta" "assistant_final")
             ^text props/text}))))
  (checkpoint_application_event! app type)
  emitted)

(fn application_find_agent [app, id : Str]
  (var found (cell nil))
  (for agent in (app/agents ~ Cell/get)
    # Canonical ids win if a future naming policy ever admits an id-shaped
    # name. Names are an ergonomic address, never a second identity.
    (if (== agent/id id)
      (found ~ Cell/set agent)
      (if (&& (== (found ~ Cell/get) nil) (== agent/name id))
        (found ~ Cell/set agent))))
  (found ~ Cell/get))

(fn application_find_worker [app, id : Str]
  (var found (cell nil))
  (for worker in (app/workers ~ Cell/get)
    (if (== worker/id id)
      (found ~ Cell/set worker)
      (if (&& (== (found ~ Cell/get) nil) (== worker/name id))
        (found ~ Cell/set worker))))
  (found ~ Cell/get))

(fn normalize_worker_name [raw] : Str
  (var normalized (lower (trim $"${raw}")))
  (if (|| (== normalized "") (> (byte_size normalized) 64))
    (fail (OsError
      ^message "worker name must contain 1-64 lowercase letters, digits, '_' or '-'")))
  (for ch in (graphemes normalized)
    (if_not (contains? "abcdefghijklmnopqrstuvwxyz0123456789_-" ch)
      (fail (OsError
        ^message "worker name must contain only lowercase letters, digits, '_' or '-'"))))
  normalized)

(fn application_assign_worker_name! [app, worker, requested]
  (var name (normalize_worker_name requested))
  (var existing (application_find_worker app name))
  (if (&& existing (!= existing/id worker/id))
    {^ok false
     ^error {^kind "worker_name_taken"
             ^message $"worker name '${name}' is already in use"}}
    (do
      (worker ~ Node/set_prop! `name name)
      {^ok true ^name name ^worker_id worker/id})))

(fn application_available_worker_name [app, requested]
  (if (|| (== requested nil) (== requested void) (== (trim $"${requested}") ""))
    nil
    (do
      (var name (normalize_worker_name requested))
      (var existing (application_find_worker app name))
      (if existing
        (fail (OsError
          ^message $"worker_name_taken: worker name '${name}' is already in use")))
      name)))

(fn application_find_worker_kind [app, kind : Str]
  (var found (cell nil))
  (for worker in (app/workers ~ Cell/get)
    (if (&& (== worker/kind kind)
            (!= (worker/lifecycle ~ Cell/get) "stopped")
            (== (found ~ Cell/get) nil))
      (found ~ Cell/set worker)))
  (found ~ Cell/get))

(fn application_find_stopped_worker_kind [app, kind : Str]
  (var found (cell nil))
  (for worker in (app/workers ~ Cell/get)
    (if (&& (== worker/kind kind)
            (== (worker/lifecycle ~ Cell/get) "stopped"))
      (found ~ Cell/set worker)))
  (found ~ Cell/get))

(fn application_live_worker_count [app] : Int
  (var count 0)
  (for worker in (app/workers ~ Cell/get)
    (if (== (worker/lifecycle ~ Cell/get) "running")
      (set count (+ count 1))))
  count)

(fn application_live_agent_count [app] : Int
  (var count 0)
  (for agent in (app/agents ~ Cell/get)
    (if (== (agent/lifecycle ~ Cell/get) "running")
      (set count (+ count 1))))
  count)

(fn application_new_worker [app, kind : Str, title : Str, output, controller]
  (if_not (>= (application_live_worker_count app) app/max_workers)
    (var seq (app/next_worker_id ~ Cell/get))
    (app/next_worker_id ~ Cell/set (+ seq 1))
    (var normalized_controller
      (if (&& (== kind "output") (== controller nil))
        (OutputController ^source "manual" ^following (cell []))
        controller))
    (var worker
      (make_worker $"w${seq}" kind title output normalized_controller))
    ((app/workers ~ Cell/get) ~ List/push! worker)
    (application_emit app "worker_started"
      {^worker_id worker/id ^kind kind ^title title})
    worker))

(fn application_new_named_worker
  [app, kind : Str, title : Str, output, controller, requested_name]
  (var name (application_available_worker_name app requested_name))
  (var worker (application_new_worker app kind title output controller))
  (if (&& worker name)
    (do
      (worker ~ Node/set_prop! `name name)
      (application_emit app "worker_named"
        {^worker_id worker/id ^kind worker/kind ^name name})))
  worker)

(fn application_new_worker_from [app, kind : Str, title : Str, output,
                                 controller, previous]
  (if_not (>= (application_live_worker_count app) app/max_workers)
    (var seq (app/next_worker_id ~ Cell/get))
    (app/next_worker_id ~ Cell/set (+ seq 1))
    (var normalized_controller
      (if (&& (== kind "output") (== controller nil))
        (OutputController ^source "manual" ^following (cell []))
        controller))
    (var worker
      (make_worker $"w${seq}" kind title output normalized_controller))
    ((app/workers ~ Cell/get) ~ List/push! worker)
    (application_emit app "worker_started"
      {^worker_id worker/id ^kind kind ^title title
       ^restarted_from (if previous previous/id)})
    worker))

(fn application_remove_worker_observers! [app, worker_id : Str]
  (var kept [])
  (for observer in (app/event_observers ~ Cell/get)
    (if (!= observer/worker_id worker_id)
      (kept ~ List/push! observer)))
  (app/event_observers ~ Cell/set kept))

(fn application_find_pane [app, id : Int]
  (var surface app/local_surface)
  (var found (cell nil))
  (for pane in (if (== surface nil) [] (surface/panes ~ Cell/get))
    (if (== pane/id id) (found ~ Cell/set pane)))
  (found ~ Cell/get))

(fn application_find_pane_kind [app, kind : Str]
  (var surface app/local_surface)
  (var found (cell nil))
  (for pane in (if (== surface nil) [] (surface/panes ~ Cell/get))
    (if (&& (== pane/kind kind) (== (found ~ Cell/get) nil))
      (found ~ Cell/set pane)))
  (found ~ Cell/get))

(fn application_find_pane_worker [app, worker_id : Str]
  (var surface app/local_surface)
  (var found (cell nil))
  (for pane in (if (== surface nil) [] (surface/panes ~ Cell/get))
    (if (&& (== pane/worker_id worker_id)
            (== (found ~ Cell/get) nil))
      (found ~ Cell/set pane)))
  (found ~ Cell/get))

(fn application_pane_ids_for_worker [app, worker_id : Str]
  # Pane membership is surface-local presentation state. Derive the invoking
  # TUI surface's compatibility view instead of caching pane ids on a shared
  # worker/agent record.
  (var surface app/local_surface)
  (var ids [])
  (for pane in (if (== surface nil) [] (surface/panes ~ Cell/get))
    (if (== pane/worker_id worker_id)
      (ids ~ List/push! pane/id)))
  ids)

(fn application_prune_stopped_workers! [app] : Int
  # Live limits bound concurrency; this second limit bounds the terminal
  # snapshots retained after stop. A stopped worker with an attached local
  # pane remains inspectable until that view detaches, while headless stopped
  # workers are evicted oldest-first with an explicit journal tombstone.
  (var eligible 0)
  (for worker in (app/workers ~ Cell/get)
    (if (&& (!= worker/id "main")
            (== (worker/lifecycle ~ Cell/get) "stopped")
            (== (application_find_pane_worker app worker/id) nil))
      (set eligible (+ eligible 1))))
  (var remaining (- eligible stopped_worker_max_count))
  (if (<= remaining 0)
    (then 0)
    (else
      (var kept [])
      (var dropped [])
      (for worker in (app/workers ~ Cell/get)
        (if (&& (> remaining 0) (!= worker/id "main")
                (== (worker/lifecycle ~ Cell/get) "stopped")
                (== (application_find_pane_worker app worker/id) nil))
          (then
            (dropped ~ List/push! worker/id)
            (set remaining (- remaining 1)))
          (else (kept ~ List/push! worker))))
      (app/workers ~ Cell/set kept)
      (var kept_agents [])
      (for agent in (app/agents ~ Cell/get)
        (if_not (dropped ~ contains? agent/id)
          (kept_agents ~ List/push! agent)))
      (app/agents ~ Cell/set kept_agents)
      (for worker_id in dropped
        (application_emit app "worker_retention_dropped"
          {^worker_id worker_id ^reason "stopped_worker_limit"
           ^limit stopped_worker_max_count}))
      dropped/~size)))

(fn application_attach_worker_pane_as [app, worker, owner_id,
                                       close_policy : Str, requested_title]
  (var surface app/local_surface)
  (if_not (|| (== surface nil)
          (>= ((surface/panes ~ Cell/get) ~ size) surface/max_panes))
    (var id (surface/next_pane_id ~ Cell/get))
    (surface/next_pane_id ~ Cell/set (+ id 1))
    (var pane_title
      (if (|| (== requested_title nil) (== requested_title void)
              (== (trim requested_title) ""))
        worker/title requested_title))
    (var pane
      (Pane ^id id ^worker_id worker/id ^worker worker
            ^kind worker/kind ^owner_id owner_id ^title pane_title
            ^output worker/output ^status worker/status
            ^current_task worker/current_task ^history worker/history
            ^scroll (cell 0)
            # Agent panes temporarily retain the shipped `controller` alias;
            # the worker itself is the agent controller. Non-agent panes point
            # at the worker-owned controller. Pane lifecycle never owns either.
            ^controller (if (== worker/kind "agent") worker worker/controller)
            ^pending_visible (cell false)
            ^hidden (cell false)
            ^close_policy close_policy))
    ((surface/panes ~ Cell/get) ~ List/push! pane)
    # A newly opened pane is the natural target for pane-local navigation.
    (surface/focused_pane ~ Cell/set id)
    (application_emit app "pane_opened"
      {^pane_id id ^worker_id worker/id ^kind worker/kind
       ^owner_id owner_id ^title pane_title
       ^surface_id (surface/instance_id ~ Cell/get)})
    pane))

(fn application_attach_worker_pane [app, worker, owner_id,
                                    close_policy : Str]
  (application_attach_worker_pane_as
    app worker owner_id close_policy worker/title))

(fn application_open_pane [app, kind : Str, owner_id, title : Str,
                           output, controller, close_policy : Str]
  (var worker
    (if (== kind "agent")
      (application_find_agent app $"${owner_id}")
      (application_new_worker app kind title output controller)))
  (if worker
    (application_attach_worker_pane app worker owner_id close_policy)))

(fn application_request_worker_attention [app, worker, title : Str]
  (application_emit app "worker_attention_requested"
    {^worker_id worker/id ^preferred_view "pane" ^title title})
  # Auto-accepting a presentation hint is policy of the in-process local TUI.
  # A headless/gateway application has no local surface and records only the
  # worker plus hint.
  (if_yes app/local_surface
    (var pane (application_find_pane_worker app worker/id))
    (if (== pane nil)
      (application_attach_worker_pane app worker
        (if (== worker/kind "agent") worker/id) "detach")
      pane)))

(fn worker_loss_marker [dropped : Int] : Str
  (var verbose $"[older output dropped: ${dropped} bytes]\n")
  (if (<= (byte_size verbose) worker_output_max_bytes)
    verbose
    (utf8_prefix $"[drop:${dropped}]\n" worker_output_max_bytes)))

(fn bounded_worker_append! [worker, text : Str]
  # Keep retained payload separate from the rendered loss marker. Otherwise
  # every later overflow would count and retain the previous marker as if it
  # were producer output, making dropped-byte accounting drift upward.
  (var safe_text (redact text))
  (var combined $"${(worker/retained_output ~ Cell/get)}${safe_text}")
  (var total (byte_size combined))
  (var previous_dropped (worker/dropped_bytes ~ Cell/get))
  (var existing_marker
    (if (> previous_dropped 0)
      (worker_loss_marker previous_dropped) ""))
  (var existing_budget
    (- worker_output_max_bytes (byte_size existing_marker)))
  (if (< existing_budget 0) (set existing_budget 0))
  (if (<= total existing_budget)
    (then
      (worker/retained_output ~ Cell/set combined)
      (worker/output ~ Cell/set
        $"${existing_marker}${combined}"))
    (else
      (var previous (worker/dropped_bytes ~ Cell/get))
      (var dropped
        (if (> previous 0)
          previous
          (- total worker_output_max_bytes)))
      (var marker "")
      (var start 0)
      (var retained "")
      (var settled (cell false))
      (var attempts 0)
      (var budget 0)
      (var sliced (cell false))
      (var exact 0)
      # Marker length and the UTF-8-safe tail boundary both affect the exact
      # dropped count. Iterate to a fixed point so digit-width changes cannot
      # make the rendered value exceed its configured cap.
      (while (&& (! (settled ~ Cell/get)) (< attempts 8))
        (set marker (worker_loss_marker dropped))
        (set budget (- worker_output_max_bytes (byte_size marker)))
        (if (< budget 0) (set budget 0))
        (set start (- total budget))
        (set retained "")
        (sliced ~ Cell/set false)
        # `slice_bytes` rejects a start inside UTF-8. Advancing at most
        # three bytes reaches the next scalar boundary.
        (while (&& (! (sliced ~ Cell/get)) (< start total))
          (try
            (set retained (slice_bytes combined start (- total start)))
            (sliced ~ Cell/set true)
          catch _ (set start (+ start 1))))
        (set exact (+ previous start))
        (if (== exact dropped)
          (settled ~ Cell/set true)
          (set dropped exact))
        (set attempts (+ attempts 1)))
      (set marker (worker_loss_marker dropped))
      (worker/dropped_bytes ~ Cell/set dropped)
      (worker/dropped_before ~ Cell/set
        (worker/next_output_seq ~ Cell/get))
      (worker/retained_output ~ Cell/set retained)
      (worker/output ~ Cell/set $"${marker}${retained}")))
  nil)

(fn worker_history_push! [worker, value : Str, adapter : Str, surface_id]
  ((worker/history ~ Cell/get) ~ List/push!
    {^text (redact value) ^adapter adapter ^surface_id surface_id})
  (if_yes (> ((worker/history ~ Cell/get) ~ size) worker_history_max)
    (var current (worker/history ~ Cell/get))
    (var first (- (current ~ size) worker_history_max))
    (var kept [])
    (repeat i in current/~size
      (if (>= i first) (kept ~ List/push! current/%i)))
    (worker/history ~ Cell/set kept)
    (worker/history_dropped ~ Cell/set
      (+ (worker/history_dropped ~ Cell/get) first)))
  # Surface recall is derived at the same accepted-input boundary as durable
  # worker history. Global commands and rejected input never reach this
  # function, so Up/Down cannot be polluted by presentation commands.
  (if (== adapter "local_tui")
    (record_local_surface_history! worker/id value surface_id)))

(fn application_emit_worker_output!
  [app, worker, text : Str, source : Str, projection : Bool]
  (var seq (worker/next_output_seq ~ Cell/get))
  (worker/next_output_seq ~ Cell/set (+ seq 1))
  (var operation (worker/current_operation ~ Cell/get))
  (application_emit app "worker_output"
    {^worker_id worker/id ^kind worker/kind
     ^task_id (if operation operation/task_id)
     ^seq seq ^stream source ^text text ^projection projection})
  seq)

(fn application_append_projection_output!
  [app, worker, text : Str, source : Str]
  (bounded_worker_append! worker text)
  # Projection state is derived from canonical application events. Charging
  # each rendered row back to that same journal multiplies records by the
  # number of live tails/stats workers and can evict the source history. Keep a
  # worker-local version for snapshot consumers; the source event itself is the
  # remote invalidation signal.
  (var seq (worker/next_output_seq ~ Cell/get))
  (worker/next_output_seq ~ Cell/set (+ seq 1))
  seq)

(fn application_set_projection_output!
  [app, worker, text : Str, source : Str]
  # Replacement projections (notably stats) are atomic current-state views,
  # not append-only histories. Old truncation metadata must not leak into a
  # later smaller replacement.
  (worker/retained_output ~ Cell/set "")
  (worker/output ~ Cell/set "")
  (worker/dropped_bytes ~ Cell/set 0)
  (worker/dropped_before ~ Cell/set nil)
  (bounded_worker_append! worker text)
  (var seq (worker/next_output_seq ~ Cell/get))
  (worker/next_output_seq ~ Cell/set (+ seq 1))
  seq)

(fn application_output_reaches?
  [app, from_id : Str, target_id : Str, seen] : Bool
  (if (== from_id target_id)
    (then true)
    (else
      (if (seen ~ contains? from_id)
        (then false)
        (else
          (var next_seen (append seen from_id))
          (var found (cell false))
          (for candidate in (app/workers ~ Cell/get)
            (if (&& (! (found ~ Cell/get)) (== candidate/kind "output")
                    ((candidate/controller/following ~ Cell/get)
                      ~ contains? from_id))
              (if (application_output_reaches?
                    app candidate/id target_id next_seen)
                (found ~ Cell/set true))))
          (found ~ Cell/get))))))

(fn application_follow_output! [app, output, source]
  (if (|| (== output nil) (!= output/kind "output"))
    (then {^ok false ^error "target must be an output worker"})
    (elif (== source nil)
      {^ok false ^error "source worker not found"})
    (elif (|| (== output/id source/id)
              (application_output_reaches? app output/id source/id []))
      {^ok false ^error "worker_follow_cycle"})
    (else
      (var following (output/controller/following ~ Cell/get))
      (if_not (following ~ contains? source/id)
        (following ~ List/push! source/id)
        (application_emit app "worker_followed"
          {^worker_id output/id ^source_worker_id source/id}))
      {^ok true})))

(fn application_unfollow_output! [app, output, source_id : Str] : Bool
  (if (|| (== output nil) (!= output/kind "output"))
    (then false)
    (else
      (var kept [])
      (var removed (cell false))
      (for id in (output/controller/following ~ Cell/get)
        (if (== id source_id)
          (removed ~ Cell/set true)
          (kept ~ List/push! id)))
      (output/controller/following ~ Cell/set kept)
      (if (removed ~ Cell/get)
        (application_emit app "worker_unfollowed"
          {^worker_id output/id ^source_worker_id source_id}))
      (removed ~ Cell/get))))

(fn application_remove_worker_follow_links! [app, worker]
  (if (== worker/kind "output")
    (worker/controller/following ~ Cell/set []))
  (for candidate in (app/workers ~ Cell/get)
    (if (== candidate/kind "output")
      (application_unfollow_output! app candidate worker/id)))
  nil)

(fn application_propagate_followers! [app, source, text : Str]
  (for candidate in (app/workers ~ Cell/get)
    (if (&& (== candidate/kind "output")
            (== (candidate/lifecycle ~ Cell/get) "running")
            ((candidate/controller/following ~ Cell/get)
              ~ contains? source/id))
      (then
        (application_append_projection_output!
          app candidate text $"follow:${source/id}")
        (application_propagate_followers! app candidate text)))))

(fn application_append_worker_output! [app, worker, text : Str, source : Str]
  (if (|| (== worker nil) (!= worker/kind "output")
          (== (worker/lifecycle ~ Cell/get) "stopped"))
    (then false)
    (else
      (bounded_worker_append! worker text)
      (application_emit_worker_output! app worker text source false)
      # Preserve the shipped pane event additively for local consumers.
      (var pane (application_find_pane_worker app worker/id))
      (if pane
        (application_emit app "pane_output"
          {^surface_id (app/local_surface/instance_id ~ Cell/get)
           ^pane_id pane/id
           ^worker_id worker/id ^text text ^source source}))
      (application_propagate_followers! app worker text)
      true)))

(fn application_spawn_agent_with_attachments
  [app, title : Str, assignment : Str, items, transcript, attachments]
  (if_not (|| (>= (application_live_agent_count app) app/max_agents)
              (>= (application_live_worker_count app) app/max_workers))
    (var seq (app/next_agent_id ~ Cell/get))
    (app/next_agent_id ~ Cell/set (+ seq 1))
    (var id $"a${seq}")
    (var safe_title (redact title))
    (var safe_assignment (redact assignment))
    (var label
      (if (== (trim safe_title) "") $"agent ${seq}" (trim safe_title)))
    (var agent
      (make_agent id app/main_agent/id label safe_assignment items transcript
                  (cell nil)))
    (agent/attachments ~ Cell/set attachments)
    ((app/agents ~ Cell/get) ~ List/push! agent)
    ((app/workers ~ Cell/get) ~ List/push! agent)
    (var attachment_text (stringify attachments))
    (var attachment_kinds [])
    (for attachment in attachments
      (attachment_kinds ~ List/push! attachment/kind))
    (application_emit app "agent_spawned"
      {^worker_id id ^agent_id id ^parent_agent_id app/main_agent/id
       ^assignment safe_assignment ^title label
       ^attachment_kinds attachment_kinds
       ^attachment_digest (hash attachment_text)
       ^attachment_bytes (byte_size attachment_text)})
    agent))

(fn application_spawn_agent [app, title : Str, assignment : Str, items,
                             transcript]
  (application_spawn_agent_with_attachments
    app title assignment items transcript []))

(fn application_spawn_named_agent_with_attachments
  [app, title : Str, assignment : Str, items, transcript, attachments,
   requested_name]
  (var name (application_available_worker_name app requested_name))
  (var agent
    (application_spawn_agent_with_attachments
      app title assignment items transcript attachments))
  (if (&& agent name)
    (do
      (agent ~ Node/set_prop! `name name)
      (application_emit app "worker_named"
        {^worker_id agent/id ^kind "agent" ^name name})))
  agent)

(fn application_next_task_id! [app] : Str
  (var seq (app/next_task_id ~ Cell/get))
  (app/next_task_id ~ Cell/set (+ seq 1))
  $"t${seq}")

(fn invocation_field [invocation, key]
  (match invocation
    (when (m : Map)
      (var value (m ~ Map/get key))
      (if (== value void) nil value))
    (else nil)))

(fn application_begin_worker_operation! [app, worker, task, kind : Str]
  (if_not (== (worker/lifecycle ~ Cell/get) "stopped")
    (var invocation (worker/pending_invocation ~ Cell/get))
    (worker/pending_invocation ~ Cell/set nil)
    (var origin (invocation_field invocation "origin"))
    (var caller_worker_id
      (invocation_field invocation "caller_worker_id"))
    (var declared_kind (invocation_field invocation "operation_name"))
    (var operation_kind (if declared_kind declared_kind kind))
    (var operation
      {^task_id (application_next_task_id! app) ^kind operation_kind
       ^origin origin ^caller_worker_id caller_worker_id})
    (worker/current_task ~ Cell/set task)
    (worker/current_operation ~ Cell/set operation)
    (worker/last_finish_event ~ Cell/set nil)
    (worker/streamed_output ~ Cell/set false)
    (worker/status ~ Cell/set "working")
    (var props
      {^worker_id worker/id ^kind worker/kind
       ^task_id operation/task_id ^operation_kind operation_kind})
    (if origin (props ~ Map/put! "origin" origin))
    (if caller_worker_id
      (props ~ Map/put! "caller_worker_id" caller_worker_id))
    (application_emit app "worker_operation_started" props)
    operation))

(fn application_finish_worker_operation! [app, worker, outcome : Str]
  (var operation (worker/current_operation ~ Cell/get))
  (var task (worker/current_task ~ Cell/get))
  (var emitted nil)
  (if_not (&& (== operation nil) (== task nil))
    (worker/current_task ~ Cell/set nil)
    (worker/current_operation ~ Cell/set nil)
    (worker/last_outcome ~ Cell/set outcome)
    (worker/status ~ Cell/set
      (if (== (worker/lifecycle ~ Cell/get) "stopped") "stopped" "idle"))
    (var props
      {^worker_id worker/id ^kind worker/kind
       ^task_id (if operation operation/task_id)
       ^operation_kind (if operation operation/kind)
       ^outcome outcome})
    (if (&& operation operation/origin)
      (props ~ Map/put! "origin" operation/origin))
    (if (&& operation operation/caller_worker_id)
      (props ~ Map/put! "caller_worker_id" operation/caller_worker_id))
    (set emitted
      (application_emit app "worker_operation_finished" props))
    (worker/last_finish_event ~ Cell/set emitted)
  emitted))

(fn application_cancel_worker [app, worker] : Bool
  (var task (worker/current_task ~ Cell/get))
  (if (== task nil)
    (then
      (if (worker/input_reserved ~ Cell/get)
        (then
        # Preflight confirmation owns a reservation before a Task exists.
        # Revoking it is a real cancellation; the admitting path must prove
        # the reservation survived before it may install host work.
        (worker/input_reserved ~ Cell/set false)
        (worker/status ~ Cell/set
          (if (== (worker/lifecycle ~ Cell/get) "stopped")
            "stopped" "idle"))
        (application_emit app "worker_admission_cancelled"
          {^worker_id worker/id ^kind worker/kind ^reason "cancelled"})
          true)
        (else false)))
    (else
      (task ~ Task/cancel)
      (var operation (worker/current_operation ~ Cell/get))
      (application_emit app "worker_operation_cancelling"
        {^worker_id worker/id ^kind worker/kind
         ^task_id (if operation operation/task_id)})
      true)))

(fn application_cancel_agent [app, agent] : Bool
  (var cancelled (application_cancel_worker app agent))
  (if cancelled
    (then
      (application_emit app "agent_status"
        {^worker_id agent/id ^agent_id agent/id ^status "cancelling"})
      true)
    (else false)))

(fn workspace_owner_token [app, worker_id : Str] : Str
  $"${app/coordinator_id}/${worker_id}")

(fn application_stop_worker [app, worker] : Bool
  (if (== worker/id "main")
    false
    (if (== (worker/lifecycle ~ Cell/get) "stopped")
      (then false)
      (else
        (var had_task (!= (worker/current_task ~ Cell/get) nil))
        # Stop also revokes an input admission that has not created its Task
        # yet. The admitted handler rechecks lifecycle before executing, so a
        # late confirmation response cannot resurrect this worker.
        (worker/input_reserved ~ Cell/set false)
        (application_cancel_worker app worker)
        (worker/lifecycle ~ Cell/set "stopped")
        (worker/status ~ Cell/set "stopped")
        (if had_task
          (application_finish_worker_operation! app worker "cancelled"))
        (if (== (app/workspace_coordinator/owner ~ Cell/get)
                (workspace_owner_token app worker/id))
          (application_release_workspace app worker/id "worker_stop"))
        (if (&& (== worker/kind "repl")
                (!= worker/controller nil)
                (!= worker/controller/session nil))
          (repl_close worker/controller/session))
        (application_remove_worker_follow_links! app worker)
        (application_remove_worker_observers! app worker/id)
        (application_emit app "worker_stopped"
          {^worker_id worker/id ^kind worker/kind})
        (application_prune_stopped_workers! app)
        true))))

(fn application_stop_agent [app, agent] : Bool
  (var had_operation
    (|| (!= (agent/current_operation ~ Cell/get) nil)
        (!= (agent/current_task ~ Cell/get) nil)))
  (var stopped (application_stop_worker app agent))
  (if stopped
    (then
      (if had_operation
        (application_finish_agent_operation!
          app agent "cancelled" "" "cancelled" "agent stopped" nil))
      (application_emit app "agent_status"
        {^worker_id agent/id ^agent_id agent/id ^status "stopped"})
      true)
    (else false)))

(fn application_close_pane [app, id : Int] : Bool
  (var surface app/local_surface)
  (if (== surface nil)
    (then false)
    (else
      (var kept (cell []))
      (var removed (cell nil))
      (for pane in (surface/panes ~ Cell/get)
        (if (== pane/id id)
          (removed ~ Cell/set pane)
          ((kept ~ Cell/get) ~ List/push! pane)))
      (var pane (removed ~ Cell/get))
      (if (== pane nil)
        (then false)
        (else
          (surface/panes ~ Cell/set (kept ~ Cell/get))
          (if (== (surface/focused_pane ~ Cell/get) id)
            (surface/focused_pane ~ Cell/set nil))
          (if (== (surface/maximized_pane ~ Cell/get) id)
            (surface/maximized_pane ~ Cell/set nil))
          (application_emit app "pane_closed"
            {^pane_id id ^worker_id pane/worker_id
             ^kind pane/kind ^owner_id pane/owner_id
             ^surface_id (surface/instance_id ~ Cell/get)})
          (application_prune_stopped_workers! app)
          true)))))

(fn pane_pending_marker [pane] : Str
  (if (pane/pending_visible ~ Cell/get)
    "assistant|...\n"
    (if (!= (pane/current_task ~ Cell/get) nil) "assistant|   \n" "")))

(fn main_pending_marker [app] : Str
  (if (|| (== app nil) (== app/local_surface nil))
    ""
    (if (app/local_surface/main_pending_visible ~ Cell/get)
      "agent> ...\n"
      (if (!= (app/main_agent/current_task ~ Cell/get) nil)
        "agent>    \n" ""))))

(fn output_with_pending_marker [output : Str, marker : Str] : Str
  (if (== marker "")
    (then output)
    (else
      (var separator
        (if (|| (== output "") (ends_with? output "\n")) "" "\n"))
      $"${output}${separator}${marker}")))

(fn main_presented_output [app, transcript] : Str
  (var notice
    (if (|| (== app nil) (== app/local_surface nil)) ""
      (app/local_surface/help_notice ~ Cell/get)))
  (var base (transcript ~ Cell/get))
  (var separator
    (if (|| (== base "") (ends_with? base "\n")) "" "\n"))
  (var presented
    (if (== notice "") base
      $"${base}${separator}\n${notice}"))
  (output_with_pending_marker
    presented (main_pending_marker app)))

(fn application_pane_views [app]
  (var surface app/local_surface)
  (var views (cell []))
  (for pane in (if (== surface nil) [] (surface/panes ~ Cell/get))
    (if_not (pane/hidden ~ Cell/get)
      (var marker
        (if (== (surface/focused_pane ~ Cell/get) pane/id) "*" ""))
      (var unread
        (if (== pane/kind "agent")
          (match (pane/worker/result ~ Cell/get)
            (when (m : Map) (if (== m/read false) "!" ""))
            (else ""))
          ""))
      ((views ~ Cell/get) ~ List/push!
        {^title $"[${pane/id}]${marker}${unread} ${pane/title} (${(pane/status ~ Cell/get)})"
         ^output
           (output_with_pending_marker
             (pane/output ~ Cell/get) (pane_pending_marker pane))
         ^scroll (pane/scroll ~ Cell/get)
         ^focused (== (surface/focused_pane ~ Cell/get) pane/id)
         ^maximized (== (surface/maximized_pane ~ Cell/get) pane/id)})))
  (views ~ Cell/get))

(fn application_scroll_target! [app, main_scroll, direction : Int,
                                amount : Int]
  (var surface app/local_surface)
  (var pane_id
    (if surface (surface/focused_pane ~ Cell/get)))
  (var pane
    (if pane_id (application_find_pane app pane_id)))
  (var target (if (== pane nil) main_scroll pane/scroll))
  (var current (target ~ Cell/get))
  (target ~ Cell/set
    (if (> direction 0)
      (+ current amount)
      (if (> current amount) (- current amount) 0)))
  (if pane pane/id))

(fn application_pane_page_rows [app, rows : Int] : Int
  (var surface app/local_surface)
  (var available (if (> rows 5) (- rows 5) 1))
  (var pane_count 0)
  (for pane in (if (== surface nil) [] (surface/panes ~ Cell/get))
    (if_not (pane/hidden ~ Cell/get)
      (set pane_count (+ pane_count 1))))
  (var page
    (if (|| (== surface nil) (== (surface/focused_pane ~ Cell/get) nil))
      available
      (if (> pane_count 0)
        (if (< available (* pane_count 7))
          (- available 1)
          (- (/ available pane_count) 1))
        available)))
  (if (> page 0) page 1))

(fn application_cycle_visible_pane! [app, direction : Int]
  (var surface app/local_surface)
  (if_not (== surface nil)
    (var ids [0])
    (for pane in (surface/panes ~ Cell/get)
      (if_not (pane/hidden ~ Cell/get) (ids ~ List/push! pane/id)))
    (var current
      (if (== (surface/focused_pane ~ Cell/get) nil)
        0 (surface/focused_pane ~ Cell/get)))
    (var index 0)
    (repeat i in ids/~size
      (if (== ids/%i current) (set index i)))
    (var next (+ index direction))
    (if (< next 0) (set next (- ids/~size 1)))
    (if (>= next ids/~size) (set next 0))
    (var target ids/%next)
    (surface/focused_pane ~ Cell/set (if (== target 0) nil target))
    (surface/maximized_pane ~ Cell/set nil)
    target))

(fn application_shutdown [app]
  (if_not (app/shutting_down ~ Cell/get)
      (app/shutting_down ~ Cell/set true)
      (for worker in (app/workers ~ Cell/get)
        (if_not (== (worker/lifecycle ~ Cell/get) "stopped")
            # A reservation can exist before preflight installs a Task.
            # Controlled shutdown must revoke both admission states so a late
            # confirmation cannot execute against a stopped application.
            (worker/input_reserved ~ Cell/set false)
            (var task (worker/current_task ~ Cell/get))
            (if task (task ~ Task/cancel))
            (worker/lifecycle ~ Cell/set "stopped")
            (worker/status ~ Cell/set "stopped")
            (if task
              (if (== worker/kind "agent")
                (application_finish_agent_operation!
                  app worker "cancelled" "" "cancelled"
                  "application shutdown" nil)
                (application_finish_worker_operation!
                  app worker "cancelled")))
            (if (&& (== worker/kind "repl") (!= worker/controller nil)
                    (!= worker/controller/session nil))
              (repl_close worker/controller/session))
            (application_remove_worker_follow_links! app worker)
            (application_remove_worker_observers! app worker/id)
            (application_emit app "worker_stopped"
              {^worker_id worker/id ^kind worker/kind
               ^reason "shutdown"})))
      (var owner (app/workspace_coordinator/owner ~ Cell/get))
      (if (&& (!= owner nil)
              (starts_with? owner $"${app/coordinator_id}/"))
        (app/workspace_coordinator/owner ~ Cell/set nil))
      (application_emit app "application_stopped" {})
      nil))

(fn agent_result_text [result] : Str
  (match result
    (when (m : Map)
      (if (match m/text (when (text : Str) true) (else false))
        m/text ""))
    (when (text : Str) text)
    (else "")))

(fn agent_result_with_flags [result, read : Bool, incorporated : Bool]
  (if (== result nil) nil
    (match result
      (when (m : Map)
        {^task_id m/task_id ^outcome m/outcome ^text (agent_result_text m)
         ^error m/error ^finished_v m/finished_v
         ^read read ^incorporated incorporated})
      (when (text : Str)
        {^task_id nil ^outcome "completed" ^text text ^error nil
         ^finished_v nil ^read read ^incorporated incorporated})
      (else nil))))

(fn agent_result_report [agent] : Str
  (var result (agent/result ~ Cell/get))
  (if (== result nil)
    $"agent ${agent/id} has no result"
    (match result
      (when (m : Map)
        (var error_text
          (if (== m/error nil) ""
            $" error=${m/error/kind}: ${m/error/message}"))
        (var cursor_text
          (if (&& (!= m/finished_v nil) (!= m/finished_v void)
                  (> (event_dropped_before ~ Cell/get) 0)
                  (< m/finished_v (event_dropped_before ~ Cell/get)))
            $" [evidence expired (v${m/finished_v})]" ""))
        $"agent ${agent/id} ${m/outcome} task=${m/task_id}${error_text}${cursor_text}\n${(agent_result_text m)}")
      (when (text : Str) $"agent ${agent/id} completed\n${text}")
      (else $"agent ${agent/id} has an invalid result"))))

(fn application_inspect_agent_result! [app, agent] : Str
  (var report (agent_result_report agent))
  (application_mark_agent_result_read! app agent)
  report)

(fn application_mark_agent_result_read! [app, agent] : Bool
  (var result (agent/result ~ Cell/get))
  (if (== result nil)
    false
    (do
      (var already
        (match result
          (when (m : Map) (== m/read true))
          (else false)))
      (var incorporated
        (match result
          (when (m : Map) (== m/incorporated true))
          (else false)))
      (if_not already
        (agent/result ~ Cell/set
          (agent_result_with_flags result true incorporated))
        (checkpoint_agent_state! app "agent_result_read"))
      true)))

(fn application_incorporate_agent_result! [app, agent] : Bool
  (var result (agent/result ~ Cell/get))
  (if (== result nil)
    (then false)
    (else
      (var already
        (match result
          (when (m : Map) (== m/incorporated true))
          (else false)))
      (var read
        (match result
          (when (m : Map) (== m/read true))
          (else false)))
      (if_not already
        (var outcome_text
          (match result
            (when (m : Map) m/outcome)
            (else "completed")))
        (var result_verb
          (if (== outcome_text "completed") "completed" "finished"))
        (var item_text
          $"Sub-agent ${agent/id} ${result_verb} assignment: ${agent/assignment}\nOutcome: ${outcome_text}\nResult:\n${(agent_result_text result)}")
        (app/main_agent/items ~ Cell/set
          (append (app/main_agent/items ~ Cell/get)
            (system_item item_text))))
      (agent/result ~ Cell/set
        (agent_result_with_flags result read true))
      (checkpoint_agent_state! app "agent_result_incorporated")
      true)))

(fn application_enqueue_supervisor_result! [app, agent, result]
  (var inbox (app/supervisor_inbox ~ Cell/get))
  (var normalized
    (match result
      (when (m : Map) m)
      (when (text : Str)
        {^task_id nil ^outcome "completed" ^text (redact text) ^error nil
         ^finished_v nil ^read false ^incorporated false})
      (else
        {^task_id nil ^outcome "failed" ^text ""
         ^error {^kind "invalid_result" ^message "invalid agent result"}
         ^finished_v nil ^read false ^incorporated false})))
  (inbox ~ List/push!
    {^agent_id agent/id ^assignment agent/assignment
     ^result normalized})
  (if_yes (> inbox/~size supervisor_inbox_max_count)
      (var kept [])
      (var first (- inbox/~size supervisor_inbox_max_count))
      (repeat i in inbox/~size
        (if (>= i first) (kept ~ List/push! inbox/%i)))
      (app/supervisor_inbox ~ Cell/set kept)
      (application_emit app "supervisor_result_dropped"
        {^worker_id agent/id ^agent_id agent/id
         ^reason "supervisor_inbox_limit"
         ^limit supervisor_inbox_max_count})))

(fn application_finish_agent_operation!
  [app, agent, outcome : Str, text : Str, error_kind : Str,
   error_text : Str, pane_id]
  # Worker finish, structured result, agent finish, compatibility alias, and
  # supervisor notification form one checkpoint transaction. Events remain
  # observable during the transaction, but no snapshot can capture the agent
  # as idle while still missing its terminal result.
  (var operation (agent/current_operation ~ Cell/get))
  (var task (agent/current_task ~ Cell/get))
  (var prior_worker_event (agent/last_finish_event ~ Cell/get))
  (var prior_result (agent/result ~ Cell/get))
  # Stop and shutdown may synchronously close the worker boundary before a
  # cancelled Task reaches its ensure block. Reusing the recorded finish event
  # preserves the task/source link; the later ensure is then idempotent.
  (var already_finished
    (match prior_result
      (when (m : Map)
        (&& (== operation nil) (== task nil)
            (!= prior_worker_event nil)
            (== m/task_id prior_worker_event/task_id)))
      (else false)))
  (if already_finished
    prior_result
    (do
      (var previous_suspension (agent_checkpoint_suspended ~ Cell/get))
      (var final_result nil)
      (agent_checkpoint_suspended ~ Cell/set true)
      (try
        (var worker_event
          (application_finish_worker_operation! app agent outcome))
        (if (== worker_event nil)
          (set worker_event (agent/last_finish_event ~ Cell/get)))
        (var task_id (if worker_event worker_event/task_id))
        (var worker_v
          (if (&& worker_event (present? worker_event/v)) worker_event/v nil))
        (var safe_text (utf8_prefix (redact text) agent_result_max_bytes))
        (var safe_error (utf8_prefix (redact error_text) agent_result_max_bytes))
        (var error
          (if (== outcome "completed") nil
            {^kind (if (== error_kind "") outcome error_kind)
             ^message safe_error}))
        # Main output was presented directly and is already part of main
        # model context. Sub-agent results remain unread/unincorporated until
        # an explicit surface action.
        (var main_result (== agent/id "main"))
        (var result_read main_result)
        (var result_incorporated main_result)
        (var pending_result
          {^task_id task_id ^outcome outcome ^text safe_text ^error error
           ^finished_v nil ^read result_read
           ^incorporated result_incorporated})
        (agent/result ~ Cell/set pending_result)
        (var event_props
          {^worker_id agent/id ^agent_id agent/id
           ^parent_agent_id agent/parent_id ^task_id task_id ^outcome outcome
           ^source_v worker_v ^result_unread (! result_read) ^pane_id pane_id
           ^error_kind (if error error/kind)
           ^error_text (if error error/message)})
        (var agent_event (application_emit app "agent_finished" event_props))
        (var finished_v
          (if (&& agent_event (present? agent_event/v)) agent_event/v nil))
        (set final_result
          {^task_id task_id ^outcome outcome ^text safe_text ^error error
           ^finished_v finished_v ^read result_read
           ^incorporated result_incorporated})
        (agent/result ~ Cell/set final_result)
        (if_not main_result
          (application_enqueue_supervisor_result! app agent final_result))
        (if (== outcome "completed")
          (application_emit app "agent_completed"
            {^worker_id agent/id ^agent_id agent/id
             ^parent_agent_id agent/parent_id ^task_id task_id
             ^status "completed" ^text safe_text ^source_v finished_v}))
        (if_not main_result
          (append_agent_transcript! app/main_agent
            $"[agent ${agent/id} ${outcome} — /agent ${agent/id} result]\n"))
      ensure
        (agent_checkpoint_suspended ~ Cell/set previous_suspension))
      (checkpoint_agent_state! app "agent_finished")
      (refresh_active_input)
      final_result)))

# Child results cross into the main conversation only at this explicit
# supervision boundary. Private child tool transcripts stay private.
(fn application_drain_supervisor_inbox [app]
  (var inbox (app/supervisor_inbox ~ Cell/get))
  (if_not (empty? inbox)
      (for result in inbox
        (var agent (application_find_agent app result/agent_id))
        (if agent
          (then
            (if (== (agent/result ~ Cell/get) nil)
              (agent/result ~ Cell/set result/result))
            (application_incorporate_agent_result! app agent))
          (app/main_agent/items ~ Cell/set
            (append (app/main_agent/items ~ Cell/get)
              (system_item
                $"Sub-agent ${result/agent_id} finished assignment: ${result/assignment}\nResult:\n${(agent_result_text result/result)}")))))
      (app/supervisor_inbox ~ Cell/set [])
      nil))

(fn project_progress_report [app] : Str
  (var progress (app/progress ~ Cell/get))
  (var evidence [])
  (var dropped (event_dropped_before ~ Cell/get))
  (for cursor in progress/evidence_v
    (evidence ~ List/push!
      (if (&& (> dropped 0) (< cursor dropped))
        $"evidence expired (v${cursor})" cursor)))
  (var blocked
    (if (== progress/status "blocked")
      $"\nblocked: ${progress/blocked_reason}\naction: ${progress/required_action}"
      ""))
  $"objective: ${progress/objective}\nphase: ${progress/phase}\nstatus: ${progress/status}\nsummary: ${progress/summary}${blocked}\nagents: ${progress/agent_ids}\nworkers: ${progress/worker_ids}\nevidence: ${evidence}")

(fn list_of_type? [value, kind : Str] : Bool
  (match value
    (when (items : List)
      (var valid (cell true))
      (for item in items
        (if_not
          (match kind
            (when "str" (match item (when (_v : Str) true) (else false)))
            (when "int" (match item (when (_v : Int) true) (else false)))
            (else false))
          (valid ~ Cell/set false)))
      (valid ~ Cell/get))
    (else false)))

(fn optional_int? [value] : Bool
  (|| (== value nil) (== value void)
      (match value (when (_v : Int) true) (else false))))

(fn normalized_agent_result [value, main_result : Bool]
  (if (|| (== value nil) (== value void)) nil
    (match value
      (when (text : Str)
        {^task_id nil ^outcome "completed" ^text text ^error nil
         ^finished_v nil ^read main_result ^incorporated main_result})
      (when (m : Map)
        (if_not (["completed" "cancelled" "failed"] ~ contains? m/outcome)
          (fail (OsError ^message "agent result outcome is invalid")))
        (if_not (match m/text (when (_v : Str) true) (else false))
          (fail (OsError ^message "agent result text must be a Str")))
        (if_not (|| (== m/task_id nil) (== m/task_id void)
                    (match m/task_id (when (_v : Str) true) (else false)))
          (fail (OsError ^message "agent result task_id must be nil or Str")))
        (if_not (|| (== m/finished_v nil) (== m/finished_v void)
                    (match m/finished_v (when (_v : Int) true) (else false)))
          (fail (OsError ^message "agent result finished_v must be nil or Int")))
        (var result_read (if (present? m/read) m/read main_result))
        (var incorporated
          (if (present? m/incorporated) m/incorporated main_result))
        (if_not (match result_read (when (_v : Bool) true) (else false))
          (fail (OsError ^message "agent result read must be a Bool")))
        (if_not (match incorporated (when (_v : Bool) true) (else false))
          (fail (OsError ^message "agent result incorporated must be a Bool")))
        (var error (if (present? m/error) m/error nil))
        (if_not (|| (== error nil)
                    (match error
                      (when (e : Map)
                        (&& (match e/kind (when (_v : Str) true) (else false))
                            (match e/message (when (_v : Str) true) (else false))))
                      (else false)))
          (fail (OsError
            ^message "agent result error must be nil or {^kind Str ^message Str}")))
        {^task_id (if (== m/task_id void) nil m/task_id)
         ^outcome m/outcome ^text m/text ^error error
         ^finished_v (if (== m/finished_v void) nil m/finished_v)
         ^read result_read ^incorporated incorporated})
      (else (fail (OsError ^message "agent result must be a map, Str, or nil"))))))

(fn normalized_project_progress [value]
  (match value
    (when (m : Map)
      (if_not (match m/objective (when (_v : Str) true) (else false))
        (fail (OsError ^message "progress objective must be a Str")))
      (if_not (["planning" "research" "implementing" "verifying" "handoff"]
                ~ contains? m/phase)
        (fail (OsError ^message "progress phase is invalid")))
      (if_not (["active" "blocked" "complete"] ~ contains? m/status)
        (fail (OsError ^message "progress status is invalid")))
      (if_not (match m/summary (when (_v : Str) true) (else false))
        (fail (OsError ^message "progress summary must be a Str")))
      (var blocked_reason
        (if (present? m/blocked_reason) m/blocked_reason nil))
      (var required_action
        (if (present? m/required_action) m/required_action nil))
      (if_not (|| (== blocked_reason nil)
                  (match blocked_reason (when (_v : Str) true) (else false)))
        (fail (OsError ^message "progress blocked_reason must be nil or Str")))
      (if_not (|| (== required_action nil)
                  (match required_action (when (_v : Str) true) (else false)))
        (fail (OsError ^message "progress required_action must be nil or Str")))
      (if (&& (== m/status "blocked")
              (|| (== blocked_reason nil) (== required_action nil)
                  (== (trim blocked_reason) "")
                  (== (trim required_action) "")))
        (fail (OsError
          ^message "blocked progress requires blocked_reason and required_action")))
      (var updated_v (if (present? m/updated_v) m/updated_v nil))
      (if_not (|| (== updated_v nil)
                  (match updated_v (when (_v : Int) true) (else false)))
        (fail (OsError ^message "progress updated_v must be nil or Int")))
      (var agent_ids (if (present? m/agent_ids) m/agent_ids []))
      (var worker_ids (if (present? m/worker_ids) m/worker_ids []))
      (var evidence_v (if (present? m/evidence_v) m/evidence_v []))
      (if_not (list_of_type? agent_ids "str")
        (fail (OsError ^message "progress agent_ids must contain only Str")))
      (if_not (list_of_type? worker_ids "str")
        (fail (OsError ^message "progress worker_ids must contain only Str")))
      (if_not (list_of_type? evidence_v "int")
        (fail (OsError ^message "progress evidence_v must contain only Int")))
      {^objective m/objective ^phase m/phase ^status m/status
       ^summary m/summary
       ^blocked_reason blocked_reason ^required_action required_action
       ^updated_v updated_v ^agent_ids agent_ids ^worker_ids worker_ids
       ^evidence_v evidence_v})
    (else (fail (OsError ^message "progress record must be a map")))))

(fn application_update_progress!
  [app, objective : Str, phase : Str, status : Str, summary : Str,
   blocked_reason, required_action, agent_ids, worker_ids, evidence_v]
  (var phases ["planning" "research" "implementing" "verifying" "handoff"])
  (var statuses ["active" "blocked" "complete"])
  (if_not (phases ~ contains? phase)
    (fail (OsError ^message $"invalid progress phase: ${phase}")))
  (if_not (statuses ~ contains? status)
    (fail (OsError ^message $"invalid progress status: ${status}")))
  (if (&& (== status "blocked")
          (|| (== blocked_reason nil) (== required_action nil)
              (== (trim $"${blocked_reason}") "")
              (== (trim $"${required_action}") "")))
    (fail (OsError
      ^message "blocked progress requires blocked_reason and required_action")))
  (var previous_suspension (agent_checkpoint_suspended ~ Cell/get))
  (var updated nil)
  (agent_checkpoint_suspended ~ Cell/set true)
  (try
    (set updated
      {^objective (redact objective) ^phase phase
       ^status status ^summary (redact summary)
       ^blocked_reason (if (== status "blocked") (redact_any blocked_reason))
       ^required_action (if (== status "blocked") (redact_any required_action))
       ^updated_v nil ^agent_ids agent_ids ^worker_ids worker_ids
       ^evidence_v evidence_v})
    (app/progress ~ Cell/set updated)
    (var event
      (application_emit app "progress_updated"
        {^phase phase ^status status ^summary (redact summary)
         ^agent_ids agent_ids ^worker_ids worker_ids ^evidence_v evidence_v}))
    (var updated_v (if (&& event (present? event/v)) event/v nil))
    (set updated
      {^objective updated/objective ^phase phase
       ^status status ^summary updated/summary
       ^blocked_reason updated/blocked_reason
       ^required_action updated/required_action ^updated_v updated_v
       ^agent_ids agent_ids ^worker_ids worker_ids ^evidence_v evidence_v})
    (app/progress ~ Cell/set updated)
  ensure
    (agent_checkpoint_suspended ~ Cell/set previous_suspension))
  (checkpoint_agent_state! app "progress_updated")
  updated)

(fn workspace_request_ready? [coordinator, request_id : Int]
  (var waiters (coordinator/waiters ~ Cell/get))
  (&& (== (coordinator/owner ~ Cell/get) nil)
      (! (empty? waiters))
      (== waiters/0/id request_id)))

(fn application_acquire_workspace [app, worker_id : Str, operation : Str]
  (var coordinator app/workspace_coordinator)
  (var seq (coordinator/next_request ~ Cell/get))
  (coordinator/next_request ~ Cell/set (+ seq 1))
  (var owner_token (workspace_owner_token app worker_id))
  (var request
    {^id seq ^application_id app/coordinator_id
     ^worker_id worker_id ^owner_token owner_token ^operation operation})
  ((coordinator/waiters ~ Cell/get) ~ List/push! request)
  (var acquired (cell false))
  (try
    (while (&& (! (app/shutting_down ~ Cell/get))
                (! (workspace_request_ready? coordinator seq)))
      (sleep 10))
    (if (app/shutting_down ~ Cell/get)
      (then false)
      (else
        (coordinator/owner ~ Cell/set owner_token)
        (var remaining [])
        (for waiter in (coordinator/waiters ~ Cell/get)
          (if (!= waiter/id seq) (remaining ~ List/push! waiter)))
        (coordinator/waiters ~ Cell/set remaining)
        (acquired ~ Cell/set true)
        (application_emit app "workspace_lease"
          {^application_id app/coordinator_id
           ^worker_id worker_id ^agent_id worker_id
           ^workspace coordinator/root ^operation operation
           ^request_id seq ^status "acquired"})
        true))
  ensure
    (if_yes (! (acquired ~ Cell/get))
      (var remaining [])
      (for waiter in (coordinator/waiters ~ Cell/get)
        (if (!= waiter/id seq) (remaining ~ List/push! waiter)))
      (coordinator/waiters ~ Cell/set remaining))))

(fn application_release_workspace [app, worker_id : Str, operation : Str]
  (var coordinator app/workspace_coordinator)
  (if (== (coordinator/owner ~ Cell/get)
          (workspace_owner_token app worker_id))
    (then
      (coordinator/owner ~ Cell/set nil)
      (application_emit app "workspace_lease"
        {^application_id app/coordinator_id
         ^worker_id worker_id ^agent_id worker_id
         ^workspace coordinator/root ^operation operation ^status "released"})
      true)
    (else false)))

(fn set_events_enabled [on : Bool]
  (events_enabled ~ Cell/set on))

# Redact recursively through every container an event value can hold — a
# model_item's `content` is a list of maps, so stopping at maps would persist
# a token echoed in assistant content (§8.5).
(fn redact_any [v]
  (match v
    (when (s : Str) (redact s))
    (when (m : Map)
      (var out {})
      (for [k mv] in m
        (out ~ Map/put! k (redact_any mv)))
      out)
    (when (xs : List)
      ((to_stream xs) ~ map redact_any ; ~ into []))
    (else v)))

(fn first_line [s : Str] : Str
  (var lines (split s "\n"))
  (if (> lines/~size 1) $"${lines/0} ..." lines/0))

(fn event_summary [e] : Str
  (match e/type
    (when "user_input"  (first_line e/text))
    (when "agent_text"  (first_line e/text))
    (when "text_delta"  (first_line e/text))
    (when "turn_done"   (if (present? e/text) (first_line e/text) ""))
    (when "model_item"  (if (present? e/item/type) e/item/type "item"))
    (when "tool_call"   $"${e/name} ${(stringify e/args)}")
    (when "tool_result"
      (var flag (if (== e/truncated true) " [truncated]" ""))
      $"${e/name}${flag}: ${(first_line e/value)}")
    (when "file_change"
      (if (present? e/undo_of)
        $"undo #${e/undo_of}: ${e/path}"
        $"#${e/id} ${e/op}: ${e/path}"))
    (when "check"
      $"${e/scope} status=${e/status} ${e/duration_ms}ms: ${(first_line e/command)}")
    (when "confirmation" $"${e/risk} ${e/decision}: ${(first_line e/target)}")
    (when "context_compacted"
      (var elided
        (if (present? e/elided_tool_outputs)
          e/elided_tool_outputs
          0))
      $"${e/removed_turns} turns / ${e/removed_items} items removed; ${elided} tool outputs elided; ${e/bytes_after} bytes retained")
    (when "context_limit_warning"
      $"context remains over its configured floor: ${e/bytes} bytes / ${e/items} items")
    (when "worker_operation_started"
      $"worker=${e/worker_id} task=${e/task_id} operation=${e/operation_kind}")
    (when "worker_operation_finished"
      (var duration
        (if (present? e/duration_ms) $" duration=${e/duration_ms}ms" ""))
      $"worker=${e/worker_id} task=${e/task_id} operation=${e/operation_kind} outcome=${e/outcome}${duration}")
    (when "agent_finished"
      (var error
        (if (present? e/error_text)
          $" error=${(first_line e/error_text)}" ""))
      $"agent=${e/agent_id} task=${e/task_id} outcome=${e/outcome}${error}")
    (when "agent_completed"
      $"agent=${e/agent_id} task=${e/task_id} outcome=completed alias_of=${e/source_v}")
    (when "worker_output"
      $"worker=${e/worker_id} task=${e/task_id} seq=${e/seq} stream=${e/stream}: ${(first_line e/text)}")
    (when "progress_updated"
      $"phase=${e/phase} status=${e/status}: ${(first_line e/summary)}")
    (when "restore_record_rejected"
      $"${e/record_kind}/${e/record_id} ${e/error_kind}: ${(first_line e/error_text)}")
    (when "tool_registered" $"${e/name} (${e/risk})")
    (when "memory"      (first_line e/text))
    (when "error"       (first_line e/text))
    (else "")))

(fn format_event [e] : Str
  $"#${e/v} t${e/turn} ${e/type} ${(event_summary e)}")

(fn subscribed? [type : Str]
  (var hit (cell false))
  ((to_stream (event_subscriptions ~ Cell/get))
    ~ each (fn [t] (if (== t type) (Cell/set hit true))))
  (Cell/get hit))

(fn echo_subscribed [e]
  (if_yes (&& (present? (event_echo ~ Cell/get)) (subscribed? e/type))
    (var f (event_echo ~ Cell/get))
    (f (format_event e))))

(fn evidence_event? [e]
  (|| (== e/type "file_change") (== e/type "check")))

(fn bounded_event_record [event, capacity : Int]
  (var original_bytes (byte_size (stringify event)))
  (if (<= original_bytes capacity)
    (then event)
    (else
      # Structured records stay atomic. Oversized payloads become a typed
      # summary rather than an invalid byte slice.
      (var summary
        {^v event/v ^type event/type ^truncated true
         ^original_bytes original_bytes
         ^summary "event payload exceeded the journal record capacity"})
      (if (!= event/turn void) (summary ~ Map/put! "turn" event/turn))
      (for key in ["application_id" "worker_id" "agent_id"
                   "parent_agent_id" "task_id" "turn_id" "tool_call_id"
                   "pane_id" "surface_id"]
        (var value (event ~ Map/get key))
        (if (!= value void) (summary ~ Map/put! key value)))
      summary)))

(fn trim_agent_event_journal! [] : Bool
  (var current (agent_events ~ Cell/get))
  (var first 0)
  (var retained_bytes (agent_event_bytes ~ Cell/get))
  (while (&& (< first current/~size)
             (|| (> (- current/~size first) event_max_count)
                 (> retained_bytes event_max_bytes)))
    (set retained_bytes
      (- retained_bytes (byte_size (stringify current/%first))))
    (event_dropped_before ~ Cell/set current/%first/v)
    (set first (+ first 1)))
  (if (== first 0)
    (then false)
    (else
      (var kept [])
      (repeat i in current/~size
        (if (>= i first) (kept ~ List/push! current/%i)))
      (agent_events ~ Cell/set kept)
      (agent_event_bytes ~ Cell/set retained_bytes)
      (agent_evidence ~ Cell/set
        ((to_stream kept) ~ filter evidence_event? ; ~ into []))
      true)))

(fn emit_event! [type : Str, props]
  (if_not (! (events_enabled ~ Cell/get))
    (var v (next_event_v ~ Cell/get))
    (next_event_v ~ Cell/set (+ v 1))
    (var e {^v v ^turn (current_turn ~ Cell/get) ^type type})
    (for [k pv] in props
      (e ~ Map/put! k (redact_any pv)))
    (var stored (bounded_event_record e event_max_bytes))
    (var stored_bytes (byte_size (stringify stored)))
    (agent_events ~ Cell/set (append (agent_events ~ Cell/get) stored))
    (agent_event_bytes ~ Cell/set
      (+ (agent_event_bytes ~ Cell/get) stored_bytes))
    (var overflowed (trim_agent_event_journal!))
    (if (&& (! overflowed) (evidence_event? stored))
      (agent_evidence ~ Cell/set
        (append (agent_evidence ~ Cell/get) stored)))
    (echo_subscribed stored)
    (trace! event_log "event appended"
      ^payload {^event_type type ^event_v v
                ^turn_id (current_turn ~ Cell/get)
                ^worker_id stored/worker_id
                ^agent_id stored/agent_id
                ^task_id stored/task_id
                ^pane_id stored/pane_id
                ^surface_id stored/surface_id
                ^evidence (evidence_event? stored)})
    stored))

(fn begin_turn! []
  (current_turn ~ Cell/set (+ (current_turn ~ Cell/get) 1))
  (debug! turn_log "turn initialized"
    ^payload {^turn_id (current_turn ~ Cell/get)}))

# Successful file tools record exact before/after snapshots. `/undo` restores
# one operation only when the current file still equals that operation's after
# snapshot, so pre-existing or later edits are never erased by inference.
(var file_changes (cell []))
(var next_file_change_id (cell 1))

(fn file_snapshot [path : Str]
  (if (exists? ReadDir path)
    {^exists true ^text (read_text ReadDir path)}
    {^exists false ^text ""}))

(fn content_identity [text : Str]
  {^hash (hash text) ^bytes (size (bytes text))})

(fn emit_owned_event! [sink, type : Str, props]
  (if (present? sink) (sink type props) (emit_event! type props)))

(fn record_file_change! [sink, op : Str, path : Str, before, after]
  (var id (next_file_change_id ~ Cell/get))
  (next_file_change_id ~ Cell/set (+ id 1))
  (var change {^id id ^op op ^path path
               ^before_exists before/exists ^before before/text
               ^after_exists after/exists ^after after/text
               ^undone false})
  (file_changes ~ Cell/set (append (file_changes ~ Cell/get) change))
  (var before_id (content_identity before/text))
  (var after_id (content_identity after/text))
  (emit_owned_event! sink "file_change"
    {^id id ^op op ^path path
     ^before_exists before/exists ^before_hash before_id/hash
     ^before_bytes before_id/bytes
     ^after_exists after/exists ^after_hash after_id/hash
     ^after_bytes after_id/bytes})
  change)

(fn active_file_changes []
  ((to_stream (file_changes ~ Cell/get))
    ~ filter (fn [c] (! (== c/undone true)))
    ; ~ into []))

(fn diff_lines [prefix : Str, text : Str]
  (var lines (split text "\n"))
  (var shown
    ((take (to_stream lines) 40)
      ~ map (fn [line] $"${prefix}${line}")
      ; ~ into []))
  (var body (join shown "\n"))
  (if (> lines/~size 40)
    $"${body}\n${prefix}[... ${lines/~size} lines total]"
    body))

(fn format_file_change [c]
  (var origin (if c/before_exists "pre-existing file" "new file"))
  (var before_diff (diff_lines "- " c/before))
  (var after_diff (diff_lines "+ " c/after))
  $"change #${c/id} ${c/op} ${c/path} (${origin})\n--- before\n${before_diff}\n+++ after\n${after_diff}")

(fn file_diff_report []
  (var changes (active_file_changes))
  (if (empty? changes)
    "no attributable file changes"
    (join ((to_stream changes) ~ map format_file_change ; ~ into [])
          "\n\n")))

(fn find_file_change [wanted]
  (var found (cell nil))
  ((to_stream (file_changes ~ Cell/get))
    ~ each (fn [c]
        (if (&& (! (== c/undone true))
                (|| (== wanted nil) (== c/id wanted)))
          (found ~ Cell/set c))))
  (found ~ Cell/get))

(fn undo_file_change! [wanted]
  (var c (find_file_change wanted))
  (if (== c nil)
    (then
      (if (== wanted nil) "nothing to undo" $"no active file change #${wanted}"))
    (else
      (var path (safe_path c/path))
      (var current (file_snapshot path))
      (if (|| (!= current/exists c/after_exists)
              (!= current/text c/after))
        (then $"refused: ${c/path} changed after agent change #${c/id}; current content was preserved")
        (else
          (if c/before_exists
            (write_text WriteDir path c/before)
            (remove WriteDir path))
          (c ~ Map/put! "undone" true)
          (var undo_id (next_file_change_id ~ Cell/get))
          (next_file_change_id ~ Cell/set (+ undo_id 1))
          (emit_event! "file_change"
            {^id undo_id ^op "undo" ^path c/path ^undo_of c/id
             ^before_exists c/after_exists ^after_exists c/before_exists})
          $"undid change #${c/id} (${c/path})")))))

(fn undo_with_workspace_lease [app, worker_id : Str, wanted]
  (if (== app nil)
    (undo_file_change! wanted)
    (if (application_acquire_workspace app worker_id "undo")
      (try
        (undo_file_change! wanted)
      ensure
        (application_release_workspace app worker_id "undo"))
      "error: application is shutting down")))

# Hierarchical AGENTS.md instructions are loaded only along a target path, not
# by scanning the whole workspace. This keeps startup bounded and gives the
# exact parent-to-child precedence for the file or directory being touched.
(var agent_instruction_records (cell []))
(var loaded_instruction_paths (cell []))
(var instruction_bytes (cell 0))
(var max_instruction_depth 8)
(var max_instruction_file_bytes 32768)
(var max_instruction_total_bytes 65536)

(fn instruction_loaded? [source : Str]
  ((loaded_instruction_paths ~ Cell/get) ~ contains? source))

(fn load_instruction_file [scope : Str, source : Str]
  (if_not (instruction_loaded? source)
    (loaded_instruction_paths ~ Cell/set
      (append (loaded_instruction_paths ~ Cell/get) source))
    (var safe (safe_path source))
    (if_not (! (exists? ReadDir safe))
      (try
        (var text (read_text ReadDir safe))
        (var bytes_count (size (bytes text)))
        (if (> bytes_count max_instruction_file_bytes)
          (then
            {^scope scope ^source source ^skipped "file exceeds byte cap"
             ^bytes bytes_count})
          (elif (> (+ (instruction_bytes ~ Cell/get) bytes_count)
                    max_instruction_total_bytes)
            {^scope scope ^source source ^skipped "total byte cap reached"
             ^bytes bytes_count})
            (else
              (instruction_bytes ~ Cell/set
                (+ (instruction_bytes ~ Cell/get) bytes_count))
              (var record {^scope scope ^source source
                           ^text text ^bytes bytes_count})
              (agent_instruction_records ~ Cell/set
                (append (agent_instruction_records ~ Cell/get) record))
              record))
      catch (OsError ^message _)
        {^scope scope ^source source ^skipped "unreadable"}))))

(fn ensure_agents_for_path [path : Str, include_leaf : Bool]
  (var before_paths (loaded_instruction_paths ~ Cell/get))
  (load_instruction_file "." "AGENTS.md")
  (var parts (split path "/"))
  (var count
    (if (== path ".") 0
      (if include_leaf parts/~size (- parts/~size 1))))
  (if (> count max_instruction_depth) (set count max_instruction_depth))
  (var scope_cell (cell "."))
  (repeat i in count
    (scope_cell ~ Cell/set
      (if (== (scope_cell ~ Cell/get) ".")
        parts/%i
        $"${(scope_cell ~ Cell/get)}/${parts/%i}"))
    (load_instruction_file (scope_cell ~ Cell/get)
      $"${(scope_cell ~ Cell/get)}/AGENTS.md"))
  (var records (agent_instruction_records ~ Cell/get))
  ((to_stream records)
    ~ filter (fn [r] (! (before_paths ~ contains? r/source)))
    ; ~ into []))

(fn instruction_applies? [record, path : Str]
  (|| (== record/scope ".")
      (== path record/scope)
      (starts_with? path $"${record/scope}/")))

(fn effective_agent_instructions [path : Str]
  ((to_stream (agent_instruction_records ~ Cell/get))
    ~ filter (fn [r]
        (&& (== r/skipped void) (instruction_applies? r path)))
    ; ~ into []))

(fn format_instruction_records [records]
  (if (empty? records)
    ""
    (join
      ((to_stream records)
        ~ map (fn [r] $"[${r/source} scope=${r/scope}]\n${r/text}")
        ; ~ into [])
      "\n\n")))

(fn newly_loaded_instruction_text [path : Str, include_leaf : Bool]
  (var newly (ensure_agents_for_path path include_leaf))
  (for record in newly
    (if (== record/skipped void)
      (debug! instruction_log "instruction file loaded"
        ^payload {^instruction_scope record/scope ^instruction_path record/source
                  ^bytes record/bytes})
      (warn! instruction_log "instruction file skipped"
        ^payload {^instruction_scope record/scope ^instruction_path record/source
                  ^bytes record/bytes ^reason record/skipped})))
  (format_instruction_records
    ((to_stream newly) ~ filter (fn [r] (== r/skipped void)) ; ~ into [])))

# Root instructions are part of the first model request. Nested instructions
# enter through the first tool result for that subtree; mutating tools defer
# that first operation so the model must retry after seeing them.
(ensure_agents_for_path "__root_probe__" false)

# --- /trace: filters over the event log (type=, tool=, path=, turn=, from=,
# to=; a bare token is shorthand for type=token) --------------------------------

(fn event_matches? [e, f]
  (var ok (cell true))
  (if (present? f/type)
    (if_not (== e/type f/type) (Cell/set ok false)))
  (if (present? f/tool)
    (if_not (== e/name f/tool) (Cell/set ok false)))
  (if_yes (present? f/turn)
    (var expected_turn
      (if (== f/turn "current") $"${(current_turn ~ Cell/get)}" f/turn))
    (if_not (== $"${e/turn}" expected_turn) (Cell/set ok false)))
  (if (present? f/worker)
    (if_not (== $"${e/worker_id}" f/worker) (Cell/set ok false)))
  (if (present? f/agent)
    (if_not (== $"${e/agent_id}" f/agent) (Cell/set ok false)))
  (if (present? f/task)
    (if_not (== $"${e/task_id}" f/task) (Cell/set ok false)))
  (if (present? f/from)
    (if_not (>= e/v (parse_int f/from)) (Cell/set ok false)))
  (if (present? f/to)
    (if_not (<= e/v (parse_int f/to)) (Cell/set ok false)))
  (if_yes (present? f/path)
      (var p (cell ""))
      (if (present? e/path) (Cell/set p e/path))
      (if (present? e/args)
        (if (present? e/args/path) (Cell/set p e/args/path)))
      (if_not (contains? (Cell/get p) f/path) (Cell/set ok false)))
  (Cell/get ok))

(fn parse_trace_filters [rest : Str]
  (var f {})
  ((to_stream (split (trim rest) " "))
    ~ each (fn [raw]
        (var tok (trim raw))
        (if_not (== tok "")
            (if (== tok "--detail")
              (then (f ~ Map/put! "detail" true))
              (else
                (var kv (split tok "="))
                (if (== kv/~size 2)
                  (f ~ Map/put! kv/0 kv/1)
                  (f ~ Map/put! "type" tok)))))))
  f)

(fn format_event_with_filters [e, filters] : Str
  (if (== filters/detail true)
    (stringify e)
    (format_event e)))

(fn trace_report [rest : Str] : Str
  (var f (parse_trace_filters rest))
  (var lines (cell []))
  (if (> (event_dropped_before ~ Cell/get) 0)
    ((lines ~ Cell/get) ~ List/push!
      $"[events through v${(event_dropped_before ~ Cell/get)} were dropped]"))
  ((to_stream (agent_events ~ Cell/get))
    ~ filter (fn [e] (event_matches? e f))
    ; ~ each (fn [e]
        ((lines ~ Cell/get) ~ List/push!
          (format_event_with_filters e f))))
  (if (empty? (lines ~ Cell/get))
    "no matching events"
    (join (lines ~ Cell/get) "\n")))

# Deny/confirm gate for run_shell and /sh-adjacent tool commands. Returns nil
# when the command may run, or the denial text otherwise. Confirmation and
# audit events go through the injected guard strategy so an embedding host
# (gateway) gets them in its per-session log and never blocks on stdin.
(fn guard_audit! [emit, props]
  (if (present? emit)
    (emit "confirmation" props)
    (guard_emit! "confirmation" props)))

(fn guard_shell_in [cmd : Str, confirm, emit]
  (var detach_reason (mediated_shell_detach_reason cmd))
  (if (present? detach_reason)
    (then
      (warn! guard_log "background shell command denied"
        ^payload {^risk "detached_process" ^decision "deny"
                  ^reason detach_reason})
      (guard_audit! emit
        {^risk "detached_process" ^decision "deny" ^target cmd
         ^reason detach_reason})
      "denied: mediated shell commands must stay in the foreground; use /tty for persistent or background work")
    (else
      (if (! (guard_enabled?))
        (then
          (debug! guard_log "command guard bypassed"
            ^payload {^guard_enabled false})
          nil)
        (else
          (match (classify_command cmd)
        (when "catastrophic"
          (warn! guard_log "catastrophic command denied"
            ^payload {^risk "catastrophic" ^decision "deny"})
          (guard_audit! emit
            {^risk "catastrophic" ^decision "deny" ^target cmd})
          "denied by catastrophe guard (GENE_AGENT_GUARD=0 outside the session overrides)")
        (when "destructive"
          (if (if (present? confirm) (confirm cmd) (guard_confirmed? cmd))
            (then
              (info! guard_log "destructive command allowed"
                ^payload {^risk "destructive" ^decision "allow"})
              (guard_audit! emit
                {^risk "destructive" ^decision "allow" ^target cmd})
              nil)
            (else
              (warn! guard_log "destructive command denied"
                ^payload {^risk "destructive" ^decision "deny"})
              (guard_audit! emit
                {^risk "destructive" ^decision "deny" ^target cmd})
              "denied: destructive command was not confirmed")))
        (else nil)))))))

(fn guard_shell [cmd : Str]
  (guard_shell_in cmd nil nil))

# -----------------------------------------------------------------------------
# Typed tools (§6, slice A). One Tool declaration per tool is the single source
# of truth: the registry entry, the model-facing JSON Schema (both wire
# shapes), argument validation, and the risk class all derive from it. New
# tools register live from /repl via (session ~ add_tool (Tool ...)).
# -----------------------------------------------------------------------------

(fn json_type_ok? [t : Str, v]
  (match t
    (when "string"  (match v (when (s : Str) true) (else false)))
    (when "integer" (match v (when (i : Int) true) (else false)))
    (when "boolean" (match v (when (b : Bool) true) (else false)))
    (when "object"  (match v (when (m : Map) true) (else false)))
    (when "array"   (match v (when (items : List) true) (else false)))
    (else true)))

(fn gene_type_json_schema [expr]
  (var name $"${expr}")
  (match name
    (when "Str" {^type "string"}) (when "Str?" {^type "string"})
    (when "Int" {^type "integer"}) (when "Int?" {^type "integer"})
    (when "Float" {^type "number"}) (when "Float?" {^type "number"})
    (when "Bool" {^type "boolean"}) (when "Bool?" {^type "boolean"})
    (when "Map" {^type "object"}) (when "Map?" {^type "object"})
    (when "PropMap" {^type "object"})
    (when "PropMap?" {^type "object"})
    (when "List" {^type "array"}) (when "List?" {^type "array"})
    (else {})))

(type Tool
  ^props {^name Str ^description Str ^risk Str ^args Type? ^result Any?
          ^errors Any? ^params Any? ^handler Any
          ^handler_ref Any? ^enabled Bool?}

  # The model-facing schema in the Responses wire shape.
  (message schema [self]
    (var props {})
    (var required (cell []))
    (if (present? self/args)
      (for field in (self/args ~ fields)
        (do
          (var spec (gene_type_json_schema field/type))
          # Typed declarations may retain doc/enum annotations in ^params,
          # but name/type/required and runtime validation come only from the
          # Gene Type. The legacy form keeps all four in ^params.
          (for metadata in (if (present? self/params) self/params [])
            (if (== metadata/name field/name)
              (do
                (if (present? metadata/doc)
                  (spec ~ Map/put! "description" metadata/doc))
                (if (present? metadata/enum)
                  (spec ~ Map/put! "enum" metadata/enum)))))
          (props ~ Map/put! field/name spec)
          (if_not field/optional
            ((required ~ Cell/get) ~ List/push! field/name))))
      (for p in self/params
        (do
          (var spec {^type p/type})
          (if (present? p/doc)
            (spec ~ Map/put! "description" p/doc))
          (if (present? p/enum)
            (spec ~ Map/put! "enum" p/enum))
          (props ~ Map/put! p/name spec)
          (if (== p/required true)
            ((required ~ Cell/get) ~ List/push! p/name)))))
    (var parameters
      {^type "object" ^properties props
       ^additionalProperties (if (present? self/args) false true)})
    (if_not (empty? (required ~ Cell/get))
      (parameters ~ Map/put! "required" (required ~ Cell/get)))
    {^type "function" ^name self/name
     ^description self/description ^parameters parameters})

  # nil when args satisfy the declaration, else a problem description.
  (message validate_args [self, args]
    (if (present? self/args)
      (return
        (try
          (construct_type self/args args)
          nil
        catch (TypeError ^message message) message
        catch {^message message} message
        catch _ "arguments do not satisfy the declared Gene type")))
    (var problems (cell []))
    (for p in self/params
      (var v (args ~ Map/get p/name))
      (if (== v void)
        (if (== p/required true)
          ((problems ~ Cell/get) ~ List/push!
            $"missing required argument ${p/name}"))
        (if_not (json_type_ok? p/type v)
          ((problems ~ Cell/get) ~ List/push!
            $"argument ${p/name} must be a ${p/type}"))))
    (if_not (empty? (problems ~ Cell/get))
      (join (problems ~ Cell/get) "; "))))

(var tool_registry (cell {}))
(var tool_names (cell []))

(fn handler_ref_data [handler_ref]
  (if (|| (== handler_ref nil) (== handler_ref void)) nil
    {^module handler_ref/module ^path handler_ref/path
     ^version handler_ref/version}))

(fn capture_dynamic_registration! [record]
  (if (&& (registration_capture_enabled ~ Cell/get)
          (! (restoring_registrations ~ Cell/get)))
    (do
      (var retained [])
      (for current in (dynamic_registration_records ~ Cell/get)
        (if_not (&& (== current/kind record/kind)
                    (== current/name record/name)
                    (== current/worker_kind record/worker_kind))
          (retained ~ List/push! current)))
      (retained ~ List/push! record)
      (dynamic_registration_records ~ Cell/set retained))))

(fn find_tool [name : Str]
  ((tool_registry ~ Cell/get) ~ Map/get name))

(fn register_tool! [t]
  (if (== t/enabled void) (t ~ Node/set_prop! `enabled true))
  (var existing (find_tool t/name))
  ((tool_registry ~ Cell/get) ~ Map/put! t/name t)
  (if (== existing void)
    (tool_names ~ Cell/set (append (tool_names ~ Cell/get) t/name)))
  (emit_event! "tool_registered" {^name t/name ^risk t/risk})
  (debug! tool_log
    (if (== existing void) "tool registered" "tool registration replaced")
    ^payload {^tool_name t/name ^risk t/risk
              ^parameter_count
                (if (present? t/args) ((t/args ~ fields) ~ size)
                  (t/params ~ size))})
  (capture_dynamic_registration!
    {^kind "tool" ^worker_kind nil ^name t/name
     ^description t/description ^risk t/risk
     ^params (if (present? t/params) t/params [])
     ^args_schema (if (present? t/args) $"${t/args}" nil)
     ^handler_ref (handler_ref_data t/handler_ref)})
  t)

# Derived live so tools added/replaced from /repl reach the very next model
# call without re-registration ceremony.
(fn tool_schemas_now []
  ((to_stream (tool_names ~ Cell/get))
    ~ map (fn [n] (find_tool n))
    ; ~ filter (fn [t] (!= t/enabled false))
    ; ~ map (fn [t] (t ~ schema))
    ; ~ into []))

# Responses tool schemas are flat; chat nests them under ^function.
(fn chat_tool_schemas_now []
  ((to_stream (tool_schemas_now))
    ~ map (fn [t] {^type "function"
                   ^function {^name t/name
                              ^description t/description
                              ^parameters t/parameters}})
    ; ~ into []))

# Await a native subprocess task with structured cancellation. Cancelling the
# surrounding turn runs the ensure before unwinding, which forwards the
# request to os/exec-*-async and terminates the child process.
(fn await_exec [task]
  (try
    (await task)
  ensure
    (task ~ Task/cancel)))

(fn command_scope [command : Str] : Str
  (var c (lower (trim command)))
  (if (starts_with? c "nimble test")
    "test"
    (if (starts_with? c "nimble spec")
      "spec"
      (if (starts_with? c "nimble perf")
        "benchmark"
        (if (starts_with? c "nimble wasm") "wasm" "command")))))

(fn emit_check! [sink, tool : Str, command : Str, started : Int, result]
  (var status (if result result/status))
  (var timed_out (if (== result nil) false (== result/timed_out true)))
  (var truncated (if (== result nil) false (== result/truncated true)))
  (emit_owned_event! sink "check"
    {^tool tool ^command command ^scope (command_scope command)
     ^status status ^duration_ms (- (monotonic_ms) started)
     ^timed_out timed_out ^truncated truncated
     ^cancelled (== result nil)
     ^verified (&& (!= result nil) (== status 0) (! timed_out))}))

(fn run_checked_exec [sink, tool : Str, command : Str, task]
  (var started (monotonic_ms))
  (var result (cell nil))
  (debug! tool_log "subprocess started"
    ^payload {^tool_name tool ^check_scope (command_scope command)})
  (try
    (result ~ Cell/set (await_exec task))
    ((result ~ Cell/get) ~ Map/put! "duration_ms"
      (- (monotonic_ms) started))
    (emit_check! sink tool command started (result ~ Cell/get))
    (var completed_result (result ~ Cell/get))
    (debug! tool_log "subprocess completed"
      ^payload {^tool_name tool ^check_scope (command_scope command)
                ^status completed_result/status
                ^duration_ms completed_result/duration_ms
                ^timed_out (== completed_result/timed_out true)
                ^truncated (== completed_result/truncated true)})
    (result ~ Cell/get)
  ensure
    (if_yes (== (result ~ Cell/get) nil)
      (emit_check! sink tool command started nil)
      (info! tool_log "subprocess cancelled"
        ^payload {^tool_name tool ^check_scope (command_scope command)
                  ^duration_ms (- (monotonic_ms) started)}))))

# Give exact-edit failures a bounded, deterministic re-anchoring hint. This is
# deliberately not fuzzy matching: the first nonblank old line must exactly
# equal a current line, and at most three candidate windows are
# returned. Very long lines are elided so an error cannot flood model context.
(fn first_nonblank_line [text : Str] : Str
  (var found (cell ""))
  (for line in (split text "\n")
    (if (&& (== (found ~ Cell/get) "") (!= (trim line) ""))
      (found ~ Cell/set line)))
  (found ~ Cell/get))

(fn bounded_line [line : Str] : Str
  (if (> (byte_size line) 1000)
    $"[line omitted: ${(byte_size line)} bytes]"
    line))

(fn edit_candidate_window [lines, i : Int] : Str
  (var window_start (if (> i 3) (- i 3) 0))
  (var window_stop
    (if (< (+ i 4) lines/~size) (+ i 4) lines/~size))
  (var excerpt [])
  (repeat j in lines/~size
    (if (&& (>= j window_start) (< j window_stop))
      (excerpt ~ List/push!
        $"${(+ j 1)} | ${(bounded_line lines/%j)}")))
  (var excerpt_text (join excerpt "\n"))
  $"candidate near line ${(+ i 1)}:\n${excerpt_text}")

(fn edit_mismatch_hint [current : Str, old_text : Str] : Str
  (var anchor (first_nonblank_line old_text))
  (if (== anchor "")
    (then "No nonblank anchor was available; read the current file and retry.")
    (else
      (var lines (split current "\n"))
      (var windows (cell []))
      (var candidates (cell 0))
      (repeat i in lines/~size
        (if_yes (&& (< (candidates ~ Cell/get) 3)
                (== lines/%i anchor))
          (candidates ~ Cell/set (+ (candidates ~ Cell/get) 1))
          ((windows ~ Cell/get) ~ List/push!
            (edit_candidate_window lines i))))
      (if (empty? (windows ~ Cell/get))
        (then $"No current line equals the anchor `${(bounded_line anchor)}`; read the current file and retry.")
        (else
          (var windows_text (join (windows ~ Cell/get) "\n\n"))
          $"Re-anchor against the current file:\n${windows_text}")))))

# Writing temporarily invalid source is allowed and remains attributable. For
# Gene files, report reader diagnostics in the same tool result so the model
# can repair delimiters without spending another shell round. This is syntax
# validation only; semantic/compiler verification still requires `gene
# compile` or `gene run`.
(fn gene_parse_warning [path : Str, content : Str] : Str
  (if (! (ends_with? path ".gene"))
    ""
    (try
      (read_all content)
      ""
    catch (ParseError ^message message ^line line ^col col)
      $"\nwarning: file does not parse at ${line}:${col}: ${message}"
    catch (ParseError ^message message)
      $"\nwarning: file does not parse: ${message}")))

(fn read_file_lines [content : Str, start_line : Int, max_lines : Int]
  (var lines (split content "\n"))
  (var total lines/~size)
  (if (> start_line total)
    (then {^error $"start_line ${start_line} is beyond the file's ${total} lines"})
    (else
      (var start (- start_line 1))
      (var stop
        (if (< (+ start max_lines) total) (+ start max_lines) total))
      (var selected [])
      (repeat i in total
        (if (&& (>= i start) (< i stop))
          (selected ~ List/push! lines/%i)))
      {^text (join selected "\n")
       ^first start_line ^last stop ^total total})))

(fn read_file_range [content : Str, start_line : Int, max_lines : Int,
                     start_byte : Int, max_bytes : Int] : Str
  (var line_range (read_file_lines content start_line max_lines))
  (if (present? line_range/error)
    (then $"error: ${line_range/error}")
    (else
      (var line_text line_range/text)
      (var total_bytes (byte_size line_text))
      (if (> start_byte total_bytes)
        (then $"error: start_byte ${start_byte} is beyond the selected range's ${total_bytes} bytes")
        (else
          (var chunk (slice_bytes line_text start_byte max_bytes))
          (var end_byte (+ start_byte (byte_size chunk)))
          (if (&& (< start_byte total_bytes) (== end_byte start_byte))
            (then "error: max_bytes is too small to include the next complete UTF-8 character")
            (else
              (var headers [])
              (if (|| (> line_range/first 1)
                      (< line_range/last line_range/total))
                (headers ~ List/push!
                  $"lines ${line_range/first}-${line_range/last} of ${line_range/total}"))
              (if (|| (> start_byte 0) (< end_byte total_bytes))
                (headers ~ List/push!
                  $"bytes ${start_byte}-${end_byte} of ${total_bytes}"))
              (if (empty? headers)
                (then chunk)
                (else
                  (var header_text (join headers "; "))
                  $"[${header_text}; request start_line/max_lines and start_byte/max_bytes for another range]\n${chunk}")))))))))

(type ReadFileToolArgs
  ^props {^path Str ^start_line Int? ^max_lines Int?
          ^start_byte Int? ^max_bytes Int?})
(type WriteFileToolArgs ^props {^path Str ^content Str})
(type EditFileToolArgs ^props {^path Str ^old_text Str ^new_text Str})
(type ListDirToolArgs ^props {^path Str?})
(type RunShellToolArgs ^props {^command Str ^timeout_ms Int?})
(type GrepToolArgs ^props {^pattern Str ^path Str?})

(register_tool! (Tool
  ^name "read_file"
  ^description "Read a bounded line range from a UTF-8 text file inside the workspace."
  ^risk "read"
  ^args ReadFileToolArgs
  ^params [{^name "path" ^doc "workspace-relative file path"}
           {^name "start_line" ^doc "one-based first line; defaults to 1"}
           {^name "max_lines" ^doc "maximum lines selected; defaults to 400, maximum 2000"}
           {^name "start_byte" ^doc "zero-based UTF-8 byte offset within the selected line range; defaults to 0"}
           {^name "max_bytes" ^doc "maximum bytes returned; defaults to 65536, maximum 262144"}]
  ^handler (fn [args]
    (var path (safe_path args/path))
    (var start_line (if (== args/start_line void) 1 args/start_line))
    (var max_lines (if (== args/max_lines void) 400 args/max_lines))
    (var start_byte (if (== args/start_byte void) 0 args/start_byte))
    (var max_bytes (if (== args/max_bytes void) 65536 args/max_bytes))
    (if (< start_line 1)
      "error: start_line must be at least 1"
      (if (|| (< max_lines 1) (> max_lines 2000))
        "error: max_lines must be between 1 and 2000"
        (if (< start_byte 0)
          "error: start_byte must be non-negative"
          (if (|| (< max_bytes 1) (> max_bytes 262144))
            (then "error: max_bytes must be between 1 and 262144")
            (else
              (var instructions (newly_loaded_instruction_text args/path false))
              (var content
                (read_file_range (read_text ReadDir path)
                                 start_line max_lines start_byte max_bytes))
              (if (== instructions "")
                content
                $"New applicable instructions (parent-to-child):\n${instructions}\n--- file ---\n${content}")))))))))

(register_tool! (Tool
  ^name "write_file"
  ^description "Write a UTF-8 text file inside the workspace."
  ^risk "write"
  ^args WriteFileToolArgs
  ^handler (fn [args]
    (var path (safe_path args/path))
    (var instructions (newly_loaded_instruction_text args/path false))
    (if (!= instructions "")
      $"write deferred: apply these newly discovered instructions, then retry:\n${instructions}"
      (if (|| (== args/_approval_checked true)
              (approve? "write_file" args/path))
        (then
          (var before (file_snapshot path))
          (write_text WriteDir path args/content)
          (record_file_change! args/_emit "write" args/path before
            {^exists true ^text args/content})
          $"wrote ${args/path}${(gene_parse_warning args/path args/content)}")
        (else "denied by user policy"))))))

(register_tool! (Tool
  ^name "edit_file"
  ^description "Replace one exact text span in a UTF-8 text file inside the workspace."
  ^risk "write"
  ^args EditFileToolArgs
  ^handler (fn [args]
    (var path (safe_path args/path))
    (var old_text args/old_text)
    (var new_text args/new_text)
    (var instructions (newly_loaded_instruction_text args/path false))
    (if (!= instructions "")
      $"edit deferred: apply these newly discovered instructions, then retry:\n${instructions}"
      (if (== old_text "")
        "error: old_text must not be empty"
        (if (|| (== args/_approval_checked true)
                (approve? "edit_file" args/path))
          (then
            (var text (read_text ReadDir path))
            (var parts (split text old_text))
            (var matches (- parts/~size 1))
            (if (== matches 0)
              $"error: old_text not found\n${(edit_mismatch_hint text old_text)}"
              (if (> matches 1)
                (then $"error: old_text matched ${matches} times; provide a larger unique old_text")
                (else
                  (var after_text (join parts new_text))
                  (write_text WriteDir path after_text)
                  (record_file_change! args/_emit "edit" args/path
                    {^exists true ^text text}
                    {^exists true ^text after_text})
                  $"edited ${args/path}${(gene_parse_warning args/path after_text)}"))))
          (else "denied by user policy")))))))

(register_tool! (Tool
  ^name "list_dir"
  ^description "List directory entries inside the workspace."
  ^risk "read"
  ^args ListDirToolArgs
  ^handler (fn [args]
    (var p (if (== args/path void) "." args/path))
    (var checked_path (safe_path p))
    (var instructions (newly_loaded_instruction_text p true))
    (var listing ((list_dir ReadDir checked_path) ~ join "\n"))
    (if (== instructions "")
      listing
      $"New applicable instructions (parent-to-child):\n${instructions}\n--- listing ---\n${listing}"))))

(register_tool! (Tool
  ^name "run_shell"
  ^description "Run a shell command in the workspace (10s default, 120s maximum timeout)."
  ^risk "execute"
  ^args RunShellToolArgs
  ^handler (fn [args]
    (var timeout_ms
      (if (== args/timeout_ms void) 10000 args/timeout_ms))
    (if (|| (< timeout_ms 1) (> timeout_ms 120000))
      (then "error: timeout_ms must be between 1 and 120000")
      (else
        (var context args/_context)
        (var denial
          (if_not (== args/_guard_checked true)
            (guard_shell_in args/command
              (if (present? context) context/guard_confirm)
              args/_emit)))
        (if (present? denial)
          denial
          (if (|| (== args/_approval_checked true)
                  (approve? "run_shell" args/command))
            (then
              (var r (run_checked_exec args/_emit "run_shell" args/command
                       (exec_async Exec ^cmd "sh" ^args ["-c" args/command]
                                   ^dir workspace_root
                                   ^timeout_ms timeout_ms ^max_bytes 65536)))
              (var tail
                (if r/timed_out
                  $"\n[timed out after ${r/duration_ms} ms; requested cap ${timeout_ms} ms. Retry with timeout_ms up to 120000 only when the command is expected to be slow.]"
                  ""))
              (var timing
                $"\n[execution: duration_ms=${r/duration_ms} timeout_ms=${timeout_ms} timed_out=${r/timed_out}]")
              {^text $"${r/stdout}${r/stderr}${tail}${timing}"
               ^truncated (== r/truncated true)})
            (else "denied by user policy"))))))))

(register_tool! (Tool
  ^name "grep"
  ^description "Search files in the workspace with grep -rn."
  ^risk "read"
  ^args GrepToolArgs
  ^handler (fn [args]
    (var p (if (== args/path void) "." args/path))
    (var checked_path (safe_path p))
    (var command $"grep -rn ${args/pattern} ${p}")
    (var r (run_checked_exec args/_emit "grep" command
             (exec_async Exec ^cmd "grep"
                         ^args ["-rn" args/pattern checked_path]
                         ^dir workspace_root
                         ^timeout_ms 10000 ^max_bytes 65536)))
    (var tail (if r/timed_out "\n[timed out]" ""))
    {^text $"${r/stdout}${r/stderr}${tail}"
     ^truncated (== r/truncated true)})))

# -----------------------------------------------------------------------------
# Responses-API item helpers.
# -----------------------------------------------------------------------------

(fn user_item [text : Str]
  {^role "user" ^content (redact text)})

(fn system_item [text : Str]
  {^role "system" ^content text})

(var gene_system_prompt """
You are a coding agent working in the Gene language repository. You can read,
write, and edit files, list directories, grep, and run shell commands after user
approval.

When writing Gene code, use the current repo's language, not generic Lisp:

- Programs are s-expressions. Calls are callable-first: `(f x y)`.
- Top-level forms run in order. `gene run file.gene` calls `(fn main [...])` if
  present; scripts may also do work at top level.
- Comments start with `#`. Modules may start with `(mod name @doc "...")`.
- Imports use namespace/module forms:
  `(import str [join split trim lower])`
  `(import std/stream [to_stream map filter each into])`
  `(import [foo : local] from "./module")`
- Bind with `(var name value)` or `(var name : Type value)`. Reassign existing
  bindings with `(set name value)`. Avoid redeclaring the same local name in a
  loop or branch; allocate mutable loop state once and update it.
- Functions use `(fn name [a : Type, b] : Return body...)`; anonymous functions
  use `(fn [x] body)`. The last expression is returned.
- `false`, `nil`, and `void` are falsy; every other value is truthy. Prefer
  truthiness over separate `nil`/`void` tests when all falsy values mean the
  same thing.
- Use compact `(if cond value)` when the false result is `nil`; do not write an
  explicit trailing `nil`. Use `(if_not cond value)` for a false-only branch.
  Guards with multiple expressions use `(if_yes cond body...)` or
  `(if_not cond body...)`. Full branches use `(if cond (then body...)
  (elif other body...) (else body...))`, without `do` wrappers.
- Other control forms include `(do ...)`, `(while cond ...)`, `(loop ...)`,
  `(repeat n ...)`, `(repeat i in n ...)`, `(for item in items ...)`, and
  `match` with `(when pattern ...)` and `(else ...)`. Boolean operators are
  `(&& a b ...)`, `(|| a b ...)`, and `(! a)`.
- Recoverable errors use `(try body... catch (ErrorType ^field name)
  recovery... ensure cleanup...)`; each section accepts multiple expressions
  directly. Use `fail` for recoverable errors and `panic` only for fatal bugs.
- Data:
  - Lists: `[a b c]`
    Grow a fresh, locally owned list with `(xs ~ List/push! value)`, which is
    amortized O(1). Repeated copy-and-append inside a loop is quadratic;
    reserve persistent copy updates for intentionally shared data.
  - Maps: `{^key value}`; property access is `m/key`
  - Nodes: `(tag ^prop value child...)`; quasiquote nodes with backtick and
    unquote with `%`, for example `` `(p ^class "x" %text)``.
  - `nil` is absence, `void` means missing selector/omitted storage.
- Selectors and sends:
  - `x/key` is selector/property/index access.
  - `xs/~size` sends the `size` message to `xs`; prefer this over `size xs`
    when modeling receiver behavior.
  - `(x ~ msg arg)` sends a message; `(x ~ Protocol/msg)` disambiguates protocol
    message collisions.
  - Type-direct messages live inside `type`; protocol messages live inside
    `protocol` and are implemented with `impl`.
- Types/protocols:
  `(type T ^props {^name Str} (message label [self] self/name))`
  `(enum Color red green blue)` and `(enum Result (ok Any) (err Str))`
  `(protocol P (message render [self : Self] : Str))`
  `(impl P for T (message render [self] "..."))`
  Single data inheritance is `^is`; behavioral composition is `^inherit`.
- Streams are pull-based and skip `void`. Common shape:
  `((to_stream xs) ~ map (fn [x] ...) ; ~ filter pred ; ~ into [])`.
- Useful stdlib examples:
  - `examples/todo_app.gene` for end-to-end web + sqlite.
  - `examples/web_demo.gene` for nodes, streams, routes, selectors.
  - `examples/protocol_demo.gene` for types, protocols, inheritance, messages.
  - `docs/design.md`, `docs/core.md`, and `docs/stdlib.md` for details.

Before changing Gene code, inspect nearby examples or docs if uncertain. After
writing Gene code, verify with at least `bin/gene parse file.gene` or
`bin/gene compile file.gene`; use `bin/gene run file.gene` when behavior matters.
Only claim verification that a successful command result directly supports.
State that broader behavior is unverified when no matching successful check ran.
""")

(var root_instruction_text
  (format_instruction_records (effective_agent_instructions ".")))
(if (!= root_instruction_text "")
  (set gene_system_prompt
    $"${gene_system_prompt}\n\nWorkspace instructions (root scope):\n${root_instruction_text}"))

(fn approximate_bytes [value] : Int
  (match value
    (when (text : Str)
      (+ (byte_size text) 2))
    (when (entries : Map)
      (var total (cell 2))
      (for [key item] in entries
        (var key_text $"${key}")
        (total ~ Cell/set
          (+ (total ~ Cell/get)
             (byte_size key_text) 3 (approximate_bytes item))))
      (total ~ Cell/get))
    (when (values : List)
      (var total (cell 2))
      (for item in values
        (total ~ Cell/set
          (+ (total ~ Cell/get) 1 (approximate_bytes item))))
      (total ~ Cell/get))
    (else
      (var text $"${value}")
      (byte_size text))))

(fn approximate_tokens [byte_count : Int] : Int
  (/ (+ byte_count 3) 4))

(fn context_turns [items]
  (var turns (cell []))
  (var current (cell []))
  (for item in items
    (if_not (== item/role "system")
      (if (== item/role "user")
        (then
          (if (! (empty? (current ~ Cell/get)))
            ((turns ~ Cell/get) ~ List/push! (current ~ Cell/get)))
          (current ~ Cell/set [item]))
        (else ((current ~ Cell/get) ~ List/push! item)))))
  (if (! (empty? (current ~ Cell/get)))
    ((turns ~ Cell/get) ~ List/push! (current ~ Cell/get)))
  (turns ~ Cell/get))

(fn context_system_items [items]
  (var systems (cell []))
  (for item in items
    (if (&& (== item/role "system")
            (!= item/context_summary true)
            (!= item/context_limit_warning true))
      ((systems ~ Cell/get) ~ List/push! item)))
  (systems ~ Cell/get))

(fn has_context_limit_warning [items] : Bool
  (var found (cell false))
  (for item in items
    (if (== item/context_limit_warning true)
      (found ~ Cell/set true)))
  (found ~ Cell/get))

(fn without_context_limit_warning [items]
  (var out [])
  (for item in items
    (if (!= item/context_limit_warning true)
      (out ~ List/push! item)))
  out)

(fn context_stats [items, memory]
  (var bytes (approximate_bytes items))
  {^bytes bytes
   ^approx_tokens (approximate_tokens bytes)
   ^items (items ~ size)
   ^retained_turns ((context_turns items) ~ size)
   ^memory_items (memory ~ size)
   ^memory_bytes (approximate_bytes memory)
   ^max_bytes context_max_bytes
   ^max_items context_max_items
   ^keep_turns context_keep_turns
   ^over_limit (|| (> bytes context_max_bytes)
                    (> (items ~ size) context_max_items))})

# Reduce oversized retained context without splitting a function_call from its
# function_call_output. Only the output text is replaced; ids and item order
# remain intact. Work oldest-first so the newest tool evidence survives when
# older output is enough to get below the byte ceiling.
(fn elide_old_tool_outputs [items]
  (var remaining_bytes (cell (approximate_bytes items)))
  (var elided_count (cell 0))
  (var elided_bytes (cell 0))
  (var out (cell []))
  (for item in items
    (var replacement item)
    (if_yes (&& (> (remaining_bytes ~ Cell/get) context_max_bytes)
                (== item/type "function_call_output")
                (match item/output (when (s : Str) true) (else false)))
      (var old_bytes (approximate_bytes item))
      (var output_bytes (byte_size item/output))
      (var marker
        $"[tool output omitted during context compaction: ${output_bytes} bytes; rerun the tool with a narrower request if supported and the content is still needed]")
      (var candidate {})
      (for [key value] in item
        (candidate ~ Map/put! key value))
      (candidate ~ Map/put! "output" marker)
      (var new_bytes (approximate_bytes candidate))
      (if_yes (< new_bytes old_bytes)
        (set replacement candidate)
        (remaining_bytes ~ Cell/set
          (- (remaining_bytes ~ Cell/get) (- old_bytes new_bytes)))
        (elided_count ~ Cell/set (+ (elided_count ~ Cell/get) 1))
        (elided_bytes ~ Cell/set
          (+ (elided_bytes ~ Cell/get) (- old_bytes new_bytes)))))
    ((out ~ Cell/get) ~ List/push! replacement))
  {^items (out ~ Cell/get)
   ^outputs (elided_count ~ Cell/get)
   ^bytes (elided_bytes ~ Cell/get)})

(fn compact_context [items, emit]
  (var before (context_stats items []))
  (debug! context_log "context evaluated"
    ^payload {^bytes before/bytes ^items before/items
              ^retained_turns before/retained_turns
              ^over_limit (== before/over_limit true)})
  (if (!= before/over_limit true)
    (then
      (if (has_context_limit_warning items)
        (without_context_limit_warning items)
        items))
    (else
      (var had_limit_warning (has_context_limit_warning items))
      (var turns (context_turns items))
      (var turn_count (turns ~ size))
      (var start
        (if (> turn_count context_keep_turns)
          (- turn_count context_keep_turns)
          0))
      (var compacted (cell (context_system_items items)))
      (if (> start 0)
        (compacted ~ Cell/set
          (append (compacted ~ Cell/get)
            {^role "system" ^^context_summary
             ^content $"Context compacted: ${start} older turns were removed. Persistent memory, explicit remembered decisions, and workspace instructions remain in the preceding system content."})))
      (repeat i in turn_count
        (if (>= i start)
          (compacted ~ Cell/set
            (append_all (compacted ~ Cell/get) turns/%i))))
      (var elided (elide_old_tool_outputs (compacted ~ Cell/get)))
      (var result elided/items)
      (var after (context_stats result []))
      (var irreducible (== after/over_limit true))
      # Count only source items actually removed. The explanatory warning item
      # below is new context, not a negative removal.
      (var source_items
        (if had_limit_warning (- before/items 1) before/items))
      (var removed_items (- source_items after/items))
      (if_yes irreducible
          (set result
            (append result
              {^role "system" ^^context_limit_warning
               ^content "Context remains above its configured floor after whole-turn compaction and tool-output elision. Irreducible system/user content was preserved; use narrower tool reads or start a fresh session if more room is required."}))
          (set after (context_stats result []))
          (if_not had_limit_warning
              (warn! context_log "context remains over configured limit"
                ^payload {^bytes after/bytes ^items after/items
                          ^max_bytes context_max_bytes
                          ^max_items context_max_items})
              (emit "context_limit_warning"
                {^bytes after/bytes ^items after/items
                 ^max_bytes context_max_bytes ^max_items context_max_items
                 ^irreducible_over_limit true})))
      (if_yes (|| (> removed_items 0)
                  (> elided/outputs 0))
          (info! context_log "context compacted"
            ^payload {^bytes_before before/bytes ^bytes_after after/bytes
                      ^items_before before/items ^items_after after/items
                      ^removed_items removed_items ^removed_turns start
                      ^elided_tool_outputs elided/outputs
                      ^elided_output_bytes elided/bytes
                      ^irreducible_over_limit irreducible})
          (emit "context_compacted"
            {^bytes_before before/bytes
             ^bytes_after after/bytes
             ^items_before before/items
             ^items_after after/items
             ^removed_items removed_items
             ^removed_turns start
             ^retained_turns after/retained_turns
             ^elided_tool_outputs elided/outputs
             ^elided_output_bytes elided/bytes
             ^irreducible_over_limit irreducible
             ^over_limit after/over_limit}))
      result)))

(enum ResponseItemKind
  assistant_message
  function_call
  other_item)

(enum ResponseContentKind
  output_text
  other_content)

(enum SseEventKind
  output_text_delta
  output_item_done
  output_text_done
  completed
  failed
  incomplete
  other_event)

(fn response_item_kind [item] : ResponseItemKind
  (match item/type
    (when "message"       ResponseItemKind/assistant_message)
    (when "function_call" ResponseItemKind/function_call)
    (else                ResponseItemKind/other_item)))

(fn response_content_kind [part] : ResponseContentKind
  (match part/type
    (when "output_text" ResponseContentKind/output_text)
    (else              ResponseContentKind/other_content)))

(fn sse_event_kind [event] : SseEventKind
  (match event/type
    (when "response.output_text.delta" SseEventKind/output_text_delta)
    (when "response.output_item.done"  SseEventKind/output_item_done)
    (when "response.output_text.done"  SseEventKind/output_text_done)
    (when "response.completed"         SseEventKind/completed)
    (when "response.failed"            SseEventKind/failed)
    (when "response.incomplete"        SseEventKind/incomplete)
    (else                              SseEventKind/other_event)))

# Pull the assistant's text out of a Responses `output` list (message items ->
# content parts of type output_text).
(fn response_output_items [resp]
  (if (== resp/output void)
    []
    (try
      ((to_stream resp/output) ~ into [])
    catch _ [])))

# Joined output_text parts of one assistant message item.
(fn message_item_text [item] : Str
  (var acc (cell ""))
  ((to_stream item/content)
    ~ each (fn [part]
        (if (== (response_content_kind part) ResponseContentKind/output_text)
          (Cell/set acc $"${(Cell/get acc)}${part/text}"))))
  (Cell/get acc))

(fn response_text [resp] : Str
  (if (!= resp/output_text void)
    (then resp/output_text)
    (else
      (var acc (cell ""))
      ((to_stream (response_output_items resp))
        ~ each (fn [item]
            (if (== (response_item_kind item) ResponseItemKind/assistant_message)
              (Cell/set acc $"${(Cell/get acc)}${(message_item_text item)}"))))
      (Cell/get acc))))

# function_call items the model emitted this turn.
(fn response_calls [resp]
  ((to_stream (response_output_items resp))
    ~ filter (fn [item] (== (response_item_kind item) ResponseItemKind/function_call))
    ; ~ into []))

# Handlers may return a plain Str or {^text Str ^truncated Bool}; normalize to
# the map shape so truncation always reaches the event log and the model. Any
# other shape (nil, a number, a map without a Str ^text — easy to produce from
# a /repl-registered tool) becomes a tool error instead of escaping into
# redact/selectors and aborting the turn.
(fn normalize_tool_result [res]
  (match res
    (when (s : Str) {^text s ^truncated false})
    (when (m : Map)
      (match m/text
        (when (t : Str) {^text t ^truncated (== m/truncated true)})
        (else {^text "error: tool returned an invalid result shape"
               ^truncated false})))
    (else {^text "error: tool returned an invalid result shape"
           ^truncated false})))

(fn tool_mutates_workspace? [name : Str]
  (["write_file" "edit_file" "run_shell"] ~ contains? name))

(fn tool_context_agent_id [context]
  (if (&& (present? context) (present? context/agent))
    context/agent/id))

(fn mutation_digest [name : Str, args]
  (match name
    (when "write_file"
      (hash $"write_file\n${args/path}\n${(hash args/content)}"))
    (when "edit_file"
      (hash $"edit_file\n${args/path}\n${(hash args/old_text)}\n${(hash args/new_text)}"))
    (when "run_shell"
      (hash $"run_shell\n${args/command}\n${args/timeout_ms}"))
    (else (hash name))))

(fn mutation_target_real [name : Str, args]
  (if (["write_file" "edit_file"] ~ contains? name)
    (confined_real_path args/path)))

(fn preflight_tool_mutation [name : Str, args, context]
  (if_not (! (tool_mutates_workspace? name))
    (var denial
      (if (== name "run_shell")
        (guard_shell_in args/command
          (if (present? context) context/guard_confirm)
          args/_emit)))
    (if (present? denial)
      (then denial)
      (else
        (var detail
          (if (== name "run_shell") args/command args/path))
        # A destructive command already received the guard's one explicit
        # confirmation. The legacy prompt-all layer must not ask for the
        # same operation a second time; normal commands and file mutations
        # still honor APPROVE_ALL=0.
        (var guard_confirmed_destructive
          (&& (== name "run_shell") (guard_enabled?)
              (== (classify_command args/command) "destructive")))
        (if (&& (! guard_confirmed_destructive)
                (! (approve? name detail)))
          (then "denied by user policy")
          (else
            (args ~ Map/put! "_guard_checked" true)
            (args ~ Map/put! "_approval_checked" true)
            (args ~ Map/put! "_mutation_digest"
              (mutation_digest name args))
            (args ~ Map/put! "_target_real"
              (mutation_target_real name args))
            nil))))))

(fn mutation_preflight_valid? [name : Str, args] : Bool
  (&& (== args/_mutation_digest (mutation_digest name args))
      (if (["write_file" "edit_file"] ~ contains? name)
        (== args/_target_real (mutation_target_real name args))
        true)))

(fn invoke_tool_handler [tool, name : Str, args, context]
  (var handler tool/handler)
  (var app (if (present? context) context/app))
  (var agent_id (tool_context_agent_id context))
  (var denial (preflight_tool_mutation name args context))
  (if (present? denial)
    denial
    (if (&& (tool_mutates_workspace? name)
            (present? app) (present? agent_id))
      (if (application_acquire_workspace app agent_id name)
        (try
          (if (mutation_preflight_valid? name args)
            (handler args)
            "error: mutation target changed while waiting for the workspace lease; retry")
        ensure
          (application_release_workspace app agent_id name))
        "error: application is shutting down")
      (handler args))))

# Execute one function_call item, returning its function_call_output item.
# `emit` is the event sink (§9.2): the CLI passes its process-global logger,
# the gateway passes a per-session sink, so each session owns its own tool
# trail. The declared param schema validates arguments before the handler runs.
(fn run_tool_call_in [call, emit, context]
  (var started (monotonic_ms))
  (var name call/name)
  (var t (find_tool name))
  (var args (cell nil))
  (var parse_err (cell nil))
  (try
    (args ~ Cell/set (parse call/arguments))
  catch (JsonError ^message m) (parse_err ~ Cell/set m))
  (var call_props
    {^id call/call_id ^name name
     ^args (if (present? (parse_err ~ Cell/get))
             call/arguments
             (args ~ Cell/get))})
  (var context_agent_id (tool_context_agent_id context))
  (if (present? context_agent_id)
    (call_props ~ Map/put! "agent_id" context_agent_id))
  (emit "tool_call" call_props)
  (info! tool_log "tool call started"
    ^payload {^tool_name name ^call_id call/call_id
              ^known_tool (!= t void)
              ^risk (if (== t void) "unknown" t/risk)})
  # The guard (called inside handlers) emits confirmation events through this
  # turn's sink. Set synchronously here and cleared after the handler: the
  # guard runs before the handler's first await, so interleaved sessions
  # cannot observe each other's sink.
  (guard_emit ~ Cell/set emit)
  (var result
    (if (== t void)
      {^text $"error: unknown tool ${name}" ^truncated false}
      (if (== t/enabled false)
        {^text $"error: tool ${name} is disabled; its handler is not available at the saved version"
         ^truncated false}
      (if (present? (parse_err ~ Cell/get))
        {^text $"error: bad tool arguments: ${(parse_err ~ Cell/get)}"
         ^truncated false}
        # The model may send valid JSON that is not an object ([], null, "x").
        # Check the top-level kind before field validation, which sends Map/get
        # to the value, so a malformed response is a tool error, not a crash.
        (match (args ~ Cell/get)
          (when (m : Map)
            (var verr (t ~ validate_args m))
            (if (present? verr)
              (then {^text $"error: ${verr}" ^truncated false})
              (else
                # Internal per-turn context is added only after model-arg
                # validation, so it is neither schema-visible nor accepted
                # from the wire. Async handlers use this explicit sink
                # instead of a process-global callback (gateway sessions
                # may interleave while a subprocess is awaited).
                (m ~ Map/put! "_emit" emit)
                (m ~ Map/put! "_context" context)
                (try
                  (normalize_tool_result
                    (invoke_tool_handler t name m context))
                catch (OsError ^message em)
                  {^text $"error: ${em}" ^truncated false}
                catch {^message em}
                  {^text $"error: ${em}" ^truncated false}
                catch _
                  {^text "error: tool failed" ^truncated false}))))
          (else
            {^text "error: tool arguments must be a JSON object" ^truncated false}))))))
  (guard_emit ~ Cell/set nil)
  (var truncated (== result/truncated true))
  # Surface truncation in both the transcript and the model-visible output
  # (§8.5), and redact before the output re-enters the model transcript: a
  # tool like run_shell can echo the environment, and the raw API token must
  # never leak back into the next request.
  (var shown
    (if truncated $"${result/text}\n[output truncated]" result/text))
  (var tool_failed (starts_with? result/text "error:"))
  (if tool_failed
    (warn! tool_log "tool call completed with error"
      ^payload {^tool_name name ^call_id call/call_id
                ^duration_ms (- (monotonic_ms) started)
                ^output_bytes (byte_size shown) ^truncated truncated})
    (info! tool_log "tool call completed"
      ^payload {^tool_name name ^call_id call/call_id
                ^duration_ms (- (monotonic_ms) started)
                ^output_bytes (byte_size shown) ^truncated truncated}))
  (var result_props
    {^id call/call_id ^name name ^value shown ^truncated truncated})
  (if (present? context_agent_id)
    (result_props ~ Map/put! "agent_id" context_agent_id))
  (emit "tool_result" result_props)
  {^type "function_call_output" ^call_id call/call_id ^output (redact shown)})

(fn run_tool_call [call, emit]
  (run_tool_call_in call emit nil))

# -----------------------------------------------------------------------------
# Transport. Live mode uses the native libcurl-backed net/http_client; curl(1)
# remains a packaging bootstrap only when libcurl cannot be loaded. Both paths
# run off the scheduler and present complete lines to the SSE parser.
# -----------------------------------------------------------------------------

(fn exec_curl_lines [curl_args, timeout_ms, on_line]
  (var ch (channel ^capacity 256))
  (var t (exec_stream_async Exec ^cmd "curl" ^args curl_args
                            ^timeout_ms timeout_ms ^max_bytes 4000000
                            ^stdout_chan ch))
  (var line nil)
  (try
    (try
      (loop
        (set line (ch ~ Channel/recv))
        (on_line line))
    catch (ChannelClosed) nil)
    (await t)
  ensure
    (t ~ Task/cancel)))

(fn feed_http_chunk [pending, chunk : Str, on_line]
  (var parts (split $"${(pending ~ Cell/get)}${chunk}" "\n"))
  (var count (parts ~ size))
  (var last (- count 1))
  (if (> count 1)
    (repeat i in last
      (if (ends_with? parts/%i "\r")
        (on_line ((split parts/%i "\r")/%0))
        (on_line parts/%i))))
  (pending ~ Cell/set parts/%last))

(fn exec_native_http_lines [url, headers, body, timeout_ms, on_line]
  (var transfer
    (stream Http ^method "POST" ^url url ^headers headers ^body body
                 ^timeout_ms timeout_ms ^max_bytes 4000000
                 ^channel_capacity 256 ^max_pending_bytes 1000000))
  (var pending (cell ""))
  (try
    (try
      (loop
        (feed_http_chunk pending (transfer/channel ~ Channel/recv) on_line))
    catch (ChannelClosed) nil)
    (if (!= (pending ~ Cell/get) "")
      (on_line (pending ~ Cell/get)))
    (var response (await transfer/task))
    {^status 0 ^stdout response/body ^stderr ""
     ^http_status response/status ^truncated response/truncated}
  ensure
    (transfer/task ~ Task/cancel)))

(fn exec_http_lines [url, headers, body, curl_args, timeout_ms, on_line]
  (var started (monotonic_ms))
  (try
    (var native_result
      (exec_native_http_lines url headers body timeout_ms on_line))
    (debug! transport_log "HTTP request completed"
      ^payload {^backend "native" ^status native_result/status
                ^http_status native_result/http_status
                ^duration_ms (- (monotonic_ms) started)
                ^response_bytes (byte_size native_result/stdout)
                ^truncated (== native_result/truncated true)})
    native_result
  catch (HttpClientError ^kind "unavailable")
    (warn! transport_log "native HTTP unavailable; using curl fallback"
      ^payload {^backend "curl"})
    (var curl_result (exec_curl_lines curl_args timeout_ms on_line))
    (debug! transport_log "HTTP request completed"
      ^payload {^backend "curl" ^status curl_result/status
                ^duration_ms (- (monotonic_ms) started)
                ^response_bytes (byte_size curl_result/stdout)
                ^truncated (== curl_result/truncated true)})
    curl_result))

(fn api_error_text [resp]
  (var status (if (== resp/status void) "?" resp/status))
  (var message
    (if (== resp/error/message void)
      (if (== resp/detail void) "unknown API error" resp/detail)
      resp/error/message))
  (var code (if (== resp/error/code void) "" $" (${resp/error/code})"))
  $"OpenAI API error ${status}: ${message}${code}")

# Native HTTP distinguishes transport success from HTTP success: a completed
# request has ^status 0 even when the server answered 4xx/5xx. Normalize those
# responses before either wire decoder sees them, otherwise a short JSON error
# body can look like a successful response with no assistant output.
(fn http_status_error_text [result]
  (var status result/http_status)
  (if_not (|| (== status void)
          (&& (>= status 200) (< status 300)))
    (try
      (var body (parse result/stdout))
      (var message
        (if (present? body/error/message)
          body/error/message
          (if (present? body/detail)
            body/detail
            "request failed")))
      (redact $"OpenAI API error ${status}: ${message}")
    catch (JsonError ^message _)
      $"OpenAI API error ${status}: request failed")))

# Strip one leading "data: " prefix. Rejoin the remaining pieces so a payload
# that itself contains "data: " (e.g. a streamed code snippet) survives intact.
(fn sse_data_payload [line : Str]
  (if_yes (starts_with? line "data: ")
    (var parts (split line "data: "))
    (var i (cell 0))
    (var acc (cell ""))
    ((to_stream parts)
      ~ each (fn [p]
          (var n (Cell/get i))
          (Cell/set i (+ n 1))
          (if_not (== n 0)
            (if (== n 1)
              (Cell/set acc p)
              (Cell/set acc $"${(Cell/get acc)}data: ${p}")))))
    (Cell/get acc)))

(fn ignore_stream_delta [text]
  nil)

(fn sse_build_response [output, output_text, final]
  (if (== (Cell/get final) nil)
    (then {^output (Cell/get output) ^output_text (Cell/get output_text)})
    (else
      ((Cell/get final) ~ Map/put! "output" (Cell/get output))
      ((Cell/get final) ~ Map/put! "output_text" (Cell/get output_text))
      (Cell/get final))))

(fn sse_handle_payload [payload : Str, output, output_text, final, render_stream]
  (if_not (== payload "[DONE]")
    (try
      (var event (parse payload))
      (match (sse_event_kind event)
        (when SseEventKind/output_text_delta
          (render_stream (redact event/delta))
          (Cell/set output_text $"${(Cell/get output_text)}${event/delta}"))
        (when SseEventKind/output_item_done
          ((Cell/get output) ~ List/push! event/item)
          nil)
        (when SseEventKind/output_text_done
          (Cell/set output_text event/text))
        (when SseEventKind/completed
          (Cell/set final event/response))
        (when SseEventKind/failed
          (Cell/set final event/response))
        (when SseEventKind/incomplete
          (Cell/set final event/response))
        (when SseEventKind/other_event
          nil))
    catch (JsonError ^message _) nil)))

(fn sse_handle_line [line : Str, output, output_text, final, render_stream]
  (var payload (sse_data_payload line))
  (if payload
    (sse_handle_payload payload output output_text final render_stream)))

(fn sse_response [raw : Str]
  (var output (cell []))
  (var output_text (cell ""))
  (var final (cell nil))
  ((to_stream (split raw "\n"))
    ~ each (fn [line]
        (sse_handle_line line output output_text final ignore_stream_delta)))
  (sse_build_response output output_text final))

(fn responses_live_transport [body : Str, render_stream]
  (var output (cell []))
  (var output_text (cell ""))
  (var final (cell nil))
  (var saw_sse (cell false))
  (var request_headers
    [$"Authorization: Bearer ${auth_token}"
     "Content-Type: application/json"
     "Accept: text/event-stream"])
  (var curl_args ["-sS" "-N" "-X" "POST" $"${base}/responses"
                  "-H" $"Authorization: Bearer ${auth_token}"
                  "-H" "Content-Type: application/json"
                  "-H" "Accept: text/event-stream"])
  (if_yes (== base codex_base)
      (set request_headers (append_all request_headers
        ["User-Agent: codex_cli_rs/0.0.0 (Gene AI Agent)"
         "originator: codex_cli_rs"]))
      (set curl_args (append_all curl_args
        ["-H" "User-Agent: codex_cli_rs/0.0.0 (Gene AI Agent)"
         "-H" "originator: codex_cli_rs"])))
  (set curl_args (append_all curl_args ["-d" body]))
  (var r (exec_http_lines $"${base}/responses" request_headers body
               curl_args 60000
               (fn [line]
                 (if (|| (starts_with? line "event:")
                         (starts_with? line "data:"))
                   (Cell/set saw_sse true))
                 (sse_handle_line line output output_text final render_stream))))
  (if (!= r/status 0)
    (then {^agent_error (redact $"HTTP transport failed (${r/status}): ${r/stderr}")})
    (else
      (var http_error (http_status_error_text r))
      (if (present? http_error)
        (then {^agent_error http_error})
        (else
          (var resp
            (if (Cell/get saw_sse)
              (sse_build_response output output_text final)
              (try
                (parse r/stdout)
              catch (JsonError ^message m)
                {^agent_error (redact $"OpenAI API returned invalid JSON: ${m}")})))
          (if (== resp/error void)
            (if (== resp/status "failed")
              {^agent_error (redact (api_error_text resp))}
              resp)
            (if (== resp/error nil)
              (if (== resp/status "failed")
                {^agent_error (redact (api_error_text resp))}
                resp)
              {^agent_error (redact (api_error_text resp))})))))))

# -----------------------------------------------------------------------------
# Chat Completions wire shape, for OpenAI-compatible endpoints (MiniMax,
# DeepSeek, vLLM, api.openai.com, ...). Internally the agent still works on
# Responses-style items; this layer converts on the way out (items -> messages)
# and normalizes on the way in (choices/deltas -> items), so run_turn and the
# tool loop are shared between both flavors.
# -----------------------------------------------------------------------------

# Convert the item transcript into chat messages. A run of assistant text /
# function_call items becomes ONE assistant message (content + tool_calls), so
# every role:"tool" message follows the assistant message that requested it —
# the ordering chat endpoints validate.
(fn items_to_chat_messages [items]
  (var msgs (cell []))
  (var pending_text (cell nil))
  (var pending_calls (cell []))
  (fn flush_assistant []
    (if_yes (|| (present? (Cell/get pending_text))
                (! (empty? (Cell/get pending_calls))))
        (var m {^role "assistant" ^content (Cell/get pending_text)})
        (if_not (empty? (Cell/get pending_calls))
          (m ~ Map/put! "tool_calls" (Cell/get pending_calls)))
        ((Cell/get msgs) ~ List/push! m)
        (Cell/set pending_text nil)
        (Cell/set pending_calls [])))
  (for item in items
    (if (== item/type void)
      (then
        (flush_assistant)
        ((Cell/get msgs) ~ List/push! item))
      (else
        (match item/type
        (when "message"
          (var sofar (if (present? (Cell/get pending_text)) (Cell/get pending_text) ""))
          (Cell/set pending_text $"${sofar}${(message_item_text item)}"))
        (when "function_call"
          ((Cell/get pending_calls) ~ List/push!
            {^id item/call_id ^type "function"
             ^function {^name item/name ^arguments item/arguments}}))
        (when "function_call_output"
          (flush_assistant)
          ((Cell/get msgs) ~ List/push!
            {^role "tool" ^tool_call_id item/call_id ^content item/output}))
        (else nil)))))
  (flush_assistant)
  (Cell/get msgs))

(fn chat_api_error [resp]
  (if (present? resp/error)
    (api_error_text resp)
    # MiniMax-style envelope: base_resp/status_code != 0 signals an error.
    (if (&& (present? resp/base_resp/status_code)
            (!= resp/base_resp/status_code 0))
      $"API error ${resp/base_resp/status_code}: ${resp/base_resp/status_msg}")))

# Streamed tool calls arrive as fragments keyed by ^index: the first carries
# id/name, the rest append argument text. Accumulate into mutable maps.
(fn chat_note_call_frag [calls_map, max_cell, frag]
  (var idx (if (present? frag/index) frag/index 0))
  (var key $"${idx}")
  (var entry (calls_map ~ Map/get key))
  (if_yes (== entry void)
      (set entry {^id "" ^name "" ^arguments ""})
      (calls_map ~ Map/put! key entry)
      (if (< (Cell/get max_cell) (+ idx 1))
        (Cell/set max_cell (+ idx 1))))
  (if (present? frag/id)
    (entry ~ Map/put! "id" frag/id))
  (if (present? frag/function/name)
    (entry ~ Map/put! "name" $"${entry/name}${frag/function/name}"))
  (if (present? frag/function/arguments)
    (entry ~ Map/put! "arguments" $"${entry/arguments}${frag/function/arguments}")))

(fn chat_call_items [calls_map, max_cell]
  (var items (cell []))
  (var entry nil)
  (repeat i in (Cell/get max_cell)
    (set entry (calls_map ~ Map/get $"${i}"))
    (if_not (== entry void)
      ((Cell/get items) ~ List/push!
        {^type "function_call" ^name entry/name
         ^call_id entry/id ^arguments entry/arguments})))
  (Cell/get items))

(fn chat_build_response [text_cell, calls_map, max_cell]
  (var items (cell (chat_call_items calls_map max_cell)))
  (if_not (== (Cell/get text_cell) "")
    (Cell/set items
      ((to_stream (Cell/get items))
        ~ into [{^type "message" ^role "assistant"
                 ^content [{^type "output_text" ^text (Cell/get text_cell)}]}])))
  {^output (Cell/get items) ^output_text (Cell/get text_cell)})

(fn chat_handle_payload [payload : Str, text_cell, calls_map, max_cell, err_cell, render_stream]
  (if_not (== payload "[DONE]")
    (try
      (var chunk (parse payload))
      (var errtext (chat_api_error chunk))
      (if (present? errtext)
        (then (Cell/set err_cell errtext))
        (else
          (var delta chunk/choices/0/delta)
          (if_yes (present? delta/content)
              (render_stream (redact delta/content))
              (Cell/set text_cell $"${(Cell/get text_cell)}${delta/content}"))
          (if (present? delta/tool_calls)
            ((to_stream delta/tool_calls)
              ~ each (fn [frag] (chat_note_call_frag calls_map max_cell frag))))))
    catch (JsonError ^message _) nil)))

# Non-streaming (or error) chat body: normalize choices/0/message into items.
(fn chat_response_from_json [resp]
  (var errtext (chat_api_error resp))
  (if (present? errtext)
    (then {^agent_error (redact errtext)})
    (else
      (var message resp/choices/0/message)
      (var text (if (present? message/content) message/content ""))
      (var items (cell []))
      (if_not (== text "")
        ((Cell/get items) ~ List/push!
          {^type "message" ^role "assistant"
           ^content [{^type "output_text" ^text text}]}))
      (if (present? message/tool_calls)
        ((to_stream message/tool_calls)
          ~ each (fn [tc]
              ((Cell/get items) ~ List/push!
                {^type "function_call" ^name tc/function/name
                 ^call_id tc/id ^arguments tc/function/arguments}))))
      {^output (Cell/get items) ^output_text text})))

(fn chat_live_transport [body : Str, render_stream]
  (var text (cell ""))
  (var calls {})
  (var callmax (cell 0))
  (var err (cell nil))
  (var saw_sse (cell false))
  (var chat_headers
    [$"Authorization: Bearer ${auth_token}"
     "Content-Type: application/json"
     "Accept: text/event-stream"])
  (var curl_args
               ["-sS" "-N" "-X" "POST" $"${base}/chat/completions"
                "-H" $"Authorization: Bearer ${auth_token}"
                "-H" "Content-Type: application/json"
                "-H" "Accept: text/event-stream"
                "-d" body])
  (var r (exec_http_lines $"${base}/chat/completions" chat_headers body
               curl_args 120000
               (fn [line]
                 (if (|| (starts_with? line "event:")
                         (starts_with? line "data:"))
                   (Cell/set saw_sse true))
                 (var payload (sse_data_payload line))
                 (if payload
                   (chat_handle_payload payload text calls callmax err render_stream)))))
  (if (!= r/status 0)
    (then {^agent_error (redact $"HTTP transport failed (${r/status}): ${r/stderr}")})
    (else
      (var http_error (http_status_error_text r))
      (if (present? http_error)
        {^agent_error http_error}
        (if (present? (Cell/get err))
          {^agent_error (redact (Cell/get err))}
          (if (Cell/get saw_sse)
            (chat_build_response text calls callmax)
            (try
              (chat_response_from_json (parse r/stdout))
            catch (JsonError ^message m)
              {^agent_error (redact $"API returned invalid JSON: ${m}")})))))))

(var live_transport
  (if (== api_flavor "chat") chat_live_transport responses_live_transport))

(fn call_model [transport, input_items, render_stream]
  (var started (monotonic_ms))
  (var request
    (if (== api_flavor "chat")
      {^model model
       ^messages (items_to_chat_messages input_items)
       ^tools (chat_tool_schemas_now)
       ^tool_choice "auto"
       ^stream true}
      {^model model
       ^store false
       ^stream true
       ^input input_items
       ^tools (tool_schemas_now)
       ^tool_choice "auto"
       ^parallel_tool_calls true}))
  (var effort (reasoning_effort ~ Cell/get))
  # Omitting the setting preserves the backend/model default. OpenAI's two
  # wire shapes use different field names for the same user-facing control.
  (if (!= effort "default")
    (if (== api_flavor "chat")
      (request ~ Map/put! "reasoning_effort" effort)
      (request ~ Map/put! "reasoning" {^effort effort})))
  (var body (stringify request))
  (debug! model_log "model request started"
    ^payload {^api_flavor api_flavor ^model_name model
              ^reasoning_effort effort
              ^input_items (input_items ~ size)
              ^tool_count ((tool_names ~ Cell/get) ~ size)
              ^request_bytes (byte_size body)})
  (var resp (transport body render_stream))
  (if (!= resp/agent_error void)
    (warn! model_log "model request failed"
      ^payload {^api_flavor api_flavor ^model_name model
                ^duration_ms (- (monotonic_ms) started)
                ^request_bytes (byte_size body)
                ^error_kind "transport_or_api"})
    (debug! model_log "model request completed"
      ^payload {^api_flavor api_flavor ^model_name model
                ^duration_ms (- (monotonic_ms) started)
                ^request_bytes (byte_size body)
                ^response_items ((response_output_items resp) ~ size)
                ^output_bytes (byte_size (response_text resp))}))
  resp)

# One turn: call the model; if it asked for tools, run them and recurse with the
# outputs appended, else render the final text. `budget` bounds tool rounds so a
# model that never stops calling tools cannot loop forever. `emit` is the event
# sink (§9.2): CLI passes its global logger, gateway passes a per-session sink.
# `turn_done` fires once, at the outermost completion (each terminal branch
# returns without recursing; the tool_call branch recurses and does not emit it).
(fn run_turn_ready_in [transport, input_items, render, render_stream, budget,
                       emit, context]
  (var active_items input_items)
  # Budget notices affect only this request; they are operational policy, not
  # durable conversation history. A round may contain multiple parallel calls.
  (var request_items
    (if (== budget 2)
      (append active_items
        (system_item "Two executable tool rounds remain. Plan the landing now: avoid exploratory edits and leave the final round for verification."))
      (if (== budget 1)
        (append active_items
          (system_item "One executable tool round remains. Prioritize verification and avoid further writes unless absolutely necessary; after this round only a final answer can be accepted."))
        (if (<= budget 0)
          (append active_items
            (system_item "The executable tool-round budget is exhausted. Do not request tools; give an honest final status with any unverified work stated explicitly."))
          active_items))))
  (debug! turn_log "model round started"
    ^payload {^budget_remaining budget ^input_items (active_items ~ size)
              ^request_items (request_items ~ size)})
  (var streamed (cell false))
  (var resp (call_model transport request_items
              (fn [text]
                (Cell/set streamed true)
                # Redact at this choke point (transports also redact — belt
                # and braces for any future transport) and emit the delta
                # through the sink so /trace and subscriptions see text_delta
                # events; the gateway sink skips them to avoid double-logging.
                (var safe (redact text))
                (trace! model_log "model stream delta"
                  ^payload {^bytes (byte_size safe)
                            ^budget_remaining budget})
                (emit "text_delta" {^text safe})
                (render_stream safe))))
  (if (!= resp/agent_error void)
    (then
      (emit "error" {^text resp/agent_error})
      (render resp/agent_error)
      (emit "turn_done" {^failed true})
      (fail (OsError ^message resp/agent_error)))
    (else
      (each (to_stream (response_output_items resp))
        (fn [item] (emit "model_item" {^item item})))
      (var calls (response_calls resp))
      (debug! turn_log "model round completed"
        ^payload {^budget_remaining budget ^tool_calls (calls ~ size)
                  ^response_items ((response_output_items resp) ~ size)
                  ^streamed (Cell/get streamed)})
      (if (empty? calls)
        (then
          (emit "agent_text" {^text (response_text resp)})
          (if (Cell/get streamed)
            (render "")
            (render (redact (response_text resp))))
          (emit "turn_done" {^text (response_text resp)})
          # Retain the final assistant message in the conversation so the next
          # turn can see what the agent just said (mirrors the tool_call path,
          # which already appends resp's output items).
          (append_all active_items (response_output_items resp)))
        (elif (<= budget 0)
          (warn! turn_log "tool round budget exhausted"
            ^payload {^requested_tools (calls ~ size)
                      ^budget_remaining budget})
          (render "[stopped: tool_call budget exhausted]")
          (emit "error"
            {^kind "tool_budget" ^text "tool_call budget exhausted"})
          (emit "turn_done" {^failed true})
          (fail (OsError ^message "tool_call budget exhausted")))
        (else
          # Execute tool handlers in this turn fiber. A lazy stream mapper
          # would own a separate generator continuation; cancelling the turn
          # could then leave an awaited subprocess alive in that continuation.
          (var outputs (cell []))
          (for c in calls
            ((outputs ~ Cell/get) ~ List/push!
              (run_tool_call_in c emit context))
            (render $"  · tool ${c/name} ${c/arguments}"))
          (run_turn_in transport
                    ((to_stream (outputs ~ Cell/get))
                      ~ into (append_all active_items (response_output_items resp)))
                    render
                    render_stream
                    (- budget 1)
                    emit
                    context))))))

(fn run_turn_ready [transport, input_items, render, render_stream, budget, emit]
  (run_turn_ready_in transport input_items render render_stream budget emit nil))

(fn run_turn_in [transport, input_items, render, render_stream, budget, emit,
                 context]
  (run_turn_ready_in transport
                     (compact_context input_items emit)
                     render render_stream budget emit context))

(fn run_turn [transport, input_items, render, render_stream, budget, emit]
  (run_turn_in transport input_items render render_stream budget emit nil))

# Run a CLI turn as a first-class Task so the stable Session projection and
# future input surfaces have one cancellation target. Gateway sessions use
# their own per-session tracked tasks in gateway.gene.
(fn run_turn_tracked_in [transport, input_items, render, render_stream, budget,
                         emit, context]
  (var started (monotonic_ms))
  (var outcome (cell "running"))
  (var result (cell input_items))
  (var terminal_emitted (cell false))
  (var interrupted (cell false))
  (var failure_text (cell "turn failed"))
  (var final_text (cell ""))
  (var watching (cell true))
  (var done (channel ^capacity 1))
  (fn tracked_emit [type : Str, props]
    (if (== type "turn_done") (terminal_emitted ~ Cell/set true))
    (if (&& (== type "agent_text") (present? props/text))
      (final_text ~ Cell/set props/text))
    (emit type props))
  (var prepared_items (compact_context input_items tracked_emit))
  (result ~ Cell/set prepared_items)
  (info! turn_log "turn started"
    ^payload {^turn_id (current_turn ~ Cell/get) ^budget budget
              ^input_items (input_items ~ size)
              ^prepared_items (prepared_items ~ size)})
  (var task (spawn
    (try
      (result ~ Cell/set
        (run_turn_ready_in transport prepared_items render render_stream
                           budget tracked_emit context))
      (outcome ~ Cell/set "done")
    catch {^message m}
      (failure_text ~ Cell/set m)
      (outcome ~ Cell/set "failed")
    catch _
      (outcome ~ Cell/set "failed")
    ensure
      (done ~ Channel/close))))
  (active_turn_task ~ Cell/set task)
  (var operation_app
    (if (&& (present? context) (present? context/app)) context/app))
  (var operation_agent
    (if (&& (present? context) (present? context/agent)) context/agent))
  (if (&& (!= operation_app nil) (!= operation_agent nil))
    (application_begin_worker_operation!
      operation_app operation_agent task "agent_turn"))
  (var interrupt_armed (begin_interrupt))
  (var watcher
    (spawn
      (while (watching ~ Cell/get)
        (sleep 25)
        (if_yes (|| (&& interrupt_armed (take_interrupt))
                (&& (!= (user_screen ~ Cell/get) nil)
                    (escape_pressed? (user_screen ~ Cell/get))))
          (interrupted ~ Cell/set true)
          (task ~ Task/cancel)))))
  (try
    (try (done ~ Channel/recv) catch (ChannelClosed) nil)
    (match (outcome ~ Cell/get)
      (when "done"
        (info! turn_log "turn completed"
          ^payload {^turn_id (current_turn ~ Cell/get)
                    ^duration_ms (- (monotonic_ms) started)
                    ^result_items ((result ~ Cell/get) ~ size)})
        (result ~ Cell/get))
      (when "failed"
        (error! turn_log "turn failed"
          ^payload {^turn_id (current_turn ~ Cell/get)
                    ^duration_ms (- (monotonic_ms) started)
                    ^error_detail (redact (failure_text ~ Cell/get))})
        (if_yes (! (terminal_emitted ~ Cell/get))
          (tracked_emit "error"
            {^kind "failed" ^text (failure_text ~ Cell/get)})
          (tracked_emit "turn_done" {^failed true}))
        (render $"[turn failed: ${(failure_text ~ Cell/get)}]")
        prepared_items)
      (else
        (info! turn_log "turn cancelled"
          ^payload {^turn_id (current_turn ~ Cell/get)
                    ^duration_ms (- (monotonic_ms) started)
                    ^interrupt_requested (interrupted ~ Cell/get)})
        (if_yes (! (terminal_emitted ~ Cell/get))
          (tracked_emit "error" {^kind "cancelled" ^text "turn cancelled"})
          (tracked_emit "turn_done" {^cancelled true}))
        (render
          (if (interrupted ~ Cell/get)
            "[turn cancelled; enter steering to continue]"
            "[turn cancelled]"))
        prepared_items))
  ensure
    (watching ~ Cell/set false)
    (if interrupt_armed (end_interrupt))
    (watcher ~ Task/cancel)
    (if (&& (!= operation_app nil) (!= operation_agent nil))
      (then
        (var terminal_outcome
          (if (== (outcome ~ Cell/get) "done") "completed"
            (if (== (outcome ~ Cell/get) "failed") "failed" "cancelled")))
        (application_finish_agent_operation!
          operation_app operation_agent terminal_outcome
          (final_text ~ Cell/get)
          (if (== terminal_outcome "failed") "AgentError" terminal_outcome)
          (if (== terminal_outcome "failed") (failure_text ~ Cell/get)
            (if (== terminal_outcome "cancelled") "turn cancelled" ""))
          nil))
      (else (active_turn_task ~ Cell/set nil)))
    (trace! turn_log "turn resources released"
      ^payload {^turn_id (current_turn ~ Cell/get)})))

(fn run_turn_tracked [transport, input_items, render, render_stream, budget,
                      emit]
  (run_turn_tracked_in transport input_items render render_stream budget emit
                       nil))

# -----------------------------------------------------------------------------
# Local persistence. GENE_AGENT_STATE selects a Store backend:
#   fs:<path>          — filesystem records under path
#   db:sqlite:<path>   — SQLite records in path
# When it is unset or blank, a non-empty GENE_AGENT_HOME is equivalent to
# fs:<home>.
# A bare GENE_AGENT_STATE path remains a filesystem compatibility form.
# The store contains:
#   config  — non-secret runtime config
#   session — current interactive transcript and Responses-style items
#   memory  — user-managed durable notes included in the system prompt
#   events  — the versioned event log (§9.2) plus its version/turn counters
#   application — agents, workers, panes, histories, drafts, and bounded output
# Reusing the same store restores these records automatically. The existing
# resume policy remains available to a future launcher flag without changing
# the persistence format.
# -----------------------------------------------------------------------------

(var agent_store (cell nil))
(var agent_state_db (cell nil))
(var agent_loaded_checkpoint (cell nil))
(var agent_artifacts (cell []))
(var next_artifact_id (cell 1))
(var artifact_max_count 128)
(var artifact_max_bytes 16777216)
(var registration_restore_done (cell false))
(var workspace_advisory_owned (cell false))
(var workspace_heartbeat_task (cell nil))
(var workspace_advisory_key $"workspace/${(sha256 workspace_real)}")

(fn state_enabled? []
  (!= (trim (if agent_state_spec agent_state_spec "")) ""))

(fn resume_enabled? []
  (flag_enabled? agent_resume))

(fn state_fs_path [spec : Str]
  (if (starts_with? spec "fs:")
    (after_prefix spec "fs:")
    spec))

(fn state_db_path [url : Str]
  (if (starts_with? url "sqlite:")
    (after_prefix url "sqlite:")
    (fail (OsError
      ^message "GENE_AGENT_STATE db URL must use sqlite:<path>"))))

(fn state_display []
  (if (state_enabled?) (state_fs_path agent_state_spec)))

(fn open_agent_store [spec : Str]
  (if (starts_with? spec "db:")
    (then
      (var path (state_db_path (after_prefix spec "db:")))
      (if (== (trim path) "")
        (fail (OsError ^message "GENE_AGENT_STATE database path is empty")))
      (var db (sqlite_open path))
      (agent_state_db ~ Cell/set db)
      (store_sqlite_open db ^table "agent_state"))
    (else
      (var path (state_fs_path spec))
      (if (== (trim path) "")
        (fail (OsError ^message "GENE_AGENT_STATE filesystem path is empty")))
      (store_fs_open ReadWriteDir ^root path))))

(fn close_agent_state []
  (release_workspace_advisory!)
  (agent_loaded_checkpoint ~ Cell/set nil)
  (registration_restore_done ~ Cell/set false)
  (var store (agent_store ~ Cell/get))
  (if_yes store
    (try (store ~ close) catch _ nil)
    (agent_store ~ Cell/set nil))
  (var db (agent_state_db ~ Cell/get))
  (if_yes db
    (try (db ~ close) catch _ nil)
    (agent_state_db ~ Cell/set nil)))

(fn init_agent_state []
  (if_not (|| (! (state_enabled?))
              (!= (agent_store ~ Cell/get) nil))
    (try
      (agent_checkpoint_seq ~ Cell/set 0)
      (agent_checkpoint_last_ms ~ Cell/set 0)
      (agent_store ~ Cell/set (open_agent_store agent_state_spec))
      (if_yes (resume_enabled?)
          (var saved_checkpoint ((agent_store ~ Cell/get) ~ load_checkpoint))
          (if saved_checkpoint
            (do
              (agent_loaded_checkpoint ~ Cell/set saved_checkpoint)
              (agent_checkpoint_seq ~ Cell/set saved_checkpoint/generation))
            (do
              # Compatibility migration: stores written before generation
              # checkpoints retain their loose marker for one restore.
              (var legacy
                ((agent_store ~ Cell/get) ~ get "checkpoint" ^default nil))
              (if (&& legacy (present? legacy/sequence))
                (agent_checkpoint_seq ~ Cell/set legacy/sequence)))))
      (restore_artifacts!)
      (claim_workspace_advisory!)
      (info! state_log "agent state opened"
        ^payload {^state_enabled true
                  ^state_backend
                    (if (starts_with? agent_state_spec "db:") "db" "fs")
                  ^resume_enabled (resume_enabled?)})
    catch (StoreError ^message m)
      (close_agent_state)
      (warn! state_log "agent state disabled"
        ^payload {^error_kind "store" ^error_detail (redact m)})
      (println $"agent state disabled: ${m}")
    catch (DbError ^message m)
      (close_agent_state)
      (warn! state_log "agent state disabled"
        ^payload {^error_kind "database" ^error_detail (redact m)})
      (println $"agent state disabled: ${m}")
    catch (OsError ^message m)
      (close_agent_state)
      (warn! state_log "agent state disabled"
        ^payload {^error_kind "configuration" ^error_detail (redact m)})
      (println $"agent state disabled: ${m}")
    catch _
      (close_agent_state)
      (warn! state_log "agent state disabled"
        ^payload {^error_kind "unknown"})
      (println "agent state disabled: could not open store"))))

(fn state_record_v1 [key : Str, record]
  (if (&& record (== record/schema 1) (== record/kind key)
          (present? record/data))
    record/data
    (fail (OsError
      ^message $"unsupported ${key} state record schema"))))

# Keep one pure migration entrypoint per durable record kind. They are
# intentionally boring at schema 1; later versions can evolve independently
# without making restore order-sensitive or evaluating persisted syntax.
(fn migrate_config_record [record] (state_record_v1 "config" record))
(fn migrate_memory_record [record] (state_record_v1 "memory" record))
(fn migrate_events_record [record] (state_record_v1 "events" record))
(fn migrate_session_record [record] (state_record_v1 "session" record))
(fn migrate_application_record [record]
  (state_record_v1 "application" record))
(fn migrate_registrations_record [record]
  (state_record_v1 "registrations" record))
(fn migrate_checkpoint_record [record]
  (state_record_v1 "checkpoint" record))

(fn migrate_state_record [key : Str, record]
  # Unknown versions or kinds are quarantined to the caller's default by
  # state_get; no validator evaluates ad-hoc syntax from persisted data.
  (match key
    (when "config" (migrate_config_record record))
    (when "memory" (migrate_memory_record record))
    (when "events" (migrate_events_record record))
    (when "session" (migrate_session_record record))
    (when "application" (migrate_application_record record))
    (when "registrations" (migrate_registrations_record record))
    (when "checkpoint" (migrate_checkpoint_record record))
    (else
      (fail (OsError ^message $"unknown durable state record ${key}")))))

(fn state_get [key : Str, default]
  (if (== (agent_store ~ Cell/get) nil)
    default
    (try
      (var checkpoint (agent_loaded_checkpoint ~ Cell/get))
      (var loaded default)
      (if checkpoint
        (do
          (var record (checkpoint/records ~ Map/get key))
          (if (!= record void)
            (set loaded (migrate_state_record key record))))
        (set loaded ((agent_store ~ Cell/get) ~ get key ^default default)))
      (trace! state_log "state record loaded" ^payload {^record_key key})
      # Sanitize snapshots written by older versions before they can be
      # rendered, resumed, or sent back to a model.
      (redact_any loaded)
    catch (StoreError ^message m)
      (warn! state_log "state record load failed"
        ^payload {^record_key key ^error_kind "store"
                  ^error_detail (redact m)})
      (println $"agent state load failed (${key}): ${m}")
      default
    catch _
      (warn! state_log "state record load failed"
        ^payload {^record_key key ^error_kind "unknown"})
      default)))

(fn durable_state_get [key : Str, default]
  (if (== (agent_store ~ Cell/get) nil)
    default
    (try
      ((agent_store ~ Cell/get) ~ get key ^default default)
    catch _ default)))

(fn write_workspace_heartbeat! []
  (if (&& (workspace_advisory_owned ~ Cell/get)
          (agent_store ~ Cell/get))
    ((agent_store ~ Cell/get) ~ put workspace_advisory_key
      {^workspace workspace_real ^process_id (process_id)
       ^heartbeat_ms (monotonic_ms)})))

(fn claim_workspace_advisory! []
  (if_yes (agent_store ~ Cell/get)
    (var previous (durable_state_get workspace_advisory_key nil))
    (var live
      (&& previous (present? previous/process_id)
          (!= previous/process_id (process_id))
          (present? previous/heartbeat_ms)
          (< (- (monotonic_ms) previous/heartbeat_ms) 15000)))
    (if live
      (then
        (workspace_advisory_owned ~ Cell/set false)
        (println
          $"WARNING: another Gene agent owns this workspace (pid ${previous/process_id}, ${previous/workspace})"))
      (else
        (workspace_advisory_owned ~ Cell/set true)
        (write_workspace_heartbeat!)))))

(fn start_workspace_heartbeat! []
  (if (&& (workspace_advisory_owned ~ Cell/get)
          (== (workspace_heartbeat_task ~ Cell/get) nil))
    (do
      (var task
        (spawn
          (loop
            (sleep 5000)
            (write_workspace_heartbeat!))))
      (workspace_heartbeat_task ~ Cell/set task)
      (task ~ Task/detach))))

(fn release_workspace_advisory! []
  (var task (workspace_heartbeat_task ~ Cell/get))
  (if task (task ~ Task/cancel))
  (workspace_heartbeat_task ~ Cell/set nil)
  (if (&& (workspace_advisory_owned ~ Cell/get)
          (agent_store ~ Cell/get))
    (do
      (var current (durable_state_get workspace_advisory_key nil))
      (if (&& current (== current/process_id (process_id)))
        ((agent_store ~ Cell/get) ~ delete workspace_advisory_key))))
  (workspace_advisory_owned ~ Cell/set false))

(fn artifact_find [id : Str]
  (var found (cell nil))
  (for artifact in (agent_artifacts ~ Cell/get)
    (if (== artifact/id id) (found ~ Cell/set artifact)))
  (found ~ Cell/get))

(fn restore_artifacts! []
  (agent_artifacts ~ Cell/set [])
  (next_artifact_id ~ Cell/set 1)
  (if_yes (agent_store ~ Cell/get)
    (for key in ((agent_store ~ Cell/get) ~ keys)
      (if (starts_with? key "artifact/")
        (do
          (var data (durable_state_get key nil))
          (if (&& data (present? data/id) (present? data/blob_id)
                  (present? data/kind) (present? data/size))
            (do
              ((agent_artifacts ~ Cell/get) ~ List/push! data)
              (var parts (split data/id ":"))
              (if (== (parts ~ size) 2)
                (try
                  (var value (parse_int parts/1))
                  (if (>= value (next_artifact_id ~ Cell/get))
                    (next_artifact_id ~ Cell/set (+ value 1)))
                catch _ nil)))))))))

(fn artifact_total_bytes [] : Int
  (var total 0)
  (var seen {})
  (for artifact in (agent_artifacts ~ Cell/get)
    (if (== (seen ~ Map/get artifact/blob_id) void)
      (do
        (seen ~ Map/put! artifact/blob_id true)
        (set total (+ total artifact/size)))))
  total)

(fn application_pin_artifact!
  [app, kind : Str, text : Str, source_worker, source_task]
  (if (== (agent_store ~ Cell/get) nil)
    (return {^ok false ^error "agent state is disabled"}))
  (var content (redact text))
  (var size (byte_size content))
  (var blob_id $"sha256:${(sha256 content)}")
  (var blob_key $"blob/${blob_id}")
  (if (>= ((agent_artifacts ~ Cell/get) ~ size) artifact_max_count)
    (return {^ok false ^error "artifact count limit reached; delete one first"}))
  (if (&& (! ((agent_store ~ Cell/get) ~ has? blob_key))
          (> (+ (artifact_total_bytes) size) artifact_max_bytes))
    (return {^ok false ^error "artifact byte limit reached; delete one first"}))
  (if_not ((agent_store ~ Cell/get) ~ has? blob_key)
    ((agent_store ~ Cell/get) ~ put blob_key content))
  (var id $"artifact:${(next_artifact_id ~ Cell/get)}")
  (next_artifact_id ~ Cell/set (+ (next_artifact_id ~ Cell/get) 1))
  (var artifact
    {^id id ^blob_id blob_id ^kind kind ^mime "text/plain"
     ^source_worker source_worker ^source_task source_task
     ^created_v (- (next_event_v ~ Cell/get) 1) ^size size})
  ((agent_store ~ Cell/get) ~ put $"artifact/${id}" artifact)
  ((agent_artifacts ~ Cell/get) ~ List/push! artifact)
  (if app
    (application_emit app "artifact_pinned"
      {^artifact_id id ^blob_id blob_id ^kind kind
       ^worker_id source_worker ^task_id source_task ^size size}))
  {^ok true ^artifact artifact})

(fn application_delete_artifact! [app, id : Str]
  (var artifact (artifact_find id))
  (if (== artifact nil)
    (return {^ok false ^error $"artifact ${id} not found"}))
  (var retained [])
  (var blob_referenced false)
  (for current in (agent_artifacts ~ Cell/get)
    (if (!= current/id id)
      (do
        (retained ~ List/push! current)
        (if (== current/blob_id artifact/blob_id)
          (set blob_referenced true)))))
  (agent_artifacts ~ Cell/set retained)
  ((agent_store ~ Cell/get) ~ delete $"artifact/${id}")
  (if_not blob_referenced
    ((agent_store ~ Cell/get) ~ delete $"blob/${artifact/blob_id}"))
  (if app
    (application_emit app "artifact_deleted"
      {^artifact_id id ^blob_id artifact/blob_id ^kind artifact/kind}))
  {^ok true ^artifact artifact})

(fn artifact_content [artifact]
  (durable_state_get $"blob/${artifact/blob_id}" nil))

(fn artifacts_report [] : Str
  (if (empty? (agent_artifacts ~ Cell/get))
    "no artifacts"
    (do
      (var lines [])
      (for artifact in (agent_artifacts ~ Cell/get)
        (lines ~ List/push!
          $"${artifact/id} ${artifact/kind} source=${artifact/source_worker} bytes=${artifact/size} blob=${artifact/blob_id}"))
      (lines ~ join "\n"))))

(fn handler_ref_matches? [current, saved] : Bool
  (&& current saved
      (!= current void) (!= saved void)
      (== current/module saved/module)
      (== current/path saved/path)
      (== current/version saved/version)))

(fn registration_restore_event! [app, type : Str, props]
  (if app (application_emit app type props) (emit_event! type props)))

(fn restore_dynamic_registrations! [app]
  (if (registration_restore_done ~ Cell/get) (return false))
  (registration_restore_done ~ Cell/set true)
  (var saved (state_get "registrations" []))
  (dynamic_registration_records ~ Cell/set saved)
  (restoring_registrations ~ Cell/set true)
  (try
    (for record in saved
      (if (== record/kind "tool")
        (do
          (var current (find_tool record/name))
          (if (&& (!= current void)
                  (handler_ref_matches? current/handler_ref record/handler_ref))
            (do
              (current ~ Node/set_prop! `enabled true)
              (registration_restore_event! app "registration_restored"
                {^registration_kind "tool" ^name record/name
                 ^handler_ref record/handler_ref}))
            (do
              (if (== current void)
                (set current
                  (Tool ^name record/name ^description record/description
                    ^risk record/risk ^params record/params
                    ^handler (fn [_args] "error: restored tool handler unavailable")
                    ^handler_ref record/handler_ref ^enabled false))
                (current ~ Node/set_prop! `enabled false))
              (register_tool! current)
              (registration_restore_event! app "restore_record_rejected"
                {^record_kind "tool_handler" ^record_id record/name
                 ^error_text "ephemeral or exact-version handler unavailable"}))))
        (if (== record/kind "operation")
          (do
            (var current
              (worker_operation_for record/worker_kind record/name))
            (if (&& current
                    (handler_ref_matches?
                      current/handler_ref record/handler_ref))
              (do
                (current ~ Node/set_prop! `enabled true)
                (registration_restore_event! app "registration_restored"
                  {^registration_kind "operation"
                   ^worker_kind record/worker_kind ^name record/name
                   ^handler_ref record/handler_ref}))
              (do
                (if current
                  (current ~ Node/set_prop! `enabled false)
                  (do
                    (set current
                      (Operation ^name record/name ^summary record/summary
                        ^usage record/usage ^args EmptyArgs ^result OperationAck
                        ^errors record/errors ^effects record/effects
                        ^audience record/audience ^admission record/admission
                        ^audit record/audit ^cancellable record/cancellable
                        ^idempotent record/idempotent
                        ^task_managed false ^primary_input false
                        ^handler
                          (fn [_app, _worker, _operation, _args, _invocation]
                            (fail (OsError ^message "restored operation handler unavailable")))
                        ^parse_cli (fn [text] {^raw text})
                        ^handler_ref record/handler_ref ^enabled false))
                    (register_worker_operation! record/worker_kind current)))
                (registration_restore_event! app "restore_record_rejected"
                  {^record_kind "operation_handler"
                   ^record_id $"${record/worker_kind}/${record/name}"
                   ^error_text "ephemeral or exact-version handler unavailable"})))))))
  ensure
    (restoring_registrations ~ Cell/set false))
  true)

(fn config_snapshot []
  {^model model
   ^base base
   ^api_flavor api_flavor
   ^reasoning_effort (reasoning_effort ~ Cell/get)
   ^workspace_root workspace_root
   ^approve_all approve_all
   ^max_tool_rounds max_tool_rounds
   ^context_max_bytes context_max_bytes
   ^context_max_items context_max_items
   ^context_keep_turns context_keep_turns})

(fn session_config_snapshot [items, memory]
  (var config (config_snapshot))
  (config ~ Map/put! "context" (context_stats items memory))
  config)

(fn restore_reasoning_effort! []
  # An explicit environment value is launch configuration and wins over the
  # durable interactive choice. Otherwise resume the last valid choice.
  (if (&& (resume_enabled?) (== configured_reasoning_effort nil))
    (do
      (var saved (state_get "config" nil))
      (if (&& saved
              (present? saved/reasoning_effort)
              (valid_reasoning_effort? saved/reasoning_effort))
        (reasoning_effort ~ Cell/set saved/reasoning_effort)))))

(fn prompt_with_memory [memory]
  (if (empty? memory)
    (then gene_system_prompt)
    (else
      (var sep "\n")
      (redact
        $"${gene_system_prompt}\n\nPersistent memory:\n${(join memory sep)}\n"))))

(fn initial_items [memory]
  [(system_item (prompt_with_memory memory))])

(fn refresh_system_memory [items, memory]
  (var out (cell []))
  (var i (cell 0))
  (for item in items
    (if (== (i ~ Cell/get) 0)
      ((out ~ Cell/get) ~ List/push! (system_item (prompt_with_memory memory)))
      ((out ~ Cell/get) ~ List/push! item))
    (i ~ Cell/set (+ (i ~ Cell/get) 1)))
  (if (== (i ~ Cell/get) 0)
    (initial_items memory)
    (out ~ Cell/get)))

(fn load_memory []
  (state_get "memory" []))

(fn load_session []
  (if (resume_enabled?)
    (state_get "session" nil)))

(fn application_snapshot [app]
  (var main app/main_agent)
  (var main_worker
    {^transcript (main/transcript ~ Cell/get)
     ^status (main/status ~ Cell/get)
     ^current_operation (main/current_operation ~ Cell/get)
     ^input_reserved (main/input_reserved ~ Cell/get)
     ^last_outcome (main/last_outcome ~ Cell/get)
     ^result (main/result ~ Cell/get)
     ^history (main/history ~ Cell/get)
     ^next_output_seq (main/next_output_seq ~ Cell/get)
     ^dropped_bytes (main/dropped_bytes ~ Cell/get)
     ^dropped_before (main/dropped_before ~ Cell/get)
     ^retained_output (main/retained_output ~ Cell/get)
     ^transcript_seq (main/transcript_seq ~ Cell/get)
     ^transcript_dropped_bytes (main/transcript_dropped_bytes ~ Cell/get)
     ^transcript_dropped_before (main/transcript_dropped_before ~ Cell/get)
     ^transcript_retained (main/transcript_retained ~ Cell/get)
     ^history_dropped (main/history_dropped ~ Cell/get)})
  (var agents [])
  (for agent in (app/agents ~ Cell/get)
    (if_not (== agent/id "main")
      (agents ~ List/push!
        {^id agent/id ^name agent/name
         ^parent_id agent/parent_id ^title agent/title
         ^assignment agent/assignment ^items (agent/items ~ Cell/get)
         ^transcript (agent/transcript ~ Cell/get)
         ^status (agent/status ~ Cell/get) ^result (agent/result ~ Cell/get)
         ^current_operation (agent/current_operation ~ Cell/get)
         ^input_reserved (agent/input_reserved ~ Cell/get)
         ^history (agent/history ~ Cell/get)
         ^lifecycle (agent/lifecycle ~ Cell/get)
         ^last_outcome (agent/last_outcome ~ Cell/get)
         ^history_dropped (agent/history_dropped ~ Cell/get)
         ^next_output_seq (agent/next_output_seq ~ Cell/get)
         ^dropped_bytes (agent/dropped_bytes ~ Cell/get)
         ^dropped_before (agent/dropped_before ~ Cell/get)
         ^retained_output (agent/retained_output ~ Cell/get)
         ^attachments (agent/attachments ~ Cell/get)})))
  (var workers [])
  (for worker in (app/workers ~ Cell/get)
    (if_not (== worker/kind "agent")
      (workers ~ List/push!
        {^id worker/id ^name worker/name
         ^kind worker/kind ^title worker/title
         ^output (worker/output ~ Cell/get)
         ^status (worker/status ~ Cell/get)
         ^current_operation (worker/current_operation ~ Cell/get)
         ^input_reserved (worker/input_reserved ~ Cell/get)
         ^lifecycle (worker/lifecycle ~ Cell/get)
         ^last_outcome (worker/last_outcome ~ Cell/get)
         ^history (worker/history ~ Cell/get)
         ^next_output_seq (worker/next_output_seq ~ Cell/get)
         ^dropped_bytes (worker/dropped_bytes ~ Cell/get)
         ^dropped_before (worker/dropped_before ~ Cell/get)
         ^retained_output (worker/retained_output ~ Cell/get)
         ^history_dropped (worker/history_dropped ~ Cell/get)
         ^cwd (if (== worker/kind "shell")
                (worker/controller/cwd ~ Cell/get) void)
         ^environment (if (== worker/kind "shell")
                        (worker/controller/environment ~ Cell/get) void)
         ^filter (if (== worker/kind "log_tail")
                   (worker/controller/filter ~ Cell/get) void)
         ^path (if (== worker/kind "file_view")
                 worker/controller/path void)
         ^following (if (== worker/kind "output")
                      (worker/controller/following ~ Cell/get) void)})))
  (var panes [])
  (var surface app/local_surface)
  (var surface_drafts {})
  (var surface_histories {})
  (if_yes surface
    (for [worker_id draft] in (surface/drafts ~ Cell/get)
      (surface_drafts ~ Map/put! worker_id (draft ~ Cell/get)))
    (for [worker_id history] in (surface/input_histories ~ Cell/get)
      (surface_histories ~ Map/put! worker_id (history ~ Cell/get))))
  (for pane in (if (== surface nil) [] (surface/panes ~ Cell/get))
    (panes ~ List/push!
      {^id pane/id ^worker_id pane/worker_id ^kind pane/kind
       ^owner_id pane/owner_id ^title pane/title
       ^scroll (pane/scroll ~ Cell/get)
       ^hidden (pane/hidden ~ Cell/get)}))
  {^main_worker main_worker
   ^supervisor_inbox (app/supervisor_inbox ~ Cell/get)
   ^progress (app/progress ~ Cell/get)
   ^agents agents ^workers workers ^panes panes
   ^next_agent_id (app/next_agent_id ~ Cell/get)
   ^next_worker_id (app/next_worker_id ~ Cell/get)
   ^next_task_id (app/next_task_id ~ Cell/get)
   ^surface
     (if surface
       {^id surface/id ^instance_id (surface/instance_id ~ Cell/get)
        ^next_pane_id (surface/next_pane_id ~ Cell/get)
        ^focused_pane (surface/focused_pane ~ Cell/get)
        ^maximized_pane (surface/maximized_pane ~ Cell/get)
        ^main_scroll (surface/main_scroll ~ Cell/get)
        ^drafts surface_drafts ^input_histories surface_histories})})

(fn emit_restore_normalization! [app, worker, data]
  # Process-local Tasks, confirmations, and lease requests are never durable.
  # Preserve enough operation identity in the snapshot to close the old
  # observation trail, while restoring no authority that could repeat work.
  (var finish_event nil)
  (if (present? data/current_operation)
    (set finish_event
      (application_emit app "worker_operation_finished"
        {^worker_id worker/id ^kind worker/kind
         ^task_id data/current_operation/task_id
         ^operation_kind data/current_operation/kind
         ^outcome "failed" ^reason "process_restore"}))
    (if (== data/input_reserved true)
      (application_emit app "worker_admission_cancelled"
        {^worker_id worker/id ^kind worker/kind
         ^reason "process_restore"})
      (if (== data/status "working")
        (set finish_event
          (application_emit app "worker_restore_normalized"
            {^worker_id worker/id ^kind worker/kind
             ^outcome "failed" ^reason "legacy_snapshot"})))))
  (if (&& (== worker/kind "agent") (!= finish_event nil))
    (then
      (var task_id
        (if (present? data/current_operation)
          data/current_operation/task_id nil))
      (var source_v
        (if (present? finish_event/v) finish_event/v nil))
      (var main_result (== worker/id "main"))
      (var result
        {^task_id task_id ^outcome "failed" ^text ""
         ^error {^kind "process_restore"
                 ^message "agent operation was interrupted by process restart"}
         ^finished_v nil ^read main_result ^incorporated main_result})
      (worker/result ~ Cell/set result)
      (var agent_event
        (application_emit app "agent_finished"
          {^worker_id worker/id ^agent_id worker/id
           ^parent_agent_id worker/parent_id ^task_id task_id
           ^outcome "failed" ^source_v source_v
           ^error_kind "process_restore"
           ^error_text "agent operation was interrupted by process restart"
           ^result_unread (! main_result)}))
      (var finished_v (if (present? agent_event/v) agent_event/v nil))
      (set result
        {^task_id task_id ^outcome "failed" ^text ""
         ^error {^kind "process_restore"
                 ^message "agent operation was interrupted by process restart"}
         ^finished_v finished_v ^read main_result
         ^incorporated main_result})
      (worker/result ~ Cell/set result)
      (if (!= worker/id "main")
        (application_enqueue_supervisor_result! app worker result)))))

(fn emit_restore_rejected! [app, record_kind : Str, record_id, message : Str]
  (application_emit app "restore_record_rejected"
    {^record_kind record_kind ^record_id record_id
     ^error_kind "invalid_record"
     ^error_text (utf8_prefix (redact message) 2048)}))

(fn persisted_record_id [data]
  (match data
    (when (record : Map)
      (if (present? record/id) $"${record/id}" "unknown"))
    (else "unknown")))

(fn restore_surface_record! [app, surface, data]
  (match data
    (when (_record : Map) nil)
    (else (fail (OsError ^message "surface record must be a map"))))
  (if_not (match data/next_pane_id (when (_id : Int) true) (else false))
    (fail (OsError ^message "surface next_pane_id must be an Int")))
  (if_not (|| (== data/focused_pane nil)
              (match data/focused_pane (when (_id : Int) true) (else false)))
    (fail (OsError ^message "surface focused_pane must be nil or Int")))
  (if_not (|| (== data/maximized_pane nil)
              (match data/maximized_pane (when (_id : Int) true) (else false)))
    (fail (OsError ^message "surface maximized_pane must be nil or Int")))
  (if (&& (present? data/main_scroll)
          (|| (! (match data/main_scroll
                   (when (_scroll : Int) true) (else false)))
              (< data/main_scroll 0)))
    (fail (OsError
      ^message "surface main_scroll must be a non-negative Int")))
  (if (present? data/instance_id)
    (surface/instance_id ~ Cell/set $"${data/instance_id}:r"))
  (surface/next_pane_id ~ Cell/set data/next_pane_id)
  (surface/focused_pane ~ Cell/set data/focused_pane)
  (surface/maximized_pane ~ Cell/set data/maximized_pane)
  (if (present? data/main_scroll)
    (surface/main_scroll ~ Cell/set data/main_scroll))
  (if_yes (present? data/drafts)
    (match data/drafts
      (when (saved_drafts : Map)
        (var drafts {})
        (for [worker_id text] in saved_drafts
          (match text
            (when (draft_text : Str)
              (drafts ~ Map/put! worker_id
                (cell (utf8_prefix draft_text surface_draft_max_bytes))))
            (else nil)))
        (surface/drafts ~ Cell/set drafts))
      (else (fail (OsError ^message "surface drafts must be a map")))))
  (if_yes (present? data/input_histories)
    (match data/input_histories
      (when (saved_histories : Map)
        (var histories {})
        (for [worker_id values] in saved_histories
          (match values
            (when (history : List)
              (if_not (list_of_type? history "str")
                (fail (OsError
                  ^message "surface input history must contain only Str")))
              (histories ~ Map/put! worker_id
                (cell (bounded_list_tail history surface_history_max))))
            (else nil)))
        (surface/input_histories ~ Cell/set histories))
      (else
        (fail (OsError ^message "surface input_histories must be a map")))))
  true)

(fn restore_application_snapshot! [app, saved]
  (if_yes saved
    (match saved
      (when (_record : Map) nil)
      (else (fail (OsError ^message "application snapshot must be a map"))))
    # No in-flight task or admission reservation survives a process
    # restart. Restore only the bounded main-worker projection and normalize
    # an interrupted status to idle-with-failed-last-outcome semantics.
    (if_yes (present? saved/main_worker)
        (var data saved/main_worker)
        (app/main_agent/transcript ~ Cell/set data/transcript)
        (app/main_agent/status ~ Cell/set
          (if (== data/status "working") "idle" data/status))
        (app/main_agent/last_outcome ~ Cell/set
          (if (== data/status "working") "failed" data/last_outcome))
        (try
          (app/main_agent/result ~ Cell/set
            (normalized_agent_result data/result true))
        catch {^message message}
          (app/main_agent/result ~ Cell/set nil)
          (emit_restore_rejected! app "result" "main" message)
        catch _
          (app/main_agent/result ~ Cell/set nil)
          (emit_restore_rejected! app "result" "main"
            "unknown result restore failure"))
        (var saved_history
          (if (present? data/history) data/history []))
        (var restored_history
          (bounded_list_tail saved_history worker_history_max))
        (app/main_agent/history ~ Cell/set restored_history)
        (if (present? data/next_output_seq)
          (app/main_agent/next_output_seq ~ Cell/set data/next_output_seq))
        (if (present? data/dropped_bytes)
          (app/main_agent/dropped_bytes ~ Cell/set data/dropped_bytes))
        (if (present? data/dropped_before)
          (app/main_agent/dropped_before ~ Cell/set data/dropped_before))
        (app/main_agent/retained_output ~ Cell/set
          (if (present? data/retained_output)
            data/retained_output data/transcript))
        (if (present? data/transcript_seq)
          (app/main_agent/transcript_seq ~ Cell/set data/transcript_seq))
        (if (present? data/transcript_dropped_bytes)
          (app/main_agent/transcript_dropped_bytes ~ Cell/set
            data/transcript_dropped_bytes))
        (if (present? data/transcript_dropped_before)
          (app/main_agent/transcript_dropped_before ~ Cell/set
            data/transcript_dropped_before))
        (app/main_agent/transcript_retained ~ Cell/set
          (if (present? data/transcript_retained)
            data/transcript_retained data/transcript))
        (app/main_agent/history_dropped ~ Cell/set
          (+ (if (present? data/history_dropped) data/history_dropped 0)
             (- saved_history/~size restored_history/~size)))
        (emit_restore_normalization! app app/main_agent data))
    (if (present? saved/supervisor_inbox)
      (app/supervisor_inbox ~ Cell/set
        (bounded_list_tail saved/supervisor_inbox
                           supervisor_inbox_max_count)))
    (if_yes (present? saved/progress)
      (try
        (app/progress ~ Cell/set (normalized_project_progress saved/progress))
      catch {^message message}
        (emit_restore_rejected! app "progress" "main" message)
      catch _
        (emit_restore_rejected! app "progress" "main"
          "unknown progress restore failure")))
    (for data in (if (present? saved/agents) saved/agents [])
      (var record_id (persisted_record_id data))
      (try
      (match data
        (when (_record : Map) nil)
        (else (fail (OsError ^message "agent record must be a map"))))
      (if_not (match data/id (when (_id : Str) true) (else false))
        (fail (OsError ^message "agent id must be a Str")))
      (if (&& (present? data/name)
              (! (match data/name (when (_name : Str) true) (else false))))
        (fail (OsError ^message "agent name must be a Str or nil")))
      (if_not (match data/title (when (_title : Str) true) (else false))
        (fail (OsError ^message "agent title must be a Str")))
      (if_not (match data/assignment
                (when (_assignment : Str) true) (else false))
        (fail (OsError ^message "agent assignment must be a Str")))
      (if_not (match data/items (when (_items : List) true) (else false))
        (fail (OsError ^message "agent items must be a List")))
      (if_not (match data/transcript
                (when (_transcript : Str) true) (else false))
        (fail (OsError ^message "agent transcript must be a Str")))
      (if_not (["idle" "working" "admitting" "confirming" "stopped"]
                ~ contains? data/status)
        (fail (OsError ^message "agent status is invalid")))
      (if_not (["running" "stopped"] ~ contains? data/lifecycle)
        (fail (OsError ^message "agent lifecycle is invalid")))
      (if_not (|| (== data/last_outcome nil) (== data/last_outcome void)
                  (["completed" "cancelled" "failed"]
                    ~ contains? data/last_outcome))
        (fail (OsError ^message "agent last_outcome is invalid")))
      (if (&& (present? data/history)
              (! (match data/history
                   (when (_history : List) true) (else false))))
        (fail (OsError ^message "agent history must be a List")))
      (if (&& (present? data/attachments)
              (! (match data/attachments
                   (when (_attachments : List) true) (else false))))
        (fail (OsError ^message "agent attachments must be a List")))
      (if (&& (present? data/retained_output)
              (! (match data/retained_output
                   (when (_output : Str) true) (else false))))
        (fail (OsError ^message "agent retained_output must be a Str")))
      (if_not (&& (optional_int? data/next_output_seq)
                  (optional_int? data/dropped_bytes)
                  (optional_int? data/dropped_before)
                  (optional_int? data/history_dropped)
                  (optional_int? data/transcript_seq)
                  (optional_int? data/transcript_dropped_bytes)
                  (optional_int? data/transcript_dropped_before))
        (fail (OsError ^message "agent counters must be Int or nil")))
      (var agent
          (make_agent data/id data/parent_id data/title data/assignment
            (cell data/items) (cell data/transcript) (cell nil)))
        (if_yes (present? data/name)
          (var named (application_assign_worker_name! app agent data/name))
          (if_not named/ok
            (fail (OsError ^message named/error/message))))
        (agent/status ~ Cell/set
          (if (== data/status "working") "idle" data/status))
        (agent/lifecycle ~ Cell/set
          (if (== data/lifecycle "stopped") "stopped" "running"))
        (agent/last_outcome ~ Cell/set
          (if (== data/last_outcome void)
            (if (== data/status "working") "failed" data/status)
            data/last_outcome))
        (agent/result ~ Cell/set
          (normalized_agent_result data/result false))
        (var saved_history
          (if (present? data/history) data/history []))
        (var restored_history
          (bounded_list_tail saved_history worker_history_max))
        (agent/history ~ Cell/set restored_history)
        (if (present? data/attachments)
          (agent/attachments ~ Cell/set data/attachments))
        (if (present? data/history_dropped)
          (agent/history_dropped ~ Cell/set
            (+ data/history_dropped
               (- saved_history/~size restored_history/~size)))
          (agent/history_dropped ~ Cell/set
            (- saved_history/~size restored_history/~size)))
        (if (present? data/next_output_seq)
          (agent/next_output_seq ~ Cell/set data/next_output_seq))
        (if (present? data/dropped_bytes)
          (agent/dropped_bytes ~ Cell/set data/dropped_bytes))
        (if (present? data/dropped_before)
          (agent/dropped_before ~ Cell/set data/dropped_before))
        (if (present? data/retained_output)
          (agent/retained_output ~ Cell/set data/retained_output)
          (agent/retained_output ~ Cell/set data/transcript))
        ((app/agents ~ Cell/get) ~ List/push! agent)
        ((app/workers ~ Cell/get) ~ List/push! agent)
        (emit_restore_normalization! app agent data)
      catch {^message message}
        (emit_restore_rejected! app "agent" record_id message)
      catch _
        (emit_restore_rejected! app "agent" record_id
          "unknown agent restore failure")))
    (for data in (if (present? saved/workers) saved/workers [])
      (var record_id (persisted_record_id data))
      (try
      (match data
        (when (_record : Map) nil)
        (else (fail (OsError ^message "worker record must be a map"))))
      (if_not (match data/id (when (_id : Str) true) (else false))
        (fail (OsError ^message "worker id must be a Str")))
      (if (&& (present? data/name)
              (! (match data/name (when (_name : Str) true) (else false))))
        (fail (OsError ^message "worker name must be a Str or nil")))
      (if_not (["shell" "repl" "output" "log_tail" "file_view" "stats"]
                ~ contains? data/kind)
        (fail (OsError ^message "worker kind is invalid")))
      (if_not (match data/title (when (_title : Str) true) (else false))
        (fail (OsError ^message "worker title must be a Str")))
      (if_not (match data/output (when (_output : Str) true) (else false))
        (fail (OsError ^message "worker output must be a Str")))
      (if_not (["idle" "working" "admitting" "confirming" "stopped"]
                ~ contains? data/status)
        (fail (OsError ^message "worker status is invalid")))
      (if_not (["running" "stopped"] ~ contains? data/lifecycle)
        (fail (OsError ^message "worker lifecycle is invalid")))
      (if_not (|| (== data/last_outcome nil) (== data/last_outcome void)
                  (["completed" "cancelled" "failed"]
                    ~ contains? data/last_outcome))
        (fail (OsError ^message "worker last_outcome is invalid")))
      (if (&& (present? data/history)
              (! (match data/history
                   (when (_history : List) true) (else false))))
        (fail (OsError ^message "worker history must be a List")))
      (if (&& (present? data/retained_output)
              (! (match data/retained_output
                   (when (_output : Str) true) (else false))))
        (fail (OsError ^message "worker retained_output must be a Str")))
      (if_not (&& (optional_int? data/next_output_seq)
                  (optional_int? data/dropped_bytes)
                  (optional_int? data/dropped_before)
                  (optional_int? data/history_dropped))
        (fail (OsError ^message "worker counters must be Int or nil")))
      (if (&& (== data/kind "shell") (present? data/cwd)
              (! (match data/cwd (when (_cwd : Str) true) (else false))))
        (fail (OsError ^message "shell cwd must be a Str")))
      (if (&& (== data/kind "shell") (present? data/environment)
              (! (match data/environment
                   (when (_environment : Map) true) (else false))))
        (fail (OsError ^message "shell environment must be a Map")))
      (if (&& (== data/kind "log_tail") (present? data/filter)
              (! (match data/filter
                   (when (_filter : Map) true) (else false))))
        (fail (OsError ^message "log-tail filter must be a Map")))
      (if (&& (== data/kind "file_view")
              (! (match data/path (when (_path : Str) true) (else false))))
        (fail (OsError ^message "file-view path must be a Str")))
      (if (&& (== data/kind "output") (present? data/following)
              (! (list_of_type? data/following "str")))
        (fail (OsError
          ^message "output following must contain only worker-id strings")))
      # Older snapshots could contain a locally opened host file. Shared
        # file-view workers are now workspace-confined because their output
        # is visible to every authenticated surface. Preserve the worker
        # identity for event/layout references, but never restore unsafe
        # path metadata or captured content.
        (var unsafe_file_view
          (&& (== data/kind "file_view")
              (! (confined_path? data/path))))
        (var controller
          (match data/kind
            (when "shell"
              (ShellController
                ^cwd (cell (if (== data/cwd void) workspace_root data/cwd))
                ^environment
                  (cell (if (== data/environment void) {} data/environment))))
            (when "repl"
              (ReplController ^session nil ^items nil ^transcript nil
                              ^memory nil ^streaming (cell false)
                              ^resume_requested (cell false)))
            (when "log_tail"
              (LogTailController
                ^filter (cell (if (== data/filter void) {} data/filter))))
            (when "file_view"
              (FileViewController
                ^path (if unsafe_file_view ""
                        (if (== data/path void) "" data/path))))
            (when "stats" (StatsController))
            (else
              (OutputController ^source "restored"
                ^following
                  (cell
                    (if (match data/following
                          (when (xs : List) true) (else false))
                      data/following []))))))
        (var worker
          (make_worker data/id data/kind data/title
            (cell (if unsafe_file_view "" data/output)) controller))
        (if_yes (present? data/name)
          (var named (application_assign_worker_name! app worker data/name))
          (if_not named/ok
            (fail (OsError ^message named/error/message))))
        (var saved_history
          (if (present? data/history) data/history []))
        (var restored_history
          (bounded_list_tail saved_history worker_history_max))
        (worker/history ~ Cell/set restored_history)
        (var restored_lifecycle
          (if (|| unsafe_file_view
                  (== data/kind "shell") (== data/kind "repl"))
            "stopped"
            (if (== data/lifecycle "stopped") "stopped" "running")))
        (worker/lifecycle ~ Cell/set restored_lifecycle)
        (worker/status ~ Cell/set
          (if (== restored_lifecycle "stopped") "stopped"
            (if (== data/status "working") "idle" data/status)))
        (worker/last_outcome ~ Cell/set
          (if (== data/last_outcome void)
            (if (== data/status "working") "failed" data/status)
            data/last_outcome))
        (if (present? data/next_output_seq)
          (worker/next_output_seq ~ Cell/set data/next_output_seq))
        (if (present? data/dropped_bytes)
          (worker/dropped_bytes ~ Cell/set data/dropped_bytes))
        (if (present? data/dropped_before)
          (worker/dropped_before ~ Cell/set data/dropped_before))
        (if (present? data/retained_output)
          (worker/retained_output ~ Cell/set data/retained_output)
          (worker/retained_output ~ Cell/set data/output))
        (if (present? data/history_dropped)
          (worker/history_dropped ~ Cell/set
            (+ data/history_dropped
               (- saved_history/~size restored_history/~size)))
          (worker/history_dropped ~ Cell/set
            (- saved_history/~size restored_history/~size)))
        ((app/workers ~ Cell/get) ~ List/push! worker)
        (emit_restore_normalization! app worker data)
        (if (&& (== (worker/lifecycle ~ Cell/get) "running")
                (== worker/kind "stats"))
          ((app/event_observers ~ Cell/get) ~ List/push!
            {^worker_id worker/id
             ^handler (fn [event]
               (if_not (== event/projection true)
                 (application_set_projection_output!
                   app worker (stats_worker_text app) "stats")))})
          (if (&& (== (worker/lifecycle ~ Cell/get) "running")
                  (== worker/kind "log_tail"))
            ((app/event_observers ~ Cell/get) ~ List/push!
              {^worker_id worker/id
               ^handler (fn [event]
                 (if (&& (!= event/projection true)
                         (event_matches? event
                           (worker/controller/filter ~ Cell/get)))
                   (application_append_projection_output!
                     app worker
                     $"${(format_event_with_filters event (worker/controller/filter ~ Cell/get))}\n"
                     "log_tail")))})))
      catch {^message message}
        (emit_restore_rejected! app "worker" record_id message)
      catch _
        (emit_restore_rejected! app "worker" record_id
          "unknown worker restore failure")))
    # Rebuild output follow edges only after every worker exists. Adding each
    # edge through the ordinary validator drops stale references and rejects
    # persisted self/transitive cycles before any output can propagate.
    (for worker in (app/workers ~ Cell/get)
      (if (== worker/kind "output")
        (then
          (var saved_following (worker/controller/following ~ Cell/get))
          (worker/controller/following ~ Cell/set [])
          (for source_id in saved_following
            (var followed
              (application_follow_output!
                app worker (application_find_worker app source_id)))
            (if_not followed/ok
              (emit_restore_rejected! app "worker" worker/id
                $"invalid follow ${source_id}: ${followed/error}"))))))
    (var surface app/local_surface)
    (var retained_pane_data [])
    (var dropped_panes 0)
    (for data in (if (|| (== surface nil) (! (present? saved/panes)))
                   [] saved/panes)
      (if (< retained_pane_data/~size surface/max_panes)
        (retained_pane_data ~ List/push! data)
        (set dropped_panes (+ dropped_panes 1))))
    (for data in retained_pane_data
      (var record_id (persisted_record_id data))
      (try
      (match data
        (when (_record : Map) nil)
        (else (fail (OsError ^message "pane record must be a map"))))
      (if_not (match data/id (when (_id : Int) true) (else false))
        (fail (OsError ^message "pane id must be an Int")))
      (if (&& (present? data/worker_id)
              (! (match data/worker_id
                   (when (_worker_id : Str) true) (else false))))
        (fail (OsError ^message "pane worker_id must be a Str")))
      (if_not (["agent" "shell" "repl" "output" "log_tail"
                "file_view" "stats"] ~ contains? data/kind)
        (fail (OsError ^message "pane kind is invalid")))
      (if (&& (present? data/title)
              (! (match data/title (when (_title : Str) true) (else false))))
        (fail (OsError ^message "pane title must be a Str")))
      (if (&& (present? data/scroll)
              (|| (! (match data/scroll
                       (when (_scroll : Int) true) (else false)))
                  (< data/scroll 0)))
        (fail (OsError ^message "pane scroll must be a non-negative Int")))
      (if (&& (present? data/hidden)
              (! (match data/hidden
                   (when (_hidden : Bool) true) (else false))))
        (fail (OsError ^message "pane hidden must be a Bool")))
      (var worker
          (if (present? data/worker_id)
            (application_find_worker app data/worker_id)
            (if (== data/kind "agent")
              (application_find_agent app data/owner_id))))
        # Backward compatibility for the shipped pane-owned snapshot:
        # materialize its producer as a stopped worker before attaching the
        # restored view.
        (if_yes (&& (== worker nil) (! (present? data/worker_id)))
            (var seq (app/next_worker_id ~ Cell/get))
            (app/next_worker_id ~ Cell/set (+ seq 1))
            (var controller
              (match data/kind
                (when "shell"
                  (ShellController
                    ^cwd (cell (if (== data/cwd void)
                                 workspace_root data/cwd))
                    ^environment (cell {})))
                (when "repl"
                  (ReplController ^session nil ^items nil ^transcript nil
                                  ^memory nil ^streaming (cell false)
                                  ^resume_requested (cell false)))
                (else (OutputController ^source "restored" ^following (cell [])))))
            (set worker
              (make_worker $"w${seq}" data/kind
                (if (== data/title void) data/kind data/title)
                (cell (if (== data/output void) "" data/output))
                controller))
            (worker/lifecycle ~ Cell/set
              (if (|| (== data/kind "shell") (== data/kind "repl"))
                "stopped" "running"))
            (worker/status ~ Cell/set
              (if (== (worker/lifecycle ~ Cell/get) "stopped")
                "stopped" "idle"))
            (if (!= data/history void)
              (worker/history ~ Cell/set data/history))
            ((app/workers ~ Cell/get) ~ List/push! worker))
        (if_yes worker
            (var pane
              (Pane ^id data/id ^worker_id worker/id ^worker worker
                    ^kind worker/kind ^owner_id data/owner_id
                    ^title (if (present? data/title)
                             data/title worker/title)
                    ^output worker/output
                    ^status worker/status ^current_task worker/current_task
                    ^history worker/history
                    ^scroll (cell (if (== data/scroll void) 0 data/scroll))
                    ^controller (if (== worker/kind "agent")
                                  worker worker/controller)
                    ^pending_visible (cell false)
                    ^hidden (cell (if (present? data/hidden)
                                    data/hidden false))
                    ^close_policy "detach"))
            ((surface/panes ~ Cell/get) ~ List/push! pane))
        (if (== worker nil)
          (fail (OsError ^message "pane references a missing worker")))
      catch {^message message}
        (emit_restore_rejected! app "pane" record_id message)
      catch _
        (emit_restore_rejected! app "pane" record_id
          "unknown pane restore failure")))
    (if (match saved/next_agent_id (when (_id : Int) true) (else false))
      (app/next_agent_id ~ Cell/set saved/next_agent_id)
      (emit_restore_rejected! app "counter" "next_agent_id"
        "counter must be an Int"))
    (if (present? saved/next_worker_id)
      (if (match saved/next_worker_id (when (_id : Int) true) (else false))
        (app/next_worker_id ~ Cell/set saved/next_worker_id)
        (emit_restore_rejected! app "counter" "next_worker_id"
          "counter must be an Int")))
    (if (present? saved/next_task_id)
      (if (match saved/next_task_id (when (_id : Int) true) (else false))
        (app/next_task_id ~ Cell/set saved/next_task_id)
        (emit_restore_rejected! app "counter" "next_task_id"
          "counter must be an Int")))
    (if (&& (!= surface nil) (present? saved/surface))
      (then
        (try
          (restore_surface_record! app surface saved/surface)
        catch {^message message}
          (emit_restore_rejected! app "surface" surface/id message)
        catch _
          (emit_restore_rejected! app "surface" surface/id
            "unknown surface restore failure")))
      (else
        (if (&& (!= surface nil) (present? saved/next_pane_id))
          (surface/next_pane_id ~ Cell/set saved/next_pane_id))))
    (if (&& (!= surface nil)
            (!= (surface/focused_pane ~ Cell/get) nil)
            (== (application_find_pane app
                  (surface/focused_pane ~ Cell/get)) nil))
      (surface/focused_pane ~ Cell/set nil))
    (if (&& (!= surface nil)
            (!= (surface/focused_pane ~ Cell/get) nil))
      (then
        (var focused
          (application_find_pane app (surface/focused_pane ~ Cell/get)))
        (if focused (focused/hidden ~ Cell/set false))))
    (if (&& (!= surface nil)
            (!= (surface/maximized_pane ~ Cell/get) nil)
            (== (application_find_pane app
                  (surface/maximized_pane ~ Cell/get)) nil))
      (surface/maximized_pane ~ Cell/set nil))
    (application_prune_stopped_workers! app)
    (application_emit app "application_restored"
      {^agents ((if (present? saved/agents) saved/agents []) ~ size)
       ^workers ((if (present? saved/workers) saved/workers []) ~ size)
       ^panes (if (== surface nil) 0 ((surface/panes ~ Cell/get) ~ size))
       ^dropped_panes dropped_panes})
    true))

(fn restore_application! [app]
  (var restored false)
  (agent_checkpoint_suspended ~ Cell/set true)
  (try
    (try
      (set restored
        (restore_application_snapshot! app
          (if (resume_enabled?) (state_get "application" nil))))
    catch {^message message}
      (emit_restore_rejected! app "application" "application" message)
      (set restored false)
    catch _
      (emit_restore_rejected! app "application" "application"
        "unknown restore failure")
      (set restored false))
  ensure
    (agent_checkpoint_suspended ~ Cell/set false))
  (if restored (checkpoint_agent_state! app "application_restored"))
  restored)

(fn save_agent_state_with_reason [items, transcript, memory, reason : Str]
  (debug! state_log "agent state snapshot started"
    ^payload {^items (items ~ size) ^transcript_bytes (byte_size transcript)
              ^memory_items (memory ~ size)
              ^events ((agent_events ~ Cell/get) ~ size)})
  (if_yes (agent_store ~ Cell/get)
    (var app (active_application ~ Cell/get))
    (var records
      {^config {^schema 1 ^kind "config" ^data (config_snapshot)}
       ^memory {^schema 1 ^kind "memory" ^data memory}
       ^events
         {^schema 1 ^kind "events"
          ^data {^events (agent_events ~ Cell/get)
                 ^next_v (next_event_v ~ Cell/get)
                 ^dropped_before (event_dropped_before ~ Cell/get)
                 ^turn (current_turn ~ Cell/get)}}
       ^session
         {^schema 1 ^kind "session"
          ^data {^items items ^transcript transcript}}
       ^application
         {^schema 1 ^kind "application"
          ^data (if app (application_snapshot app) nil)}
       ^registrations
         {^schema 1 ^kind "registrations"
          ^data (dynamic_registration_records ~ Cell/get)}
       ^checkpoint
         {^schema 1 ^kind "checkpoint"
          ^data {^reason reason ^turn (current_turn ~ Cell/get)
                 ^event_v (- (next_event_v ~ Cell/get) 1)}}})
    (var seq (+ (agent_checkpoint_seq ~ Cell/get) 1))
    ((agent_store ~ Cell/get) ~ checkpoint seq records)
    (agent_checkpoint_seq ~ Cell/set seq)
    (agent_checkpoint_last_ms ~ Cell/set (monotonic_ms))
    (agent_loaded_checkpoint ~ Cell/set
      {^generation seq ^schema 1 ^records records})
    seq))

(fn save_agent_state [items, transcript, memory]
  (save_agent_state_with_reason items transcript memory "state_saved"))

(fn immediate_checkpoint_event? [type : Str] : Bool
  (["tool_call" "tool_result" "turn_done"
    "worker_started" "worker_named" "worker_operation_started"
    "worker_operation_finished" "worker_operation_cancelling"
    "worker_admission_cancelled" "worker_stopped"
    "agent_spawned" "agent_status" "agent_completed"
    "pane_opened" "pane_closed" "file_change" "check"
    "context_compacted" "confirmation" "memory"
    "config_changed" "artifact_pinned" "artifact_deleted"
    "supervisor_result_dropped"] ~ contains? type))

(fn progress_checkpoint_event? [type : Str] : Bool
  (== type "worker_output"))

(fn checkpoint_local_application? [app] : Bool
  (var local (active_application ~ Cell/get))
  (&& (!= app nil) (!= local nil)
      (== app/coordinator_id local/coordinator_id)))

(fn checkpoint_agent_state! [app, reason : Str] : Bool
  (if (|| (! (state_enabled?))
          (== (agent_store ~ Cell/get) nil)
          (! (checkpoint_local_application? app))
          (agent_checkpoint_suspended ~ Cell/get)
          (agent_checkpoint_writing ~ Cell/get)
          (app/shutting_down ~ Cell/get))
    (then false)
    (else
      (agent_checkpoint_writing ~ Cell/set true)
      (try
        (var main app/main_agent)
        (var seq
          (save_agent_state_with_reason
            (main/items ~ Cell/get)
            (main/transcript ~ Cell/get)
            (app/memory ~ Cell/get) reason))
        (debug! state_log "agent state checkpoint saved"
          ^payload {^checkpoint_sequence seq ^checkpoint_reason reason
                    ^turn_id (current_turn ~ Cell/get)})
        true
      ensure
        (agent_checkpoint_writing ~ Cell/set false)))))

(fn checkpoint_application_event! [app, type : Str]
  (if (immediate_checkpoint_event? type)
    (checkpoint_agent_state! app type)
    (if (&& (progress_checkpoint_event? type)
            (>= (- (monotonic_ms)
                   (agent_checkpoint_last_ms ~ Cell/get))
                agent_checkpoint_interval_ms))
      (checkpoint_agent_state! app type))))

(fn restore_events []
  (var saved (state_get "events" nil))
  (if_yes saved
    (agent_events ~ Cell/set saved/events)
    (var restored_event_bytes 0)
    (for event in saved/events
      (set restored_event_bytes
        (+ restored_event_bytes (byte_size (stringify event)))))
    (agent_event_bytes ~ Cell/set restored_event_bytes)
    (agent_evidence ~ Cell/set
      ((to_stream saved/events) ~ filter evidence_event? ; ~ into []))
    (next_event_v ~ Cell/set saved/next_v)
    (event_dropped_before ~ Cell/set
      (if (== saved/dropped_before void) 0 saved/dropped_before))
    (trim_agent_event_journal!)
    (current_turn ~ Cell/set saved/turn)
    (info! state_log "event state restored"
      ^payload {^events (saved/events ~ size) ^next_event_v saved/next_v
                ^turn_id saved/turn})))

(fn after_prefix [s : Str, prefix : Str] : Str
  (var parts (split s prefix))
  (var i (cell 0))
  (var acc (cell ""))
  ((to_stream parts)
    ~ each (fn [p]
        (var n (i ~ Cell/get))
        (i ~ Cell/set (+ n 1))
        (if_not (== n 0)
          (if (== n 1)
            (acc ~ Cell/set p)
            (acc ~ Cell/set $"${(acc ~ Cell/get)}${prefix}${p}")))))
  (acc ~ Cell/get))

(fn undo_command [line : Str]
  (var app (active_application ~ Cell/get))
  (var worker_id (if (== app nil) "main" app/main_agent/id))
  (if (== line "/undo")
    (undo_with_workspace_lease app worker_id nil)
    (try
      (undo_with_workspace_lease app worker_id
        (parse_int (trim (after_prefix line "/undo "))))
    catch _
      "usage: /undo [change-id]")))

# -----------------------------------------------------------------------------
# Offline demo transport: turn 1 asks to list the workspace, turn 2 answers.
# Proves the full tool_call loop with no network or key.
# -----------------------------------------------------------------------------

(fn demo_transport_for []
  (var calls (cell 0))
  (fn [body, render_stream]
    (Cell/set calls (+ (Cell/get calls) 1))
    (if (== (Cell/get calls) 1)
      {^output [{^type "function_call" ^name "list_dir"
                 ^call_id "call_1" ^arguments "{\"path\":\".\"}"}]}
      {^output [{^type "message" ^role "assistant"
                 ^content [{^type "output_text"
                            ^text "I listed the workspace via the list_dir tool."}]}]})))

# -----------------------------------------------------------------------------
# Entry point.
# -----------------------------------------------------------------------------

(fn run_demo []
  (println "No OPENAI_AUTH_TOKEN, OPENAI_API_KEY, or CODEX_ACCESS_TOKEN set — running the offline demo.")
  (println "user> what's in this directory?")
  (begin_turn!)
  (emit_event! "user_input" {^text "what's in this directory?"})
  (var items [(system_item gene_system_prompt)
              (user_item "what's in this directory?")])
  (run_turn_tracked (demo_transport_for) items
    (fn [text] (println $"agent> ${text}"))
    ignore_stream_delta
    max_tool_rounds
    emit_event!)
  (println "Demo complete. Set OPENAI_AUTH_TOKEN, OPENAI_API_KEY, or CODEX_ACCESS_TOKEN to go live."))

(fn run_one_shot [task : Str]
  (init_agent_state)
  (start_workspace_heartbeat!)
  (restore_reasoning_effort!)
  (restore_dynamic_registrations! nil)
  (println $"Gene AI agent - model ${model}")
  (println $"user> ${task}")
  (if (== auth_token nil)
    (println "No OPENAI_AUTH_TOKEN, OPENAI_API_KEY, or CODEX_ACCESS_TOKEN set - using offline demo transport."))
  (var streaming (cell false))
  (var transport (if (== auth_token nil) (demo_transport_for) live_transport))
  (var memory (load_memory))
  (begin_turn!)
  (emit_event! "user_input" {^text task})
  (var result_items
    (run_turn_tracked transport
              (append (initial_items memory) (user_item task))
              (fn [text]
                (if_yes (Cell/get streaming)
                    (println "")
                    (Cell/set streaming false))
                (if_not (== text "")
                  (println $"agent> ${text}")))
              (fn [text]
                (if_not (== text "")
                  (if_not (Cell/get streaming)
                      (print "agent> ")
                      (Cell/set streaming true))
                  (print text)))
              max_tool_rounds
              emit_event!))
  (save_agent_state result_items $"Gene AI agent - model ${model}\nuser> ${task}\n" memory)
  (if (Cell/get streaming)
    (println "")))

(fn exit_word? [line]
  (["exit" "quit"] ~ contains? line))

(fn blank_line? [line]
  (== (trim line) ""))

(fn transcript_loss_marker [dropped : Int] : Str
  (var verbose $"[older transcript dropped: ${dropped} bytes]\n")
  (if (<= (byte_size verbose) transcript_max_bytes)
    verbose
    (utf8_prefix $"[drop:${dropped}]\n" transcript_max_bytes)))

(fn append_agent_transcript! [agent, text : Str]
  (var safe_text (redact text))
  (var combined $"${(agent/transcript_retained ~ Cell/get)}${safe_text}")
  (var total (byte_size combined))
  (var previous (agent/transcript_dropped_bytes ~ Cell/get))
  (var seq (agent/transcript_seq ~ Cell/get))
  (agent/transcript_seq ~ Cell/set (+ seq 1))
  (var existing_marker
    (if (> previous 0) (transcript_loss_marker previous) ""))
  (var existing_budget (- transcript_max_bytes (byte_size existing_marker)))
  (if (< existing_budget 0) (set existing_budget 0))
  (if (<= total existing_budget)
    (then
      (agent/transcript_retained ~ Cell/set combined)
      (agent/transcript ~ Cell/set $"${existing_marker}${combined}"))
    (else
      (var dropped
        (if (> previous 0) previous (- total transcript_max_bytes)))
      (var marker "")
      (var budget 0)
      (var start 0)
      (var retained "")
      (var settled (cell false))
      (var attempts 0)
      (var sliced (cell false))
      (var exact 0)
      (while (&& (! (settled ~ Cell/get)) (< attempts 8))
        (set marker (transcript_loss_marker dropped))
        (set budget (- transcript_max_bytes (byte_size marker)))
        (if (< budget 0) (set budget 0))
        (set start (- total budget))
        (set retained "")
        (sliced ~ Cell/set false)
        (while (&& (! (sliced ~ Cell/get)) (< start total))
          (try
            (set retained (slice_bytes combined start (- total start)))
            (sliced ~ Cell/set true)
          catch _ (set start (+ start 1))))
        (set exact (+ previous start))
        (if (== exact dropped)
          (settled ~ Cell/set true)
          (set dropped exact))
        (set attempts (+ attempts 1)))
      (set marker (transcript_loss_marker dropped))
      (agent/transcript_dropped_bytes ~ Cell/set dropped)
      (agent/transcript_dropped_before ~ Cell/set seq)
      (agent/transcript_retained ~ Cell/set retained)
      (agent/transcript ~ Cell/set $"${marker}${retained}")))
  seq)

(fn append_transcript [transcript, text : Str]
  (var app (active_application ~ Cell/get))
  (if (&& (!= app nil) (== app/main_agent/transcript transcript))
    (then (append_agent_transcript! app/main_agent text))
    # Offline/demo callers without an application still stay bounded; shared
    # application snapshots always take the exact branch above.
    (else
      (var combined (join [(Cell/get transcript) text] ""))
      (var total (byte_size combined))
      (if (<= total transcript_max_bytes)
        (then (Cell/set transcript combined))
        (else
          (var marker "[older transcript rows were dropped]\n")
          (var budget (- transcript_max_bytes (byte_size marker)))
          (var start (- total budget))
          (var retained "")
          (var sliced (cell false))
          (while (&& (! (sliced ~ Cell/get)) (< start total))
            (try
              (set retained (slice_bytes combined start (- total start)))
              (sliced ~ Cell/set true)
            catch _ (set start (+ start 1))))
          (Cell/set transcript $"${marker}${retained}"))))))

(fn input_route_label []
  (var app (active_application ~ Cell/get))
  (if (|| (== app nil) (== app/local_surface nil))
    (then "[0 main]")
    (else
      (var pane_id (app/local_surface/focused_pane ~ Cell/get))
      (var pane
        (if pane_id (application_find_pane app pane_id)))
      (if (== pane nil) "[0 main]" $"[${pane/id} ${pane/kind}]"))))

(fn current_input_status []
  (var app (active_application ~ Cell/get))
  (var pane_id
    (if (|| (== app nil) (== app/local_surface nil)) nil
      (app/local_surface/focused_pane ~ Cell/get)))
  (var pane
    (if pane_id (application_find_pane app pane_id)))
  (if (== pane nil)
    (then
      (var progress (if app (app/progress ~ Cell/get)))
      (var progress_hint
        (if (|| (== progress nil) (== progress/objective "")) ""
          $" | ${progress/phase}/${progress/status}"))
      $"[0 main] Enter send | Tab complete | Ctrl-R history | Ctrl-E edit | /help | Esc cancel${progress_hint}")
    (else
      (var worker pane/worker)
      (var state
        (if (!= (worker/current_task ~ Cell/get) nil) "working"
          (worker/status ~ Cell/get)))
      (match pane/kind
        (when "agent"
          $"[${pane/id} agent ${worker/id}: ${state}] Enter send | /0 main | Esc cancel | PgUp/PgDn scroll")
        (when "shell"
          $"[${pane/id} shell ${worker/id}: ${state}] Enter run | /0 main | //literal slash | Ctrl-C cancel | PgUp/PgDn scroll")
        (when "repl"
          $"[${pane/id} repl ${worker/id}: ${state}] Enter eval | /0 main | //literal slash | Ctrl-C cancel | PgUp/PgDn scroll")
        (else
          $"[${pane/id} ${pane/kind} ${worker/id}: read-only] /0 main | PgUp/PgDn scroll | /close | /help")))))

(fn surface_route_input_capable? [app] : Bool
  (if (|| (== app nil) (== app/local_surface nil))
    (then true)
    (else
      (var pane_id (app/local_surface/focused_pane ~ Cell/get))
      (var pane (if pane_id (application_find_pane app pane_id)))
      (|| (== pane nil)
          (["agent" "shell" "repl" "log_tail"] ~ contains? pane/kind)))))

(fn editor_accepts_surface_text? [app, editor, text : Str] : Bool
  (|| (surface_route_input_capable? app)
      (starts_with? (editor_text (editor/values ~ Cell/get)) "/")
      (starts_with? text "/")))

(fn surface_route_history [app]
  (var surface app/local_surface)
  (var pane_id (surface/focused_pane ~ Cell/get))
  (var pane
    (if pane_id (application_find_pane app pane_id)))
  (var worker_id (if (== pane nil) app/main_agent/id pane/worker_id))
  (var histories (surface/input_histories ~ Cell/get))
  (var history (histories ~ Map/get worker_id))
  (if_yes (== history void)
      (set history (cell []))
      (histories ~ Map/put! worker_id history))
  history)

(fn surface_route_draft [app]
  (var surface app/local_surface)
  (var pane_id (surface/focused_pane ~ Cell/get))
  (var pane
    (if pane_id (application_find_pane app pane_id)))
  (var worker_id (if (== pane nil) app/main_agent/id pane/worker_id))
  (var drafts (surface/drafts ~ Cell/get))
  (var draft (drafts ~ Map/get worker_id))
  (if_yes (== draft void)
      (set draft (cell ""))
      (drafts ~ Map/put! worker_id draft))
  draft)

(fn surface_history_push! [history, value]
  ((history ~ Cell/get) ~ List/push! value)
  (if_yes (> ((history ~ Cell/get) ~ size) surface_history_max)
      (var current (history ~ Cell/get))
      (var first (- (current ~ size) surface_history_max))
      (var kept [])
      (repeat i in current/~size
        (if (>= i first) (kept ~ List/push! current/%i)))
      (history ~ Cell/set kept)))

(fn record_local_surface_history! [worker_id : Str, value : Str, surface_id]
  (var app (active_application ~ Cell/get))
  (if (&& app app/local_surface
          (|| (== surface_id nil)
              (== surface_id (app/local_surface/instance_id ~ Cell/get))))
    (then
      (var histories (app/local_surface/input_histories ~ Cell/get))
      (var history (histories ~ Map/get worker_id))
      (if (== history void)
        (then
          (set history (cell []))
          (histories ~ Map/put! worker_id history)))
      # Worker history stores the semantic input after routing. Surface recall
      # must restore the escape needed to submit a literal leading slash
      # through the command parser again.
      (surface_history_push! history
        (if (starts_with? value "/") $"/${value}" value)))))

(fn extension_views []
  (var app (active_application ~ Cell/get))
  (if (== app nil) [] (application_pane_views app)))

(fn find_extension [id : Int]
  (var app (active_application ~ Cell/get))
  (if app (application_find_pane app id)))

(fn ensure_user_screen []
  (if (== (user_screen ~ Cell/get) nil)
    (user_screen ~ Cell/set (curses_open)))
  (user_screen ~ Cell/get))

(fn close_user_input []
  (if_yes (!= (user_screen ~ Cell/get) nil)
      (curses_close (user_screen ~ Cell/get))
      (user_screen ~ Cell/set nil)))

(fn suspend_user_input []
  # Surface-local terminal handoffs must not let an event callback reopen
  # curses over the external editor or real shell while application fibers
  # continue progressing in the background.
  (user_input_suspended ~ Cell/set true)
  (close_user_input))

(fn resume_user_input []
  (user_input_suspended ~ Cell/set false))

(fn editor_chars [text : Str]
  # Graphemes are strings (unlike `chars`, whose Char values print as source
  # literals), and they keep combining sequences together during navigation.
  (graphemes text))

(fn editor_text [values]
  (join values ""))

(fn editor_cursor_byte [values, cursor : Int]
  (var prefix [])
  (repeat i in cursor
    (prefix ~ List/push! values/%i))
  (byte_size (editor_text prefix)))

(fn editor_insert! [editor, text : Str]
  (var values (editor/values ~ Cell/get))
  (var cursor (editor/cursor ~ Cell/get))
  (var current_text (editor_text values))
  (var remaining (- surface_draft_max_bytes (byte_size current_text)))
  (var accepted
    (if (<= remaining 0) ""
      (utf8_prefix text remaining)))
  (var additions (editor_chars accepted))
  (var updated [])
  (repeat i in values/~size
    (if (== i cursor)
      (for value in additions (updated ~ List/push! value)))
    (updated ~ List/push! values/%i))
  (if (== cursor values/~size)
    (for value in additions (updated ~ List/push! value)))
  (editor/values ~ Cell/set updated)
  (editor/cursor ~ Cell/set (+ cursor additions/~size))
  nil)

(fn editor_remove! [editor, index : Int]
  (var values (editor/values ~ Cell/get))
  (if (|| (< index 0) (>= index values/~size))
    (then false)
    (else
      (var updated [])
      (repeat i in values/~size
        (if (!= i index) (updated ~ List/push! values/%i)))
      (editor/values ~ Cell/set updated)
      true)))

(fn editor_set_text! [editor, text : Str]
  (var values (editor_chars text))
  (editor/values ~ Cell/set values)
  (editor/cursor ~ Cell/set values/~size)
  nil)

(fn editor_clear! [editor]
  (editor/values ~ Cell/set [])
  (editor/cursor ~ Cell/set 0)
  (editor/history_index ~ Cell/set editor/history/~size)
  (editor/draft ~ Cell/set "")
  nil)

(fn editor_history! [editor, direction : Int]
  (var history editor/history)
  (var index (editor/history_index ~ Cell/get))
  (if (&& (< direction 0) (> index 0))
    (then
      (if (== index history/~size)
        (editor/draft ~ Cell/set
          (editor_text (editor/values ~ Cell/get))))
      (set index (- index 1))
      (editor/history_index ~ Cell/set index)
      (editor_set_text! editor history/%index)
      true)
    (else
      (if (&& (> direction 0) (< index history/~size))
        (then
          (set index (+ index 1))
          (editor/history_index ~ Cell/set index)
          (editor_set_text! editor
            (if (== index history/~size)
              (editor/draft ~ Cell/get)
              history/%index))
          true)
        (else false)))))

(fn editor_home! [editor]
  (var values (editor/values ~ Cell/get))
  (var cursor (editor/cursor ~ Cell/get))
  (while (&& (> cursor 0) (!= values/%(- cursor 1) "\n"))
    (set cursor (- cursor 1)))
  (editor/cursor ~ Cell/set cursor))

(fn editor_end! [editor]
  (var values (editor/values ~ Cell/get))
  (var cursor (editor/cursor ~ Cell/get))
  (while (&& (< cursor values/~size) (!= values/%cursor "\n"))
    (set cursor (+ cursor 1)))
  (editor/cursor ~ Cell/set cursor))

(fn completion_item [value : Str, label : Str, detail : Str]
  {^value value ^label label ^detail detail})

(fn completion_labels [overlay]
  (var labels [])
  (if overlay
    (for item in overlay/items
      (labels ~ List/push!
        (if (== item/detail "") item/label
          $"${item/label}  ${item/detail}"))))
  labels)

(fn replace_last_token [text : Str, replacement : Str] : Str
  (var tokens (split text " "))
  (var rebuilt [])
  (repeat i in tokens/~size
    (if (< i (- tokens/~size 1))
      (rebuilt ~ List/push! tokens/%i)))
  (rebuilt ~ List/push! replacement)
  (rebuilt ~ join " "))

(fn worker_completion_items [app, prefix : Str, agents_only : Bool]
  (var out [])
  (for worker in (app/workers ~ Cell/get)
    (if (|| (! agents_only) (== worker/kind "agent"))
      (do
        (var label (if worker/name worker/name worker/id))
        (if (starts_with? label prefix)
          (out ~ List/push!
            (completion_item label label
              $"${worker/kind} ${(worker/status ~ Cell/get)}")))
        (if (&& worker/name (starts_with? worker/id prefix))
          (out ~ List/push!
            (completion_item worker/id worker/id
              $"${worker/kind} ${(worker/status ~ Cell/get)}"))))))
  out)

(fn pane_completion_items [app, prefix : Str, include_main : Bool]
  (var out [])
  (if (&& include_main (starts_with? "0" prefix))
    (out ~ List/push! (completion_item "0" "0" "main agent")))
  (for pane in (app/local_surface/panes ~ Cell/get)
    (var id $"${pane/id}")
    (if (starts_with? id prefix)
      (out ~ List/push!
        (completion_item id id
          $"${pane/kind} ${(pane/status ~ Cell/get)}"))))
  out)

(fn operation_visible_to_local? [operation] : Bool
  (&& (!= operation/enabled false)
      (operation/audience ~ contains? "local_user")))

(fn verb_completion_items [verbs, prefix : Str, base : Str]
  (var out [])
  (for verb in verbs
    (if (starts_with? verb prefix)
      (out ~ List/push! (completion_item $"${base}${verb} " verb "action"))))
  out)

(fn shell_completion_context [text : Str]
  # Lex only the current shell word. No expansion is executed; substitutions
  # and quote transitions in the middle of a token are intentionally
  # ambiguous and produce no candidates.
  (var values (editor_chars text))
  (var token [])
  (var token_start 0)
  (var state "plain")
  (var quote "")
  (var escaped false)
  (var ch "")
  (repeat i in values/~size
    (set ch values/%i)
    (if escaped
      (do
        (token ~ List/push! ch)
        (set escaped false))
      (match state
        (when "single"
          (if (== ch "'") (set state "plain")
            (token ~ List/push! ch)))
        (when "double"
          (if (== ch "\"")
            (set state "plain")
            (if (== ch "\\")
              (set escaped true)
              (if (|| (== ch "$") (== ch "`"))
                (return nil)
                (token ~ List/push! ch)))))
        (else
          (if (contains? " \t\n" ch)
            (do
              (set token [])
              (set token_start (+ i 1))
              (set quote ""))
            (if (== ch "\\")
              (set escaped true)
              (if (|| (== ch "$") (== ch "`"))
                (return nil)
                (if (|| (== ch "'") (== ch "\""))
                  (if (! (empty? token))
                    (return nil)
                    (do
                      (set quote ch)
                      (set state (if (== ch "'") "single" "double"))))
                  (token ~ List/push! ch)))))))))
  (if escaped (return nil))
  (var before [])
  (repeat j in token_start (before ~ List/push! values/%j))
  {^before (editor_text before) ^prefix (editor_text token) ^quote quote})

(fn shell_completion_path_parts [prefix : Str]
  (var parts (split prefix "/"))
  (var directories [])
  (repeat i in parts/~size
    (if (< i (- parts/~size 1))
      (directories ~ List/push! parts/%i)))
  (var last (- parts/~size 1))
  {^directory (directories ~ join "/")
   ^base (if (empty? parts) "" parts/%last)})

(fn shell_completion_render [context, candidate : Str]
  (var rendered candidate)
  (if (== context/quote "'")
    (if (contains? candidate "'") (return nil)
      (set rendered $"'${candidate}'"))
    (if (== context/quote "\"")
      (if (|| (contains? candidate "\"") (contains? candidate "\\"))
        (return nil)
        (set rendered $"\"${candidate}\""))
      (if (|| (contains? candidate " ") (contains? candidate "\t"))
        (if (contains? candidate "'") (return nil)
          (set rendered $"'${candidate}'")))))
  $"${context/before}${rendered}")

(fn workspace_path_completion_items [text : Str]
  (var out [])
  (var context (shell_completion_context text))
  (if (== context nil) (return out))
  (var path_parts (shell_completion_path_parts context/prefix))
  (var directory
    (if (== path_parts/directory "") "." path_parts/directory))
  (try
    (var checked_directory (safe_path directory))
    (for name in (list_dir ReadDir checked_directory)
      (if (&& (< out/~size surface_overlay_max_items)
              (starts_with? name path_parts/base))
        (do
          (var candidate
            (if (== path_parts/directory "") name
              $"${path_parts/directory}/${name}"))
          (var detail "workspace")
          (try
            (list_dir ReadDir (safe_path candidate))
            (set candidate $"${candidate}/")
            (set detail "workspace directory")
          catch _ nil)
          (var value (shell_completion_render context candidate))
          (if value
            (out ~ List/push! (completion_item value candidate detail))))))
  catch _ nil)
  out)

(fn shell_route_completion_items [worker, text : Str]
  (var out (workspace_path_completion_items text))
  (var seen {})
  (for item in out (seen ~ Map/put! item/label true))
  (var context (shell_completion_context text))
  (if (== context nil) (return out))
  (for record in (worker/history ~ Cell/get)
    (for token in (split record/text " ")
      (if (&& (< out/~size surface_overlay_max_items)
              (!= token "")
              (starts_with? token context/prefix)
              (== (seen ~ Map/get token) void)
              (! (contains? token "$")) (! (contains? token "`"))
              (! (contains? token "'")) (! (contains? token "\""))
              (! (contains? token "\\")))
        (do
          (var value (shell_completion_render context token))
          (if value
            (do
              (seen ~ Map/put! token true)
              (out ~ List/push!
                (completion_item value token "shell history"))))))))
  out)

(fn command_completion_items [text : Str]
  (var out [])
  (for spec in surface_command_specs
    (if (starts_with? spec/name text)
      (out ~ List/push!
        (completion_item spec/name spec/name spec/summary))))
  out)

(fn operation_argument_field [operation, parts]
  (var fields (operation/args ~ fields))
  (var index (- parts/~size 4))
  (if (&& (>= index 0) (< index fields/~size)) fields/%index))

(fn worker_command_completion_items [app, text : Str, parts]
  (var out [])
  (if (<= parts/~size 2)
    (do
      (var prefix (if (== parts/~size 2) parts/1 ""))
      (for item in (worker_completion_items app prefix false)
        (out ~ List/push!
          (completion_item $"/worker ${item/value} " item/label item/detail))))
    (do
      (var target parts/1)
      (var worker (application_find_worker app target))
      (if worker
        (do
          (var operation_name parts/2)
          (if (<= parts/~size 3)
            (for operation in (worker_operations_for_kind worker/kind)
              (if (&& (operation_visible_to_local? operation)
                      (starts_with? operation/name operation_name))
                (out ~ List/push!
                  (completion_item $"/worker ${target} ${operation/name} "
                    operation/name operation/summary))))
            (do
              (var operation
                (worker_operation_for worker/kind operation_name))
              (if (&& operation (operation_visible_to_local? operation))
                (do
                  (var field (operation_argument_field operation parts))
                  (if (&& field (== field/name "path"))
                  (set out (workspace_path_completion_items text))
                  (if (&& field (== field/name "source"))
                    (do
                      (var last (- parts/~size 1))
                      (var prefix parts/%last)
                      (for item in (worker_completion_items app prefix false)
                        (out ~ List/push!
                          (completion_item
                            (replace_last_token text item/value)
                            item/label item/detail)))))))))))))
  out))

(fn agent_command_completion_items [app, parts]
  (var out [])
  (var target (if (> parts/~size 1) parts/1 ""))
  (if (<= parts/~size 2)
    (do
      (for item in (verb_completion_items ["list" "new"] target "/agent ")
        (out ~ List/push! item))
      (for item in (worker_completion_items app target true)
        (out ~ List/push!
          (completion_item $"/agent ${item/value} " item/label item/detail))))
    (do
      (var agent (application_find_agent app target))
      (if agent
        (do
          (var prefix parts/2)
          (if (starts_with? "open" prefix)
            (out ~ List/push!
              (completion_item $"/agent ${target} open " "open" "open pane")))
          (for operation in (worker_operations_for_kind "agent")
            (if (&& (operation_visible_to_local? operation)
                    (starts_with? operation/name prefix))
              (out ~ List/push!
                (completion_item $"/agent ${target} ${operation/name} "
                  operation/name operation/summary))))))))
  out)

(fn pane_command_completion_items [app, parts]
  (var out [])
  (var action (if (> parts/~size 1) parts/1 ""))
  (if (<= parts/~size 2)
    (do
      (for item in
          (verb_completion_items
            ["list" "new" "open" "focus" "show" "hide" "close" "max"]
            action "/pane ")
        (out ~ List/push! item))
      (for item in (pane_completion_items app action true)
        (out ~ List/push!
          (completion_item $"/pane ${item/value} " item/label item/detail))))
    (do
      (var prefix parts/2)
      (if (== action "new")
        (for item in
            (verb_completion_items
              ["agent" "shell" "repl" "tail" "output" "view" "stats"]
              prefix "/pane new ")
          (out ~ List/push! item)))
      (if (== action "open")
        (for item in (worker_completion_items app prefix false)
          (out ~ List/push!
            (completion_item $"/pane open ${item/value} "
              item/label item/detail))))
      (if (["focus" "show" "hide" "close" "max"] ~ contains? action)
        (for item in (pane_completion_items app prefix (== action "focus"))
          (out ~ List/push!
            (completion_item $"/pane ${action} ${item/value}"
              item/label item/detail))))
      (if (!= (pane_command_id action) nil)
        (for item in
            (verb_completion_items ["focus" "show" "hide" "close" "max"]
              prefix $"/pane ${action} ")
          (out ~ List/push! item)))))
  out)

(fn trace_completion_items [text : Str, parts]
  (var out [])
  (var last (- parts/~size 1))
  (var prefix parts/%last)
  (for key in ["type=" "tool=" "path=" "turn=" "worker=" "agent="
               "task=" "from=" "to=" "--detail"]
    (if (starts_with? key prefix)
      (out ~ List/push!
        (completion_item (replace_last_token text key) key "trace filter"))))
  out)

(fn artifact_completion_items [text : Str, parts]
  (var out [])
  (var last (- parts/~size 1))
  (var prefix parts/%last)
  (for artifact in (agent_artifacts ~ Cell/get)
    (if (starts_with? artifact/id prefix)
      (out ~ List/push!
        (completion_item (replace_last_token text artifact/id)
          artifact/id artifact/kind))))
  out)

(fn editor_completion_items [editor]
  (var app (active_application ~ Cell/get))
  (var text (editor_text (editor/values ~ Cell/get)))
  (var parts (split text " "))
  (if (&& (starts_with? text "/") (== parts/~size 1))
    (return (command_completion_items text)))
  (if (starts_with? text "/worker ")
    (return (worker_command_completion_items app text parts)))
  (if (starts_with? text "/agent ")
    (return (agent_command_completion_items app parts)))
  (if (starts_with? text "/pane ")
    (return (pane_command_completion_items app parts)))
  (if (starts_with? text "/trace ")
    (return (trace_completion_items text parts)))
  (if (starts_with? text "/artifact ")
    (return (artifact_completion_items text parts)))
  (var pane_id (app/local_surface/focused_pane ~ Cell/get))
  (var pane (if pane_id (application_find_pane app pane_id)))
  (if (&& pane (== pane/worker/kind "shell"))
    (return (shell_route_completion_items pane/worker text)))
  (var out [])
  (if (&& pane (== pane/worker/kind "repl"))
    (for binding in ["session" "session/items" "session/events"
                     "session/workers" "session/main_agent"]
      (if (starts_with? binding text)
        (out ~ List/push! (completion_item binding binding "REPL binding")))))
  out)

(fn editor_show_completion! [editor, kind : Str]
  (var items (editor_completion_items editor))
  (if (empty? items)
    (editor/overlay ~ Cell/set nil)
    (editor/overlay ~ Cell/set
      {^kind kind ^title (if (== kind "palette") "commands" "completion")
       ^items items ^selected (cell 0) ^query (cell "")
       ^original (editor_text (editor/values ~ Cell/get))})))

(fn reverse_search_items [editor, query : Str]
  (var items [])
  (for value in editor/history
    (if (|| (== query "") (contains? value query))
      (items ~ List/push! (completion_item value value "history"))))
  (bounded_list_tail items surface_overlay_max_items))

(fn editor_begin_reverse_search! [editor]
  (var current (editor/overlay ~ Cell/get))
  (if (&& current (== current/kind "reverse_search"))
    (do
      (var selected (current/selected ~ Cell/get))
      (if (> selected 0) (current/selected ~ Cell/set (- selected 1))))
    (do
      (var items (reverse_search_items editor ""))
      (editor/overlay ~ Cell/set
        {^kind "reverse_search" ^title "reverse history"
         ^items items ^selected (cell (if (empty? items) 0 (- items/~size 1)))
         ^query (cell "")
         ^original (editor_text (editor/values ~ Cell/get))}))))

(fn editor_refresh_reverse_search! [editor]
  (var overlay (editor/overlay ~ Cell/get))
  (var items (reverse_search_items editor (overlay/query ~ Cell/get)))
  (overlay ~ Map/put! "items" items)
  (overlay/selected ~ Cell/set (if (empty? items) 0 (- items/~size 1)))
  (overlay ~ Map/put! "title"
    $"reverse history: ${(overlay/query ~ Cell/get)}"))

(fn editor_overlay_move! [editor, direction : Int]
  (var overlay (editor/overlay ~ Cell/get))
  (if overlay
    (do
      (var selected (overlay/selected ~ Cell/get))
      (var last (- overlay/items/~size 1))
      (if (> last -1)
        (overlay/selected ~ Cell/set
          (if (< (+ selected direction) 0) 0
            (if (> (+ selected direction) last) last
              (+ selected direction))))))))

(fn editor_accept_overlay! [editor] : Bool
  (var overlay (editor/overlay ~ Cell/get))
  (if (|| (== overlay nil) (empty? overlay/items))
    false
    (do
      (var selected (overlay/selected ~ Cell/get))
      (editor_set_text! editor overlay/items/%selected/value)
      (editor/overlay ~ Cell/set nil)
      true)))

(fn editor_overlay_is_current_draft? [editor] : Bool
  (var overlay (editor/overlay ~ Cell/get))
  (if (|| (== overlay nil) (== overlay/kind "reverse_search")
          (empty? overlay/items))
    false
    (do
      (var selected (overlay/selected ~ Cell/get))
      (== overlay/items/%selected/value
          (editor_text (editor/values ~ Cell/get))))))

(fn editor_dismiss_overlay! [editor, restore : Bool]
  (var overlay (editor/overlay ~ Cell/get))
  (if (&& restore overlay (== overlay/kind "reverse_search"))
    (editor_set_text! editor overlay/original))
  (editor/overlay ~ Cell/set nil))

(fn draw_editor [editor]
  (var values (editor/values ~ Cell/get))
  (var app (active_application ~ Cell/get))
  (var overlay (editor/overlay ~ Cell/get))
  (curses_draw (ensure_user_screen)
    ^prompt (input_route_label) ^status (current_input_status)
    ^output (main_presented_output app editor/transcript)
    ^input (editor_text values)
    ^cursor (editor_cursor_byte values (editor/cursor ~ Cell/get))
    ^output_scroll (editor/output_scroll ~ Cell/get)
    ^panes (extension_views)
    ^overlay (completion_labels overlay)
    ^overlay_selected (if overlay (overlay/selected ~ Cell/get) 0)
    ^overlay_title (if overlay overlay/title "")))

(fn handle_surface_escape! [editor]
  (var app (active_application ~ Cell/get))
  (if (== app nil)
    (then false)
    (else
      (var surface app/local_surface)
      (var pane_id (surface/focused_pane ~ Cell/get))
      (var pane
        (if pane_id (application_find_pane app pane_id)))
      (var worker (if (== pane nil) app/main_agent pane/worker))
      (var task (worker/current_task ~ Cell/get))
      (if (!= task nil)
        (then (application_cancel_worker app worker) true)
        (else
          (if (!= (surface/maximized_pane ~ Cell/get) nil)
            (then (surface/maximized_pane ~ Cell/set nil) true)
            (else
              (if (&& (== ((editor/values ~ Cell/get) ~ size) 0)
                      (!= pane_id nil))
                (then (surface/focused_pane ~ Cell/set nil) true)
                (else false)))))))))

(fn read_user_input [transcript, history]
  (if (stdin_tty?)
    (then
      # Keep editor state at Gene level and wait through cancellable
      # next_event tasks. This yields the scheduler between keystrokes, so
      # sub-agents, pane controllers, streams, and repaint callbacks continue
      # while the user is composing the next prompt.
      (var submitted (cell nil))
      (var done (cell false))
      (var app (active_application ~ Cell/get))
      (var route_draft (surface_route_draft app))
      (var initial_values (editor_chars (route_draft ~ Cell/get)))
      (var editor
        {^values (cell initial_values)
         ^cursor (cell (initial_values ~ size)) ^history (history ~ Cell/get)
         ^history_index (cell ((history ~ Cell/get) ~ size))
         ^draft route_draft ^paste (cell false)
         ^overlay (cell nil)
         ^output_scroll app/local_surface/main_scroll
         ^transcript transcript})
      (active_editor ~ Cell/set editor)
      (try
        (draw_editor editor)
        # Hoisted because a `var` declaration inside a loop would attempt to
        # bind the same name again on the second key event.
        (var event nil)
        (var cursor 0)
        (var event_app nil)
        (while (! (done ~ Cell/get))
          (set event (await (curses_next_event (ensure_user_screen))))
          (match event/type
              (when "text"
                (var overlay (editor/overlay ~ Cell/get))
                (if (&& overlay (== overlay/kind "reverse_search"))
                  (do
                    (overlay/query ~ Cell/set
                      $"${(overlay/query ~ Cell/get)}${event/text}")
                    (editor_refresh_reverse_search! editor))
                  (if (editor_accepts_surface_text?
                        (active_application ~ Cell/get) editor event/text)
                    (do
                      (editor_insert! editor event/text)
                      (var current
                        (editor_text (editor/values ~ Cell/get)))
                      (if (&& (starts_with? current "/")
                              (! (starts_with? current "//"))
                              (! (contains? current " ")))
                        (editor_show_completion! editor "palette")
                        (editor_dismiss_overlay! editor false))))))
              (when "paste_start" (editor/paste ~ Cell/set true))
              (when "paste_end" (editor/paste ~ Cell/set false))
              (when "newline"
                (if (surface_route_input_capable?
                      (active_application ~ Cell/get))
                  (editor_insert! editor "\n")))
              (when "enter"
                (if (editor/paste ~ Cell/get)
                  (then (editor_insert! editor "\n"))
                  (else
                    # An exact command should remain one-Enter interaction
                    # even while the discovery palette is visible. Partial
                    # completion and reverse-search still accept into the
                    # draft without submitting.
                    (if (editor_overlay_is_current_draft? editor)
                      (do
                        (editor_dismiss_overlay! editor false)
                        (submitted ~ Cell/set
                          (editor_text (editor/values ~ Cell/get)))
                        (done ~ Cell/set true))
                      (if_not (editor_accept_overlay! editor)
                        (submitted ~ Cell/set
                          (editor_text (editor/values ~ Cell/get)))
                        (done ~ Cell/set true))))))
              (when "eof" (done ~ Cell/set true))
              (when "interrupt" (editor_clear! editor))
              (when "escape"
                (if (editor/overlay ~ Cell/get)
                  (editor_dismiss_overlay! editor true)
                (if (confirmation_active ~ Cell/get)
                  (then
                    (submitted ~ Cell/set "n")
                    (done ~ Cell/set true))
                  (else (handle_surface_escape! editor)))))
              (when "backspace"
                (var overlay (editor/overlay ~ Cell/get))
                (if (&& overlay (== overlay/kind "reverse_search"))
                  (do
                    (var query_values
                      (editor_chars (overlay/query ~ Cell/get)))
                    (if_not (empty? query_values)
                      (do
                        (var shortened [])
                        (repeat i in (- query_values/~size 1)
                          (shortened ~ List/push! query_values/%i))
                        (set query_values shortened)))
                    (overlay/query ~ Cell/set (editor_text query_values))
                    (editor_refresh_reverse_search! editor))
                  (do
                    (set cursor (editor/cursor ~ Cell/get))
                    (if_yes (> cursor 0)
                      (editor_remove! editor (- cursor 1))
                      (editor/cursor ~ Cell/set (- cursor 1))))))
              (when "delete"
                (editor_remove! editor (editor/cursor ~ Cell/get)))
              (when "left"
                (set cursor (editor/cursor ~ Cell/get))
                (if (> cursor 0) (editor/cursor ~ Cell/set (- cursor 1))))
              (when "right"
                (set cursor (editor/cursor ~ Cell/get))
                (if (< cursor ((editor/values ~ Cell/get) ~ size))
                  (editor/cursor ~ Cell/set (+ cursor 1))))
              (when "home" (editor_home! editor))
              (when "end" (editor_end! editor))
              (when "up"
                (if (editor/overlay ~ Cell/get)
                  (editor_overlay_move! editor -1)
                  (editor_history! editor -1)))
              (when "down"
                (if (editor/overlay ~ Cell/get)
                  (editor_overlay_move! editor 1)
                  (editor_history! editor 1)))
              (when "complete"
                (var overlay (editor/overlay ~ Cell/get))
                (if (&& overlay (== overlay/kind "palette"))
                  (do
                    (overlay ~ Map/put! "kind" "completion")
                    (overlay ~ Map/put! "title" "completion"))
                (if (&& overlay (!= overlay/kind "reverse_search"))
                  (editor_overlay_move! editor 1)
                  (editor_show_completion! editor "completion"))))
              (when "reverse_search"
                (editor_begin_reverse_search! editor))
              (when "edit"
                (editor_dismiss_overlay! editor false)
                (try
                  (editor_set_text! editor
                    (external_editor_draft
                      (editor_text (editor/values ~ Cell/get))))
                catch {^message message}
                  (var app (active_application ~ Cell/get))
                  (if app
                    (app/local_surface/help_notice ~ Cell/set
                      $"external editor failed: ${message}"))))
              (when "scroll_up"
                (application_scroll_target!
                  (active_application ~ Cell/get) editor/output_scroll 1 3))
              (when "scroll_down"
                (application_scroll_target!
                  (active_application ~ Cell/get) editor/output_scroll -1 3))
              (when "page_up"
                (set event_app (active_application ~ Cell/get))
                (application_scroll_target! event_app editor/output_scroll 1
                  (application_pane_page_rows event_app event/rows)))
              (when "page_down"
                (set event_app (active_application ~ Cell/get))
                (application_scroll_target! event_app editor/output_scroll -1
                  (application_pane_page_rows event_app event/rows)))
              (when "pane_previous"
                (application_cycle_visible_pane!
                  (active_application ~ Cell/get) -1))
              (when "pane_next"
                (application_cycle_visible_pane!
                  (active_application ~ Cell/get) 1))
            (else nil))
          (if (! (done ~ Cell/get)) (draw_editor editor)))
        (if (== (submitted ~ Cell/get) nil)
          (route_draft ~ Cell/set
            (editor_text (editor/values ~ Cell/get)))
          (route_draft ~ Cell/set ""))
        (submitted ~ Cell/get)
      ensure
        (active_editor ~ Cell/set nil)))
    (else
      (print "you> ")
      (read_line))))

(fn confirmation_answer [prompt : Str] : Bool
  (var transcript (interactive_transcript ~ Cell/get))
  (if (&& (stdin_tty?) (!= transcript nil))
    (then
      (if (!= (active_editor ~ Cell/get) nil)
      # A background worker must not steal the terminal or replace a composed
      # draft. Until the optional multi-surface confirmation inbox lands,
      # default-deny this rare collision without blocking the scheduler.
        (then false)
        (else
        (append_transcript transcript $"${prompt}\n")
        (refresh_user_input transcript)
        (confirmation_active ~ Cell/set true)
        (var answer nil)
        (try
          (set answer (read_user_input transcript (cell [])))
        ensure
          (confirmation_active ~ Cell/set false))
        (if (== answer nil)
          (then false)
          (else
            (set answer (lower (trim answer)))
            (|| (== answer "y") (== answer "yes")))))))
    (else
      # Scripted/one-shot callers have no live curses surface. Preserve the
      # ordinary stdin contract; EOF remains default deny.
      (close_user_input)
      (print prompt)
      (var answer (read_line))
      (if (== answer nil)
        (then false)
        (else
          (set answer (lower (trim answer)))
          (|| (== answer "y") (== answer "yes")))))))

(fn refresh_user_input [transcript]
  (if_yes (&& (stdin_tty?) (! (user_input_suspended ~ Cell/get)))
      (var editor (active_editor ~ Cell/get))
      (if (== editor nil)
        (curses_refresh_input (ensure_user_screen)
                              ^prompt (input_route_label)
                              ^output
                                (main_presented_output
                                  (active_application ~ Cell/get) transcript)
                              ^panes (extension_views)
                              ^status (current_input_status))
        (draw_editor editor))))

(fn refresh_active_input []
  # Background workers may emit many deltas in one scheduler turn. Collapse
  # those invalidations into one later draw; the editor's own key path still
  # draws synchronously after consuming input, so output cannot queue ahead of
  # command acknowledgement.
  (if_not (active_repaint_pending ~ Cell/get)
    (active_repaint_pending ~ Cell/set true)
    (var repaint
      (spawn
        (do
          (sleep 0)
          (active_repaint_pending ~ Cell/set false)
          (var transcript (interactive_transcript ~ Cell/get))
          (if (!= transcript nil) (refresh_user_input transcript)))))
    (repaint ~ Task/detach)))

# A pending turn owns the final transcript line until it produces visible
# output. The pulse task alternates the dots and spaces while the scheduler is
# waiting on a model or tool task; the first real output restores the saved
# transcript and replaces that line.
(fn refresh_agent_pending [transcript pending dots_visible]
  (if_yes (pending ~ Cell/get)
      (var app (active_application ~ Cell/get))
      (if (&& (!= app nil) (!= app/local_surface nil))
        (app/local_surface/main_pending_visible ~ Cell/set
          (dots_visible ~ Cell/get)))
      (if (stdin_tty?)
        (refresh_user_input transcript)
        (print (if (dots_visible ~ Cell/get) "\ragent> ..." "\ragent>    ")))))

# Remove the currently drawn placeholder before appending output, but retain
# the pending state: the placeholder is redrawn beneath that output until the
# whole turn completes.
(fn advance_agent_pending [transcript pending]
  (if_yes (pending ~ Cell/get)
      (var app (active_application ~ Cell/get))
      (if (&& (!= app nil) (!= app/local_surface nil))
        (app/local_surface/main_pending_visible ~ Cell/set false))
      (if (stdin_tty?)
        (refresh_user_input transcript)
        (print "\r"))))

(fn stop_agent_pending [transcript pending]
  (if_yes (pending ~ Cell/get)
      (pending ~ Cell/set false)
      (var app (active_application ~ Cell/get))
      (if (&& (!= app nil) (!= app/local_surface nil))
        (app/local_surface/main_pending_visible ~ Cell/set false))
      (if (stdin_tty?)
        (refresh_user_input transcript)
        (print "\r"))))

(fn output_with_pending [transcript pending dots_visible render]
  (advance_agent_pending transcript pending)
  (render)
  (if (pending ~ Cell/get)
    (refresh_agent_pending transcript pending dots_visible)))

(fn start_agent_pending [transcript]
  (var pending (cell true))
  (var dots_visible (cell true))
  (refresh_agent_pending transcript pending dots_visible)
  {^pending pending ^dots_visible dots_visible
   ^task (spawn
     (while (pending ~ Cell/get)
       (sleep 400)
       (if_yes (pending ~ Cell/get)
           (dots_visible ~ Cell/set (! (dots_visible ~ Cell/get)))
           (refresh_agent_pending transcript pending dots_visible))))})

(fn run_interactive_turn [transcript streaming transport input_items]
  (var placeholder (start_agent_pending transcript))
  (var app (active_application ~ Cell/get))
  (var context
    (if app {^app app ^agent app/main_agent ^pane nil}))
  (var turn_emit
    (if (== app nil)
      emit_event!
      (fn [type props]
        (var tagged {^worker_id app/main_agent/id
                     ^agent_id app/main_agent/id})
        (for [key value] in props
          (tagged ~ Map/put! key value))
        (application_emit app type tagged))))
  (try
    (run_turn_tracked_in transport input_items
      (fn [text]
        (output_with_pending transcript placeholder/pending placeholder/dots_visible
          (fn [] (render_agent_text transcript streaming text))))
      (fn [text]
        (output_with_pending transcript placeholder/pending placeholder/dots_visible
          (fn [] (render_agent_delta transcript streaming text))))
      max_tool_rounds
      turn_emit
      context)
  ensure
    (stop_agent_pending transcript placeholder/pending)
    (finish_agent_stream transcript streaming)
    (placeholder/task ~ Task/cancel)))

(fn interactive_transport []
  (if (== auth_token nil) (demo_transport_for) live_transport))

(fn render_agent_delta [transcript streaming text]
  (if_not (== text "")
    (if_not (Cell/get streaming)
        (append_transcript transcript "agent> ")
        (if_not (stdin_tty?)
          (print "agent> "))
        (Cell/set streaming true))
    (append_transcript transcript text)
    (if (stdin_tty?)
      (refresh_user_input transcript)
      (print text))))

(fn finish_agent_stream [transcript streaming]
  (if_yes (Cell/get streaming)
      (append_transcript transcript "\n")
      (if (stdin_tty?)
        (refresh_user_input transcript)
        (println ""))
      (Cell/set streaming false)))

(fn render_agent_text [transcript streaming text]
  (finish_agent_stream transcript streaming)
  (if_not (== text "")
    (append_transcript transcript $"agent> ${text}\n")
    (if (stdin_tty?)
      (refresh_user_input transcript)
      (println $"agent> ${text}"))))

# Convenience helpers over the native application registries. Creating an
# agent and opening its pane is a surface composite; their identities and
# lifecycles remain independent underneath.
(fn open_extension_pane [title : Str, memory]
  (var app (active_application ~ Cell/get))
  (if_yes app
    (var label (if (== (trim title) "") "sub-agent" (trim title)))
    (var transcript (cell "ready\n"))
    (var agent
      (application_spawn_agent app label "awaiting assignment"
        (cell
          (append (initial_items memory)
            (system_item
              $"You are ${label}, a supervised sub-agent in the same workspace. Work only on assignments delegated by the main agent or user. Report a concise result; your private tool transcript is not copied into the main context.")))
        transcript))
    (if_yes agent
        (var pane
          (application_open_pane app "agent" agent/id agent/title
                                 transcript agent "detach"))
        (refresh_active_input)
        pane)))

(fn open_output_pane [title : Str]
  (var app (active_application ~ Cell/get))
  (if_yes app
    (var label (if (== (trim title) "") "output" (trim title)))
    (application_open_pane app "output" nil label
      (cell "ready\n")
      (OutputController ^source "manual" ^following (cell [])) "detach")))

(fn stats_worker_text [app] : Str
  (var running 0)
  (var busy 0)
  (for worker in (app/workers ~ Cell/get)
    (if (== (worker/lifecycle ~ Cell/get) "running")
      (set running (+ running 1)))
    (if (|| (worker/input_reserved ~ Cell/get)
            (!= (worker/current_operation ~ Cell/get) nil))
      (set busy (+ busy 1))))
  (var lease (app/workspace_coordinator/owner ~ Cell/get))
  (var worker_count ((app/workers ~ Cell/get) ~ size))
  (var agent_count ((app/agents ~ Cell/get) ~ size))
  (var lease_label (if (== lease nil) "free" lease))
  $"workers: ${worker_count} (${running} running, ${busy} busy)\nagents: ${agent_count}\nworkspace lease: ${lease_label}\n")

(fn open_stats_pane []
  (var app (active_application ~ Cell/get))
  (var worker (application_find_worker_kind app "stats"))
  (if_yes (== worker nil)
      (set worker
        (application_new_worker app "stats" "stats"
          (cell "") (StatsController)))
      (if_yes worker
          (application_set_projection_output!
            app worker (stats_worker_text app) "stats")
          ((app/event_observers ~ Cell/get) ~ List/push!
            {^worker_id worker/id
             ^handler (fn [event]
               (if_not (== event/projection true)
                 (application_set_projection_output!
                   app worker (stats_worker_text app) "stats")
                 (refresh_active_input)))})))
  (if_yes worker
      (var pane (application_find_pane_worker app worker/id))
      (if (== pane nil)
        (set pane (application_attach_worker_pane app worker nil "detach")))
      (if pane (application_focus_pane! app pane/id))
      pane))

(fn open_log_tail_pane [filter_text : Str]
  (var app (active_application ~ Cell/get))
  (var filters (parse_trace_filters filter_text))
  (var worker
    (application_new_worker app "log_tail" "event tail"
      (cell "") (LogTailController ^filter (cell filters))))
  (if_yes worker
    # Seed the local TUI projection from retained events; headless sessions
    # begin at their creation cursor and receive subsequent app events.
    (for event in (if (== app/local_surface nil) []
                    (agent_events ~ Cell/get))
      (if (event_matches? event filters)
        (bounded_worker_append! worker
          $"${(format_event_with_filters event filters)}\n")))
    ((app/event_observers ~ Cell/get) ~ List/push!
      {^worker_id worker/id
       ^handler (fn [event]
         (var current (worker/controller/filter ~ Cell/get))
         (if_yes (&& (!= event/projection true)
                 (event_matches? event current))
             (application_append_projection_output!
               app worker
               $"${(format_event_with_filters event current)}\n" "log_tail")
             (refresh_active_input)))})
    (application_attach_worker_pane app worker nil "detach")))

(fn open_file_view_pane [requested_path : Str]
  (var app (active_application ~ Cell/get))
  (try
    # A file-view worker is shared session state and may be exposed through
    # gateway snapshots, so even a user-originated local view stays within
    # the workspace. Arbitrary host inspection remains available via /tty
    # or an external editor without entering shared state.
    (var path (safe_path requested_path))
    (if_yes (exists? ReadDir path)
      (var worker
        (application_new_worker app "file_view" $"view ${path}"
          (cell "") (FileViewController ^path path)))
      (if_yes worker
          (application_append_projection_output!
            app worker (read_text ReadDir path) "file_view")
          (application_attach_worker_pane app worker nil "detach")))
    catch _ nil))

(fn application_worker_snapshot [app, worker]
  (var operation (worker/current_operation ~ Cell/get))
  (var has_agent_result
    (&& (== worker/kind "agent") (!= worker/id "main")))
  (var result
    (if has_agent_result (worker/result ~ Cell/get) nil))
  (var result_unread
    (match result
      (when (m : Map) (== m/read false))
      (else false)))
  {^worker_id worker/id ^name worker/name
   ^kind worker/kind ^title worker/title
   ^lifecycle (worker/lifecycle ~ Cell/get)
   ^status (worker/status ~ Cell/get)
   ^input_reserved (worker/input_reserved ~ Cell/get)
   ^current_operation operation ^last_outcome (worker/last_outcome ~ Cell/get)
   ^result (if has_agent_result result void)
   ^result_unread (if has_agent_result result_unread void)
   ^following (if (== worker/kind "output")
                (worker/controller/following ~ Cell/get) void)
   ^output (worker/output ~ Cell/get)
   ^output_seq (- (worker/next_output_seq ~ Cell/get) 1)
   ^dropped_bytes (worker/dropped_bytes ~ Cell/get)
   ^dropped_before (worker/dropped_before ~ Cell/get)
   ^history_dropped (worker/history_dropped ~ Cell/get)
   ^transcript_seq
     (if (== worker/id "main")
       (- (worker/transcript_seq ~ Cell/get) 1) void)
   ^transcript_dropped_bytes
     (if (== worker/id "main")
       (worker/transcript_dropped_bytes ~ Cell/get) void)
   ^transcript_dropped_before
     (if (== worker/id "main")
       (worker/transcript_dropped_before ~ Cell/get) void)})

(fn application_workers_snapshot [app]
  (var out [])
  (for worker in (app/workers ~ Cell/get)
    (out ~ List/push! (application_worker_snapshot app worker)))
  out)

(fn application_create_worker_from_config [app, kind : Str, config]
  (var title
    (if (|| (== config/title void) (== config/title "")) kind config/title))
  (var requested_name
    (if (== config/name void) nil config/name))
  (match kind
    (when "shell"
      (var cwd
        (if (== config/cwd void) workspace_real
          (do
            (safe_path config/cwd)
            (list_dir ReadDir config/cwd)
            (real_path ReadDir config/cwd))))
      (application_new_named_worker app kind title
        (cell $"cwd: ${cwd}\n")
        (ShellController ^cwd (cell cwd) ^environment (cell {}))
        requested_name))
    (when "output"
      (var worker
        (application_new_named_worker app kind title (cell "")
          (OutputController ^source "gateway" ^following (cell []))
          requested_name))
      (if_yes (&& worker (present? config/text))
        (application_append_worker_output!
          app worker (redact_any config/text) "gateway"))
      worker)
    (when "stats"
      (var worker
        (application_new_named_worker app kind title (cell "")
          (StatsController) requested_name))
      (if_yes worker
        (application_set_projection_output!
          app worker (stats_worker_text app) "stats")
        ((app/event_observers ~ Cell/get) ~ List/push!
          {^worker_id worker/id
           ^handler (fn [event]
             (if_not (== event/projection true)
               (application_set_projection_output!
                 app worker (stats_worker_text app) "stats")))}))
      worker)
    (when "log_tail"
      (var filters
        (parse_trace_filters
          (if (present? config/filter) config/filter "")))
      (var worker
        (application_new_named_worker app kind title (cell "")
          (LogTailController ^filter (cell filters)) requested_name))
      (if_yes worker
        ((app/event_observers ~ Cell/get) ~ List/push!
          {^worker_id worker/id
           ^handler (fn [event]
             (if_yes (&& (!= event/projection true)
                         (event_matches? event
                           (worker/controller/filter ~ Cell/get)))
               (application_append_projection_output!
                 app worker
                 $"${(format_event_with_filters event (worker/controller/filter ~ Cell/get))}\n"
                 "log_tail")))}))
      worker)
    (when "file_view"
      (if_not (! (present? config/path))
        (var path (safe_path config/path))
        (if_not (! (exists? ReadDir path))
            (var worker
              (application_new_named_worker app kind
                (if (== title kind) $"view ${path}" title)
                (cell "") (FileViewController ^path path) requested_name))
            (if (!= worker nil)
              (application_append_projection_output!
                app worker (read_text ReadDir path) "file_view"))
            worker)))
    (else nil)))

(fn open_shell_pane []
  (var app (active_application ~ Cell/get))
  (if_yes app
    (var worker (application_find_worker_kind app "shell"))
    (var previous
      (if (== worker nil)
        (application_find_stopped_worker_kind app "shell")))
    (var existing
      (if worker
        (application_find_pane_worker app worker/id)))
    (if (!= existing nil)
      (then
        (application_focus_pane! app existing/id)
        existing)
      (else
        (if (== worker nil)
          (set worker
            (application_new_worker_from app "shell" "shell"
              (cell $"cwd: ${workspace_root}\n")
              (ShellController ^cwd (cell workspace_root)
                               ^environment (cell {})) previous)))
        (application_attach_worker_pane app worker "user" "detach")))))

(fn shell_environment_args [worker, command : Str]
  # Use argv, not shell interpolation, to project persistent overrides into
  # one foreground subprocess. The controller changes only through the typed
  # set_env/unset_env operations; arbitrary shell text cannot mutate it.
  (var args [])
  (for [name value] in (worker/controller/environment ~ Cell/get)
    (if (== value void)
      (do
        (args ~ List/push! "-u")
        (args ~ List/push! name))
      (args ~ List/push! $"${name}=${value}")))
  (args ~ List/push! (get_env Env "SHELL" "sh"))
  (args ~ List/push! "-lc")
  (args ~ List/push! command)
  args)

(fn normalized_shell_timeout [timeout_ms] : Int
  (var value (if (|| (== timeout_ms nil) (== timeout_ms void))
               120000 timeout_ms))
  (if (|| (< value 1) (> value 600000))
    (fail (OsError ^message "shell timeout_ms must be between 1 and 600000")))
  value)

(fn run_shell_worker_command_unchecked
  [app, worker, command : Str, timeout_ms, adapter : Str, surface_id, route : Str,
   detached : Bool]
  (if (== (worker/lifecycle ~ Cell/get) "stopped")
    $"shell worker ${worker/id} is stopped"
    (if (!= (worker/current_task ~ Cell/get) nil)
      (then $"shell ${route} is already working")
      (else
      (worker_history_push! worker command adapter surface_id)
      (var last_output (cell ""))
      (var process_task (cell nil))
      (var outcome (cell "cancelled"))
      (var task
        (spawn
          (do
            (var acquired false)
            (try
              (set acquired
                (application_acquire_workspace app worker/id
                                               $"shell:${route}"))
              (if acquired
                (then
                  (var started (monotonic_ms))
                  (var stdout_chan (channel ^capacity 256))
                  (var exec_task
                    (exec_stream_async Exec
                      ^cmd "env"
                      ^args (shell_environment_args worker command)
                      ^dir (worker/controller/cwd ~ Cell/get)
                      ^timeout_ms (normalized_shell_timeout timeout_ms)
                      ^max_bytes 262144
                      ^stdout_chan stdout_chan))
                  (process_task ~ Cell/set exec_task)
                  (var chunk nil)
                  (try
                    (loop
                      (set chunk (stdout_chan ~ Channel/recv))
                      (last_output ~ Cell/set
                        $"${(last_output ~ Cell/get)}${chunk}")
                      (append_worker_transcript! app worker chunk))
                  catch (ChannelClosed) nil)
                  (var result (await exec_task))
                  (var duration_ms (- (monotonic_ms) started))
                  (last_output ~ Cell/set
                    $"${(last_output ~ Cell/get)}${result/stderr}[exit ${result/status}; ${duration_ms} ms]")
                  (append_worker_transcript! app worker
                    $"${result/stderr}[exit ${result/status}; ${duration_ms} ms]\n")
                  (outcome ~ Cell/set
                    (if (== result/status 0) "completed" "failed")))
                (else
                  (append_worker_transcript! app worker
                    "[application is shutting down]\n")
                  (outcome ~ Cell/set "failed")))
            catch {^message message}
              (append_worker_transcript! app worker $"[shell failed: ${message}]\n")
              (outcome ~ Cell/set "failed")
            catch _
              (append_worker_transcript! app worker "[shell failed]\n")
              (outcome ~ Cell/set "failed")
            ensure
              (if (!= (process_task ~ Cell/get) nil)
                ((process_task ~ Cell/get) ~ Task/cancel))
              (if acquired
                (application_release_workspace app worker/id
                                               $"shell:${route}"))
              (application_finish_worker_operation!
                app worker (outcome ~ Cell/get))
              (refresh_application_input app)))))
      (application_begin_worker_operation!
        app worker task "shell_command")
      (append_worker_transcript! app worker $"$ ${command}\n")
      (task ~ Task/detach)
      (if detached
        (then "accepted")
        (else
          (await task)
          $"shell ${route}: ${(last_output ~ Cell/get)}"))))))

(fn run_shell_worker_command
  [app, worker, command : Str, timeout_ms, adapter : Str, surface_id, route : Str,
   detached : Bool, remote : Bool]
  # Every attributable shell surface uses the same reservation, guard, lease,
  # event, and cancellation path. Remote adapters deny destructive commands
  # synchronously instead of attempting a terminal confirmation.
  (if (== (worker/lifecycle ~ Cell/get) "stopped")
    $"shell worker ${worker/id} is stopped"
    (if (|| (worker/input_reserved ~ Cell/get)
            (!= (worker/current_task ~ Cell/get) nil))
      (then $"shell ${route} is already working")
      (else
      (worker/input_reserved ~ Cell/set true)
      (worker/status ~ Cell/set "confirming")
      (var denial nil)
      (var admission_survived false)
      (try
        (var guard_sink
          (fn [type props]
            (var tagged {^worker_id worker/id ^kind worker/kind})
            (for [key value] in props
              (tagged ~ Map/put! key value))
            (application_emit app type tagged)))
        (set denial
          (if remote
            (guard_shell_in command (fn [_command] false) guard_sink)
            (guard_shell_in command nil guard_sink)))
        (set admission_survived (worker/input_reserved ~ Cell/get))
      ensure
        (worker/input_reserved ~ Cell/set false)
        (if (== (worker/current_task ~ Cell/get) nil)
          (worker/status ~ Cell/set
            (if (== (worker/lifecycle ~ Cell/get) "stopped")
              "stopped" "idle"))))
      (if (present? denial)
        denial
        (if (! admission_survived)
          "shell command cancelled before start"
          (run_shell_worker_command_unchecked
            app worker command timeout_ms adapter surface_id route detached)))))))

(fn run_shell_pane_command_unchecked [pane, command : Str]
  (var app (active_application ~ Cell/get))
  (var result
    (run_shell_worker_command_unchecked app pane/worker command nil "local_tui"
      (if app/local_surface
        (app/local_surface/instance_id ~ Cell/get))
      $"pane ${pane/id}" (stdin_tty?)))
  (if (== result "accepted")
    $"shell command started in pane ${pane/id}" result))

(fn run_shell_pane_command [pane, command : Str]
  # A visible shell pane is attributable application input, not the raw /tty
  # escape hatch. Classify it on TTY and pipe surfaces alike.
  (var app (active_application ~ Cell/get))
  (var result
    (run_shell_worker_command app pane/worker command nil "local_tui"
      (if app/local_surface
        (app/local_surface/instance_id ~ Cell/get))
      $"pane ${pane/id}" (stdin_tty?) false))
  (if (== result "accepted")
    $"shell command started in pane ${pane/id}" result))

(fn run_repl_worker_command
  [app, worker, source : Str, adapter : Str, surface_id, route : Str,
   detached : Bool]
  (if (== worker/controller/session nil)
    $"REPL ${route} is restored history; reopen it locally first"
    (if (!= (worker/current_task ~ Cell/get) nil)
      (then $"REPL ${route} is already evaluating")
      (else
      (worker_history_push! worker source adapter surface_id)
      (var last_output (cell ""))
      (var outcome (cell "cancelled"))
      (var task
          (spawn
            (do
              (try
                (var result (repl_eval worker/controller/session source))
                (last_output ~ Cell/set result/text)
                (match result/status
                  (when "ok"
                    (if_not (== result/text "")
                      (append_worker_transcript! app worker $"${result/text}\n")))
                  (when "incomplete"
                    (append_worker_transcript! app worker "....> \n"))
                  (else
                    (append_worker_transcript! app worker $"${result/text}\n")))
                (outcome ~ Cell/set
                  (if (== result/status "error") "failed" "completed"))
              catch {^message message}
                (append_worker_transcript! app worker $"[REPL failed: ${message}]\n")
                (outcome ~ Cell/set "failed")
              catch _
                (append_worker_transcript! app worker "[REPL failed]\n")
                (outcome ~ Cell/set "failed")
              ensure
                (if_yes (&& (!= worker/controller/items nil)
                        (worker/controller/resume_requested ~ Cell/get))
                  (worker/controller/resume_requested ~ Cell/set false)
                  (worker/controller/items ~ Cell/set
                    (run_interactive_turn worker/controller/transcript
                      worker/controller/streaming
                      (interactive_transport)
                      (worker/controller/items ~ Cell/get))))
                (application_finish_worker_operation!
                  app worker (outcome ~ Cell/get))
                (refresh_application_input app)))))
        (application_begin_worker_operation!
          app worker task "repl_eval")
        (append_worker_transcript! app worker $"gene> ${source}\n")
        (task ~ Task/detach)
        (if detached
          (then "accepted")
          (else
            (await task)
            $"REPL ${route}: ${(last_output ~ Cell/get)}"))))))

(fn run_repl_pane_command [pane, source : Str]
  (var app (active_application ~ Cell/get))
  (var result
    (run_repl_worker_command app pane/worker source "local_tui"
      (if app/local_surface
        (app/local_surface/instance_id ~ Cell/get))
      $"pane ${pane/id}" (stdin_tty?)))
  (if (== result "accepted")
    $"REPL evaluation started in pane ${pane/id}" result))

(fn close_extension_pane [id : Int] : Bool
  (var app (active_application ~ Cell/get))
  (if (== app nil)
    (then false)
    (else
      (var removed (application_close_pane app id))
      (refresh_active_input)
      removed)))

(fn handle_close_command [line : Str, transcript, streaming]
  (var app (active_application ~ Cell/get))
  (var rest (trim (after_prefix line "/close")))
  (var id
    (if (== rest "")
      (app/local_surface/focused_pane ~ Cell/get)
      (pane_command_id rest)))
  (if (&& (!= rest "") (== id nil))
    (render_agent_text transcript streaming "usage: /close [N]")
    (if (|| (== id nil) (== id 0))
      (render_agent_text transcript streaming "pane 0 cannot be closed")
      (render_agent_text transcript streaming
        (if (application_close_pane app id)
          $"closed pane ${id}" $"pane ${id} is not open")))))

(fn refresh_application_input [app]
  (var local (active_application ~ Cell/get))
  (if (&& (!= local nil)
          (== local/coordinator_id app/coordinator_id))
    (refresh_active_input)))

(fn append_worker_transcript! [app, worker, text : Str]
  (bounded_worker_append! worker text)
  (if (["shell" "repl"] ~ contains? worker/kind)
    (application_emit_worker_output!
      app worker text worker/kind false))
  (application_propagate_followers! app worker text)
  (refresh_application_input app))

(fn append_extension_transcript [pane, text : Str]
  (append_worker_transcript!
    (active_application ~ Cell/get) pane/worker text))

(fn refresh_extension_pending [pane, pending, dots_visible]
  (if_yes (pending ~ Cell/get)
      (pane/pending_visible ~ Cell/set (dots_visible ~ Cell/get))
      (refresh_active_input)))

(fn start_extension_pending [pane]
  (var pending (cell true))
  (var dots_visible (cell true))
  (refresh_extension_pending pane pending dots_visible)
  {^pending pending ^dots_visible dots_visible
   ^task (spawn
     (while (pending ~ Cell/get)
       (sleep 400)
       (if_yes (pending ~ Cell/get)
           (dots_visible ~ Cell/set (! (dots_visible ~ Cell/get)))
           (refresh_extension_pending pane pending dots_visible))))})

(fn advance_extension_pending [pane, pending]
  (if_yes (pending ~ Cell/get)
      (pane/pending_visible ~ Cell/set false)
      (refresh_active_input)))

(fn stop_extension_pending [pane, pending]
  (if_yes (pending ~ Cell/get)
      (pending ~ Cell/set false)
      (pane/pending_visible ~ Cell/set false)
      (refresh_active_input)))

(fn render_extension_delta [pane, text : Str]
  (if_not (== text "")
    (if_not (pane/controller/streaming ~ Cell/get)
        (append_extension_transcript pane "assistant|")
        (pane/controller/streaming ~ Cell/set true))
    (append_extension_transcript pane text)))

(fn finish_extension_stream [pane]
  (if_yes (pane/controller/streaming ~ Cell/get)
      (append_extension_transcript pane "\n")
      (pane/controller/streaming ~ Cell/set false)))

(fn render_extension_text [pane, text : Str]
  (finish_extension_stream pane)
  (if_not (== text "")
    (append_extension_transcript pane $"assistant|${text}\n")))

(fn output_with_extension_pending [pane, placeholder, render]
  (advance_extension_pending pane placeholder/pending)
  (render)
  (if (placeholder/pending ~ Cell/get)
    (refresh_extension_pending pane placeholder/pending placeholder/dots_visible)))

(fn extension_emit [pane, type : Str, props]
  (var app (active_application ~ Cell/get))
  (var agent pane/controller)
  (var tagged {^pane_id pane/id ^worker_id agent/id ^agent_id agent/id
               ^parent_agent_id agent/parent_id})
  (for [key value] in props
    (tagged ~ Map/put! key value))
  (if (== app nil)
    (emit_event! type tagged)
    (application_emit app type tagged)))

(fn run_extension_prompt [pane, prompt : Str, tracked : Bool]
  (var app (active_application ~ Cell/get))
  (var agent pane/controller)
  (if (== (agent/lifecycle ~ Cell/get) "stopped")
    $"agent ${agent/id} is stopped"
    (if (|| (agent/input_reserved ~ Cell/get)
            (!= (agent/current_task ~ Cell/get) nil))
    (then $"agent ${agent/id} is already working")
    (else
      (worker_history_push! agent prompt "local_tui"
        (if app/local_surface
          (app/local_surface/instance_id ~ Cell/get)))
      (append_extension_transcript pane $"user|› ${prompt}\n")
      (application_emit app "agent_status"
        {^worker_id agent/id ^agent_id agent/id
         ^parent_agent_id agent/parent_id
         ^pane_id pane/id ^status "working"})
      (var task
        (spawn
          (do
            (var placeholder (start_extension_pending pane))
            (var result (cell (agent/items ~ Cell/get)))
            (var final_text (cell ""))
            (var outcome (cell "cancelled"))
            (var error_kind (cell "cancelled"))
            (var error_text (cell "agent operation cancelled"))
            (var render
              (fn [text]
                (output_with_extension_pending pane placeholder
                  (fn [] (render_extension_text pane text)))))
            (var render_stream
              (fn [text]
                (output_with_extension_pending pane placeholder
                  (fn [] (render_extension_delta pane text)))))
            (var emit
              (fn [type props]
                (if (&& (== type "agent_text") (present? props/text))
                  (final_text ~ Cell/set props/text))
                (extension_emit pane type props)))
            (try
              (result ~ Cell/set
              (run_turn_in (interactive_transport)
                (append (agent/items ~ Cell/get) (user_item prompt))
                render render_stream max_tool_rounds emit
                {^app app ^agent agent ^pane pane}))
              (outcome ~ Cell/set "completed")
            catch {^message message}
              (outcome ~ Cell/set "failed")
              (error_kind ~ Cell/set "AgentError")
              (error_text ~ Cell/set message)
              (render_extension_text pane $"[agent failed: ${message}]")
            catch _
              (outcome ~ Cell/set "failed")
              (error_kind ~ Cell/set "AgentError")
              (error_text ~ Cell/set "agent operation failed")
              (render_extension_text pane "[agent failed]")
            ensure
              (stop_extension_pending pane placeholder/pending)
              (finish_extension_stream pane)
              (placeholder/task ~ Task/cancel)
              (agent/items ~ Cell/set (result ~ Cell/get))
              (application_finish_agent_operation!
                app agent (outcome ~ Cell/get) (final_text ~ Cell/get)
                (error_kind ~ Cell/get) (error_text ~ Cell/get) pane/id)))))
      (application_begin_worker_operation! app agent task "agent_turn")
      (task ~ Task/detach)
      (if tracked
        (then $"agent ${agent/id} started in pane ${pane/id}")
        (else
          # `open_extension` predates first-class spawn/send/wait tools and
          # promises one delegated result to the calling model. Preserve that
          # compatibility contract while the child runs in its own Task; the
          # scheduler remains free to serve input and other agents.
          (await task)
          (var completed_text
            (agent_result_text (agent/result ~ Cell/get)))
          (if (== (agent/last_outcome ~ Cell/get) "completed")
            $"extension ${pane/id} completed: ${completed_text}"
            $"extension ${pane/id} ${(agent_result_report agent)}")))))))

# Model-facing supervision primitives use the same AgentApplication services as
# slash commands, but do not require a visible pane. This is intentionally
# separate from `open_extension`: spawning an agent, opening a view, and
# sending work are independent capabilities (§7.1/§10.4).
(fn tool_application [args]
  (var context args/_context)
  (if (&& (present? context) (present? context/app)) context/app))

(fn supervisor_tool_application [args]
  (var context args/_context)
  (var app (tool_application args))
  (if (&& (!= app nil) (present? context/agent)
          (== context/agent/id app/main_agent/id))
    app))

(fn normalize_agent_attachments [attachments]
  (if (|| (== attachments void) (== attachments nil))
    []
    (match attachments
      (when (xs : List)
        (if_yes (> xs/~size agent_attachment_max_count)
          (fail (OsError
            ^message $"agent context exceeds ${agent_attachment_max_count} attachments")))
        (var copied (parse (stringify (redact_any xs))))
        (var allowed ["message" "file" "memory" "event" "summary" "worker"])
        (for attachment in copied
          (match attachment
            (when (m : Map)
              (if_not (match m/kind
                        (when (kind : Str) (allowed ~ contains? kind))
                        (else false))
                (fail (OsError
                  ^message "agent context kind must be message, file, memory, event, summary, or worker")))
              (if (&& (== m/kind "worker")
                      (! (match m/worker_id
                           (when (_id : Str) true) (else false))))
                (fail (OsError
                  ^message "worker context attachments require ^worker_id Str"))))
            (else
              (fail (OsError
                ^message "agent context attachments must be maps")))))
        (var encoded (stringify copied))
        (if_yes (> (byte_size encoded) agent_attachment_max_bytes)
          (fail (OsError
            ^message $"agent context exceeds ${agent_attachment_max_bytes} bytes")))
        copied)
      (else
        (fail (OsError ^message "agent context must be a list"))))))

(fn spawn_supervised_named_agent_with_context
  [app, title : Str, assignment : Str, context, requested_name]
  (var attachments (normalize_agent_attachments context))
  # Resolve ergonomic names once at delegation time. Durable capability
  # records always carry the canonical immutable worker id.
  (for attachment in attachments
    (if_yes (== attachment/kind "worker")
      (var worker (application_find_worker app attachment/worker_id))
      (if (== worker nil)
        (fail (OsError
          ^message $"delegated worker ${attachment/worker_id} was not found")))
      (attachment ~ Map/put! "worker_id" worker/id)))
  (var safe_assignment (redact assignment))
  (var context_text
    (if (empty? attachments) ""
      $"\nCopied context attachments (redacted, bounded snapshots):\n${(stringify attachments)}"))
  (application_spawn_named_agent_with_attachments app title safe_assignment
    (cell
      (append (initial_items (app/memory ~ Cell/get))
        (system_item
          $"You are a supervised sub-agent. Assignment: ${safe_assignment}\nKeep private tool chatter out of the main context and return a concise result.${context_text}")))
    (cell "ready\n") attachments requested_name))

(fn spawn_supervised_agent_with_context
  [app, title : Str, assignment : Str, context]
  (spawn_supervised_named_agent_with_context
    app title assignment context nil))

(fn spawn_supervised_agent [app, title : Str, assignment : Str]
  (spawn_supervised_agent_with_context app title assignment []))

(fn release_worker_input_reservation! [worker]
  (worker/input_reserved ~ Cell/set false)
  (if (== (worker/current_task ~ Cell/get) nil)
    (worker/status ~ Cell/set
      (if (== (worker/lifecycle ~ Cell/get) "stopped") "stopped" "idle"))))

# Admission and Task installation happen without awaiting, in one scheduler
# turn. Callers may therefore acknowledge an input only after `current_task`
# and its canonical operation are visible to every adapter.
(fn start_hidden_agent_prompt [app, agent, prompt : Str, adapter : Str,
                               surface_id]
  (if (== (agent/lifecycle ~ Cell/get) "stopped")
    {^accepted false ^error $"agent ${agent/id} is stopped"}
    (if (|| (agent/input_reserved ~ Cell/get)
            (!= (agent/current_task ~ Cell/get) nil))
      (then {^accepted false ^error $"agent ${agent/id} is already working"})
      (else
      (do
      (agent/input_reserved ~ Cell/set true)
      (agent/status ~ Cell/set "admitting")
      (worker_history_push! agent prompt adapter surface_id)
      (bounded_worker_append! agent $"user|› ${prompt}\n")
      (application_emit app "agent_status"
        {^worker_id agent/id ^agent_id agent/id
         ^parent_agent_id agent/parent_id
         ^status "working"})
      (var task
        (spawn
          (do
            (var result (cell (agent/items ~ Cell/get)))
            (var final_text (cell ""))
            (var outcome (cell "cancelled"))
            (var error_kind (cell "cancelled"))
            (var error_text (cell "agent operation cancelled"))
            (var emit
              (fn [type props]
                (if (&& (== type "agent_text") (present? props/text))
                  (final_text ~ Cell/set props/text))
                (var tagged {^worker_id agent/id ^agent_id agent/id
                             ^parent_agent_id agent/parent_id})
                (for [key value] in props
                  (tagged ~ Map/put! key value))
                (application_emit app type tagged)))
            (try
              (result ~ Cell/set
                (run_turn_in (interactive_transport)
                  (append (agent/items ~ Cell/get) (user_item prompt))
                  (fn [text]
                    (if_not (== text "")
                      (bounded_worker_append! agent $"agent|${text}\n")))
                  (fn [delta]
                    (if_not (== delta "")
                      (bounded_worker_append! agent delta)))
                  max_tool_rounds emit {^app app ^agent agent}))
              (outcome ~ Cell/set "completed")
            catch {^message message}
              (outcome ~ Cell/set "failed")
              (error_kind ~ Cell/set "AgentError")
              (error_text ~ Cell/set message)
            catch _
              (outcome ~ Cell/set "failed")
              (error_kind ~ Cell/set "AgentError")
              (error_text ~ Cell/set "agent operation failed")
            ensure
              (agent/items ~ Cell/set (result ~ Cell/get))
              (application_finish_agent_operation!
                app agent (outcome ~ Cell/get) (final_text ~ Cell/get)
                (error_kind ~ Cell/get) (error_text ~ Cell/get) nil)))))
      (var operation
        (application_begin_worker_operation! app agent task "agent_turn"))
      (release_worker_input_reservation! agent)
      (if (== operation nil)
        (then
          (do
            (var rejected
              {^accepted false ^error $"agent ${agent/id} is stopped"})
            (task ~ Task/cancel)
            rejected))
        (else
          (do
            (var accepted {^accepted true ^task task})
            (task ~ Task/detach)
            accepted))))))))

(fn run_hidden_agent_prompt [app, agent, prompt : Str]
  (var started (start_hidden_agent_prompt app agent prompt "model" nil))
  (if (! started/accepted)
    (then $"error: ${started/error}")
    (else
      (await started/task)
      (if (== (agent/last_outcome ~ Cell/get) "completed")
        (then (agent_result_text (agent/result ~ Cell/get)))
        (else
          (var report (agent_result_report agent))
          $"error: ${report}")))))

(fn application_send_worker_input [app, worker, text : Str, adapter : Str]
  (var operation (worker_primary_operation worker/kind))
  (if (== operation nil)
    "error: worker does not accept input"
    (do
      (var raw_args (operation/parse_cli text))
      (var local_pane
        (if (== adapter "local_tui")
          (application_find_pane_worker app worker/id)))
      (var route
        (if local_pane $"pane ${local_pane/id}" $"worker ${worker/id}"))
      (var response
        (application_call_worker app worker/id operation/name raw_args
          {^origin (if (== adapter "local_tui") "user"
                     (if (== adapter "model") "model" "remote"))
           ^adapter adapter
           ^route route
           ^surface_id
             (if (&& (== adapter "local_tui") app/local_surface)
               (app/local_surface/instance_id ~ Cell/get))
           ^detached (if (== adapter "local_tui") (stdin_tty?) true)
           ^caller_worker_id
             (if (== adapter "model") app/main_agent/id nil)}))
      (var rendered (worker_call_text response))
      (if (&& response/ok (== adapter "local_tui") (! (stdin_tty?))
              (== operation/name "send"))
        (do
          (var pane (application_find_pane_worker app worker/id))
          (if pane $"extension ${pane/id} completed: ${rendered}" rendered))
        rendered))))

# ---------------------------------------------------------------------------
# Slice C4: one typed worker-operation surface.
# ---------------------------------------------------------------------------

(fn worker_busy? [worker] : Bool
  (|| (worker/input_reserved ~ Cell/get)
      (!= (worker/current_task ~ Cell/get) nil)
      (!= (worker/current_operation ~ Cell/get) nil)))

(fn operation_ack [worker, accepted : Bool, text : Str]
  (var operation (worker/current_operation ~ Cell/get))
  {^accepted accepted ^text text ^worker_id worker/id
   ^task_id (if operation operation/task_id)})

(fn worker_status_value [worker]
  {^worker_id worker/id ^name worker/name ^kind worker/kind
   ^lifecycle (worker/lifecycle ~ Cell/get)
   ^status (worker/status ~ Cell/get) ^busy (worker_busy? worker)
   ^current_operation (worker/current_operation ~ Cell/get)
   ^last_outcome (worker/last_outcome ~ Cell/get)})

(fn worker_tail_value [worker, requested]
  (var n (if (|| (== requested nil) (== requested void)) 40 requested))
  (if (|| (< n 1) (> n 500))
    (fail (OsError ^message "tail n must be between 1 and 500")))
  (var lines (split (worker/output ~ Cell/get) "\n"))
  {^worker_id worker/id
   ^text ((bounded_list_tail lines n) ~ join "\n")
   ^requested n ^dropped_bytes (worker/dropped_bytes ~ Cell/get)
   ^dropped_before (worker/dropped_before ~ Cell/get)
   ^history_dropped (worker/history_dropped ~ Cell/get)})

(fn agent_result_value [agent]
  (var result (agent/result ~ Cell/get))
  (var read false)
  (var incorporated false)
  (match result
    (when (m : Map)
      (set read (== m/read true))
      (set incorporated (== m/incorporated true)))
    (else nil))
  {^worker_id agent/id ^available (!= result nil) ^result result
   ^read read ^incorporated incorporated})

(fn valid_environment_name [raw : Str] : Str
  (var name (trim raw))
  (if (|| (== name "") (> (byte_size name) 128))
    (fail (OsError ^message "environment name must contain 1-128 characters")))
  (var first true)
  (for ch in (graphemes name)
    (var allowed
      (if first
        (contains? "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_" ch)
        (contains? "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_0123456789" ch)))
    (if_not allowed
      (fail (OsError
        ^message "environment name must match [A-Za-z_][A-Za-z0-9_]*")))
    (set first false))
  name)

(fn application_shell_chdir! [app, worker, path : Str]
  (safe_path path)
  # list_dir is the capability-aware directory check; it rejects files while
  # real_path gives the subprocess an immutable, symlink-resolved cwd.
  (list_dir ReadDir path)
  (var resolved (real_path ReadDir path))
  (worker/controller/cwd ~ Cell/set resolved)
  (append_worker_transcript! app worker $"[cwd ${resolved}]\n")
  (operation_ack worker true $"cwd: ${resolved}"))

(fn application_shell_set_env! [worker, name : Str, value : Str]
  (var key (valid_environment_name name))
  ((worker/controller/environment ~ Cell/get) ~ Map/put! key value)
  (operation_ack worker true $"set ${key}"))

(fn application_shell_unset_env! [worker, name : Str]
  (var key (valid_environment_name name))
  # `void` removes the binding from Gene's map surface and is also treated as
  # an explicit unset by shell_environment_args during compatibility restore.
  ((worker/controller/environment ~ Cell/get) ~ Map/put! key void)
  (operation_ack worker true $"unset ${key}"))

(fn application_file_view! [app, worker, path : Str]
  (var safe (safe_path path))
  (var text (read_text ReadDir safe))
  (worker/controller ~ Node/set_prop! `path safe)
  (application_set_projection_output! app worker text "file_view")
  (operation_ack worker true $"viewing ${safe}"))

(fn dispatch_worker_operation [app, worker, op, args, invocation]
  (match op/name
    (when "status" (worker_status_value worker))
    (when "tail" (worker_tail_value worker args/n))
    (when "cancel"
      (var accepted
        (if (== worker/kind "agent")
          (application_cancel_agent app worker)
          (application_cancel_worker app worker)))
      (operation_ack worker accepted
        (if accepted $"cancelling worker ${worker/id}"
          $"worker ${worker/id} is idle")))
    (when "stop"
      (var accepted
        (if (== worker/kind "agent")
          (application_stop_agent app worker)
          (application_stop_worker app worker)))
      (operation_ack worker accepted
        (if accepted $"stopped worker ${worker/id}"
          $"worker ${worker/id} cannot be stopped")))
    (when "restart"
      (var restarted (restart_process_worker! app worker))
      (if_not restarted/ok
        (fail (OsError ^message restarted/error)))
      (operation_ack restarted/worker true
        $"restarted worker ${worker/id} as ${restarted/worker/id}"))
    (when "send"
      (var adapter (invocation_field invocation "adapter"))
      (var detached (invocation_field invocation "detached"))
      (var started
        (start_hidden_agent_prompt app worker args/prompt
          (if adapter adapter (invocation_field invocation "origin"))
          (invocation_field invocation "surface_id")))
      (if_not started/accepted
        (fail (OsError ^message started/error)))
      (if (== detached false)
        (do
          (await started/task)
          (operation_ack worker
            (== (worker/last_outcome ~ Cell/get) "completed")
            (if (== (worker/last_outcome ~ Cell/get) "completed")
              (agent_result_text (worker/result ~ Cell/get))
              (agent_result_report worker))))
        (operation_ack worker true "accepted")))
    (when "result" (agent_result_value worker))
    (when "mark_result_read"
      (operation_ack worker (application_mark_agent_result_read! app worker)
        "result marked read"))
    (when "incorporate"
      (operation_ack worker (application_incorporate_agent_result! app worker)
        "result incorporated"))
    (when "run"
      (var adapter (invocation_field invocation "adapter"))
      (var detached (invocation_field invocation "detached"))
      (var detach_task (if (== detached false) false true))
      (var result
        (run_shell_worker_command app worker args/command args/timeout_ms
          (if adapter adapter (invocation_field invocation "origin"))
          (invocation_field invocation "surface_id")
          (if (invocation_field invocation "route")
            (invocation_field invocation "route") $"worker ${worker/id}")
          detach_task
          (== (invocation_field invocation "origin") "remote")))
      (if (&& detach_task (!= result "accepted"))
        (fail (OsError ^message result)))
      (operation_ack worker true result))
    (when "chdir" (application_shell_chdir! app worker args/path))
    (when "set_env"
      (application_shell_set_env! worker args/name args/value))
    (when "unset_env"
      (application_shell_unset_env! worker args/name))
    (when "eval"
      (var detached (invocation_field invocation "detached"))
      (var detach_task (if (== detached false) false true))
      (var result
        (run_repl_worker_command app worker args/form "local_tui"
          (invocation_field invocation "surface_id")
          (if (invocation_field invocation "route")
            (invocation_field invocation "route") $"worker ${worker/id}")
          detach_task))
      (if (&& detach_task (!= result "accepted"))
        (fail (OsError ^message result)))
      (operation_ack worker true result))
    (when "append"
      (if_not (application_append_worker_output!
                app worker (redact_any args/text)
                (invocation_field invocation "origin"))
        (fail (OsError ^message "output worker does not accept append")))
      (operation_ack worker true $"appended to worker ${worker/id}"))
    (when "follow"
      (var source (application_find_worker app args/source))
      (var followed (application_follow_output! app worker source))
      (if_not followed/ok (fail (OsError ^message followed/error)))
      (operation_ack worker true $"worker ${worker/id} follows ${source/id}"))
    (when "unfollow"
      (var source (application_find_worker app args/source))
      (if (== source nil)
        (fail (OsError ^message "source worker not found")))
      (operation_ack worker
        (application_unfollow_output! app worker source/id)
        $"worker ${worker/id} unfollowed ${source/id}"))
    (when "filter"
      (worker/controller/filter ~ Cell/set (parse_trace_filters args/expr))
      (operation_ack worker true "filter updated"))
    (when "info"
      (var path worker/controller/path)
      {^worker_id worker/id ^path path
       ^bytes (byte_size (worker/output ~ Cell/get)) ^loaded true})
    (when "view" (application_file_view! app worker args/path))
    (when "reload"
      (application_file_view! app worker worker/controller/path))
    (when "snapshot"
      {^worker_id worker/id ^snapshot (application_worker_snapshot app worker)})
    (else
      (fail (OsError ^message $"operation handler missing: ${op/name}")))))

(var worker_operation_tables {})

(fn valid_operation_member! [kind : Str, name : Str, field : Str, value,
                             allowed]
  (if_not (allowed ~ contains? value)
    (fail (OsError
      ^message $"invalid ${field} '${value}' on ${kind}/${name}"))))

(fn register_worker_operation! [kind : Str, operation]
  (if (== operation/enabled void)
    (operation ~ Node/set_prop! `enabled true))
  (if (== (trim operation/name) "")
    (fail (OsError ^message $"${kind} operation name cannot be empty")))
  (for effect in operation/effects
    (valid_operation_member! kind operation/name "effect" effect
      ["observe" "session_write" "model_call" "host_read" "host_write"]))
  (if (&& (operation/effects ~ contains? "observe")
          (!= (operation/effects ~ size) 1))
    (fail (OsError
      ^message $"observe must be the only effect on ${kind}/${operation/name}")))
  (for audience in operation/audience
    (valid_operation_member! kind operation/name "audience" audience
      ["local_user" "remote_user" "supervisor" "delegated" "self"]))
  (valid_operation_member! kind operation/name "admission"
    operation/admission
    ["none" "session_serialized" "interrupt" "worker_exclusive"])
  (valid_operation_member! kind operation/name "audit" operation/audit
    ["none" "attributed" "full"])
  (if (&& (== operation/audit "none")
          (! (operation/effects ~ contains? "observe")))
    (fail (OsError
      ^message $"audit none requires observe effect on ${kind}/${operation/name}")))
  (var current (worker_operation_tables ~ Map/get kind))
  (if (== current void)
    (do
      (set current [])
      (worker_operation_tables ~ Map/put! kind current)))
  (for existing in current
    (if (== existing/name operation/name)
      (fail (OsError
        ^message $"duplicate worker operation ${kind}/${operation/name}")))
    (if (&& operation/primary_input existing/primary_input)
      (fail (OsError
        ^message $"${kind} already has primary input ${existing/name}"))))
  (current ~ List/push! operation)
  (capture_dynamic_registration!
    {^kind "operation" ^worker_kind kind ^name operation/name
     ^summary operation/summary ^usage operation/usage
     ^args_schema $"${operation/args}"
     ^result_schema $"${operation/result}"
     ^errors operation/errors ^effects operation/effects
     ^audience operation/audience ^admission operation/admission
     ^audit operation/audit ^cancellable operation/cancellable
     ^idempotent operation/idempotent ^task_managed operation/task_managed
     ^primary_input operation/primary_input
     ^handler_ref (handler_ref_data operation/handler_ref)})
  operation)

(fn parse_cli_empty [text : Str]
  (if_not (== (trim text) "")
    (fail (OsError ^message "this operation takes no arguments")))
  {})

(fn parse_cli_tail [text : Str]
  (var value (trim text))
  (if (== value "") {}
    {^n (parse_int value)}))

(fn cli_rest_parser [field : Str]
  (fn [text : Str]
    (var value (trim text))
    (if (== value "")
      (fail (OsError ^message $"missing ${field}")))
    (var out {})
    (out ~ Map/put! field value)
    out))

(fn cli_word_parser [field : Str]
  (fn [text : Str]
    (var value (trim text))
    (if (|| (== value "") (contains? value " "))
      (fail (OsError ^message $"expected one ${field}")))
    (var out {})
    (out ~ Map/put! field value)
    out))

(fn cli_pair_parser [first_field : Str, second_field : Str]
  (fn [text : Str]
    (var value (trim text))
    (var parts (split value " "))
    (var first (if (empty? parts) "" parts/0))
    (var second (trim (after_prefix value first)))
    (if (|| (== first "") (== second ""))
      (fail (OsError
        ^message $"expected ${first_field} and ${second_field}")))
    (var out {})
    (out ~ Map/put! first_field first)
    (out ~ Map/put! second_field second)
    out))

(fn declare_worker_operation!
  [kind : Str, name : Str, summary : Str, usage : Str, args, result,
   effects, audience, admission : Str, audit : Str, cancellable : Bool,
   idempotent : Bool, task_managed : Bool, primary_input : Bool, parse_cli]
  (register_worker_operation! kind
    (Operation ^name name ^summary summary ^usage usage ^args args ^result result
      ^errors [] ^effects effects ^audience audience ^admission admission
      ^audit audit ^cancellable cancellable ^idempotent idempotent
      ^task_managed task_managed ^handler dispatch_worker_operation
      ^primary_input primary_input ^parse_cli parse_cli ^handler_ref nil)))

(fn worker_operations_for_kind [kind : Str]
  (var out [])
  (var common (worker_operation_tables ~ Map/get "*"))
  (if (!= common void) (for op in common (out ~ List/push! op)))
  (var specific (worker_operation_tables ~ Map/get kind))
  (if (!= specific void) (for op in specific (out ~ List/push! op)))
  out)

(fn worker_operation_for [kind : Str, name : Str]
  (var found (cell nil))
  (for op in (worker_operations_for_kind kind)
    (if (== op/name name) (found ~ Cell/set op)))
  (found ~ Cell/get))

(fn worker_primary_operation [kind : Str]
  (var found (cell nil))
  (for operation in (worker_operations_for_kind kind)
    (if operation/primary_input (found ~ Cell/set operation)))
  (found ~ Cell/get))

(fn agent_has_worker_attachment? [agent, worker_id : Str] : Bool
  (var found (cell false))
  (if agent
    (for attachment in (agent/attachments ~ Cell/get)
      (if (&& (== attachment/kind "worker")
              (== attachment/worker_id worker_id))
        (found ~ Cell/set true))))
  (found ~ Cell/get))

(fn invocation_audience [app, worker, invocation] : Str
  (var origin (invocation_field invocation "origin"))
  (var caller_id (invocation_field invocation "caller_worker_id"))
  (match origin
    (when "user" "local_user")
    (when "remote" "remote_user")
    (when "worker"
      (if (== caller_id app/main_agent/id) "supervisor" "delegated"))
    (when "model"
      (if (|| (== caller_id nil) (== caller_id app/main_agent/id))
        "supervisor" "delegated"))
    (else "remote_user")))

(fn invocation_authorized? [app, worker, operation, invocation] : Bool
  (var audience (invocation_audience app worker invocation))
  (if (operation/audience ~ contains? audience)
    (if (== audience "delegated")
      (do
        (var caller
          (application_find_agent app
            (invocation_field invocation "caller_worker_id")))
        (agent_has_worker_attachment? caller worker/id))
      true)
    false))

(fn application_emit_operation_boundary!
  [app, worker, operation, invocation, task_id : Str, phase : Str, outcome]
  (var props
    {^worker_id worker/id ^kind worker/kind ^task_id task_id
     ^operation_kind operation/name})
  (var origin (invocation_field invocation "origin"))
  (var caller (invocation_field invocation "caller_worker_id"))
  (if origin (props ~ Map/put! "origin" origin))
  (if caller (props ~ Map/put! "caller_worker_id" caller))
  (if outcome (props ~ Map/put! "outcome" outcome))
  (application_emit app $"worker_operation_${phase}" props))

(fn operation_failure [kind : Str, message : Str, worker_id, operation]
  {^ok false
   ^error {^kind kind ^message (redact message)
           ^worker_id worker_id ^operation operation}})

(fn application_reject_worker_operation!
  [app, worker, worker_ref : Str, operation_name : Str, invocation,
   kind : Str, message : Str]
  (var props
    {^worker_id (if worker worker/id worker_ref)
     ^kind (if worker worker/kind nil) ^operation_kind operation_name
     ^error_kind kind ^error_text (redact message)})
  (var origin (invocation_field invocation "origin"))
  (var caller (invocation_field invocation "caller_worker_id"))
  (if origin (props ~ Map/put! "origin" origin))
  (if caller (props ~ Map/put! "caller_worker_id" caller))
  (application_emit app "worker_operation_rejected" props)
  (operation_failure kind message (if worker worker/id worker_ref)
                     operation_name))

(fn application_call_worker
  [app, worker_ref : Str, operation_name : Str, raw_args, invocation]
  (var worker (application_find_worker app worker_ref))
  (if (== worker nil)
    (return
      (application_reject_worker_operation! app nil worker_ref operation_name
        invocation "worker_not_found" $"worker ${worker_ref} not found")))

  (var operation (worker_operation_for worker/kind operation_name))
  (if (== operation nil)
    (return
      (application_reject_worker_operation! app worker worker_ref operation_name
        invocation "unknown_operation"
        $"${worker/kind} worker has no '${operation_name}' operation")))
  (if (== operation/enabled false)
    (return
      (application_reject_worker_operation! app worker worker_ref operation_name
        invocation "handler_unavailable"
        "operation handler is disabled because its saved version is unavailable")))
  (if_not (invocation_authorized? app worker operation invocation)
    (return
      (application_reject_worker_operation! app worker worker_ref operation_name
        invocation "worker_access_denied"
        "caller is not in the operation audience or lacks delegation")))
  (if (&& (== operation/admission "worker_exclusive")
          (worker_busy? worker))
    (return
      (application_reject_worker_operation! app worker worker_ref operation_name
        invocation "worker_busy" "worker is already working")))
  (if (&& (== (worker/lifecycle ~ Cell/get) "stopped")
          (!= operation_name "restart")
          (! (operation/effects ~ contains? "observe")))
    (return
      (application_reject_worker_operation! app worker worker_ref operation_name
        invocation "worker_stopped" "worker is stopped")))

  (var args nil)
  (var validation_error (cell nil))
  (try
    (set args (construct_type operation/args raw_args))
  catch {^message message}
    (validation_error ~ Cell/set message)
  catch _
    (validation_error ~ Cell/set "invalid operation arguments"))
  (if (validation_error ~ Cell/get)
    (return
      (application_reject_worker_operation! app worker worker_ref
        operation_name invocation "invalid_arguments"
        (validation_error ~ Cell/get))))

  (var task_id nil)
  (if (&& (== operation/audit "full") (! operation/task_managed))
    (do
      (set task_id (application_next_task_id! app))
      (application_emit_operation_boundary!
        app worker operation invocation task_id "started" nil)))
  (if operation/task_managed
    (do
      (var pending {})
      (for [key value] in invocation
        (pending ~ Map/put! key value))
      (pending ~ Map/put! "operation_name" operation/name)
      (worker/pending_invocation ~ Cell/set pending)))
  (var value nil)
  (var execution_error (cell nil))
  (try
    (set value
      (construct_type operation/result
        (operation/handler app worker operation args invocation)))
  catch {^message message}
    (execution_error ~ Cell/set message)
  catch _
    (execution_error ~ Cell/set "worker operation failed"))
  (var task_started
    (&& operation/task_managed
        (!= (worker/current_operation ~ Cell/get) nil)))
  # A task-managed handler consumes this when it installs the canonical
  # operation. Clear a leftover reservation after pre-task failure.
  (if operation/task_managed
    (worker/pending_invocation ~ Cell/set nil))
  (if (execution_error ~ Cell/get)
    (do
      (if (&& operation/task_managed (! task_started))
        (return
          (application_reject_worker_operation! app worker worker_ref
            operation_name invocation "operation_rejected"
            (execution_error ~ Cell/get))))
      (if task_id
        (application_emit_operation_boundary!
          app worker operation invocation task_id "finished" "failed"))
      (return
        (operation_failure "operation_failed" (execution_error ~ Cell/get)
          worker/id operation_name))))
  (if task_id
    (application_emit_operation_boundary!
      app worker operation invocation task_id "finished" "completed"))
  {^ok true ^worker_id worker/id ^operation operation_name
   ^effects operation/effects ^result value})

# Universal operations.
(declare_worker_operation! "*" "status" "Show bounded worker state." "status"
  EmptyArgs WorkerStatusResult ["observe"]
  ["local_user" "remote_user" "supervisor" "delegated"] "none" "none"
  false true false false parse_cli_empty)
(declare_worker_operation! "*" "tail" "Read recent bounded output." "tail [n]"
  TailArgs WorkerTailResult ["observe"]
  ["local_user" "remote_user" "supervisor" "delegated"] "none" "none"
  false true false false parse_cli_tail)
(declare_worker_operation! "*" "cancel" "Cancel active work." "cancel"
  EmptyArgs OperationAck ["session_write"]
  ["local_user" "remote_user" "supervisor"] "interrupt" "full"
  true false false false parse_cli_empty)
(declare_worker_operation! "*" "stop" "Cancel and stop this worker." "stop"
  EmptyArgs OperationAck ["session_write"]
  ["local_user" "remote_user" "supervisor"] "interrupt" "full"
  true false false false parse_cli_empty)
(declare_worker_operation! "*" "restart" "Restart a stopped worker." "restart"
  EmptyArgs OperationAck ["session_write"]
  ["local_user" "remote_user" "supervisor"] "worker_exclusive" "full"
  false false false false parse_cli_empty)

# Agent operations.
(declare_worker_operation! "agent" "send" "Start a supervised model turn."
  "send <prompt>" AgentSendArgs OperationAck ["session_write" "model_call"]
  ["local_user" "remote_user" "supervisor"] "worker_exclusive" "full"
  true false true true (cli_rest_parser "prompt"))
(declare_worker_operation! "agent" "result" "Read the latest result without marking it."
  "result" EmptyArgs AgentResultValue ["observe"]
  ["local_user" "remote_user" "supervisor"] "none" "none"
  false true false false parse_cli_empty)
(declare_worker_operation! "agent" "mark_result_read" "Mark the result read."
  "mark_result_read" EmptyArgs OperationAck ["session_write"]
  ["local_user" "remote_user" "supervisor"] "session_serialized" "full"
  false true false false parse_cli_empty)
(declare_worker_operation! "agent" "incorporate" "Add the result to main context."
  "incorporate" EmptyArgs OperationAck ["session_write"]
  ["local_user" "remote_user" "supervisor"] "session_serialized" "full"
  false true false false parse_cli_empty)

# Stateful shell operations.
(declare_worker_operation! "shell" "run" "Run under the worker cwd/environment."
  "run <command>" ShellRunArgs OperationAck ["host_write"]
  ["local_user" "remote_user" "supervisor" "delegated"]
  "worker_exclusive" "full" true false true true (cli_rest_parser "command"))
(declare_worker_operation! "shell" "chdir" "Change confined worker cwd."
  "chdir <workspace-path>" ShellChdirArgs OperationAck
  ["host_read" "session_write"]
  ["local_user" "remote_user" "supervisor" "delegated"]
  "worker_exclusive" "full" false false false false (cli_rest_parser "path"))
(declare_worker_operation! "shell" "set_env" "Set a worker environment override."
  "set_env <name> <value>" EnvironmentSetArgs OperationAck ["session_write"]
  ["local_user" "remote_user" "supervisor" "delegated"]
  "worker_exclusive" "full" false false false false
  (cli_pair_parser "name" "value"))
(declare_worker_operation! "shell" "unset_env" "Unset a worker environment value."
  "unset_env <name>" EnvironmentUnsetArgs OperationAck ["session_write"]
  ["local_user" "remote_user" "supervisor" "delegated"]
  "worker_exclusive" "full" false false false false (cli_word_parser "name"))

(declare_worker_operation! "repl" "eval" "Evaluate one local Gene form."
  "eval <form>" ReplEvalArgs OperationAck ["session_write"] ["local_user"]
  "worker_exclusive" "full" true false true true (cli_rest_parser "form"))
(declare_worker_operation! "output" "append" "Append bounded redacted text."
  "append <text>" OutputAppendArgs OperationAck ["session_write"]
  ["local_user" "remote_user" "supervisor" "delegated"]
  "session_serialized" "full" false false false false (cli_rest_parser "text"))
(declare_worker_operation! "output" "follow" "Project a worker's future output."
  "follow <source>" WorkerSourceArgs OperationAck ["session_write"]
  ["local_user" "remote_user" "supervisor"] "session_serialized" "full"
  false true false false (cli_word_parser "source"))
(declare_worker_operation! "output" "unfollow" "Stop projecting a source worker."
  "unfollow <source>" WorkerSourceArgs OperationAck ["session_write"]
  ["local_user" "remote_user" "supervisor"] "session_serialized" "full"
  false true false false (cli_word_parser "source"))
(declare_worker_operation! "log_tail" "filter" "Replace event-tail filters."
  "filter <expr>" LogFilterArgs OperationAck ["session_write"]
  ["local_user" "remote_user" "supervisor"] "session_serialized" "full"
  false true false true (cli_rest_parser "expr"))
(declare_worker_operation! "file_view" "info" "Read file-view metadata."
  "info" EmptyArgs FileInfoResult ["observe"]
  ["local_user" "remote_user" "supervisor" "delegated"] "none" "none"
  false true false false parse_cli_empty)
(declare_worker_operation! "file_view" "view" "Load a confined workspace file."
  "view <workspace-path>" FileViewArgs OperationAck
  ["host_read" "session_write"] ["local_user" "remote_user" "supervisor"]
  "worker_exclusive" "full" false false false false (cli_rest_parser "path"))
(declare_worker_operation! "file_view" "reload" "Reload the current file."
  "reload" EmptyArgs OperationAck ["host_read" "session_write"]
  ["local_user" "remote_user" "supervisor"] "worker_exclusive" "full"
  false false false false parse_cli_empty)
(declare_worker_operation! "stats" "snapshot" "Read the bounded stats snapshot."
  "snapshot" EmptyArgs StatsSnapshotResult ["observe"]
  ["local_user" "remote_user" "supervisor" "delegated"] "none" "none"
  false true false false parse_cli_empty)

(fn worker_call_text [response] : Str
  (if response/ok
    (do
      (var text response/result/text)
      (if (|| (== text nil) (== text void))
        (stringify (props response/result)) text))
    $"error: ${response/error/kind}: ${response/error/message}"))

(fn model_worker_invocation [app, args]
  (var context args/_context)
  {^origin "model"
   ^caller_worker_id
     (if (&& (present? context) (present? context/agent))
       context/agent/id app/main_agent/id)})

(register_tool! (Tool
  ^name "call_worker"
  ^description "Invoke a worker's declared typed operation. Use status/tail to supervise without opening a pane."
  ^risk "execute"
  ^args CallWorkerToolArgs
  ^params [{^name "worker_id" ^doc "canonical worker id or immutable worker name"}
           {^name "op" ^doc "operation declared by the target worker kind"}
           {^name "args" ^doc "operation-specific argument object"}]
  ^handler (fn [args]
    (var app (tool_application args))
    (if (== app nil)
      "error: agent application is unavailable"
      (worker_call_text
        (application_call_worker app args/worker_id args/op
          (if (== args/args void) {} args/args)
          (model_worker_invocation app args)))))))

(register_tool! (Tool
  ^name "pin_artifact"
  ^description "Promote an agent result or worker tail to durable redacted evidence."
  ^risk "write"
  ^args PinArtifactToolArgs
  ^params [{^name "source" ^doc "result or tail"}
           {^name "worker_id" ^doc "agent/worker id or immutable name"}]
  ^handler (fn [args]
    (var app (supervisor_tool_application args))
    (if (== app nil)
      "error: main supervisor authority is required"
      (if (== args/source "result")
        (do
          (var agent (application_find_agent app args/worker_id))
          (var result (if agent (agent/result ~ Cell/get)))
          (if (== result nil)
            "error: agent result not found"
            (do
              (var pinned
                (application_pin_artifact! app "result"
                  (agent_result_text result) agent/id result/task_id))
              (if pinned/ok pinned/artifact/id $"error: ${pinned/error}"))))
        (if (== args/source "tail")
          (do
            (var worker (application_find_worker app args/worker_id))
            (if (== worker nil)
              "error: worker not found"
              (do
                (var operation (worker/current_operation ~ Cell/get))
                (var pinned
                  (application_pin_artifact! app "capture"
                    (worker/output ~ Cell/get) worker/id
                    (if operation operation/task_id nil)))
                (if pinned/ok pinned/artifact/id $"error: ${pinned/error}"))))
          "error: source must be result or tail"))))))

(register_tool! (Tool
  ^name "spawn_agent"
  ^description "Create a bounded supervised sub-agent without opening a pane. Returns its stable agent id."
  ^risk "execute"
  ^args SpawnAgentToolArgs
  ^params [{^name "assignment" ^doc "clear task and expected result for the sub-agent"}
           {^name "title" ^doc "short display title"}
           {^name "name" ^doc "immutable session-local worker name"}]
  ^handler (fn [args]
    (var app (supervisor_tool_application args))
    (if (== app nil)
      (then "error: main supervisor authority is required")
      (else
        (var title (if (== args/title void) "sub-agent" args/title))
        (var agent
          (spawn_supervised_named_agent_with_context app title args/assignment []
            (if (== args/name void) nil args/name)))
        (if (== agent nil)
          $"error: sub-agent limit reached (${app/max_agents})"
          agent/id))))))

(register_tool! (Tool
  ^name "send_agent"
  ^description "Send a prompt to an existing supervised agent and wait for its concise result. A visible pane is not required."
  ^risk "execute"
  ^args SendAgentToolArgs
  ^handler (fn [args]
    (var app (supervisor_tool_application args))
    (var agent (if app
                 (application_find_agent app args/agent_id)))
    (if (== agent nil)
      "error: agent not found"
      (if (== agent/id "main")
        "error: send_agent accepts supervised agents only"
        (do
          (var response
            (application_call_worker app agent/id "send"
              {^prompt args/prompt} (model_worker_invocation app args)))
          (if_not response/ok
            (return $"error: ${response/error/kind}: ${response/error/message}"))
          (var task (agent/current_task ~ Cell/get))
          (if task (await task))
          (if (== (agent/last_outcome ~ Cell/get) "completed")
            (agent_result_text (agent/result ~ Cell/get))
            $"error: ${(agent_result_report agent)}")))))))

(register_tool! (Tool
  ^name "agent_result"
  ^description "Read and explicitly incorporate the latest structured result of a supervised agent into the main model context."
  ^risk "read"
  ^args AgentIdToolArgs
  ^handler (fn [args]
    (var app (supervisor_tool_application args))
    (var agent (if app
                 (application_find_agent app args/agent_id)))
    (if (== agent nil)
      (then "error: agent not found")
      (else
        (var report (agent_result_report agent))
        (var observed
          (application_call_worker app agent/id "result" {}
            (model_worker_invocation app args)))
        (if_not observed/ok
          (return $"error: ${observed/error/kind}: ${observed/error/message}"))
        (if_not observed/result/available
          (return $"agent ${agent/id} has no result"))
        (application_call_worker app agent/id "mark_result_read" {}
          (model_worker_invocation app args))
        (application_call_worker app agent/id "incorporate" {}
          (model_worker_invocation app args))
        report)))))

(register_tool! (Tool
  ^name "update_progress"
  ^description "Update the main project's bounded objective, phase, status, and summary. Blocked status requires a reason and required action."
  ^risk "execute"
  ^args UpdateProgressToolArgs
  ^params [{^name "phase"
            ^enum ["planning" "research" "implementing" "verifying" "handoff"]}
           {^name "status" ^enum ["active" "blocked" "complete"]}]
  ^handler (fn [args]
    (var app (supervisor_tool_application args))
    (if (== app nil)
      (then "error: main supervisor authority is required")
      (else
        (var current (app/progress ~ Cell/get))
        (application_update_progress!
          app args/objective args/phase args/status args/summary
          (if (== args/blocked_reason void) nil args/blocked_reason)
          (if (== args/required_action void) nil args/required_action)
          current/agent_ids current/worker_ids current/evidence_v)
        (project_progress_report app))))))

(register_tool! (Tool
  ^name "cancel_agent"
  ^description "Request cancellation of a supervised agent's current task."
  ^risk "execute"
  ^args AgentIdToolArgs
  ^handler (fn [args]
    (var app (supervisor_tool_application args))
    (var agent (if app
                 (application_find_agent app args/agent_id)))
    (if (== agent nil)
      "error: agent not found"
      (worker_call_text
        (application_call_worker app agent/id "cancel" {}
          (model_worker_invocation app args)))))))

(register_tool! (Tool
  ^name "stop_agent"
  ^description "Stop a supervised agent. This does not close unrelated panes."
  ^risk "execute"
  ^args AgentIdToolArgs
  ^handler (fn [args]
    (var app (supervisor_tool_application args))
    (var agent (if app
                 (application_find_agent app args/agent_id)))
    (if (== agent nil)
      "error: agent not found"
      (worker_call_text
        (application_call_worker app agent/id "stop" {}
          (model_worker_invocation app args)))))))

(register_tool! (Tool
  ^name "open_pane"
  ^description "Create or identify an agent/output worker and request pane presentation. Headless sessions record the hint without creating interface state."
  ^risk "execute"
  ^args OpenPaneToolArgs
  ^params [{^name "kind" ^doc "agent or output"}
           {^name "owner_id" ^doc "required for an agent pane"}
           {^name "text" ^doc "initial redacted text for an output pane"}]
  ^handler (fn [args]
    (var app (tool_application args))
    (if (== app nil)
      "error: agent application is unavailable"
      (if (== args/kind "agent")
        (then
          (var owner (if_not (== args/owner_id void)
                       (application_find_agent app args/owner_id)))
          (if (== owner nil)
            (then "error: owner_id must name an existing agent")
            (else
              (application_request_worker_attention app owner
                (if (== args/title void) owner/title args/title))
              (refresh_active_input)
              owner/id)))
        (else
          (if (== args/kind "output")
            (then
            (var initial (if (== args/text void) "" (redact_any args/text)))
            (var worker
              (application_new_worker app "output"
                (if (== args/title void) "output" args/title)
                (cell "")
                (OutputController ^source "model" ^following (cell []))))
            (if (== worker nil)
              (then "error: worker limit reached")
              (else
                (if_not (== initial "")
                  (application_append_worker_output! app worker initial "model"))
                (application_request_worker_attention app worker worker/title)
                (refresh_active_input)
                worker/id)))
            (else "error: model open_pane kind must be agent or output"))))))))

(register_tool! (Tool
  ^name "append_pane"
  ^description "Append redacted text to an output pane through the authoritative event log."
  ^risk "execute"
  ^args AppendPaneToolArgs
  ^handler (fn [args]
    (var app (tool_application args))
    (var pane (if app
                (application_find_pane app args/pane_id)))
    (if (== pane nil)
      "error: pane not found"
      (if (!= pane/kind "output")
        (then "error: append_pane accepts output panes only")
        (else
          (var response
            (application_call_worker app pane/worker/id "append"
              {^text args/text} (model_worker_invocation app args)))
          (if response/ok (refresh_active_input))
          (if response/ok $"appended to pane ${pane/id}"
            (worker_call_text response))))))))

(register_tool! (Tool
  ^name "append_worker"
  ^description "Append redacted text to a bounded output worker. A pane is not required."
  ^risk "execute"
  ^args AppendWorkerToolArgs
  ^handler (fn [args]
    (var app (tool_application args))
    (var worker
      (if app (application_find_worker app args/worker_id)))
    (if (== worker nil)
      "error: worker not found"
      (var response
        (application_call_worker app worker/id "append"
          {^text args/text} (model_worker_invocation app args)))
      (if response/ok (refresh_active_input))
      (worker_call_text response)))))

(register_tool! (Tool
  ^name "close_pane"
  ^description "Close a pane without implicitly stopping an attached agent."
  ^risk "execute"
  ^args ClosePaneToolArgs
  ^handler (fn [args]
    (var app (tool_application args))
    (if (== app nil)
      "error: agent application is unavailable"
      (if (application_close_pane app args/pane_id)
        (then (refresh_active_input) $"closed pane ${args/pane_id}")
        (else "error: pane not found"))))))

(register_tool! (Tool
  ^name "open_extension"
  ^description "Open a secondary agent pane in the interactive TUI and optionally run a delegated prompt in it. The pane keeps its own conversation context."
  ^risk "execute"
  ^args OpenExtensionToolArgs
  ^params [{^name "title" ^doc "short pane title; defaults to ext N"}
           {^name "prompt" ^doc "delegated task to run immediately; omit to open an idle pane"}]
  ^handler (fn [args]
    (var app (tool_application args))
    (if (== app nil)
      (then "error: agent application is unavailable")
      (else
        (var title (if (== args/title void) "sub-agent" args/title))
        (var agent
          (spawn_supervised_agent app title "awaiting assignment"))
        (if (== agent nil)
          (then "error: sub-agent limit reached")
          (else
            (var pane
              (application_request_worker_attention app agent agent/title))
            (if (|| (== args/prompt void) (blank_line? args/prompt))
              $"opened agent ${agent/id}"
              (do
                (var response
                  (application_call_worker app agent/id "send"
                    {^prompt args/prompt} (model_worker_invocation app args)))
                (if_not response/ok
                  (return
                    $"error: ${response/error/kind}: ${response/error/message}"))
                (var task (agent/current_task ~ Cell/get))
                (if task (await task))
                (if (== (agent/last_outcome ~ Cell/get) "completed")
                  (agent_result_text (agent/result ~ Cell/get))
                  $"error: ${(agent_result_report agent)}"))))))))))

# Registrations after this boundary come from the live session or a loaded
# workflow module and therefore participate in C5 durability handling.
(registration_capture_enabled ~ Cell/set true)

(fn extension_command_id [line : Str]
  (var parts (split line " "))
  (var selector parts/0)
  (if (&& (starts_with? selector "/") (> (byte_size selector) 1))
    (try
      (parse_int (after_prefix selector "/"))
    catch _ nil)))

(fn handle_extension_command [line : Str, transcript, memory, streaming]
  (var parts (split line " "))
  (var selector parts/0)
  (var id (extension_command_id line))
  (var pane (find_extension id))
  (var command (trim (after_prefix line selector)))
  (if (== pane nil)
    (render_agent_text transcript streaming $"pane ${id} is not open")
  (match command
    (when "close"
      (close_extension_pane id)
      (render_agent_text transcript streaming $"closed pane ${id}"))
      (when ""
        (var app (active_application ~ Cell/get))
        (application_focus_pane! app id)
        (render_agent_text transcript streaming $"focused pane ${id}"))
    (when "cancel"
      (application_cancel_worker
        (active_application ~ Cell/get) pane/worker)
      (render_agent_text transcript streaming
        $"cancelled worker ${pane/worker_id}"))
    (when "stop"
      (var stopped
        (application_stop_worker
          (active_application ~ Cell/get) pane/worker))
      (render_agent_text transcript streaming
        (if stopped $"stopped worker ${pane/worker_id}"
          $"worker ${pane/worker_id} is already stopped")))
    (when "focus"
      (var app (active_application ~ Cell/get))
      (application_focus_pane! app id)
      (render_agent_text transcript streaming $"focused pane ${id}"))
    (when "max"
      (var app (active_application ~ Cell/get))
      (var surface app/local_surface)
      (surface/maximized_pane ~ Cell/set
        (if_not (== (surface/maximized_pane ~ Cell/get) id) id))
      (render_agent_text transcript streaming
        (if (== (surface/maximized_pane ~ Cell/get) id)
          $"maximized pane ${id}" "restored split layout")))
    (else
      (var routed
        (if (starts_with? command "-- ")
          (after_prefix command "-- ") command))
      (match pane/kind
        (when "agent"
          (interactive_memory ~ Cell/set (memory ~ Cell/get))
          (begin_turn!)
          (emit_event! "user_input"
            {^text routed ^worker_id pane/worker_id
             ^pane_id id ^agent_id pane/controller/id})
          (render_agent_text transcript streaming
            (application_send_worker_input
              (active_application ~ Cell/get) pane/worker routed "local_tui")))
        (when "shell"
          (render_agent_text transcript streaming
            (application_send_worker_input
              (active_application ~ Cell/get) pane/worker routed "local_tui")))
        (when "repl"
          (render_agent_text transcript streaming
            (application_send_worker_input
              (active_application ~ Cell/get) pane/worker routed "local_tui")))
        (when "log_tail"
          (render_agent_text transcript streaming
            (application_send_worker_input
              (active_application ~ Cell/get) pane/worker routed "local_tui")))
        (when "output"
          (if (starts_with? routed "append ")
            (then
              (var text (after_prefix routed "append "))
              (var response
                (application_call_worker (active_application ~ Cell/get)
                  pane/worker/id "append" {^text text}
                  {^origin "user" ^caller_worker_id "main"}))
              (render_agent_text transcript streaming
                (if response/ok $"appended to pane ${id}"
                  (worker_operation_cli_text pane/worker "append" response))))
            (else
              (render_agent_text transcript streaming
                $"pane ${id} is read-only; use /${id} append <text>"))))
        (else
          (render_agent_text transcript streaming
            $"pane ${id} (${pane/kind}) does not accept input")))))))

(fn handle_open_extension [transcript, memory, streaming]
  (var pane (open_extension_pane "" (memory ~ Cell/get)))
  (if (== pane nil)
    (render_agent_text transcript streaming "sub-agent limit reached")
    (render_agent_text transcript streaming
      $"opened agent ${pane/controller/id} in pane ${pane/id}; use /${pane/id} <prompt> or /close")))

(fn worker_result_unread? [worker] : Bool
  (if (!= worker/kind "agent") false
    (match (worker/result ~ Cell/get)
      (when (m : Map) (== m/read false))
      (else false))))

(fn agents_report []
  (var app (active_application ~ Cell/get))
  (if (== app nil)
    (then "application is not running")
    (else
      (var lines [])
      (for agent in (app/agents ~ Cell/get)
        (var unread (worker_result_unread? agent))
        (var last (agent/last_outcome ~ Cell/get))
        (var last_text (if (== last nil) "none" last))
        (var address
          (if (present? agent/name) $"${agent/name} (${agent/id})" agent/id))
        (lines ~ List/push!
          $"${address} lifecycle=${(agent/lifecycle ~ Cell/get)} availability=${(agent/status ~ Cell/get)} last=${last_text} unread=${unread} panes=${(application_pane_ids_for_worker app agent/id)} ${agent/title}"))
      (join lines "\n"))))

(fn workers_report []
  (var app (active_application ~ Cell/get))
  (if (== app nil)
    (then "application is not running")
    (else
      (var lines [])
      (for worker in (app/workers ~ Cell/get)
        (var pane_refs [])
        (for candidate in (app/local_surface/panes ~ Cell/get)
          (if (== candidate/worker_id worker/id)
            (pane_refs ~ List/push!
              (if (candidate/hidden ~ Cell/get)
                $"${candidate/id}:hidden" $"${candidate/id}"))))
        (var operation (worker/current_operation ~ Cell/get))
        (var state
          (if (== (worker/lifecycle ~ Cell/get) "stopped")
            "stopped"
            (if (worker/input_reserved ~ Cell/get)
              "confirming"
              (if (== operation nil) "idle" "busy"))))
        (var location
          (if (== worker/id "main") "pane=0"
            (if (empty? pane_refs) "headless"
              (if (== pane_refs/~size 1)
                $"pane=${pane_refs/0}" $"panes=${pane_refs}"))))
        (var last (worker/last_outcome ~ Cell/get))
        (var last_text (if (== last nil) "none" last))
        (var unread (worker_result_unread? worker))
        (var address
          (if (present? worker/name) $"${worker/name} (${worker/id})" worker/id))
        (lines ~ List/push!
          $"${address} ${worker/kind} ${state} ${location} ${worker/title} last=${last_text} unread=${unread}"))
      (join lines "\n"))))

(fn panes_report []
  (var app (active_application ~ Cell/get))
  (if (|| (== app nil) (== app/local_surface nil))
    (then "this session has no local layout surface")
    (else
      (var surface app/local_surface)
      (var main_outcome (app/main_agent/last_outcome ~ Cell/get))
      (var main_outcome_text
        (if (== main_outcome nil) "none" main_outcome))
      (var lines [
        $"0 main agent visible lifecycle=${(app/main_agent/lifecycle ~ Cell/get)} ${(app/main_agent/status ~ Cell/get)} last=${main_outcome_text} unread=${(worker_result_unread? app/main_agent)} main"])
      (for pane in (surface/panes ~ Cell/get)
        (var worker pane/worker)
        (var operation (worker/current_operation ~ Cell/get))
        (var operation_text
          (if (== operation nil) "idle"
            $"busy:${operation/kind}:${operation/task_id}"))
        (var outcome (worker/last_outcome ~ Cell/get))
        (var outcome_text (if (== outcome nil) "none" outcome))
        (var visibility
          (if (pane/hidden ~ Cell/get) "hidden" "visible"))
        (var unread (worker_result_unread? worker))
        (lines ~ List/push!
          $"${pane/id} ${pane/worker_id} ${pane/kind} ${visibility} lifecycle=${(worker/lifecycle ~ Cell/get)} ${operation_text} last=${outcome_text} unread=${unread} ${pane/title}"))
      (join lines "\n"))))

(fn application_focus_pane! [app, id : Int] : Bool
  (var surface app/local_surface)
  (if (== surface nil)
    (then false)
    (else
      (if (== id 0)
        (then
          (surface/focused_pane ~ Cell/set nil)
          (surface/maximized_pane ~ Cell/set nil)
          true)
        (else
          (var pane (application_find_pane app id))
          (if (== pane nil)
            (then false)
            (else
              (pane/hidden ~ Cell/set false)
              (surface/focused_pane ~ Cell/set id)
              true)))))))

(fn application_hide_pane! [app, id : Int] : Bool
  (var pane (application_find_pane app id))
  (if (== pane nil)
    (then false)
    (else
      (pane/hidden ~ Cell/set true)
      (if (== (app/local_surface/focused_pane ~ Cell/get) id)
        (app/local_surface/focused_pane ~ Cell/set nil))
      (if (== (app/local_surface/maximized_pane ~ Cell/get) id)
        (app/local_surface/maximized_pane ~ Cell/set nil))
      true)))

(fn application_show_pane! [app, id : Int] : Bool
  (var pane (application_find_pane app id))
  (if (== pane nil)
    (then false)
    (else
      (pane/hidden ~ Cell/set false)
      true)))

(fn pane_command_id [text : Str]
  (try (parse_int (trim text)) catch _ nil))

(fn handle_pane_command [line : Str, items, transcript, memory, streaming]
  (var app (active_application ~ Cell/get))
  (var rest (trim (after_prefix line "/pane")))
  # Preserve the shipped `/pane output [title]` spelling as a concise alias.
  (if (|| (== rest "output") (starts_with? rest "output "))
    (then
      (var output_suffix
        (if (== rest "output") "" (after_prefix rest "output")))
      (set rest $"new output${output_suffix}")))
  (if (|| (== rest "") (== rest "list"))
    (render_agent_text transcript streaming (panes_report))
    (if (starts_with? rest "new ")
      (then
        (var create_rest (trim (after_prefix rest "new ")))
        (var parts (split create_rest " "))
        (var kind (if (empty? parts) "" parts/0))
        (var args (trim (after_prefix create_rest kind)))
        (match kind
          (when "agent"
            (handle_agent_command
              (if (== args "") "/agent new" $"/agent new ${args}")
              transcript memory streaming))
          (when "shell" (handle_shell_pane transcript streaming))
          (when "repl" (handle_repl_pane items transcript memory streaming))
          (when "tail"
            (var pane (open_log_tail_pane args))
            (render_agent_text transcript streaming
              (if pane $"opened event tail pane ${pane/id}"
                "worker limit reached")))
          (when "output"
            (var pane (open_output_pane args))
            (render_agent_text transcript streaming
              (if pane $"opened output pane ${pane/id}"
                "worker limit reached")))
          (when "view"
            (if (== args "")
              (render_agent_text transcript streaming
                "usage: /pane new view <workspace-path>")
              (do
                (var pane (open_file_view_pane args))
                (render_agent_text transcript streaming
                  (if pane $"opened ${args} in pane ${pane/id}"
                    $"cannot open ${args}")))))
          (when "stats"
            (var pane (open_stats_pane))
            (render_agent_text transcript streaming
              (if pane $"opened stats pane ${pane/id}"
                "worker limit reached")))
          (else
            (render_agent_text transcript streaming
              "usage: /pane new <agent|shell|repl|tail|output|view|stats> [args]"))))
      (else
        (if (starts_with? rest "open ")
          (then
            (var open_rest (trim (after_prefix rest "open ")))
            (var parts (split open_rest " "))
            (var worker_id (if (empty? parts) "" parts/0))
            (var pane_title (trim (after_prefix open_rest worker_id)))
            (var worker (application_find_worker app worker_id))
            (if (== worker nil)
              (render_agent_text transcript streaming
                $"worker ${worker_id} not found")
              (do
                (var pane
                  (application_attach_worker_pane_as app worker
                    (if (== worker/kind "agent") worker/id "user") "detach"
                    pane_title))
                (render_agent_text transcript streaming
                  (if pane $"opened worker ${worker/id} in pane ${pane/id}"
                    "pane limit reached")))))
          (else
            (var parts (split rest " "))
            (var action (if (empty? parts) "" parts/0))
            (var id_text (trim (after_prefix rest action)))
            (var id nil)
            # Accept both canonical action-first `/pane max 1` and natural
            # id-first `/pane 1 max`. Short `/1 max` remains available too.
            (var leading_id (pane_command_id action))
            (if (&& (!= leading_id nil)
                    (["focus" "show" "hide" "close" "max"] ~ contains? id_text))
              (do
                (set action id_text)
                (set id leading_id))
              (set id (pane_command_id id_text)))
            (if (== id nil)
              (render_agent_text transcript streaming
                (do
                  (var literal_help
                    (if (surface_route_input_capable? app)
                      "\nto send literal leading-slash input, use //text or /N -- text"
                      ""))
                  $"usage: /pane list | /pane new ... | /pane open W | /pane focus|show|hide|close|max N${literal_help}"))
              (match action
                (when "focus"
                  (render_agent_text transcript streaming
                    (if (application_focus_pane! app id)
                      (if (== id 0) "focused main agent" $"focused pane ${id}")
                      $"pane ${id} is not open")))
                (when "show"
                  (render_agent_text transcript streaming
                    (if (application_show_pane! app id)
                      $"showing pane ${id}" $"pane ${id} is not open")))
                (when "hide"
                  (render_agent_text transcript streaming
                    (if (application_hide_pane! app id)
                      $"hid pane ${id}" $"pane ${id} is not open")))
                (when "close"
                  (render_agent_text transcript streaming
                    (if (== id 0) "pane 0 cannot be closed"
                      (if (application_close_pane app id)
                        $"closed pane ${id}" $"pane ${id} is not open"))))
                (when "max"
                  (var pane (application_find_pane app id))
                  (if (== pane nil)
                    (render_agent_text transcript streaming
                      $"pane ${id} is not open")
                    (do
                      (pane/hidden ~ Cell/set false)
                      (app/local_surface/focused_pane ~ Cell/set id)
                      (app/local_surface/maximized_pane ~ Cell/set
                        (if_not (== (app/local_surface/maximized_pane ~ Cell/get)
                                   id) id))
                      (render_agent_text transcript streaming
                        (if (== (app/local_surface/maximized_pane ~ Cell/get) id)
                          $"maximized pane ${id}" "restored split layout")))))
                (else
                  (render_agent_text transcript streaming
                    "usage: /pane list | /pane new ... | /pane open W | /pane focus|show|hide|close|max N"))))))))))

(fn worker_operation_cli_text [worker, operation_name : Str, response] : Str
  (if response/ok
    (match operation_name
      (when "status"
        (var value response/result)
        $"${value/worker_id} ${value/kind} ${value/lifecycle}/${value/status} busy=${value/busy}")
      (when "tail" response/result/text)
      (when "result" (agent_result_report worker))
      (when "info"
        $"${response/result/path}: ${response/result/bytes} bytes")
      (when "snapshot" (stringify response/result/snapshot))
      (else
        (var text response/result/text)
        (if (|| (== text nil) (== text void))
          (stringify response/result) text)))
    $"${response/error/kind}: ${response/error/message}"))

(fn worker_operations_usage [worker] : Str
  (var entries [])
  (for operation in (worker_operations_for_kind worker/kind)
    (entries ~ List/push! operation/usage))
  (var joined (entries ~ join " | "))
  $"operations: ${joined}")

(fn handle_worker_command [line : Str, transcript, streaming]
  (var app (active_application ~ Cell/get))
  (var rest (trim (after_prefix line "/worker")))
  (var parts (split rest " "))
  (var worker_ref (if (empty? parts) "" parts/0))
  (var operation_text (trim (after_prefix rest worker_ref)))
  (var worker (application_find_worker app worker_ref))
  (if (== rest "list")
    (then (render_agent_text transcript streaming (workers_report)))
    (elif (|| (== worker_ref "") (== operation_text ""))
      (render_agent_text transcript streaming
        "usage: /worker list | /worker W open | /worker W <operation> [args]"))
    (elif (== worker nil)
      (render_agent_text transcript streaming $"worker ${worker_ref} not found"))
    (elif (== operation_text "open")
      (var pane (application_find_pane_worker app worker/id))
      (if (== pane nil)
        (set pane
          (application_attach_worker_pane app worker
            (if (== worker/kind "agent") worker/id "user") "detach")))
      (if pane (application_focus_pane! app pane/id))
      (render_agent_text transcript streaming
        (if pane $"opened worker ${worker/id} in pane ${pane/id}"
          "this session has no local layout surface")))
    (else
      (var op_parts (split operation_text " "))
      (var operation_name (if (empty? op_parts) "" op_parts/0))
      (var cli_args (trim (after_prefix operation_text operation_name)))
      (var operation (worker_operation_for worker/kind operation_name))
      (if (== operation nil)
        (do
          (var response
            (application_call_worker app worker/id operation_name {}
              {^origin "user" ^adapter "local_tui" ^detached (stdin_tty?)
               ^caller_worker_id app/main_agent/id}))
          (render_agent_text transcript streaming
            $"${response/error/kind}: ${response/error/message}; ${(worker_operations_usage worker)}"))
        (try
          (var raw_args (operation/parse_cli cli_args))
          (var response
            (application_call_worker app worker/id operation_name raw_args
              {^origin "user" ^adapter "local_tui" ^detached (stdin_tty?)
               ^caller_worker_id app/main_agent/id}))
          (render_agent_text transcript streaming
            (worker_operation_cli_text worker operation_name response))
        catch {^message message}
          (render_agent_text transcript streaming
            $"usage: /worker ${worker_ref} ${operation/usage}\n${message}"))))))

(fn handle_agent_command [line : Str, transcript, memory, streaming]
  (var app (active_application ~ Cell/get))
  (var rest (trim (after_prefix line "/agent")))
  (if (== rest "list")
    (then (render_agent_text transcript streaming (agents_report)))
    (else
  (if (|| (== rest "") (== rest "new"))
    (then (handle_open_extension transcript memory streaming))
    (else
      (if (starts_with? rest "new ")
        (then
        (var prompt (trim (after_prefix rest "new ")))
        (var pane (open_extension_pane "" (memory ~ Cell/get)))
        (if (== pane nil)
          (render_agent_text transcript streaming "sub-agent limit reached")
          (do
            (var response
              (application_call_worker app pane/worker/id "send" {^prompt prompt}
                {^origin "user" ^adapter "local_tui"
                 ^detached (stdin_tty?)
                 ^caller_worker_id app/main_agent/id}))
            (render_agent_text transcript streaming
              (if (&& response/ok (! (stdin_tty?)))
                $"extension ${pane/id} completed: ${response/result/text}"
                (worker_operation_cli_text pane/worker "send" response))))))
        (else
        (var parts (split rest " "))
        (var agent_id parts/0)
        (var action (trim (after_prefix rest agent_id)))
        (var agent (application_find_agent app agent_id))
        (if (== agent nil)
          (render_agent_text transcript streaming $"agent ${agent_id} not found")
          (if (starts_with? action "send ")
            (then
              (var prompt (after_prefix action "send "))
              (var response
                (application_call_worker app agent/id "send" {^prompt prompt}
                  {^origin "user" ^adapter "local_tui"
                   ^detached (stdin_tty?)
                   ^caller_worker_id app/main_agent/id}))
              (render_agent_text transcript streaming
                (worker_operation_cli_text agent "send" response)))
          (else
          (match action
            (when "open"
              (var pane (application_find_pane_worker app agent/id))
              (if (== pane nil)
                (set pane
                  (application_open_pane app "agent" agent/id agent/title
                    agent/transcript agent "detach"))
                (application_focus_pane! app pane/id))
              (render_agent_text transcript streaming
                (if pane $"opened agent ${agent/id} in pane ${pane/id}"
                  "pane limit reached")))
            (when "cancel"
              (var response
                (application_call_worker app agent/id "cancel" {}
                  {^origin "user" ^caller_worker_id app/main_agent/id}))
              (render_agent_text transcript streaming
                (worker_operation_cli_text agent "cancel" response)))
            (when "stop"
              (var response
                (application_call_worker app agent/id "stop" {}
                  {^origin "user" ^caller_worker_id app/main_agent/id}))
              (render_agent_text transcript streaming
                (worker_operation_cli_text agent "stop" response)))
            (when "result"
              (var observed
                (application_call_worker app agent/id "result" {}
                  {^origin "user" ^caller_worker_id app/main_agent/id}))
              (var text (worker_operation_cli_text agent "result" observed))
              (if observed/ok
                (application_call_worker app agent/id "mark_result_read" {}
                  {^origin "user" ^caller_worker_id app/main_agent/id}))
              (render_agent_text transcript streaming text))
            (when "incorporate"
              (var response
                (application_call_worker app agent/id "incorporate" {}
                  {^origin "user" ^caller_worker_id app/main_agent/id}))
              (render_agent_text transcript streaming
                (worker_operation_cli_text agent "incorporate" response)))
            (else
              (render_agent_text transcript streaming
                "usage: /agent list | /agent new [prompt] | /agent A send <prompt>|open|result|incorporate|cancel|stop")))))))))))))

(fn handle_output_pane_command [line : Str, transcript, streaming]
  (var title
    (if (== line "/pane output") ""
      (trim (after_prefix line "/pane output "))))
  (var pane (open_output_pane title))
  (render_agent_text transcript streaming
    (if (== pane nil) "application is not running"
      $"opened output pane ${pane/id}")))

(fn handle_shell_pane [transcript, streaming]
  (var pane (open_shell_pane))
  (if (== pane nil)
    (then (render_agent_text transcript streaming "application is not running"))
    (else
      (var app (active_application ~ Cell/get))
      (application_focus_pane! app pane/id)
      (render_agent_text transcript streaming
        $"shell pane ${pane/id}; use /${pane/id} <command>"))))

(fn agent_status_report [items, memory] : Str
  (var state_label
    (if (== (agent_store ~ Cell/get) nil) "off" (state_display)))
  (var context (context_stats (items ~ Cell/get) (memory ~ Cell/get)))
  (var item_count context/items)
  (var memory_count context/memory_items)
  (var event_count ((agent_events ~ Cell/get) ~ size))
  (var instruction_count ((agent_instruction_records ~ Cell/get) ~ size))
  (var guard_label (if (guard_enabled?) "on" "off"))
  (var app (active_application ~ Cell/get))
  (var agent_count (if (== app nil) 1 ((app/agents ~ Cell/get) ~ size)))
  (var pane_count
    (if (|| (== app nil) (== app/local_surface nil))
      0
      ((app/local_surface/panes ~ Cell/get) ~ size)))
  $"state: ${state_label}\nmodel: ${model}\napi: ${api_flavor}\neffort: ${(reasoning_effort ~ Cell/get)}\ntool rounds: max ${max_tool_rounds}\ncontext: ${context/bytes} bytes (~${context/approx_tokens} tokens), ${item_count} items, ${context/retained_turns} turns\ncontext limits: ${context/max_bytes} bytes, ${context/max_items} items, keep ${context/keep_turns} turns\nmemory: ${memory_count} items, ${context/memory_bytes} bytes\nevents: ${event_count}\ninstructions: ${instruction_count}\nagents: ${agent_count}\npanes: ${pane_count}\nguard: ${guard_label}")

(fn run_shell_session []
  (suspend_user_input)
  (var shell (get_env Env "SHELL" "sh"))
  (println $"Entering shell (${shell}). Ctrl-C stops the running command or clears the line; exit/quit or Ctrl-D returns.")
  (if (stdin_tty?)
    (then
      # Ctrl-C: the trap marks the interrupt, so a failed read reprompts
      # (cleared line) instead of exiting; a running command just dies and the
      # loop continues. EOF (read fails without the mark) exits the session.
      (var script "intr=0; trap 'intr=1; printf \"\\n\"' INT; while true; do printf 'sh> '; intr=0; IFS= read -r line; rc=$?; if [ $rc -ne 0 ]; then if [ $intr -eq 1 ]; then continue; fi; break; fi; case \"$line\" in exit|quit) break;; *) eval \"$line\";; esac; done")
      (await (exec_stdio_async Exec ^cmd shell ^args ["-c" script]
                               ^dir workspace_root))
      (println "")
      nil)
    (else
      # Scripted (piped) /sh: unlike the interactive TTY loop, we read each
      # line in Gene, so route it through the same catastrophe guard as
      # model-issued run_shell (§8.5) before executing.
      (var running (cell true))
      (var line nil)
      (var r nil)
      # Hoisted: re-`var` inside a while body is a duplicate binding on the
      # second iteration, so allocate loop state once and `set` it.
      (var denial nil)
      (while (Cell/get running)
        (print "sh> ")
        (set line (read_line))
        (if (== line nil)
          (Cell/set running false)
          (if (exit_word? line)
            (then (Cell/set running false))
            (else
              (set denial (guard_shell line))
              (if (present? denial)
                (then (println denial))
                (else
                  (set r (exec Exec ^cmd shell ^args ["-lc" line] ^dir workspace_root
                             ^timeout_ms 60000 ^max_bytes 400000))
                  (print (redact r/stdout))
                  (print (redact r/stderr))
                  (if r/timed_out
                    (println "[timed out]"))))))))
      (println ""))))

# Stable live session object (§9.1). Projections are props holding the live
# cells and registry; mutations go through messages so the session can keep
# invariants (system-prompt memory refresh, persistence) and append an audit
# event. `evidence` arrives with the later slice-B evidence work.
(type Session
  ^props {^items Any ^transcript Any ^memory Any ^tools Any ^events Any
          ^changes Any ^evidence Any ^instructions Any ^config Any ^workspace Any
          ^current_task Any ^resume_requested Any ^application Any
          ^main_agent Any ^agents Any ^workers Any ^panes Any}

  # Register (or replace) a typed Tool; it reaches the next model call.
  (message add_tool [self, t]
    (register_tool! t)
    $"tool ${t/name} registered")

  (message add_operation [self, kind : Str, operation]
    (register_worker_operation! kind operation)
    $"worker operation ${kind}/${operation/name} registered")

  # Durable note: memory list + system prompt + persisted state stay in sync.
  (message remember [self, note : Str]
    (self/memory ~ Cell/set (append (self/memory ~ Cell/get) note))
    (self/items ~ Cell/set
      (refresh_system_memory (self/items ~ Cell/get) (self/memory ~ Cell/get)))
    (emit_event! "memory" {^text note})
    (save_agent_state (self/items ~ Cell/get)
                      (self/transcript ~ Cell/get)
                      (self/memory ~ Cell/get))
    $"remembered: ${note}")

  # Echo future events of this type into the transcript as they are emitted.
  (message subscribe [self, type]
    (var t $"${type}")
    (event_subscriptions ~ Cell/set
      (append (event_subscriptions ~ Cell/get) t))
    $"subscribed to ${t} events")

  # Query the event log with the same filters as /trace.
  (message trace [self, filters : Str]
    (trace_report filters))

  (message diff [self]
    (file_diff_report))

  (message undo [self, id : Int?]
    (undo_with_workspace_lease self/application self/main_agent/id id))

  (message spawn_agent [self, assignment : Str]
    (var app self/application)
    (var child_transcript (cell "ready\n"))
    (var agent
      (application_spawn_agent app "sub-agent" assignment
        (cell
          (append (initial_items (self/memory ~ Cell/get))
            (system_item
              $"You are a supervised sub-agent. Assignment: ${assignment}\nKeep private tool chatter out of the main context and return a concise result.")))
        child_transcript))
    (if agent agent/id))

  (message stop_agent [self, agent_id : Str]
    (var agent (application_find_agent self/application agent_id))
    (if (== agent nil) false
      (application_stop_agent self/application agent)))

  (message stop_worker [self, worker_id : Str]
    (var worker (application_find_worker self/application worker_id))
    (if (== worker nil) false
      (application_stop_worker self/application worker)))

  # REPL scripts and embedded callers share the exact declaration-backed
  # validation/admission path used by slash commands, the model tool, and the
  # gateway. A live REPL is local-user authority; it does not inherit model
  # access merely because the main agent owns the session.
  (message call_worker [self, worker_id : Str, operation : Str, args]
    (application_call_worker self/application worker_id operation args
      {^origin "user" ^caller_worker_id self/main_agent/id}))

  (message pin_artifact [self, source : Str, worker_id : Str]
    (var app self/application)
    (if (== source "result")
      (do
        (var agent (application_find_agent app worker_id))
        (var result (if agent (agent/result ~ Cell/get)))
        (if (== result nil) {^ok false ^error "agent result not found"}
          (application_pin_artifact! app "result"
            (agent_result_text result) agent/id result/task_id)))
      (if (== source "tail")
        (do
          (var worker (application_find_worker app worker_id))
          (if (== worker nil) {^ok false ^error "worker not found"}
            (do
              (var operation (worker/current_operation ~ Cell/get))
              (application_pin_artifact! app "capture"
                (worker/output ~ Cell/get) worker/id
                (if operation operation/task_id nil)))))
        {^ok false ^error "source must be result or tail"})))

  (message open_pane [self, kind : Str, owner_id, title : Str]
    (match kind
      (when "agent"
        (var agent (application_find_agent self/application $"${owner_id}"))
        (if_yes agent
          (application_request_worker_attention self/application agent title)
          agent/id))
      (when "output"
        (var worker
          (application_new_worker self/application "output" title
            (cell "ready\n")
            (OutputController ^source "session" ^following (cell []))))
        (if_yes worker
          (application_request_worker_attention self/application worker title)
          worker/id))
      (when "shell" (open_shell_pane))
      (when "repl" (open_repl_pane self/items self/transcript self/memory))
      (else nil)))

  (message close_pane [self, pane_id : Int]
    (application_close_pane self/application pane_id))

  (message send_pane [self, pane_id : Int, text : Str]
    (var pane (application_find_pane self/application pane_id))
    (if (== pane nil)
      "pane not found"
      (application_send_worker_input
        self/application pane/worker text "local_tui")))

  # Cancel the active model/tool turn. The embedded CLI currently exposes
  # this through the programmable session; gateway.gene also maps it to HTTP.
  (message cancel [self]
    (var task (self/current_task ~ Cell/get))
    (if (== task nil)
      (then "no turn in flight")
      (else
        (task ~ Task/cancel)
        "cancellation requested")))

  # Ask the agent to run another model turn on the current items (no new user
  # input) right after the REPL exits — the add-a-tool-and-continue flow.
  (message resume [self]
    (self/resume_requested ~ Cell/set true)
    "resume requested: exit the REPL (exit/quit) to continue the current turn"))

(fn make_live_session [items, transcript, memory, resume_flag]
  (var app (active_application ~ Cell/get))
  (Session ^items items ^transcript transcript ^memory memory
           ^tools tool_registry ^events agent_events ^changes file_changes
           ^evidence agent_evidence ^instructions agent_instruction_records
           ^config (session_config_snapshot (items ~ Cell/get)
                                            (memory ~ Cell/get))
           ^workspace workspace_real ^current_task active_turn_task
           ^resume_requested resume_flag ^application app
           ^main_agent app/main_agent ^agents app/agents ^workers app/workers
           ^panes (if (== app/local_surface nil)
                    (cell []) app/local_surface/panes)))

(fn live_session_env [items, transcript, memory, resume_flag]
  (env ^bindings
    {^session (make_live_session items transcript memory resume_flag)
     ^Tool Tool ^classify_command classify_command}))

(fn open_repl_pane [items, transcript, memory]
  (var app (active_application ~ Cell/get))
  (var worker (application_find_worker_kind app "repl"))
  (var previous
    (if (== worker nil)
      (application_find_stopped_worker_kind app "repl")))
    (var existing
      (if worker
        (application_find_pane_worker app worker/id)))
    (if (!= existing nil)
    (then
      (application_focus_pane! app existing/id)
      existing)
    (else
      (if_yes (== worker nil)
          (var resume_flag (cell false))
          (var session
            (repl_open (live_session_env items transcript memory resume_flag)))
          (set worker
            (application_new_worker_from app "repl" "Gene REPL"
              (cell "session is bound; enter one Gene form per /N command\n")
              (ReplController ^session session ^items items
                              ^transcript transcript ^memory memory
                              ^streaming app/main_agent/streaming
                              ^resume_requested resume_flag)
              previous)))
      (application_attach_worker_pane app worker "user" "detach"))))

(fn restart_process_worker! [app, previous]
  # Restart is intentionally identity-preserving only through the
  # `restarted_from` event edge. Captured output remains on the stopped worker;
  # a live shell or REPL always receives a fresh worker id and controller.
  (if (!= (previous/lifecycle ~ Cell/get) "stopped")
    (then {^ok false ^error "worker must be stopped first"})
    (else
      (var worker nil)
      (match previous/kind
        (when "agent"
          (if (!= previous/id "main")
            (do
              (set worker
                (application_spawn_agent_with_attachments app previous/title
                  previous/assignment
                  (cell (previous/items ~ Cell/get)) (cell "ready\n")
                  (previous/attachments ~ Cell/get)))
              (if worker
                (application_emit app "worker_started"
                  {^worker_id worker/id ^kind "agent" ^title worker/title
                   ^restarted_from previous/id})))))
        (when "shell"
          (set worker
            (application_new_worker_from app "shell" previous/title
              (cell $"cwd: ${(previous/controller/cwd ~ Cell/get)}\n")
              (ShellController
                ^cwd (cell (previous/controller/cwd ~ Cell/get))
                ^environment
                  (cell (previous/controller/environment ~ Cell/get)))
              previous)))
        (when "repl"
          (var resume_flag (cell false))
          (var session
            (repl_open
              (live_session_env app/main_agent/items
                app/main_agent/transcript interactive_memory resume_flag)))
          (set worker
            (application_new_worker_from app "repl" previous/title
              (cell "session is bound; enter one Gene form per /N command\n")
              (ReplController ^session session ^items app/main_agent/items
                              ^transcript app/main_agent/transcript
                              ^memory interactive_memory
                              ^streaming app/main_agent/streaming
                              ^resume_requested resume_flag)
              previous)))
        (when "output"
          (set worker
            (application_new_worker_from app "output" previous/title
              (cell "")
              (OutputController ^source previous/controller/source
                                ^following (cell [])) previous)))
        (when "log_tail"
          (set worker
            (application_new_worker_from app "log_tail" previous/title
              (cell "")
              (LogTailController
                ^filter (cell (previous/controller/filter ~ Cell/get)))
              previous))
          (if worker
            ((app/event_observers ~ Cell/get) ~ List/push!
              {^worker_id worker/id
               ^handler (fn [event]
                 (var current (worker/controller/filter ~ Cell/get))
                 (if (&& (!= event/projection true)
                         (event_matches? event current))
                   (application_append_projection_output!
                     app worker
                     $"${(format_event_with_filters event current)}\n"
                     "log_tail")))})))
        (when "file_view"
          (var path previous/controller/path)
          (set worker
            (application_new_worker_from app "file_view" previous/title
              (cell "") (FileViewController ^path path) previous))
          (if worker
            (application_set_projection_output!
              app worker (read_text ReadDir (safe_path path)) "file_view")))
        (when "stats"
          (set worker
            (application_new_worker_from app "stats" previous/title
              (cell "") (StatsController) previous))
          (if worker
            (do
              (application_set_projection_output!
                app worker (stats_worker_text app) "stats")
              ((app/event_observers ~ Cell/get) ~ List/push!
                {^worker_id worker/id
                 ^handler (fn [event]
                   (if_not (== event/projection true)
                     (application_set_projection_output!
                       app worker (stats_worker_text app) "stats")))}))))
        (else nil))
      (if (== worker nil)
        (then
          {^ok false
           ^error "worker could not be restarted (limit reached or unsupported)"})
        (else
          {^ok true ^worker worker ^pane nil})))))

(fn handle_repl_pane [items, transcript, memory, streaming]
  (var pane (open_repl_pane items transcript memory))
  (var app (active_application ~ Cell/get))
  (application_focus_pane! app pane/id)
  (render_agent_text transcript streaming
    $"REPL pane ${pane/id}; use /${pane/id} <Gene form>"))

# Returns true when the user asked to continue the turn after the REPL.
(fn run_session_repl [items, transcript, memory]
  (close_user_input)
  (var resume_flag (cell false))
  # classify_command is bound so the guard's classification of dangerous
  # strings can be inspected (and tested) without ever executing them.
  (var repl_env (live_session_env items transcript memory resume_flag))
  (println "Entering Gene REPL. `session` is bound: session/items session/events session/evidence session/instructions session/changes session/current_task (session ~ diff) (session ~ undo nil) (session ~ add_tool (Tool ...)) (session ~ remember \"...\") (session ~ trace \"type=tool_call\") (session ~ cancel) (session ~ resume). Ctrl-C stops the running eval or clears the line; exit/quit or Ctrl-D returns.")
  (run_repl_session repl_env ^interactive true)
  (resume_flag ~ Cell/get))

(fn handle_main_input [app, input : Str, items, transcript, memory, streaming]
  (if (|| (app/main_agent/input_reserved ~ Cell/get)
          (!= (app/main_agent/current_task ~ Cell/get) nil))
    (then
      (render_agent_text transcript streaming
        "main agent is already working; press Esc to cancel it or send this input after it finishes"))
    (else
      (worker_history_push! app/main_agent input "local_tui"
        (if app/local_surface
          (app/local_surface/instance_id ~ Cell/get)))
      (Cell/set streaming false)
      (begin_turn!)
      (application_emit app "user_input"
        {^worker_id app/main_agent/id ^agent_id app/main_agent/id ^text input})
      (Cell/set items
        (run_interactive_turn transcript streaming (interactive_transport)
          (append (Cell/get items) (user_item input))))
      (save_agent_state (items ~ Cell/get)
                        (transcript ~ Cell/get)
                        (memory ~ Cell/get)))))

(fn editor_command_words [command : Str]
  (var words [])
  (var current (cell ""))
  # `quote` is a reader/compiler form name; keeping parser state under a
  # normal identifier avoids it being resolved as syntax in deferred code.
  (var quote_char (cell ""))
  (var escaped (cell false))
  (for ch in (graphemes command)
    (if (escaped ~ Cell/get)
      (then
        (current ~ Cell/set $"${(current ~ Cell/get)}${ch}")
        (escaped ~ Cell/set false))
      (else
        (if (== ch "\\")
          (escaped ~ Cell/set true)
          (if (!= (quote_char ~ Cell/get) "")
            (if (== ch (quote_char ~ Cell/get))
              (quote_char ~ Cell/set "")
              (current ~ Cell/set $"${(current ~ Cell/get)}${ch}"))
            (if (|| (== ch "\"") (== ch "'"))
              (quote_char ~ Cell/set ch)
              (if (|| (== ch " ") (== ch "\t"))
                (if_not (== (current ~ Cell/get) "")
                  (words ~ List/push! (current ~ Cell/get))
                  (current ~ Cell/set ""))
                (current ~ Cell/set $"${(current ~ Cell/get)}${ch}"))))))))
  (if (escaped ~ Cell/get)
    (current ~ Cell/set $"${(current ~ Cell/get)}\\"))
  (if (!= (quote_char ~ Cell/get) "")
    (fail (OsError ^message "unterminated quote in $VISUAL/$EDITOR")))
  (if (!= (current ~ Cell/get) "")
    (words ~ List/push! (current ~ Cell/get)))
  words)

(fn external_editor_draft [draft : Str]
  (var configured (env? Env "VISUAL"))
  # Empty environment values mean “unset”. This matters in an embedding (and
  # in the combined test process), where restoring a previously absent value
  # may leave VISUAL="" while EDITOR is valid.
  (if (|| (== configured nil) (== (trim configured) ""))
    (set configured (env? Env "EDITOR")))
  (if (|| (== configured nil) (== (trim configured) ""))
    (set configured "vi"))
  (var words (editor_command_words configured))
  (if (empty? words)
    (fail (OsError ^message "$VISUAL/$EDITOR resolved to an empty command")))
  (var executable words/0)
  (var args [])
  (repeat i in words/~size
    (if (> i 0) (args ~ List/push! words/%i)))
  (var path $".gene-agent-draft-${(monotonic_ms)}.tmp")
  (write_text WriteDir path draft)
  (suspend_user_input)
  (try
    (args ~ List/push! path)
    (var status
      (await (exec_stdio_async Exec ^cmd executable ^args args
                               ^dir workspace_root)))
    (if (== status 0)
      (then
        (var composed (read_text ReadDir path))
        (if (> (byte_size composed) surface_draft_max_bytes)
          (fail (OsError
            ^message $"editor draft exceeds ${surface_draft_max_bytes} bytes"))
          composed))
      (else draft))
  ensure
    (resume_user_input)
    (if (exists? ReadDir path) (remove WriteDir path))))

(fn run_gene_view [app, path : Str] : Int
  (var owner app/main_agent/id)
  (if_not (application_acquire_workspace app owner "view")
    (fail (OsError
      ^message "workspace is busy; stop the mutating worker and retry /view")))
  (try
    (suspend_user_input)
    (await (exec_stdio_async Exec ^cmd (executable_path)
                             ^args ["view" path] ^dir workspace_root))
  ensure
    (resume_user_input)
    (application_release_workspace app owner "view")))

# One registry drives command recognition and comprehensive help. Handlers stay
# ordinary Gene functions, but a command cannot be accepted by the surface
# without a matching entry here; this keeps typo rejection and documentation
# aligned while the command dispatcher is incrementally flattened.
(var surface_command_specs [
  {^name "/help" ^section "input" ^usage "/help [topic|command|worker <kind>|search <text>|all]"
   ^summary "show comprehensive help in pane 0"}
  {^name "/?" ^section "input" ^usage "/? [topic]"
   ^summary "exact alias for /help"}
  {^name "/0" ^section "input" ^usage "/0 [prompt]"
   ^summary "focus main, or send an explicit main prompt"}
  {^name "/focus" ^section "input" ^usage "/focus <0|N>"
   ^summary "focus main or an extension pane"}
  {^name "/close" ^section "pane" ^usage "/close [N]"
   ^summary "close the focused pane, or pane N; pane 0 is protected"}
  {^name "/pane" ^section "pane" ^usage "/pane list | /pane new <agent|shell|repl|tail|output|view|stats> [args] | /pane open <W> [title] | /pane focus <0|N> | /pane show|hide|close|max <N> | /pane <N> focus|show|hide|close|max"
   ^summary "create and manage surface-local panes"}
  {^name "/agent" ^section "agent" ^usage "/agent list | /agent new [prompt] | /agent <A> send <prompt> | /agent <A> open|result|incorporate|cancel|stop"
   ^summary "create and supervise sub-agents"}
  {^name "/agents" ^section "agent" ^usage "/agents"
   ^summary "list agent lifecycle, outcome, result, and pane state"}
  {^name "/worker" ^section "worker" ^usage "/worker list | /worker <W> open | /worker <W> <operation> [args]"
   ^summary "invoke the target kind's declared operation table by id or name"}
  {^name "/workers" ^section "worker" ^usage "/workers"
   ^summary "list workers with pane ids and operation state"}
  {^name "/sh" ^section "pane" ^usage "/sh"
   ^summary "open or focus the line-oriented shell"}
  {^name "/repl" ^section "pane" ^usage "/repl"
   ^summary "open or focus the persistent Gene REPL"}
  {^name "/tail" ^section "pane" ^usage "/tail [filter]"
   ^summary "open an authoritative event-tail projection"}
  {^name "/stats" ^section "pane" ^usage "/stats"
   ^summary "open the live application-stats projection"}
  {^name "/view" ^section "pane" ^usage "/view <file>"
   ^summary "suspend the TUI and run gene view; quitting returns here"}
  {^name "/status" ^section "session" ^usage "/status"
   ^summary "show application and context status"}
  {^name "/effort" ^section "session" ^usage "/effort [default|none|minimal|low|medium|high|xhigh|max]"
   ^summary "show or set model reasoning effort"}
  {^name "/progress" ^section "session" ^usage "/progress"
   ^summary "show the main project-progress record"}
  {^name "/pin" ^section "session" ^usage "/pin result [A] | /pin worker <W> tail"
   ^summary "promote redacted live output to a durable content-addressed artifact"}
  {^name "/artifacts" ^section "session" ^usage "/artifacts"
   ^summary "list durable artifact provenance records"}
  {^name "/artifact" ^section "session" ^usage "/artifact <id> | /artifact delete <id>"
   ^summary "read or explicitly delete a durable artifact"}
  {^name "/trace" ^section "trace" ^usage "/trace [filters] [--detail]"
   ^summary "query redacted authoritative events"}
  {^name "/diff" ^section "session" ^usage "/diff"
   ^summary "show attributable application file changes"}
  {^name "/undo" ^section "session" ^usage "/undo [change-id]"
   ^summary "undo an attributable change after validation"}
  {^name "/remember" ^section "session" ^usage "/remember <note>"
   ^summary "add durable user memory"}
  {^name "/memory" ^section "session" ^usage "/memory"
   ^summary "show durable user memory"}
  {^name "/forget-memory" ^section "session" ^usage "/forget-memory"
   ^summary "clear durable user memory"}
  {^name "/edit" ^section "input" ^usage "/edit [initial text]"
   ^summary "compose the focused draft in VISUAL or EDITOR"}
  {^name "/tty" ^section "session" ^usage "/tty"
   ^summary "temporarily hand the terminal to an interactive shell"}
  {^name "/quit" ^section "session" ^usage "/quit"
   ^summary "save state and exit"}
  {^name "/exit" ^section "session" ^usage "/exit"
   ^summary "alias for /quit"}
])

(fn help_command? [line : Str] : Bool
  (|| (== line "/help") (starts_with? line "/help ")
      (== line "/?") (starts_with? line "/? ")))

(fn help_command_topic [line : Str] : Str
  (if (|| (== line "/help") (== line "/?")) ""
    (trim
      (if (starts_with? line "/help ")
        (after_prefix line "/help ")
        (after_prefix line "/? ")))))

(fn surface_command_head [line : Str] : Str
  (var parts (split line " "))
  (if (empty? parts) "" parts/0))

(fn registered_surface_command? [line : Str] : Bool
  (var head (surface_command_head line))
  (var found (cell false))
  (for spec in surface_command_specs
    (if (== spec/name head) (found ~ Cell/set true)))
  (found ~ Cell/get))

(fn unregistered_surface_command? [line : Str] : Bool
  (&& (starts_with? line "/")
      (! (starts_with? line "//"))
      (== (extension_command_id line) nil)
      (! (registered_surface_command? line))))

(fn worker_kind_help [kind : Str] : Str
  (var known ["agent" "shell" "repl" "output" "log_tail" "file_view" "stats"])
  (var known_text (known ~ join ", "))
  (if_not (known ~ contains? kind)
    (return $"unknown worker kind '${kind}'\nworker kinds: ${known_text}"))
  (var lines [$"${kind} worker operations"])
  (for operation in (worker_operations_for_kind kind)
    (var effects (operation/effects ~ join "+"))
    (var audience (operation/audience ~ join ","))
    (lines ~ List/push!
      $"${operation/usage}\n    ${operation/summary} [${effects}; ${operation/admission}; ${operation/audit}; ${audience}]"))
  (lines ~ join "\n"))

(fn surface_command_spec [name : Str]
  (var requested (if (starts_with? name "/") name $"/${name}"))
  (var found (cell nil))
  (for spec in surface_command_specs
    (if (== spec/name requested) (found ~ Cell/set spec)))
  (found ~ Cell/get))

(fn command_help_page [spec] : Str
  $"${spec/name}\nusage: ${spec/usage}\n${spec/summary}\nsection: ${spec/section}")

(fn help_search [term : Str] : Str
  (var query (lower term))
  (var lines [$"help search: ${term}"])
  (for spec in surface_command_specs
    (var haystack
      (lower $"${spec/name} ${spec/usage} ${spec/summary} ${spec/section}"))
    (if (contains? haystack query)
      (lines ~ List/push! $"${spec/usage}\n    ${spec/summary}")))
  (if (== (lines ~ size) 1)
    $"no help matches '${term}'"
    (lines ~ join "\n")))

(fn common_prefix_size [a : Str, b : Str] : Int
  (var aa (editor_chars a))
  (var bb (editor_chars b))
  (var limit (if (< aa/~size bb/~size) aa/~size bb/~size))
  (var count 0)
  (while (&& (< count limit) (== aa/%count bb/%count))
    (set count (+ count 1)))
  count)

(fn surface_command_suggestion [name : Str] : Str
  (var best "")
  (var best_score 0)
  (for spec in surface_command_specs
    (var score (common_prefix_size name spec/name))
    (if (> score best_score)
      (do (set best spec/name) (set best_score score))))
  (if (>= best_score 2) $"; did you mean '${best}'?" ""))

(fn comprehensive_help [topic : Str] : Str
  (if (starts_with? topic "worker ")
    (return (worker_kind_help (trim (after_prefix topic "worker ")))))
  (if (starts_with? topic "search ")
    (return (help_search (trim (after_prefix topic "search ")))))
  (var command_spec
    (if (|| (starts_with? topic "/")
            (&& (!= topic "")
                (! (["pane" "agent" "worker" "input" "session" "trace"
                      "all"] ~ contains? topic))))
      (surface_command_spec topic)))
  (if command_spec (return (command_help_page command_spec)))
  (if (== topic "all") (set topic ""))
  (var valid_topics ["pane" "agent" "worker" "input" "session" "trace"])
  (if (&& (!= topic "") (! (valid_topics ~ contains? topic)))
    (then
      (var topic_separator ", ")
      (var topics_text (join valid_topics topic_separator))
      $"unknown help topic '${topic}'\ntopics: ${topics_text}\n")
    (else
      (var lines ["Gene agent help" "topics: pane, agent, worker, input, session, trace" ""])
      (for spec in surface_command_specs
        (if (|| (== topic "") (== spec/section topic))
          (lines ~ List/push! $"${spec/usage}\n    ${spec/summary}")))
      (if (|| (== topic "") (== topic "input"))
        (then
          (lines ~ List/push! "")
          (lines ~ List/push! "keys: Up/Down history | Tab complete | Ctrl-R search | Ctrl-E edit | PgUp/PgDn or wheel scroll | Ctrl-PgUp/PgDn cycle panes | Esc cancel/back | Ctrl-C clear | Ctrl-D exit")
          (lines ~ List/push! "literal leading slash: //text for focused input | /N -- /absolute/path for pane N")))
      (lines ~ List/push! "")
      (lines ~ List/push! "pane shortcuts: /N focus | /close [N] | /N cancel|stop|max | /N <input> | /0 main")
      (var line_separator "\n")
      (var help_text (join lines line_separator))
      $"${help_text}\n")))

(fn show_surface_help! [app, transcript, line : Str]
  (var surface app/local_surface)
  (var text (comprehensive_help (help_command_topic line)))
  (if surface
    (then
      (surface/focused_pane ~ Cell/set nil)
      (surface/maximized_pane ~ Cell/set nil)
      (surface/main_scroll ~ Cell/set 0)
      (surface/help_notice ~ Cell/set text)
      (if (stdin_tty?)
        (refresh_user_input transcript)
        (println text)))
    (else (println text)))
  text)

(fn effort_report [] : Str
  $"reasoning effort levels: ${reasoning_effort_levels_text}\ncurrent effort: ${(reasoning_effort ~ Cell/get)}\navailability depends on the selected model")

(fn latest_subagent [app]
  (var found nil)
  (for agent in (app/agents ~ Cell/get)
    (if (!= agent/id "main") (set found agent)))
  found)

(fn handle_pin_command [line : Str, app, transcript, streaming]
  (var rest (trim (after_prefix line "/pin")))
  (if (starts_with? rest "result")
    (do
      (var agent_ref (trim (after_prefix rest "result")))
      (var agent
        (if (== agent_ref "") (latest_subagent app)
          (application_find_agent app agent_ref)))
      (if (== agent nil)
        (render_agent_text transcript streaming "agent result not found")
        (do
          (var result (agent/result ~ Cell/get))
          (if (== result nil)
            (render_agent_text transcript streaming $"agent ${agent/id} has no result")
            (do
              (var pinned
                (application_pin_artifact! app "result"
                  (agent_result_text result) agent/id result/task_id))
              (render_agent_text transcript streaming
                (if pinned/ok
                  $"pinned ${pinned/artifact/id} ${pinned/artifact/blob_id}"
                  pinned/error)))))))
    (if (starts_with? rest "worker ")
      (do
        (var worker_rest (trim (after_prefix rest "worker ")))
        (var parts (split worker_rest " "))
        (var worker_ref (if (empty? parts) "" parts/0))
        (var action (trim (after_prefix worker_rest worker_ref)))
        (var worker (application_find_worker app worker_ref))
        (if (|| (== worker nil) (!= action "tail"))
          (render_agent_text transcript streaming
            "usage: /pin worker <W> tail")
          (do
            (var operation (worker/current_operation ~ Cell/get))
            (var pinned
              (application_pin_artifact! app "capture"
                (worker/output ~ Cell/get) worker/id
                (if operation operation/task_id nil)))
            (render_agent_text transcript streaming
              (if pinned/ok
                $"pinned ${pinned/artifact/id} ${pinned/artifact/blob_id}"
                pinned/error)))))
      (render_agent_text transcript streaming
        "usage: /pin result [A] | /pin worker <W> tail"))))

(fn handle_artifact_command [line : Str, app, transcript, streaming]
  (var rest (trim (after_prefix line "/artifact")))
  (if (starts_with? rest "delete ")
    (do
      (var id (trim (after_prefix rest "delete ")))
      (var deleted (application_delete_artifact! app id))
      (render_agent_text transcript streaming
        (if deleted/ok $"deleted ${id}" deleted/error)))
    (do
      (var artifact (artifact_find rest))
      (if (== artifact nil)
        (render_agent_text transcript streaming $"artifact ${rest} not found")
        (do
          (var content (artifact_content artifact))
          (render_agent_text transcript streaming
            (if (== content nil)
              $"artifact ${rest}: content missing"
              $"${artifact/id} ${artifact/kind} (${artifact/size} bytes)\n${content}")))))))

(fn handle_effort_command [line : Str, app, transcript, streaming]
  (var requested (trim (after_prefix line "/effort")))
  (if (== requested "")
    (render_agent_text transcript streaming (effort_report))
    (do
      (var level (lower requested))
      (if (! (valid_reasoning_effort? level))
        (render_agent_text transcript streaming
          $"invalid reasoning effort '${requested}'\n${(effort_report)}")
        (do
          (reasoning_effort ~ Cell/set level)
          (application_emit app "config_changed"
            {^setting "reasoning_effort" ^value level})
          (render_agent_text transcript streaming
            $"reasoning effort set to ${level}"))))))

(fn handle_surface_global_command [line : Str, app, items, transcript, memory,
                                   streaming] : Bool
  (if (starts_with? line "/pin ")
    (then
      (handle_pin_command line app transcript streaming)
      true)
    (else
  (if (== line "/artifacts")
    (then
      (render_agent_text transcript streaming (artifacts_report))
      true)
    (else
  (if (starts_with? line "/artifact ")
    (then
      (handle_artifact_command line app transcript streaming)
      true)
    (else
  (if (|| (== line "/effort") (starts_with? line "/effort "))
    (then
      (handle_effort_command line app transcript streaming)
      true)
    (else
  (if (help_command? line)
    (then
      (show_surface_help! app transcript line)
      true)
    (else
      (if (starts_with? line "/focus ")
      (then
        (var focus_id_text (trim (after_prefix line "/focus ")))
        (handle_pane_command
          $"/pane focus ${focus_id_text}"
          items transcript memory streaming)
        true)
    (else
      (if (|| (== line "/pane") (starts_with? line "/pane "))
      (then
        (handle_pane_command line items transcript memory streaming)
        true)
    (else
      (if (== line "/0")
    (then
      (app/local_surface/focused_pane ~ Cell/set nil)
      (render_agent_text transcript streaming "focused main agent")
      true)
    (else
      (if (starts_with? line "/0 ")
      (then
        (app/local_surface/focused_pane ~ Cell/set nil)
        (var main_input (after_prefix line "/0 "))
        (if (blank_line? main_input)
          (render_agent_text transcript streaming "focused main agent")
          (handle_main_input app main_input items transcript memory streaming))
        true)
      (else
        (if (== line "/workers")
        (then
          (render_agent_text transcript streaming (workers_report))
          true)
        (else
          (if (== line "/stats")
          (then
            (var pane (open_stats_pane))
            (render_agent_text transcript streaming
              (if (== pane nil) "worker limit reached"
                $"opened stats pane ${pane/id}"))
            true)
        (else
          (if (|| (== line "/tail") (starts_with? line "/tail "))
          (then
            (var filter_text
              (if (== line "/tail") "" (after_prefix line "/tail ")))
            (var pane (open_log_tail_pane filter_text))
            (render_agent_text transcript streaming
              (if (== pane nil) "worker limit reached"
                $"opened event tail pane ${pane/id}"))
            true)
        (else
          (if (starts_with? line "/view ")
          (then
            (var path (trim (after_prefix line "/view ")))
            (try
              (var status (run_gene_view app path))
              (render_agent_text transcript streaming
                (if (== status 0) "returned from gene view"
                  $"gene view exited with status ${status}"))
            catch {^message message}
              (render_agent_text transcript streaming
                $"cannot run gene view: ${message}"))
            true)
        (else
          (if (|| (== line "/edit") (starts_with? line "/edit "))
          (then
            (var draft (surface_route_draft app))
            (var initial
              (if (== line "/edit") (draft ~ Cell/get)
                (after_prefix line "/edit ")))
            (try
              (draft ~ Cell/set (external_editor_draft initial))
              (render_agent_text transcript streaming
                "external editor draft loaded; Enter submits it")
            catch {^message message}
              (render_agent_text transcript streaming
                $"external editor failed: ${message}"))
            true)
        (else
          (if (== line "/tty")
          (then
            (var acquired
              (application_acquire_workspace app app/main_agent/id "tty"))
            (if acquired
              (try
                (run_shell_session)
              ensure
                (resume_user_input)
                (application_release_workspace app app/main_agent/id "tty"))
              (render_agent_text transcript streaming
                "application is shutting down"))
            (refresh_user_input transcript)
            true)
        (else
          (if (|| (== line "/worker") (starts_with? line "/worker "))
          (then
            (handle_worker_command line transcript streaming)
            true)
          (else false)))))))))))))))))))))))))))))))))

(fn route_surface_input [app, line : Str, items, transcript, memory, streaming]
  (if (&& (starts_with? line "/") (! (starts_with? line "//")))
    (then
      (var literal_hint
        (if (surface_route_input_capable? app)
          "; to send a literal leading slash use //text or /N -- text" ""))
      (render_agent_text transcript streaming
        (if (registered_surface_command? line)
          $"invalid command form: ${line}\nuse /help or /? for syntax${literal_hint}"
          $"unknown command: ${(surface_command_head line)}${(surface_command_suggestion (surface_command_head line))}\nuse /help or /?${literal_hint}")))
    (else
      (var pane_id (app/local_surface/focused_pane ~ Cell/get))
      (var routed_line
        (if (starts_with? line "//") (after_prefix line "/") line))
      (if (!= pane_id nil)
        (handle_extension_command $"/${pane_id} -- ${routed_line}"
                                  transcript memory streaming)
        (handle_main_input app routed_line items transcript memory streaming)))))

(fn run_repl []
  (init_agent_state)
  (start_workspace_heartbeat!)
  (restore_reasoning_effort!)
  (println $"Started Gene AI agent - model ${model}.")
  (var memory (cell (load_memory)))
  (var saved (load_session))
  (if saved
    (restore_events))
  (var items
    (cell
      (if (== saved nil)
        (initial_items (memory ~ Cell/get))
        (refresh_system_memory saved/items (memory ~ Cell/get)))))
  (var transcript
    (cell
      (if (== saved nil)
        $"Gene AI agent - model ${model}\n"
        saved/transcript)))
  (var running (cell true))
  (var line nil)
  (var input_history nil)
  (var streaming (cell false))
  (var app (make_application items transcript memory emit_event!))
  (active_application ~ Cell/set app)
  (restore_dynamic_registrations! app)
  (restore_application! app)
  (interactive_transcript ~ Cell/set transcript)
  (interactive_memory ~ Cell/set (memory ~ Cell/get))
  # Subscribed event types echo into the transcript as they are emitted.
  (event_echo ~ Cell/set
    (fn [text] (render_agent_text transcript streaming $"[event] ${text}")))
  (if_yes saved
      (append_transcript transcript $"[restored session from ${(state_display)}]\n")
      (refresh_user_input transcript))
  (while (Cell/get running)
    (interactive_memory ~ Cell/set (memory ~ Cell/get))
    (set input_history (surface_route_history app))
    (set line (read_user_input transcript input_history))
    (if (== line nil)
      (then
        (close_user_input)
        (save_agent_state (items ~ Cell/get)
                          (transcript ~ Cell/get)
                          (memory ~ Cell/get))
        (interactive_transcript ~ Cell/set nil)
        (Cell/set running false))
      (else
        (if_not (blank_line? line)
        (if_not (help_command? line)
          # Keep ordinary submitted commands in the visible/persisted
          # transcript. Help is a replaceable surface notice and deliberately
          # bypasses both transcript and checkpoint state.
          (if app/local_surface
            (app/local_surface/help_notice ~ Cell/set ""))
          (append_transcript transcript $"──────\n${line}\n")
          (checkpoint_agent_state! app "input_submitted"))
        (refresh_user_input transcript)
        # Registry recognition is the gate in front of every static slash
        # handler. Dynamic /N routes are parsed separately; nothing else can
        # become a control command unless its metadata/help entry exists.
        (if (unregistered_surface_command? line)
          (route_surface_input app line items transcript memory streaming)
          (if_not (handle_surface_global_command line app items transcript memory
                                             streaming)
        ((fn []
        (if (|| (== line "/quit") (== line "/exit"))
          (then
            (close_user_input)
            (save_agent_state (items ~ Cell/get)
                              (transcript ~ Cell/get)
                              (memory ~ Cell/get))
            (interactive_transcript ~ Cell/set nil)
            (Cell/set running false))
          (else
            (if (== line "/agents")
            (render_agent_text transcript streaming (agents_report))
              (if (|| (== line "/agent") (starts_with? line "/agent "))
              (handle_agent_command line transcript memory streaming)
                (if (|| (== line "/pane output")
                      (starts_with? line "/pane output "))
                (handle_output_pane_command line transcript streaming)
                (if (|| (== line "/close") (starts_with? line "/close "))
                  (handle_close_command line transcript streaming)
                  (if (== line "/sh")
                    (handle_shell_pane transcript streaming)
                  (if (== line "/repl")
                    (handle_repl_pane items transcript memory streaming)
              (if (== line "/memory")
                (then
                  (var sep "\n")
                  (render_agent_text transcript streaming
                    (if (empty? (memory ~ Cell/get))
                      "memory is empty"
                      $"memory:\n${(join (memory ~ Cell/get) sep)}")))
                (else
                  (if (== line "/forget-memory")
                    (then
                    (memory ~ Cell/set [])
                    (items ~ Cell/set
                      (refresh_system_memory (items ~ Cell/get)
                                             (memory ~ Cell/get)))
                    (emit_event! "memory" {^action "clear" ^text "memory cleared"})
                    (save_agent_state (items ~ Cell/get)
                                      (transcript ~ Cell/get)
                                      (memory ~ Cell/get))
                    (render_agent_text transcript streaming "memory cleared"))
                  (else
                    (if (starts_with? line "/remember ")
                      (then
                      (var note (trim (after_prefix line "/remember ")))
                      (if (== note "")
                        (then
                          (render_agent_text transcript streaming
                            "usage: /remember <note>"))
                        (else
                          (memory ~ Cell/set (append (memory ~ Cell/get) note))
                          (items ~ Cell/set
                            (refresh_system_memory (items ~ Cell/get)
                                                   (memory ~ Cell/get)))
                          (emit_event! "memory" {^action "remember" ^text note})
                          (save_agent_state (items ~ Cell/get)
                                            (transcript ~ Cell/get)
                                            (memory ~ Cell/get))
                          (render_agent_text transcript streaming
                            $"remembered: ${note}"))))
                    (else
                      (if (== line "/status")
                      (render_agent_text transcript streaming
                        (agent_status_report items memory))
                      (if (== line "/progress")
                        (render_agent_text transcript streaming
                          (project_progress_report app))
                      (if (== line "/diff")
                        (render_agent_text transcript streaming (file_diff_report))
                        (if (|| (== line "/undo") (starts_with? line "/undo "))
                          (render_agent_text transcript streaming (undo_command line))
                          (if (|| (== line "/trace") (starts_with? line "/trace "))
                            (render_agent_text transcript streaming
                              (trace_report
                                (if (== line "/trace")
                                  ""
                                  (after_prefix line "/trace "))))
                            (if (!= (extension_command_id line) nil)
                                (handle_extension_command line transcript
                                                          memory streaming)
                                (route_surface_input app line items transcript
                                                     memory streaming))))))))))))))))))))))))))))))

# Project a remotely initiated turn into an attached transcript without giving
# the adapter any curses knowledge. In headless/remote-only applications these
# cells are still the canonical transcript projection, just with no screen to
# refresh.
(fn gateway_project_event [app, type : Str, text : Str]
  (var agent app/main_agent)
  (var transcript app/main_agent/transcript)
  (var streaming app/main_agent/streaming)
  (match type
    (when "user_input"
      (append_agent_transcript! agent $"──────\n[remote] ${text}\n"))
    (when "text_delta"
      (if_not (== text "")
        (if_not (streaming ~ Cell/get)
          (append_agent_transcript! agent "agent> ")
          (streaming ~ Cell/set true))
        (append_agent_transcript! agent text)))
    (when "agent_text"
      (var was_streaming (streaming ~ Cell/get))
      (if_yes was_streaming
        (append_agent_transcript! agent "\n")
        (streaming ~ Cell/set false))
      (if_not (|| was_streaming (== text ""))
        (append_agent_transcript! agent $"agent> ${text}\n")))
    (when "turn_done"
      (if_yes (streaming ~ Cell/get)
        (append_agent_transcript! agent "\n")
        (streaming ~ Cell/set false)))
    (else nil)))

(fn gateway_render_event [app, type : Str, text : Str]
  (gateway_project_event app type text)
  # A headless or non-local gateway session must update its own snapshot
  # without repainting some other application's terminal surface.
  (var local (active_application ~ Cell/get))
  (if (&& (!= local nil)
          (== local/coordinator_id app/coordinator_id))
    (refresh_active_input)))

(fn gateway_save_application [app]
  (save_agent_state (app/main_agent/items ~ Cell/get)
                    (app/main_agent/transcript ~ Cell/get)
                    (app/memory ~ Cell/get)))

# Explicit dependency bundle consumed by the UI-neutral gateway adapter.
(fn gateway_api []
  {^gene_system_prompt gene_system_prompt ^system_item system_item
   ^user_item user_item ^run_turn_in run_turn_in
   ^live_transport live_transport ^demo_transport_for demo_transport_for
   ^max_tool_rounds max_tool_rounds ^append append ^model model
   ^auth_token auth_token ^redact_any redact_any
   ^bounded_event_record bounded_event_record
   ^store_fs_open store_fs_open ^sqlite_open sqlite_open
   ^store_sqlite_open store_sqlite_open ^ReadWriteDir ReadWriteDir
   ^active_application active_application ^agent_events agent_events
   ^next_event_v next_event_v ^event_dropped_before event_dropped_before
   ^make_application make_headless_application_with_task
   ^application_emit application_emit ^application_shutdown application_shutdown
   ^application_workers_snapshot application_workers_snapshot
   ^application_find_worker application_find_worker
   ^application_find_agent application_find_agent
   ^spawn_supervised_agent spawn_supervised_agent
   ^spawn_supervised_agent_with_context spawn_supervised_agent_with_context
   ^spawn_supervised_named_agent_with_context spawn_supervised_named_agent_with_context
   ^application_create_worker application_create_worker_from_config
   ^application_call_worker application_call_worker
   ^application_send_worker_input application_send_worker_input
   ^application_cancel_worker application_cancel_worker
   ^application_cancel_agent application_cancel_agent
   ^application_stop_worker application_stop_worker
   ^application_stop_agent application_stop_agent
   ^agent_result_report agent_result_report
   ^application_inspect_agent_result application_inspect_agent_result!
   ^application_mark_agent_result_read application_mark_agent_result_read!
   ^application_incorporate_agent_result application_incorporate_agent_result!
   ^project_progress_report project_progress_report
   ^application_update_progress application_update_progress!
   ^application_begin_worker_operation application_begin_worker_operation!
   ^application_finish_worker_operation application_finish_worker_operation!
   ^application_finish_agent_operation application_finish_agent_operation!
   ^record_worker_input worker_history_push!
   ^application_drain_supervisor_inbox application_drain_supervisor_inbox
   ^application_snapshot application_snapshot
   ^restore_application restore_application_snapshot!
   ^gateway_project_event gateway_project_event
   ^gateway_render_event gateway_render_event
   ^gateway_save_application gateway_save_application ^begin_turn begin_turn!})

(fn parse_launch_options [raw : Str]
  (var gateway (cell false))
  (var headless (cell false))
  (var port (cell void))
  (var task_parts [])
  (for token in (split (trim raw) " ")
    (if_not (== token "")
      (if (== token "--gateway")
        (gateway ~ Cell/set true)
        (if (starts_with? token "--gateway=")
          (then
            (gateway ~ Cell/set true)
            (port ~ Cell/set
              (parse_int (after_prefix token "--gateway="))))
          (else
            (if (== token "--headless")
              (headless ~ Cell/set true)
              (task_parts ~ List/push! token)))))))
  (if (&& (headless ~ Cell/get) (! (gateway ~ Cell/get)))
    (fail (OsError ^message "--headless requires --gateway")))
  (if (&& (!= (port ~ Cell/get) void)
          (|| (< (port ~ Cell/get) 1) (> (port ~ Cell/get) 65535)))
    (fail (OsError ^message "--gateway port must be between 1 and 65535")))
  {^gateway (gateway ~ Cell/get) ^headless (headless ~ Cell/get)
   ^port (port ~ Cell/get) ^task (join task_parts " ")})

(fn run_local_entry [launch, task : Str]
  (if (blank_line? task)
    (if (&& (== auth_token nil) (! launch/gateway))
      (run_demo)
      (try
        (run_repl)
      ensure
        (close_user_input)))
    (run_one_shot task)))

# `gene run` auto-invokes a top-level `main` (src/gene.nim), so no explicit call.
(fn main [args]
  (var launch (parse_launch_options args/raw))
  (var task launch/task)
  (var run_mode
    (if launch/headless
      "gateway_headless"
      (if launch/gateway
        "gateway_tui"
        (if (blank_line? task)
      (if (== auth_token nil) "offline_demo" "interactive")
          "one_shot"))))
  (info! agent_log "agent starting"
    ^payload {^run_mode run_mode ^api_flavor api_flavor ^model_name model
              ^live_auth (present? auth_token) ^state_enabled (state_enabled?)
              ^resume_enabled (resume_enabled?) ^guard_enabled (guard_enabled?)
              ^approve_all (flag_enabled? approve_all)
              ^max_tool_rounds max_tool_rounds
              ^tool_count ((tool_names ~ Cell/get) ~ size)})
  (var gateway_server (cell nil))
  (var gateway_task (cell nil))
  (try
    (if launch/headless
      (then (run_gateway (gateway_api) {^port launch/port}))
      (else
        (if launch/gateway
          (then
          (gateway_server ~ Cell/set
            (prepare_gateway (gateway_api)
              {^port launch/port ^quiet true}))
          # `net/http/serve` is itself the scheduler-driving root loop. Keep
          # it at the root and make the local entrypoint a sibling Task;
          # spawning `serve` from inside the TUI fiber would recursively pump
          # the scheduler and starve curses input in combined mode.
          (gateway_task ~ Cell/set
            (spawn
              (try
                (run_local_entry launch task)
              ensure
                (stop_gateway (gateway_server ~ Cell/get)))))
          ((gateway_task ~ Cell/get) ~ Task/detach)
          (serve_gateway (gateway_server ~ Cell/get))
          (try (await (gateway_task ~ Cell/get)) catch _ nil)
          # The local task requested and completed gateway shutdown. Clear
          # both handles so the outer failure-cleanup path does not stop the
          # already-dropped native listener a second time.
          (gateway_task ~ Cell/set nil)
          (gateway_server ~ Cell/set nil))
          (else (run_local_entry launch task)))))
  ensure
    (if_yes (gateway_server ~ Cell/get)
      (var task (gateway_task ~ Cell/get))
      (if_yes task
        (task ~ Task/cancel)
        (try (await task) catch _ nil))
      # An interrupted local task normally stops the server in its own
      # ensure. The fallback is intentionally idempotent at this boundary.
      (try (stop_gateway (gateway_server ~ Cell/get)) catch _ nil))
    (var app (active_application ~ Cell/get))
    (if app (application_shutdown app))
    (active_application ~ Cell/set nil)
    (close_agent_state)
    (close_user_input)
    (info! agent_log "agent stopped"
      ^payload {^run_mode run_mode
                ^turns (current_turn ~ Cell/get)
                ^events ((agent_events ~ Cell/get) ~ size)})))
