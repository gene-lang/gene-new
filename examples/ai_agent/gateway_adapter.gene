# =============================================================================
# UI-neutral Gene agent gateway adapter — examples/ai_agent/design.md §12.
#
# One long-running process that owns every conversation. Sessions are actors
# (mailbox = per-session turn ordering; the scheduler runs sessions
# concurrently because model calls and tools ride native worker-backed tasks).
# Surfaces are thin HTTP+JSON clients:
#
#   POST /api/sessions                     -> {"id": "s1"}
#   GET  /api/sessions                     -> {"sessions": [...]}
#   POST /api/sessions/:id/messages        {"text": "..."} -> 202
#   GET  /api/sessions/:id/events?cursor=N -> long-poll {"events": [...], "cursor": M}
#   GET  /                                 -> embedded web chat page
#
# Config: GENE_GATEWAY_HOST (default 127.0.0.1), GENE_GATEWAY_PORT (8090),
# GENE_GATEWAY_TOKEN (optional bearer token; open when unset — bind localhost).
# Model/backend config is shared with examples/ai_agent/tui.gene (OPENAI_* env);
# with no model token, sessions run the offline demo transport.
# =============================================================================

(mod agent_gateway_adapter
  @doc "multi-session gateway over the ai_agent turn loop (§12 milestone 8)")

(import os [get_env exec_async monotonic_ms Env Exec])
(import crypto [random_hex secure_equal?])
(import json [parse stringify JsonError])
(import str [split trim join starts_with? contains? byte_size])
(import std/stream [to_stream filter each into])
(import std/parse [parse_int])
(import net/http [Server serve listen stop Response])
(import net/http_client [Http request HttpClientError])

(var gw_host (get_env Env "GENE_GATEWAY_HOST" "127.0.0.1"))
(var gw_port 8090)
(var gw_token (get_env Env "GENE_GATEWAY_TOKEN" ""))
# Optional persistence (examples/ai_agent/design.md §12 milestone 11): set GENE_GATEWAY_DB
# to a sqlite path and sessions survive restarts — transcripts and event logs
# are pure data, stored as serde text (docs/proposals/serialization.md §4).
(var gw_db_path (get_env Env "GENE_GATEWAY_DB" ""))
(var gw_state_dir (get_env Env "GENE_GATEWAY_STATE" ""))
(var gw_resume (get_env Env "GENE_GATEWAY_RESUME" "1"))
(var gw_quiet false)

(fn positive_env_int [name : Str, fallback : Int] : Int
  (try
    (var parsed (parse_int (get_env Env name $"${fallback}")))
    (if (> parsed 0) parsed fallback)
  catch _ fallback))

(var gw_event_max
  (positive_env_int "GENE_GATEWAY_EVENT_MAX_COUNT" 4096))
(var configured_gw_event_max_bytes
  (positive_env_int "GENE_GATEWAY_EVENT_MAX_BYTES" 2097152))
(var gw_event_max_bytes
  (if (< configured_gw_event_max_bytes 1024)
    1024 configured_gw_event_max_bytes))

(fn gw_notice [text : Str]
  (if_not gw_quiet (println text)))

# Injected by the composing application. Keeping this adapter independent of
# tui.gene avoids a module cycle and lets the TUI and compatibility launcher
# address the same gateway implementation.
(var agent_api nil)

# Telegram channel (examples/ai_agent/design.md §12.6). Outbound HTTPS only: a getUpdates
# long-poll rides os/exec_async, so no inbound port, webhook, or TLS server.
(var tg_token (get_env Env "TELEGRAM_BOT_TOKEN" ""))
(var tg_base  (get_env Env "TELEGRAM_API_BASE" "https://api.telegram.org"))
(var tg_allowed (get_env Env "TELEGRAM_ALLOWED_CHAT_IDS" ""))

# -----------------------------------------------------------------------------
# Sessions. Each is an actor whose handler runs one user turn; the mailbox
# gives per-session ordering, the scheduler gives cross-session concurrency.
# Events are a versioned log (§12.3) that long-poll clients read by cursor.
# -----------------------------------------------------------------------------

(var sessions {})
(var session_seq (cell 0))

(var gw_store (cell nil))

# C9 logical client attachments are process-local delivery/authorization state.
# Durable session state never contains them; a service restart intentionally
# invalidates resume credentials and leaves mutation outcomes unknown.
(type GatewayAttachment
  ^props {^id Str ^session_id Str ^principal Str ^tier Str
          ^capabilities List ^label Str ^resume_credential Str
          ^ack_cursor Cell ^expires_at_ms Cell})

(type IdempotencyRecord
  ^props {^session_id Str ^attachment_id Str ^key Str ^fingerprint Str
          ^status Int ^headers Map ^body Str ^expires_at_ms Int})

(var gateway_attachments (cell []))
(var gateway_idempotency_records (cell []))
(var gateway_attachment_max
  (positive_env_int "GENE_GATEWAY_ATTACHMENT_MAX_COUNT" 64))
(var gateway_attachment_lease_ms
  (positive_env_int "GENE_GATEWAY_ATTACHMENT_LEASE_MS" 3600000))
(var gateway_idempotency_max
  (positive_env_int "GENE_GATEWAY_IDEMPOTENCY_MAX_COUNT" 1024))
(var gateway_idempotency_ttl_ms
  (positive_env_int "GENE_GATEWAY_IDEMPOTENCY_TTL_MS" 300000))

(var full_client_capabilities
  ["observe" "session_write" "model_call" "host_read" "host_write"])

(fn attachment_invocation [attachment]
  {^origin "remote" ^caller_worker_id nil
   ^attachment_id attachment/id ^principal attachment/principal
   ^principal_capabilities attachment/capabilities})

(fn persist_session [id, items, events, next_v, dropped_before, app]
  (if (gw_store ~ Cell/get)
    (try
      ((gw_store ~ Cell/get) ~ put
        id
        {^items (agent_api/redact_any (items ~ Cell/get))
         ^events (agent_api/redact_any (events ~ Cell/get))
         ^next_v (next_v ~ Cell/get)
         ^dropped_before (dropped_before ~ Cell/get)
         ^application
           (agent_api/redact_any (agent_api/application_snapshot app))})
    catch _ (gw_notice $"persist failed for session ${id}"))))

# on_event: nil, or (fn [event] ...) called after each event is logged — how
# push surfaces (Telegram) mirror the log without polling it. It runs inside
# the session actor's turn fiber, so per-session ordering carries over.
# saved: nil, or a restored {^items ^events ^next_v} snapshot from the db.
# existing_app is non-nil only for the combined program's already-live local
# session. Remote and restored sessions still get their own AgentApplication;
# the gateway no longer has a second agent/task model.
(fn make_session [id, on_event, saved, existing_app]
  (var shared (!= existing_app nil))
  (var events
    (if shared agent_api/agent_events
      (cell (if (== saved nil) [] saved/events))))
  (var next_v
    (if shared agent_api/next_event_v
      (cell (if (== saved nil) 0 saved/next_v))))
  (var dropped_before
    (if shared agent_api/event_dropped_before
      (cell (if (|| (== saved nil) (== saved/dropped_before void))
              0 saved/dropped_before))))
  (var event_bytes (cell 0))
  (for retained in (events ~ Cell/get)
    (event_bytes ~ Cell/set
      (+ (event_bytes ~ Cell/get) (byte_size (stringify retained)))))
  (var current_task
    (if shared existing_app/main_agent/current_task (cell nil)))
  (var current_terminal_emitted (cell false))
  # Reserve admission before the actor dequeues a message. Two concurrent
  # handlers must not both return 202 while the worker still appears idle.
  (var input_pending (cell false))
  (var cancel_requested (cell false))
  (var pending_confirmation (cell nil))
  (var confirmation_seq (cell 0))
  (var current_attachment_id (cell nil))
  (var current_principal (cell nil))
  (var items
    (if shared existing_app/main_agent/items
      (cell (if (== saved nil)
              [(agent_api/system_item agent_api/gene_system_prompt)]
              saved/items))))
  (var app existing_app)
  (fn trim_events! []
    (var current (events ~ Cell/get))
    (var first 0)
    (var retained_bytes (event_bytes ~ Cell/get))
    (while (&& (< first current/~size)
               (|| (> (- current/~size first) gw_event_max)
                   (> retained_bytes gw_event_max_bytes)))
      (set retained_bytes
        (- retained_bytes (byte_size (stringify current/%first))))
      (dropped_before ~ Cell/set current/%first/v)
      (set first (+ first 1)))
    (if_yes (> first 0)
      (var kept [])
      (repeat i in current/~size
        (if (>= i first) (kept ~ List/push! current/%i)))
      (events ~ Cell/set kept)
      (event_bytes ~ Cell/set retained_bytes)))
  (trim_events!)
  (fn add_turn_provenance! [props]
    (if (current_attachment_id ~ Cell/get)
      (props ~ Map/put! "attachment_id"
        (current_attachment_id ~ Cell/get)))
    (if (current_principal ~ Cell/get)
      (props ~ Map/put! "principal" (current_principal ~ Cell/get)))
    props)
  (fn append_event [event]
    (var stored (agent_api/bounded_event_record event gw_event_max_bytes))
    ((events ~ Cell/get) ~ List/push! stored)
    (event_bytes ~ Cell/set
      (+ (event_bytes ~ Cell/get) (byte_size (stringify stored))))
    (trim_events!)
    (if on_event
      (try (on_event stored) catch _ nil))
    stored)
  (fn push_event [type : Str, text : Str]
    (if shared
      (then
        (var props
          {^worker_id app/main_agent/id ^agent_id app/main_agent/id
           ^text text ^surface "gateway"})
        (add_turn_provenance! props)
        (agent_api/application_emit app type props))
      (else
        (next_v ~ Cell/set (+ (next_v ~ Cell/get) 1))
        (var event
          {^v (next_v ~ Cell/get) ^type type
           ^worker_id app/main_agent/id ^agent_id app/main_agent/id
           ^text (agent_api/redact_any text)})
        (add_turn_provenance! event)
        (append_event event)
        # The application observes the same event and derives canonical
        # worker_output records; its sink intentionally skips the already
        # appended compatibility event.
        (agent_api/application_emit app type
          {^worker_id app/main_agent/id ^agent_id app/main_agent/id
           ^text text ^surface "gateway"})
        (agent_api/gateway_project_event app type text)
        event)))
  # Per-session structured sink for the turn loop (§12.1/§12.3): the same
  # versioned events the CLI logs (tool_call/tool_result/model_item/error/
  # turn_done) land in THIS session's log, redacted, so a persisted session
  # keeps its full tool trail. agent_text/text_delta come from the render
  # callbacks below, so the sink skips them to avoid double-logging.
  (fn push_structured [type : Str, props]
    (add_turn_provenance! props)
    (if shared
      (then (agent_api/application_emit app type props))
      (else
        (next_v ~ Cell/set (+ (next_v ~ Cell/get) 1))
        (var event {^v (next_v ~ Cell/get) ^type type})
        (for [k pv] in props
          (event ~ Map/put! k (agent_api/redact_any pv)))
        (append_event event)
        event)))
  (fn emit_turn_event [type : Str, props]
    (if (== type "turn_done")
      (current_terminal_emitted ~ Cell/set true))
    (match type
      (when "agent_text" nil)
      (when "text_delta" nil)
      (else
        (var emitted (push_structured type props))
        (if (== type "turn_done")
          (if shared
            (agent_api/gateway_render_event app "turn_done" "")
            (agent_api/gateway_project_event app "turn_done" "")))
        emitted)))
  (fn request_confirmation [cmd : Str, input] : Bool
    # Channel clients and unattached internal producers cannot approve host
    # mutations. A full attachment gets one initiator-bound pending request;
    # waiting here parks only this model Task, never the HTTP scheduler.
    (if (== input/attachment_id nil)
      (return false))
    (if (!= (pending_confirmation ~ Cell/get) nil)
      (return false))
    (confirmation_seq ~ Cell/set (+ (confirmation_seq ~ Cell/get) 1))
    (var id $"c${(confirmation_seq ~ Cell/get)}")
    (var reply (channel ^capacity 1))
    (var record
      {^id id ^attachment_id input/attachment_id
       ^principal input/principal ^risk "destructive"
       ^target (agent_api/redact_any cmd) ^reply reply
       ^created_ms (monotonic_ms)})
    (pending_confirmation ~ Cell/set record)
    (push_structured "confirmation_requested"
      {^confirmation_id id ^attachment_id input/attachment_id
       ^principal input/principal ^risk "destructive"
       ^target (agent_api/redact_any cmd)})
    (try
      (var allowed (reply ~ Channel/recv))
      (push_structured "confirmation_resolved"
        {^confirmation_id id ^attachment_id input/attachment_id
         ^principal input/principal
         ^decision (if allowed "allow" "deny")})
      allowed
    ensure
      (var pending (pending_confirmation ~ Cell/get))
      (if (&& pending (== pending/id id))
        (pending_confirmation ~ Cell/set nil))))
  (if (== app nil)
    (set app
      (agent_api/make_application items (cell "") (cell [])
                                  emit_turn_event current_task)))
  (if (&& (!= saved nil) (!= saved/application void))
    (agent_api/restore_application app saved/application))
  (var transport
    (if (== agent_api/auth_token nil)
      (agent_api/demo_transport_for)
      agent_api/live_transport))
  (var current_final_text (cell ""))
  # A small detached monitor owns terminal bookkeeping. It is deliberately a
  # separate task: cancelling a turn before its fiber first runs would skip
  # that fiber's ensure blocks, while the monitor starts normally, observes
  # the cancelled Task, and still emits the terminal events and clears the
  # session's current_task projection.
  (fn monitor_turn [task]
    (var outcome (cell "running"))
    (try
      (try
        (await task)
        (outcome ~ Cell/set "done")
      catch _
        (outcome ~ Cell/set "failed"))
    ensure
      (if (== (outcome ~ Cell/get) "running")
        (then
          (if (&& (! (current_terminal_emitted ~ Cell/get))
                  (cancel_requested ~ Cell/get))
            (then
              (push_structured "error" {^kind "cancelled" ^text "turn cancelled"})
              (push_structured "turn_done" {^cancelled true}))
            (elif (! (current_terminal_emitted ~ Cell/get))
              (push_structured "error" {^kind "failed" ^text "turn failed"})
              (push_structured "turn_done" {^failed true}))))
        (elif (== (outcome ~ Cell/get) "failed")
          (if_not (current_terminal_emitted ~ Cell/get)
            (push_structured "error" {^kind "failed" ^text "turn failed"})
            (push_structured "turn_done" {^failed true}))))
      (var worker_outcome
        (if (== (outcome ~ Cell/get) "done") "completed"
          (if (cancel_requested ~ Cell/get) "cancelled" "failed")))
      (agent_api/application_finish_agent_operation
        app app/main_agent worker_outcome (current_final_text ~ Cell/get)
        (if (== worker_outcome "failed") "AgentError" worker_outcome)
        (if (== worker_outcome "failed") "turn failed"
          (if (== worker_outcome "cancelled") "turn cancelled" ""))
        nil)
      (push_structured "agent_status"
        {^worker_id app/main_agent/id ^agent_id app/main_agent/id
         ^status worker_outcome})
      (input_pending ~ Cell/set false)
      (app/main_agent/input_reserved ~ Cell/set false)
      (if shared (agent_api/gateway_save_application app))
      (persist_session id items events next_v dropped_before app)))
  (var turn_actor
    (actor/spawn ^init (fn [] 0)
      ^handle (fn [ctx, state, input]
        (if (!= (current_task ~ Cell/get) nil)
          (then
            (input_pending ~ Cell/set false)
            (app/main_agent/input_reserved ~ Cell/set false)
            (push_structured "error"
              {^kind "busy" ^text "turn already in flight"}))
          (else
            (current_attachment_id ~ Cell/set input/attachment_id)
            (current_principal ~ Cell/set input/principal)
            (if shared (agent_api/begin_turn))
            (agent_api/record_worker_input
              app/main_agent input/text input/adapter nil)
            (var text input/text)
            (push_event "user_input" text)
            (if shared
              (agent_api/gateway_render_event app "user_input" text))
            (cancel_requested ~ Cell/set false)
            (push_structured "agent_status"
              {^worker_id app/main_agent/id ^agent_id app/main_agent/id
               ^status "working"})
            (current_terminal_emitted ~ Cell/set false)
            (current_final_text ~ Cell/set "")
            (var task
              (spawn
                (items ~ Cell/set
                  (agent_api/run_turn_in transport
                            (agent_api/append (items ~ Cell/get)
                                              (agent_api/user_item text))
                            (fn [t]
                              (if_not (== t "")
                                (push_event "agent_text" t)
                                (current_final_text ~ Cell/set t)
                                (if shared
                                  (agent_api/gateway_render_event app "agent_text" t))))
                            (fn [d]
                              (if_not (== d "")
                                (push_event "text_delta" d)
                                (if shared
                                  (agent_api/gateway_render_event app "text_delta" d))))
                            agent_api/max_tool_rounds
                            emit_turn_event
                            {^app app ^agent app/main_agent ^pane nil
                             ^guard_confirm
                               (fn [cmd]
                                 (request_confirmation cmd input))}))))
            (agent_api/application_begin_worker_operation
              app app/main_agent task "agent_turn")
            # The canonical task is now visible. Release only the admission
            # reservation; `current_task` continues rejecting competing input.
            (app/main_agent/input_reserved ~ Cell/set false)
            (task ~ Task/detach)
            ((spawn (monitor_turn task)) ~ Task/detach)))
        (actor/continue state))))
  (fn submit_input [text : Str, adapter : Str, attachment] : Bool
    (if (|| (input_pending ~ Cell/get)
            (app/main_agent/input_reserved ~ Cell/get)
            (!= (current_task ~ Cell/get) nil))
      (then false)
      (else
        (input_pending ~ Cell/set true)
        # Shared worker state lets the TUI observe admission before this
        # adapter's actor installs the Task.
        (app/main_agent/input_reserved ~ Cell/set true)
        (turn_actor ~ actor/send
          (freeze
            {^text text ^adapter adapter
             ^attachment_id (if attachment attachment/id)
             ^principal (if attachment attachment/principal)}))
        true)))
  # Persist terminal worker transitions even when no main-agent message runs.
  # Projection deltas are captured by the terminal operation snapshot (or by
  # the synchronous route save below), avoiding a store write per text chunk.
  ((app/event_observers ~ Cell/get) ~ List/push!
    {^worker_id "__gateway_persistence__"
     ^handler (fn [event]
       (if (["worker_operation_finished" "worker_stopped" "agent_spawned"]
             ~ contains? event/type)
         (persist_session id items events next_v dropped_before app)))})
  {^id id ^actor turn_actor ^events events ^next_v next_v
   ^dropped_before dropped_before
   ^event_bytes event_bytes
   ^items items
   ^current_task current_task ^input_pending input_pending
   ^pending_confirmation pending_confirmation
   ^submit_input submit_input ^cancel_requested cancel_requested
   ^application app ^shared shared})

(fn events_after [s, cursor : Int]
  ((to_stream (s/events ~ Cell/get))
    ~ filter (fn [e] (> e/v cursor))
    ; ~ into []))

(fn max_event_v [evs, fallback : Int] : Int
  (var m (cell fallback))
  ((to_stream evs)
    ~ each (fn [e] (if (> e/v (m ~ Cell/get)) (m ~ Cell/set e/v))))
  (m ~ Cell/get))

# -----------------------------------------------------------------------------
# Telegram channel (§12.6). An adapter task long-polls getUpdates; messages
# from allowlisted chats route into per-chat sessions; replies stream back by
# sendMessage plus size-throttled editMessageText, with a final edit on
# turn_done. Calls use the native async HTTP client; curl(1) remains only as a
# bootstrap fallback when libcurl cannot be loaded.
# -----------------------------------------------------------------------------

(fn tg_call [method : Str, payload]
  (var url $"${tg_base}/bot${tg_token}/${method}")
  (var body (stringify payload))
  (try
    (var response
      (await (request Http ^method "POST" ^url url
                      ^headers ["Content-Type: application/json"]
                      ^body body ^timeout_ms 30000 ^max_bytes 400000)))
    {^status 0 ^stdout response/body ^stderr ""
     ^http_status response/status ^truncated response/truncated}
  catch (HttpClientError ^kind "unavailable")
    (await (exec_async Exec ^cmd "curl"
              ^args ["-sS" "-X" "POST" url
                     "-H" "Content-Type: application/json" "-d" body]
              ^timeout_ms 30000 ^max_bytes 400000))))

(fn tg_send_message [chat_id, text : Str]
  # returns the sent message_id, or nil
  (if_not (== text "")
    (try
      (var r (tg_call "sendMessage" {^chat_id chat_id ^text text}))
      (var resp (parse r/stdout))
      (if (== resp/ok true) resp/result/message_id)
    catch _ nil)))

(fn tg_edit_message [chat_id, message_id, text : Str]
  (if_not (|| (== message_id nil) (== text ""))
    (try (tg_call "editMessageText"
                  {^chat_id chat_id ^message_id message_id ^text text})
    catch _ nil)
    nil))

# Outbound path. Session events are mirrored to Telegram through a queue: the
# session's on_event hook does a non-blocking try_send (it may run inside a
# native render callback, where suspending is not allowed), and a dedicated
# sender fiber drains the queue and talks to Telegram — its awaits park
# properly, so a slow Telegram call never stalls a turn or another session.
# Entries cross the channel as JSON strings: channel items must be Send-safe
# (immutable), which mutable event maps are not.
(var tg_outbox (channel ^capacity 1024))

# Only the display-relevant event types reach Telegram; the structured tool
# trail (tool_call/tool_result/model_item/...) stays in the session log but is
# not mirrored to chat, so a tool-heavy turn does not flood the outbox.
(fn tg_relevant? [type : Str]
  (["text_delta" "agent_text" "turn_done"] ~ contains? type))

(fn make_telegram_sender [chat_id]
  (fn [event]
    (if_not (! (tg_relevant? event/type))
      (if_not (tg_outbox ~ Channel/try_send
            (stringify {^chat_id chat_id ^event event}))
        (gw_notice $"telegram: outbox full, dropped event for chat ${chat_id}")))))

(fn telegram_notice [chat_id, text : Str]
  (if_not (tg_outbox ~ Channel/try_send
        (stringify
          {^chat_id chat_id
           ^event {^type "agent_text" ^text text ^adapter_result true}}))
    (gw_notice $"telegram: outbox full, dropped notice for chat ${chat_id}")))

# Per-chat streaming state for the sender fiber: deltas accumulate into one
# message edited every ~200 new characters (size-based throttle) and
# finalized on turn_done; non-streamed lines go out as individual messages.
(var tg_chat_state {})

(fn tg_state_for [chat_id]
  (var key $"${chat_id}")
  (var st (tg_chat_state ~ Map/get key))
  (if (== st void)
    (then
      (set st {^pending (cell "") ^sent_id (cell nil) ^sent_len (cell 0)})
      (tg_chat_state ~ Map/put! key st)
      st)
    (else st)))

(fn tg_dispatch [raw : Str]
  (var entry (parse raw))
  (var chat_id entry/chat_id)
  (var event entry/event)
  (var st (tg_state_for chat_id))
  (match event/type
    (when "text_delta"
      (st/pending ~ Cell/set $"${(st/pending ~ Cell/get)}${event/text}")
      (var text (st/pending ~ Cell/get))
      (if (== (st/sent_id ~ Cell/get) nil)
        (then
          (st/sent_id ~ Cell/set (tg_send_message chat_id text))
          (st/sent_len ~ Cell/set text/~size))
        (else
          (if_yes (>= (- text/~size (st/sent_len ~ Cell/get)) 200)
            (tg_edit_message chat_id (st/sent_id ~ Cell/get) text)
            (st/sent_len ~ Cell/set text/~size)))))
    (when "agent_text"
      # A streamed answer is already represented by the pending edited
      # message. agent_text is then terminal metadata, not a second reply.
      (if (== (st/pending ~ Cell/get) "")
        (tg_send_message chat_id event/text))
      nil)
    (when "turn_done"
      (var text (st/pending ~ Cell/get))
      (if (&& (!= (st/sent_id ~ Cell/get) nil)
              (> text/~size (st/sent_len ~ Cell/get)))
        (tg_edit_message chat_id (st/sent_id ~ Cell/get) text))
      (st/pending ~ Cell/set "")
      (st/sent_id ~ Cell/set nil)
      (st/sent_len ~ Cell/set 0))
    (else nil)))

(fn telegram_sender_loop []
  (var entry nil)
  (loop
    (set entry (tg_outbox ~ Channel/recv))
    (try
      (tg_dispatch entry)
    catch _ nil)))

(fn tg_chat_allowed? [chat_id] : Bool
  (if (== tg_allowed "*")
    (then true)
    (else
      (var key $"${chat_id}")
      (var found (cell false))
      ((to_stream (split tg_allowed ","))
        ~ each (fn [entry]
            (if (== (trim entry) key) (found ~ Cell/set true))))
      (found ~ Cell/get))))

(fn tg_session_for [chat_id]
  (var id $"tg-${chat_id}")
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (then
      (set s (make_session id (make_telegram_sender chat_id) nil nil))
      (sessions ~ Map/put! id s)
      s)
    (else s)))

(fn tg_handle_update [u]
  (var msg u/message)
  (if_not (== msg void)
    (var chat_id msg/chat/id)
    (var text msg/text)
    (if_not (|| (== chat_id void) (== text void) (== text nil) (== text ""))
      (if (tg_chat_allowed? chat_id)
        (then
          (var s (tg_session_for chat_id))
          (if_not (s/submit_input text "telegram" nil)
            (telegram_notice chat_id
              $"worker_busy: session ${s/id} already has a turn in flight")
            (gw_notice
              $"telegram: session ${s/id} is busy; input rejected")))
        (else
          (gw_notice $"telegram: dropped message from unlisted chat ${chat_id} - add it to TELEGRAM_ALLOWED_CHAT_IDS to allow"))))))

# One getUpdates long-poll round. Loop-local state lives in the fn body (fresh
# scope per call) because re-`var` inside a loop body is a duplicate binding.
(fn telegram_poll_once [offset]
  (var r (await (exec_async Exec ^cmd "curl"
            ^args ["-sS" $"${tg_base}/bot${tg_token}/getUpdates?timeout=50&offset=${(offset ~ Cell/get)}"]
            ^timeout_ms 65000 ^max_bytes 1000000)))
  (if (== r/status 0)
    (then
      (var resp (parse r/stdout))
      (if (== resp/ok true)
        ((to_stream resp/result)
          ~ each (fn [u]
              (if (>= u/update_id (offset ~ Cell/get))
                (offset ~ Cell/set (+ u/update_id 1)))
              (tg_handle_update u)))
        (sleep 2000)))
    (else (sleep 2000))))

(fn telegram_loop []
  (var offset (cell 0))
  (loop
    (try
      (telegram_poll_once offset)
    catch _ (sleep 2000))))

# -----------------------------------------------------------------------------
# HTTP API.
# -----------------------------------------------------------------------------

(fn json_response [status : Int, value]
  (Response ^status status
            ^headers {^content-type "application/json"}
            ^body (stringify value)))

(fn authorized? [req]
  (if (== gw_token "")
    (then true)
    (else
      (var h req/headers/authorization)
      (if (== h void)
        false
        (secure_equal? h $"Bearer ${gw_token}")))))

(fn request_header [req, name : Str]
  (var value (req/headers ~ Map/get name))
  (if (== value void) nil value))

(fn gateway_principal [] : Str
  (if (== gw_token "") "loopback" "bearer"))

(fn attachment_expired? [attachment] : Bool
  (>= (monotonic_ms) (attachment/expires_at_ms ~ Cell/get)))

(fn prune_gateway_attachments! []
  (var retained [])
  (for attachment in (gateway_attachments ~ Cell/get)
    (if_not (attachment_expired? attachment)
      (retained ~ List/push! attachment)))
  (gateway_attachments ~ Cell/set retained))

(fn gateway_attachment [id : Str]
  (prune_gateway_attachments!)
  (for attachment in (gateway_attachments ~ Cell/get)
    (if (== attachment/id id)
      (return attachment)))
  nil)

(fn remove_gateway_attachment! [id : Str] : Bool
  (var retained [])
  (var removed (cell false))
  (for attachment in (gateway_attachments ~ Cell/get)
    (if (== attachment/id id)
      (removed ~ Cell/set true)
      (retained ~ List/push! attachment)))
  (gateway_attachments ~ Cell/set retained)
  (removed ~ Cell/get))

(fn touch_gateway_attachment! [attachment]
  (attachment/expires_at_ms ~ Cell/set
    (+ (monotonic_ms) gateway_attachment_lease_ms))
  attachment)

(fn attachment_response [attachment]
  (var pending [])
  (var s (sessions ~ Map/get attachment/session_id))
  (if_yes (!= s void)
    (var request (s/pending_confirmation ~ Cell/get))
    (if (&& request (== request/attachment_id attachment/id))
      (pending ~ List/push!
        {^confirmation_id request/id ^risk request/risk
         ^target request/target ^created_ms request/created_ms})))
  {^attachment_id attachment/id
   ^resume_credential attachment/resume_credential
   ^principal attachment/principal ^tier attachment/tier
   ^capabilities attachment/capabilities
   ^acknowledged_cursor (attachment/ack_cursor ~ Cell/get)
   ^pending_confirmations pending
   ^lease_ms gateway_attachment_lease_ms})

(fn create_attachment [session_id : Str, req]
  (var s (sessions ~ Map/get session_id))
  (if (== s void)
    (return (json_response 404 {^error "no_such_session"})))
  (prune_gateway_attachments!)
  (if (>= ((gateway_attachments ~ Cell/get) ~ size) gateway_attachment_max)
    (return
      (json_response 429
        {^error "attachment_limit"
         ^limit gateway_attachment_max})))
  (try
    (var body
      (if (== (trim req/body) "") {} (parse req/body)))
    (var raw_label
      (if (== body/display_label void) "client" body/display_label))
    (match raw_label
      (when (label : Str)
        (if (> (byte_size label) 128)
          (return
            (json_response 400
              {^error "invalid_display_label"
               ^message "display_label exceeds 128 bytes"})))
        (var attachment
          (GatewayAttachment
            ^id $"att_${(random_hex 16)}"
            ^session_id session_id
            ^principal (gateway_principal)
            ^tier "full"
            ^capabilities full_client_capabilities
            ^label label
            ^resume_credential $"resume_${(random_hex 32)}"
            ^ack_cursor (cell (session_event_cursor s))
            ^expires_at_ms
              (cell (+ (monotonic_ms) gateway_attachment_lease_ms))))
        ((gateway_attachments ~ Cell/get) ~ List/push! attachment)
        (json_response 201 (attachment_response attachment)))
      (else
        (json_response 400
          {^error "invalid_display_label"
           ^message "display_label must be a string"})))
  catch (JsonError ^message message)
    (json_response 400 {^error "invalid_json" ^message message})))

(fn resume_attachment [session_id : Str, attachment_id : Str, req]
  (var attachment (gateway_attachment attachment_id))
  (if (|| (== attachment nil) (!= attachment/session_id session_id))
    (return (json_response 401 {^error "attachment_invalid"})))
  (try
    (var body (parse req/body))
    (if (|| (== body/resume_credential void)
            (! (match body/resume_credential
                 (when (credential : Str)
                   (secure_equal? credential attachment/resume_credential))
                 (else false))))
      (return
        (json_response 401 {^error "resume_credential_invalid"})))
    (touch_gateway_attachment! attachment)
    (json_response 200 (attachment_response attachment))
  catch (JsonError ^message message)
    (json_response 400 {^error "invalid_json" ^message message})))

(fn require_attachment [session_id : Str, req]
  (var id (request_header req "x-gene-attachment"))
  (if (== id nil)
    (return
      {^ok false
       ^response
         (json_response 428
           {^error "attachment_required"
            ^header "X-Gene-Attachment"})}))
  (var attachment (gateway_attachment id))
  (if (|| (== attachment nil) (!= attachment/session_id session_id))
    (return
      {^ok false
       ^response (json_response 401 {^error "attachment_invalid"})}))
  (touch_gateway_attachment! attachment)
  {^ok true ^attachment attachment})

(fn detach_attachment [session_id : Str, attachment_id : Str, attachment]
  (if (!= attachment/id attachment_id)
    (return (json_response 403 {^error "attachment_mismatch"})))
  (var s (sessions ~ Map/get session_id))
  (if (!= s void)
    (var pending (s/pending_confirmation ~ Cell/get))
    (if_yes (&& pending (== pending/attachment_id attachment_id))
      (pending/reply ~ Channel/try_send false)
      (s/pending_confirmation ~ Cell/set nil)))
  (remove_gateway_attachment! attachment_id)
  (json_response 200 {^ok true}))

(fn resolve_confirmation
  [session_id : Str, confirmation_id : Str, req, attachment]
  (var s (sessions ~ Map/get session_id))
  (if (== s void)
    (return (json_response 404 {^error "no_such_session"})))
  (var pending (s/pending_confirmation ~ Cell/get))
  (if (|| (== pending nil) (!= pending/id confirmation_id))
    (return
      (json_response 404
        {^error "confirmation_not_found"
         ^confirmation_id confirmation_id})))
  (if (!= pending/attachment_id attachment/id)
    (return
      (json_response 403
        {^error "confirmation_not_owned"
         ^confirmation_id confirmation_id})))
  (try
    (var body (parse req/body))
    (if_not (["allow" "deny"] ~ contains? body/decision)
      (return
        (json_response 400
          {^error "invalid_confirmation_decision"
           ^message "decision must be allow or deny"})))
    (var accepted
      (pending/reply ~ Channel/try_send (== body/decision "allow")))
    (if_not accepted
      (return
        (json_response 409
          {^error "confirmation_already_resolved"
           ^confirmation_id confirmation_id})))
    (s/pending_confirmation ~ Cell/set nil)
    (json_response 200
      {^ok true ^confirmation_id confirmation_id
       ^decision body/decision})
  catch (JsonError ^message message)
    (json_response 400 {^error "invalid_json" ^message message})))

(fn acknowledge_attachment
  [session_id : Str, attachment_id : Str, attachment, req]
  (if (!= attachment/id attachment_id)
    (return (json_response 403 {^error "attachment_mismatch"})))
  (try
    (var body (parse req/body))
    (match body/cursor
      (when (cursor : Int)
        (var s (sessions ~ Map/get session_id))
        (var high_water (session_event_cursor s))
        (if (|| (< cursor 0) (> cursor high_water))
          (return
            (json_response 400
              {^error "invalid_cursor" ^cursor cursor
               ^high_water high_water})))
        (if (> cursor (attachment/ack_cursor ~ Cell/get))
          (attachment/ack_cursor ~ Cell/set cursor))
        (json_response 200
          {^ok true
           ^acknowledged_cursor
             (attachment/ack_cursor ~ Cell/get)}))
      (else
        (json_response 400
          {^error "invalid_cursor"
           ^message "cursor must be an integer"})))
  catch (JsonError ^message message)
    (json_response 400 {^error "invalid_json" ^message message})))

(fn prune_idempotency_records! []
  (var now (monotonic_ms))
  (var retained [])
  (for record in (gateway_idempotency_records ~ Cell/get)
    (if (> record/expires_at_ms now)
      (retained ~ List/push! record)))
  (var overflow (- retained/~size gateway_idempotency_max))
  (if_yes (> overflow 0)
    (var bounded [])
    (repeat index in retained/~size
      (if (>= index overflow)
        (bounded ~ List/push! retained/%index)))
    (set retained bounded))
  (gateway_idempotency_records ~ Cell/set retained))

(fn idempotency_record [session_id : Str, attachment_id : Str, key : Str]
  (prune_idempotency_records!)
  (for record in (gateway_idempotency_records ~ Cell/get)
    (if (&& (== record/session_id session_id)
            (== record/attachment_id attachment_id)
            (== record/key key))
      (return record)))
  nil)

(fn cached_response [record]
  (Response ^status record/status ^headers record/headers ^body record/body))

(fn dispatch_idempotent [session_id : Str, attachment, req, dispatch]
  (var key (request_header req "idempotency-key"))
  (if (|| (== key nil) (== key ""))
    (return (dispatch)))
  (if (> (byte_size key) 128)
    (return
      (json_response 400
        {^error "invalid_idempotency_key"
         ^message "Idempotency-Key exceeds 128 bytes"})))
  (var fingerprint $"${req/method}\n${req/path}\n${req/body}")
  (var existing
    (idempotency_record session_id attachment/id key))
  (if existing
    (return
      (if (== existing/fingerprint fingerprint)
        (cached_response existing)
        (json_response 409
          {^error "idempotency_key_reused"
           ^message "Idempotency-Key was already used for a different request"}))))
  (var response (dispatch))
  ((gateway_idempotency_records ~ Cell/get) ~ List/push!
    (IdempotencyRecord
      ^session_id session_id ^attachment_id attachment/id ^key key
      ^fingerprint fingerprint ^status response/status
      ^headers response/headers ^body response/body
      ^expires_at_ms (+ (monotonic_ms) gateway_idempotency_ttl_ms)))
  (prune_idempotency_records!)
  response)

(fn create_session []
  (session_seq ~ Cell/set (+ (session_seq ~ Cell/get) 1))
  (var id $"s${(session_seq ~ Cell/get)}")
  (sessions ~ Map/put! id (make_session id nil nil nil))
  (json_response 200 {^id id}))

(fn ensure_local_session []
  (var app (agent_api/active_application ~ Cell/get))
  (if (&& (!= app nil) (== (sessions ~ Map/get "local") void))
    (sessions ~ Map/put! "local" (make_session "local" nil nil app))))

(fn list_sessions []
  (var out (cell []))
  (sessions/%to_pairs_stream
    ~ each (fn [pair]
        (var [k, s] pair)
        ((out ~ Cell/get) ~ List/push!
          {^id k ^events (session_event_cursor s)
           ^busy (|| (s/input_pending ~ Cell/get)
                     (!= (s/current_task ~ Cell/get) nil))})))
  (json_response 200 {^sessions (out ~ Cell/get)}))

(fn post_message [id : Str, req, attachment]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (json_response 404 {^error "no such session"})
    (try
      (var body (parse req/body))
      (if (|| (== body/text void) (== body/text nil) (== body/text ""))
        (json_response 400 {^error "missing text"})
        (if (s/submit_input body/text $"http:${attachment/id}" attachment)
          (then (json_response 202 {^ok true}))
          (else
            (var operation
              (s/application/main_agent/current_operation ~ Cell/get))
            (json_response 409
              {^error "worker_busy" ^message "turn already in flight"
               ^worker_id s/application/main_agent/id
               ^task_id (if operation operation/task_id)
               ^reserved
                 (s/application/main_agent/input_reserved ~ Cell/get)}))))
      catch (JsonError ^message m)
        (json_response 400 {^error m}))))

(fn cancel_turn [id : Str, attachment]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (json_response 404 {^error "no such session"})
    (cancel_worker id s/application/main_agent/id attachment)))

(fn list_workers [id : Str]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (json_response 404 {^error "no such session"})
    (json_response 200
      {^workers (agent_api/application_workers_snapshot s/application)})))

(fn session_event_cursor [s] : Int
  # The embedded local application exposes the next cursor to allocate;
  # standalone gateway sessions historically retain the last allocated one.
  (if s/shared
    (- (s/next_v ~ Cell/get) 1)
    (s/next_v ~ Cell/get)))

(fn session_snapshot [s]
  # This handler contains no await. It captures the shared worker projection
  # and the journal cursor in one scheduler turn. Per-worker output_seq lets a
  # client suppress an already-snapshotted worker_output record if a producer
  # crossed the boundary immediately before capture.
  {^session_id s/id
   ^cursor (session_event_cursor s)
   ^dropped_before (s/dropped_before ~ Cell/get)
   ^main_worker_id s/application/main_agent/id
   ^progress
     (agent_api/redact_any (s/application/progress ~ Cell/get))
   ^workers
     (agent_api/redact_any
     (agent_api/application_workers_snapshot s/application))})

(fn projection_worker_ids [s]
  # Projection rows are snapshot-only derived state. Conservatively
  # invalidate every live projection after a canonical event batch; this is
  # bounded by the worker limit and avoids journal amplification.
  (var ids [])
  (for worker in (agent_api/application_workers_snapshot s/application)
    (if (&& (== worker/lifecycle "running")
            (|| (["stats" "log_tail"] ~ contains? worker/kind)
                (&& (== worker/kind "output")
                    (! (empty? worker/following)))))
      (ids ~ List/push! worker/worker_id)))
  ids)

(fn get_snapshot [id : Str]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (json_response 404 {^error "no such session"})
    (json_response 200 (session_snapshot s))))

(fn persist_gateway_session [s]
  (persist_session s/id s/items s/events s/next_v s/dropped_before
                   s/application))

(fn create_worker [id : Str, req]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (json_response 404 {^error "no such session"})
    (try
      (var body (parse req/body))
      (if (|| (== body/kind void) (== body/kind nil))
        (then (json_response 400 {^error "missing worker kind"}))
        (elif (! (["shell" "output" "log_tail" "file_view" "stats"]
                   ~ contains? body/kind))
          (json_response 403
            {^error "remote worker kind is not allowed"}))
        (else
          (var worker
            (agent_api/application_create_worker
              s/application body/kind
              (if (== body/config void) body body/config)))
          (if (== worker nil)
            (then
              (json_response 400
                {^error "worker configuration was rejected or limit reached"}))
            (else
              (persist_gateway_session s)
              (json_response 201 {^worker_id worker/id})))))
    catch (JsonError ^message m)
      (json_response 400 {^error m})
    catch {^message m}
      (json_response 400 {^error m}))))

# Agent routes are explicit aliases over the agent subset of the canonical
# worker registry. They never maintain a second task, id, or lifecycle.
(fn list_agents [id : Str]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (json_response 404 {^error "no such session"})
    (do
      (var agents [])
      (for worker in
           (agent_api/application_workers_snapshot s/application)
        (if (== worker/kind "agent")
          (agents ~ List/push! worker)))
      (json_response 200 {^agents agents}))))

(fn create_agent [id : Str, req]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (json_response 404 {^error "no such session"})
    (try
      (var body (parse req/body))
      (var assignment
        (if (|| (== body/assignment void) (== body/assignment nil))
          "" (trim body/assignment)))
      (if (== assignment "")
        (then (json_response 400 {^error "missing assignment"}))
        (else
          (var agent
            (agent_api/spawn_supervised_named_agent_with_context s/application
              (if (|| (== body/title void) (== body/title nil))
                "sub-agent" body/title)
              assignment
              (if (== body/context void) [] body/context)
              (if (== body/name void) nil body/name)))
          (if (== agent nil)
            (then (json_response 409 {^error "sub-agent limit reached"}))
            (else
              (persist_gateway_session s)
              (json_response 201
                {^agent_id agent/id ^worker_id agent/id})))))
    catch (JsonError ^message m)
      (json_response 400 {^error m})
    catch {^message m}
      (json_response 400 {^error m}))))

(fn get_agent_result [id : Str, agent_id : Str, attachment]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (json_response 404 {^error "no such session"})
    (do
      (var response
        (agent_api/application_call_worker s/application agent_id "result" {}
          (attachment_invocation attachment)))
      (if_not response/ok
        (return (json_response
          (if (== response/error/kind "worker_not_found") 404 403)
          {^error response/error})))
      (var result (props response/result))
      (if_not result/available
        (return (json_response 404 {^error "no agent result"})))
      (json_response 200 {^agent_id response/worker_id ^result result/result}))))

(fn mark_agent_result_read [id : Str, agent_id : Str, attachment]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (json_response 404 {^error "no such session"})
    (do
      (var response
        (agent_api/application_call_worker s/application agent_id
          "mark_result_read" {} (attachment_invocation attachment)))
      (if_not response/ok
        (return (json_response 409 {^error response/error})))
      (persist_gateway_session s)
      (var agent (agent_api/application_find_agent s/application agent_id))
      (json_response 200
        {^agent_id response/worker_id ^result (agent/result ~ Cell/get)}))))

(fn incorporate_agent_result [id : Str, agent_id : Str, attachment]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (json_response 404 {^error "no such session"})
    (do
      (var response
        (agent_api/application_call_worker s/application agent_id
          "incorporate" {} (attachment_invocation attachment)))
      (if_not response/ok
        (return (json_response 409 {^error response/error})))
      (persist_gateway_session s)
      (var agent (agent_api/application_find_agent s/application agent_id))
      (json_response 200
        {^agent_id response/worker_id ^result (agent/result ~ Cell/get)}))))

(fn get_progress [id : Str]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (json_response 404 {^error "no such session"})
    (json_response 200 {^progress (s/application/progress ~ Cell/get)})))

(fn put_progress [id : Str, req]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (json_response 404 {^error "no such session"})
    (try
      (var body (parse req/body))
      (var current (s/application/progress ~ Cell/get))
      (var updated
        (agent_api/application_update_progress
          s/application
          (if (== body/objective void) current/objective body/objective)
          (if (== body/phase void) current/phase body/phase)
          (if (== body/status void) current/status body/status)
          (if (== body/summary void) current/summary body/summary)
          (if (== body/blocked_reason void)
            current/blocked_reason body/blocked_reason)
          (if (== body/required_action void)
            current/required_action body/required_action)
          current/agent_ids current/worker_ids current/evidence_v))
      (persist_gateway_session s)
      (json_response 200 {^progress updated})
    catch (JsonError ^message m)
      (json_response 400 {^error "invalid_json" ^message m})
    catch {^message m}
      (json_response 400 {^error "invalid_progress" ^message m}))))

(fn agent_input [id : Str, agent_id : Str, req, attachment]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (then (json_response 404 {^error "no such session"}))
    (else
      (var agent (agent_api/application_find_agent s/application agent_id))
      (if (|| (== agent nil) (== agent/id "main"))
        (json_response 404 {^error "no such sub-agent"})
        (worker_input id agent_id req attachment)))))

(fn cancel_agent [id : Str, agent_id : Str, attachment]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (then (json_response 404 {^error "no such session"}))
    (else
      (var agent (agent_api/application_find_agent s/application agent_id))
      (if (|| (== agent nil) (== agent/id "main"))
        (json_response 404 {^error "no such sub-agent"})
        (cancel_worker id agent/id attachment)))))

(fn stop_agent [id : Str, agent_id : Str, attachment]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (then (json_response 404 {^error "no such session"}))
    (else
      (var agent (agent_api/application_find_agent s/application agent_id))
      (if (|| (== agent nil) (== agent/id "main"))
        (json_response 404 {^error "no such sub-agent"})
        (stop_worker id agent/id attachment)))))

(fn worker_operation_failure_response [response]
  (var kind response/error/kind)
  (var status
    (if (== kind "worker_not_found") 404
      (if (== kind "unknown_operation") 404
        (if (== kind "worker_access_denied") 403
          (if (== kind "invalid_arguments") 400 409)))))
  (json_response status {^ok false ^error response/error}))

(fn worker_operation_success_response
  [s, response, operation : Str, status : Int]
  # Observe-only operations are side-effect-free all the way through the
  # adapter: they do not append operation events or force a checkpoint.
  (if_not (response/effects ~ contains? "observe")
    (persist_gateway_session s))
  (json_response status
    {^ok true ^worker_id response/worker_id ^operation operation
     ^result (props response/result)}))

(fn worker_operation
  [id : Str, worker_id : Str, operation : Str, req, attachment]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (return (json_response 404 {^error "no such session"})))
  (try
    (var body (if (== (trim req/body) "") {} (parse req/body)))
    (var raw_args
      (if (== body/args void) body body/args))
    (var response
      (agent_api/application_call_worker s/application worker_id operation
        raw_args
        (attachment_invocation attachment)))
    (if response/ok
      (worker_operation_success_response s response operation 200)
      (worker_operation_failure_response response))
  catch (JsonError ^message m)
    (json_response 400 {^error "invalid_json" ^message m})
  catch {^message m}
    (json_response 400 {^error "invalid_operation" ^message m})))

(fn worker_observation
  [id : Str, worker_id : Str, operation : Str, req, attachment]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (return (json_response 404 {^error "no such session"})))
  (try
    (var args {})
    (if (&& (== operation "tail") (!= req/params/n void))
      (args ~ Map/put! "n" (parse_int req/params/n)))
    (var response
      (agent_api/application_call_worker s/application worker_id operation args
        (attachment_invocation attachment)))
    (if response/ok
      (worker_operation_success_response s response operation 200)
      (worker_operation_failure_response response))
  catch {^message m}
    (json_response 400 {^error "invalid_arguments" ^message m})))

(fn worker_input [id : Str, worker_id : Str, req, attachment]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (then (json_response 404 {^error "no such session"}))
    (else
      (var worker
        (agent_api/application_find_worker s/application worker_id))
      (if (== worker nil)
        (json_response 404 {^error "no such worker"})
        (if (== (worker/lifecycle ~ Cell/get) "stopped")
          (json_response 409
            {^error "worker_stopped" ^message "worker is stopped"
             ^worker_id worker/id})
          (if (&& (["agent" "shell" "repl"] ~ contains? worker/kind)
                  (|| (worker/input_reserved ~ Cell/get)
                      (!= (worker/current_task ~ Cell/get) nil)))
            (then
              (var operation (worker/current_operation ~ Cell/get))
              (json_response 409
                {^error "worker_busy" ^message "worker is already working"
                 ^worker_id worker/id
                 ^task_id (if operation operation/task_id)
                 ^reserved (worker/input_reserved ~ Cell/get)}))
            (else
              (try
                (var body (parse req/body))
                (if (|| (== body/text void) (== body/text nil))
                  (then (json_response 400 {^error "missing_text"}))
                  (else
                    (var result
                      (agent_api/application_send_worker_input_invoked
                        s/application worker body/text
                        $"http:${attachment/id}"
                        (attachment_invocation attachment)))
                    (if (starts_with? result "error:")
                      (then
                        (json_response 409
                          {^error "worker_input_rejected" ^message result
                           ^worker_id worker/id}))
                      (else
                        (persist_gateway_session s)
                        (json_response 202 {^ok true ^result result})))))
              catch (JsonError ^message m)
                (json_response 400 {^error "invalid_json" ^message m})))))))))

(fn cancel_worker [id : Str, worker_id : Str, attachment]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (return (json_response 404 {^error "no such session"})))
  (var response
    (agent_api/application_call_worker s/application worker_id "cancel" {}
      (attachment_invocation attachment)))
  (if_not response/ok
    (return (worker_operation_failure_response response)))
  (var result (props response/result))
  (if_not result/accepted
    (return
      (json_response 409
        {^error "worker_idle" ^message result/text
         ^worker_id response/worker_id})))
  (if (== response/worker_id s/application/main_agent/id)
    (s/cancel_requested ~ Cell/set true))
  (worker_operation_success_response s response "cancel" 202))

(fn stop_worker [id : Str, worker_id : Str, attachment]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (return (json_response 404 {^error "no such session"})))
  (if (== worker_id s/application/main_agent/id)
    (return
      (json_response 409
        {^error "main_worker_cannot_stop"
         ^message "main worker cannot be stopped" ^worker_id worker_id})))
  (var response
    (agent_api/application_call_worker s/application worker_id "stop" {}
      (attachment_invocation attachment)))
  (if_not response/ok
    (return (worker_operation_failure_response response)))
  (var result (props response/result))
  (if_not result/accepted
    (return
      (json_response 409
        {^error "worker_stopped" ^message result/text
         ^worker_id response/worker_id})))
  (worker_operation_success_response s response "stop" 200))

# Long-poll: return events after ^cursor as soon as any exist, waiting up to
# ~20s. A handler parked in sleep does not stall other requests (task-per-
# request dispatch), so this works without streaming responses (§12.9 gap 2).
(fn get_events [id : Str, req]
  (var s (sessions ~ Map/get id))
  (if (== s void)
    (then (json_response 404 {^error "no such session"}))
    (else
      (var cursor 0)
      (if_not (== req/params/cursor void)
        (try
          (set cursor (parse_int req/params/cursor))
        catch _ nil))
      (if (< cursor (s/dropped_before ~ Cell/get))
        (then
          (json_response 409
            {^error "cursor_gap"
             ^dropped_before (s/dropped_before ~ Cell/get)
             ^oldest_cursor (+ (s/dropped_before ~ Cell/get) 1)
             ^snapshot_url $"/api/sessions/${id}/snapshot"}))
        (else
          (var out (cell (events_after s cursor)))
          (var waited (cell 0))
          (while (&& (empty? (out ~ Cell/get)) (< (waited ~ Cell/get) 200))
            (sleep 100)
            (waited ~ Cell/set (+ (waited ~ Cell/get) 1))
            (out ~ Cell/set (events_after s cursor)))
          (var evs (out ~ Cell/get))
          (json_response 200 {^events evs
                              ^cursor (max_event_v evs cursor)
                              ^changed_worker_ids
                                (if (empty? evs) []
                                  (projection_worker_ids s))}))))))

(var web_page """<!doctype html>
<meta charset="utf-8">
<title>Gene Agent Gateway</title>
<style>
body { font-family: ui-monospace, monospace; max-width: 52rem; margin: 2rem auto; padding: 0 1rem; }
#log { white-space: pre-wrap; border: 1px solid #8884; padding: 1rem; min-height: 16rem; }
.user { color: #06c; } .text { color: inherit; } .muted { color: #888; }
form { display: flex; gap: .5rem; margin-top: .75rem; }
input { flex: 1; font: inherit; padding: .4rem; }
</style>
<h1>Gene Agent Gateway</h1>
<div id="log" class="muted">connecting...</div>
<form id="f"><input id="t" autofocus placeholder="message..."><button>send</button></form>
<script>
var tok = localStorage.gwToken || new URLSearchParams(location.search).get('token') || '';
if (tok) localStorage.gwToken = tok;
function hdrs(json) {
  var h = {};
  if (json) h['content-type'] = 'application/json';
  if (tok) h['authorization'] = 'Bearer ' + tok;
  if (attachmentId) h['x-gene-attachment'] = attachmentId;
  return h;
}
var log = document.getElementById('log');
var sid = null, attachmentId = null, cursor = 0, streaming = false;
function mutationHeaders() {
  var h = hdrs(true);
  h['idempotency-key'] =
    (crypto.randomUUID ? crypto.randomUUID() :
      Date.now().toString(36) + Math.random().toString(36).slice(2));
  return h;
}
function show(cls, text) {
  if (log.classList.contains('muted')) { log.textContent = ''; log.classList.remove('muted'); }
  var span = document.createElement('span');
  span.className = cls;
  span.textContent = text;
  log.appendChild(span);
  log.scrollTop = log.scrollHeight;
}
function render(ev) {
  if (ev.type === 'user_input') { if (streaming) { show('text', '\n'); streaming = false; } show('user', 'you> ' + ev.text + '\n'); }
  else if (ev.type === 'text_delta') { if (!streaming) { show('text', 'agent> '); streaming = true; } show('text', ev.text); }
  else if (ev.type === 'agent_text') { if (streaming) { show('text', '\n'); streaming = false; } else { show('text', 'agent> ' + ev.text + '\n'); } }
  else if (ev.type === 'turn_done') { if (streaming) { show('text', '\n'); streaming = false; } }
}
function installSnapshot(s) {
  var main = (s.workers || []).find(function (w) { return w.worker_id === s.main_worker_id; });
  log.textContent = main && main.output ? main.output : '';
  log.classList.remove('muted');
  streaming = false;
  cursor = s.cursor || 0;
  log.scrollTop = log.scrollHeight;
}
function resync() {
  return fetch('/api/sessions/' + sid + '/snapshot', { headers: hdrs(false) })
    .then(function (r) { return r.json(); })
    .then(installSnapshot);
}
function poll() {
  fetch('/api/sessions/' + sid + '/events?cursor=' + cursor, { headers: hdrs(false) })
    .then(function (r) { return r.json(); })
    .then(function (d) {
      if (d.error === 'cursor_gap') { return resync().then(poll); }
      (d.events || []).forEach(render);
      if (d.cursor > cursor) cursor = d.cursor;
      poll();
    })
    .catch(function () { setTimeout(poll, 1000); });
}
fetch('/api/sessions', { method: 'POST', headers: hdrs(false) })
  .then(function (r) { return r.json(); })
  .then(function (d) {
    sid = d.id;
    return fetch('/api/sessions/' + sid + '/attachments',
      { method: 'POST', headers: hdrs(true),
        body: JSON.stringify({ display_label: 'web' }) });
  })
  .then(function (r) { return r.json(); })
  .then(function (d) {
    attachmentId = d.attachment_id;
    show('muted', 'session ' + sid + '\n');
    poll();
  });
document.getElementById('f').addEventListener('submit', function (e) {
  e.preventDefault();
  var t = document.getElementById('t');
  if (!t.value || !sid) return;
  fetch('/api/sessions/' + sid + '/messages',
        { method: 'POST', headers: mutationHeaders(),
          body: JSON.stringify({ text: t.value }) });
  t.value = '';
});
</script>
""")

(fn dispatch_attached_session [req, parts, attachment]
  (match parts/4
    (when "messages"
      (if (== req/method "POST")
        (post_message parts/3 req attachment)
        (json_response 405 {^error "method_not_allowed"})))
    (when "events"
      (if (== req/method "GET")
        (get_events parts/3 req)
        (json_response 405 {^error "method_not_allowed"})))
    (when "snapshot"
      (if (== req/method "GET")
        (get_snapshot parts/3)
        (json_response 405 {^error "method_not_allowed"})))
    (when "cancel"
      (if (== req/method "POST")
        (cancel_turn parts/3 attachment)
        (json_response 405 {^error "method_not_allowed"})))
    (when "agents"
      (if (== parts/~size 5)
        (if (== req/method "GET")
          (list_agents parts/3)
          (if (== req/method "POST")
            (create_agent parts/3 req)
            (json_response 405 {^error "method_not_allowed"})))
        (if (== parts/~size 6)
          (if (== req/method "DELETE")
            (stop_agent parts/3 parts/5 attachment)
            (json_response 405 {^error "method_not_allowed"}))
          (if (== parts/~size 7)
            (match parts/6
              (when "messages"
                (if (== req/method "POST")
                  (agent_input parts/3 parts/5 req attachment)
                  (json_response 405 {^error "method_not_allowed"})))
              (when "cancel"
                (if (== req/method "POST")
                  (cancel_agent parts/3 parts/5 attachment)
                  (json_response 405 {^error "method_not_allowed"})))
              (when "result"
                (if (== req/method "GET")
                  (get_agent_result parts/3 parts/5 attachment)
                  (json_response 405 {^error "method_not_allowed"})))
              (when "incorporate"
                (if (== req/method "POST")
                  (incorporate_agent_result parts/3 parts/5 attachment)
                  (json_response 405 {^error "method_not_allowed"})))
              (else (json_response 404 {^error "not_found"})))
            (if (&& (== parts/~size 8)
                    (== parts/6 "result") (== parts/7 "read"))
              (if (== req/method "POST")
                (mark_agent_result_read parts/3 parts/5 attachment)
                (json_response 405 {^error "method_not_allowed"}))
              (json_response 404 {^error "not_found"}))))))
    (when "progress"
      (if (== req/method "GET")
        (get_progress parts/3)
        (if (== req/method "PUT")
          (put_progress parts/3 req)
          (json_response 405 {^error "method_not_allowed"}))))
    (when "confirmations"
      (if (&& (== parts/~size 6) (== req/method "POST"))
        (resolve_confirmation parts/3 parts/5 req attachment)
        (json_response 405 {^error "method_not_allowed"})))
    (when "workers"
      (if (== parts/~size 5)
        (if (== req/method "GET")
          (list_workers parts/3)
          (if (== req/method "POST")
            (create_worker parts/3 req)
            (json_response 405 {^error "method_not_allowed"})))
        (if (== parts/~size 6)
          (if (== req/method "DELETE")
            (stop_worker parts/3 parts/5 attachment)
            (json_response 405 {^error "method_not_allowed"}))
          (if (== parts/~size 7)
            (match parts/6
              (when "input"
                (if (== req/method "POST")
                  (worker_input parts/3 parts/5 req attachment)
                  (json_response 405 {^error "method_not_allowed"})))
              (when "cancel"
                (if (== req/method "POST")
                  (cancel_worker parts/3 parts/5 attachment)
                  (json_response 405 {^error "method_not_allowed"})))
              (when "status"
                (if (== req/method "GET")
                  (worker_observation
                    parts/3 parts/5 "status" req attachment)
                  (json_response 405 {^error "method_not_allowed"})))
              (when "tail"
                (if (== req/method "GET")
                  (worker_observation
                    parts/3 parts/5 "tail" req attachment)
                  (json_response 405 {^error "method_not_allowed"})))
              (else (json_response 404 {^error "not_found"})))
            (if (&& (== parts/~size 8) (== parts/6 "ops"))
              (if (== req/method "POST")
                (worker_operation
                  parts/3 parts/5 parts/7 req attachment)
                (json_response 405 {^error "method_not_allowed"}))
              (json_response 404 {^error "not_found"}))))))
    (else (json_response 404 {^error "not_found"}))))

(fn attached_session_route [req, parts]
  (var authorization (require_attachment parts/3 req))
  (if_not authorization/ok
    (return authorization/response))
  (var attachment authorization/attachment)
  (if (["POST" "PUT" "DELETE"] ~ contains? req/method)
    (dispatch_idempotent parts/3 attachment req
      (fn [] (dispatch_attached_session req parts attachment)))
    (dispatch_attached_session req parts attachment)))

(fn attachment_route [req, parts]
  (var session_id parts/3)
  (if (== parts/~size 5)
    (return
      (if (== req/method "POST")
        (create_attachment session_id req)
        (json_response 405 {^error "method_not_allowed"}))))
  (if (&& (== parts/~size 7) (== parts/6 "resume"))
    (return
      (if (== req/method "POST")
        (resume_attachment session_id parts/5 req)
        (json_response 405 {^error "method_not_allowed"}))))
  (var authorization (require_attachment session_id req))
  (if_not authorization/ok
    (return authorization/response))
  (var attachment authorization/attachment)
  (if (== parts/~size 6)
    (if (== req/method "DELETE")
      (detach_attachment session_id parts/5 attachment)
      (json_response 405 {^error "method_not_allowed"}))
    (if (&& (== parts/~size 7) (== parts/6 "ack"))
      (if (== req/method "POST")
        (acknowledge_attachment session_id parts/5 attachment req)
        (json_response 405 {^error "method_not_allowed"}))
      (json_response 404 {^error "not_found"}))))

(fn route [req]
  (ensure_local_session)
  (var parts (split req/path "/"))
  (if (== req/path "/")
    (Response ^status 200
              ^headers {^content-type "text/html; charset=utf-8"}
              ^body web_page)
    (if (== req/path "/api/operations")
      (if (== req/method "GET")
        (json_response 200
          {^operations (agent_api/operation_registry_snapshot)})
        (json_response 405 {^error "method_not_allowed"}))
    (if (== req/path "/api/sessions")
      (if (== req/method "POST")
        (create_session)
        (if (== req/method "GET")
          (list_sessions)
          (json_response 405 {^error "method_not_allowed"})))
      (if (&& (>= parts/~size 5)
              (== parts/1 "api")
              (== parts/2 "sessions"))
        (if (== parts/4 "attachments")
          (attachment_route req parts)
          (attached_session_route req parts))
        (json_response 404 {^error "not_found"}))))))

(fn handle [req]
  (if (authorized? req)
    (route req)
    (json_response 401 {^error "unauthorized"})))

# -----------------------------------------------------------------------------
# Persistence bootstrap (§12 milestone 11). Sessions restore with their event
# log and transcript; Telegram sessions (tg-<chat_id>) reattach their sender
# hook so replies keep flowing after a restart. session_seq resumes past the
# highest restored s<N> id so new ids never collide.
# -----------------------------------------------------------------------------

(fn restore_session_id_seq [id : Str]
  (if (starts_with? id "s")
    (try
      (var n (parse_int ((split id "s") ~ join "")))
      (if (> n (session_seq ~ Cell/get))
        (session_seq ~ Cell/set n))
    catch _ nil)))

(fn restore_sessions []
  (var count (cell 0))
  (for id in ((gw_store ~ Cell/get) ~ keys)
    (try
      (var saved ((gw_store ~ Cell/get) ~ get id))
      (var hook
        (if (starts_with? id "tg-")
          (make_telegram_sender ((split id "tg-") ~ join ""))))
      # Redact legacy snapshots at restore as well as new writes, before any
      # retained model context or transcript becomes live session state.
      (sessions ~ Map/put! id
        (make_session id hook (agent_api/redact_any saved) nil))
      (restore_session_id_seq id)
      (count ~ Cell/set (+ (count ~ Cell/get) 1))
    catch _ (gw_notice $"failed to restore session ${id}")))
  (count ~ Cell/get))

(fn finish_gateway_store [label : Str]
  (if (== gw_resume "0")
    (then
      ((gw_store ~ Cell/get) ~ clear)
      (gw_notice $"Persistence enabled - ${label} (fresh start)"))
    (else
      (var n (restore_sessions))
      (gw_notice $"Persistence enabled - ${label} (${n} sessions restored)"))))

(fn open_gateway_store []
  (if (== gw_state_dir "")
    (then
      (if_not (== gw_db_path "")
        (var db (agent_api/sqlite_open gw_db_path))
        (gw_store ~ Cell/set
          (agent_api/store_sqlite_open db
            ^table "sessions" ^key_column "id" ^data_column "data"))
        (finish_gateway_store gw_db_path)))
    (else
      (gw_store ~ Cell/set
        (agent_api/store_fs_open agent_api/ReadWriteDir ^root gw_state_dir))
      (finish_gateway_store gw_state_dir))))

(fn prepare_gateway [api, options]
  (set agent_api api)
  (set gw_quiet
    (&& (!= options nil) (== options/quiet true)))
  # Each gateway session owns its own event log and passes a per-turn
  # deny-without-terminal confirmation strategy to the shared agent core.
  (set gw_port
    (if (&& (!= options nil) (!= options/port void))
      options/port
      (parse_int (get_env Env "GENE_GATEWAY_PORT" "8090"))))
  (if (|| (< gw_port 1) (> gw_port 65535))
    (fail (OsError ^message "gateway port must be between 1 and 65535")))
  (if_not (["127.0.0.1" "::1" "localhost"] ~ contains? gw_host)
    (fail (OsError
      ^message
        "GENE_GATEWAY_HOST must be loopback; use an authenticated TLS proxy or tunnel for remote access")))
  (open_gateway_store)
  (gw_notice $"Gene agent gateway - http://${gw_host}:${gw_port} (model ${agent_api/model})")
  (if (== agent_api/auth_token nil)
    (gw_notice "No model API token set - sessions use the offline demo transport."))
  (if (== gw_token "")
    (gw_notice "GENE_GATEWAY_TOKEN unset - API is open; keep the bind on localhost."))
  # Bind eagerly. The combined application calls this before opening curses,
  # so invalid/unavailable ports fail without leaving a half-live TUI.
  (listen ^host gw_host ^port gw_port))

(fn serve_gateway [server]
  (if (== tg_token "")
    (then
      (gw_notice "TELEGRAM_BOT_TOKEN unset - Telegram channel disabled.")
      (serve server handle))
    (else
      (scope
        (spawn (telegram_loop))
        (spawn (telegram_sender_loop))
        (gw_notice $"Telegram channel enabled - long-polling ${tg_base}")
        (serve server handle)))))

(fn stop_gateway [server]
  (sessions/%to_pairs_stream
    ~ each (fn [pair]
        (var [id, session] pair)
        (agent_api/application_shutdown session/application)))
  (stop server))

(fn run_gateway [api, options]
  (serve_gateway (prepare_gateway api options)))
