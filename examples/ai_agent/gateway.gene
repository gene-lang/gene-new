#!/usr/bin/env gene run
# Compatibility launcher. The gateway implementation is UI-neutral in
# gateway_adapter.gene; tui.gene composes the same adapter for --gateway.

(mod agent_gateway
  @doc "compatibility launcher for the integrated AI-agent gateway")

(import [gateway_api] from "./tui")
(import [run_gateway] from "./gateway_adapter")

(fn main [args]
  (run_gateway (gateway_api) {}))
