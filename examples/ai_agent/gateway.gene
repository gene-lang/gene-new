#!/usr/bin/env gene run
# Headless gateway launcher (design.md §12, slice C9 Shape B service). The
# engine lives in core.gene; the HTTP/session adapter in gateway_adapter.gene.
# No TUI module is loaded — the service never touches curses or a TTY.

(mod agent_gateway
  @doc "headless launcher for the AI-agent gateway service")

(import [gateway_api init_agent_state] from "./core")
(import [run_gateway] from "./gateway_adapter")

(fn main [args]
  # Durable artifacts (/pin) ride the agent store when GENE_AGENT_STATE /
  # GENE_AGENT_HOME configure one; session persistence stays on
  # GENE_GATEWAY_DB. Headless sessions never write session checkpoints, so
  # opening the store here only enables the artifact surface.
  (init_agent_state)
  (run_gateway (gateway_api) {}))
