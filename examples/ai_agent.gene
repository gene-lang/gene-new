#!/usr/bin/env gene run
# =============================================================================
# Gene AI coding agent — MVP (docs/ai-agent.md milestones 1-4).
#
#   * Talks to Codex's ChatGPT-account Responses backend by default, or to any
#     OpenAI-compatible Chat Completions endpoint (MiniMax, DeepSeek, vLLM,
#     api.openai.com, ...) configured entirely from the environment. Streaming
#     in both modes.
#   * Transport is `curl` shelled out through os/exec-stream-async, so a model
#     call never blocks the scheduler (the gateway runs sessions concurrently).
#   * Tools: read_file / write_file / edit_file / list_dir / run_shell / grep,
#     each declared ONCE as a typed Tool value — the model-facing JSON schema,
#     argument validation, risk class, and handler all derive from that single
#     declaration (docs/ai-agent.md §6, slice A).
#   * §8.5 catastrophe guard: host-destroying commands (rm -rf of protected
#     roots, mkfs, fork bombs, shutdown, DROP DATABASE) are denied; destructive
#     git/db/infra commands take one explicit confirmation; file paths are
#     realpath-confined to the workspace; timeouts + output caps apply and
#     truncation is surfaced; known secrets are redacted everywhere. Routine
#     work runs without prompts. GENE_AGENT_GUARD=0 disables the guard.
#   * Every action is appended to a versioned event log (§9.2): /trace queries
#     it, and /repl binds a stable `session` object with message-based
#     mutations (add-tool / remember / subscribe / trace / resume).
#   * Ncurses-backed prompt on TTY; paste and Shift+Enter/Alt+Enter keep newlines.
#
# Run live (Codex Responses backend, the default):
#   OPENAI_AUTH_TOKEN=... gene run examples/ai_agent.gene
# Run live against any OpenAI-compatible chat-completions endpoint, e.g. MiniMax:
#   OPENAI_BASE_URL=https://api.minimax.io/v1 OPENAI_MODEL=MiniMax-M2 \
#   OPENAI_API_KEY=... gene run examples/ai_agent.gene
# Wire shape is OPENAI_API=responses|chat; it defaults to responses for the
# Codex backend and chat for any custom OPENAI_BASE_URL.
# Tools auto-approve by default (single-user agent); set GENE_AGENT_APPROVE_ALL=0
# to be prompted before writes and shell commands.
# Optional local persistence: set GENE_AGENT_STATE=.gene-agent-state to save
# non-secret config, the interactive session, and memory across restarts.
# Run demo:   gene run examples/ai_agent.gene         (no token -> offline demo
#             that drives the same loop with a scripted transport, incl. a
#             tool-call round trip — needs no network)
#
# Auth is a bearer token from `OPENAI_AUTH_TOKEN`, `OPENAI_API_KEY`, or
# `CODEX_ACCESS_TOKEN` (checked in that order).
# =============================================================================

(mod ai-agent
  @doc "a terminal coding agent over the OpenAI Responses API")

(import os [get-env env? exec exec-async exec-stream-async exec-stdio stdin-tty? read-line read-input refresh-input close-input Env Exec OsError])
(import json [parse stringify JsonError])
(import str [join split starts_with? contains? lower trim])
(import std/stream [to_stream map filter into each])
(import std/parse [parse_int])
(import Fs [read-text write-text list-dir real-path ReadDir WriteDir ReadWriteDir])
(import store/fs [open : store-open StoreError])
(import repl [run : run-repl-session])

# -----------------------------------------------------------------------------
# Config (all from the environment; nothing hard-coded).
# -----------------------------------------------------------------------------

(var auth-token (env? Env "OPENAI_AUTH_TOKEN"))
(if (= auth-token nil)
  (set auth-token (env? Env "OPENAI_API_KEY")))
(if (= auth-token nil)
  (set auth-token (env? Env "CODEX_ACCESS_TOKEN")))
(var codex-base "https://chatgpt.com/backend-api/codex")
(var base    (get-env Env "OPENAI_BASE_URL" codex-base))
(var model   (get-env Env "OPENAI_MODEL" "gpt-5.4-mini"))
# Wire shape: the Codex backend speaks the Responses API; generic
# OpenAI-compatible endpoints (MiniMax, DeepSeek, vLLM, ...) speak Chat
# Completions. Default follows the backend; override with
# OPENAI_API=responses|chat.
(var api-flavor
  (get-env Env "OPENAI_API" (if (= base codex-base) "responses" "chat")))
(var workspace-root ".")
(var approve-all (get-env Env "GENE_AGENT_APPROVE_ALL" "1"))
(var agent-state-dir (get-env Env "GENE_AGENT_STATE" ""))
(var agent-resume (get-env Env "GENE_AGENT_RESUME" "1"))
(var guard-flag (get-env Env "GENE_AGENT_GUARD" "1"))

(fn present? [v]
  (! (|| (= v void) (= v nil))))

(fn flag-enabled? [value : Str]
  (var v (lower (trim value)))
  (|| (= v "1")
      (|| (= v "true")
          (|| (= v "yes") (= v "on")))))

(fn append-all [xs, ys]
  ((to_stream ys) ~ into xs))

(fn append [xs, x]
  ((to_stream [x]) ~ into xs))

# -----------------------------------------------------------------------------
# §8.5 catastrophe guard. Posture: single-user power tool — routine work runs
# without prompts; narrow hard stops for catastrophic, hard-to-recover actions;
# one explicit confirmation for destructive-but-plausibly-intentional commands.
# GENE_AGENT_GUARD=0 (set outside the session) disables classification.
# -----------------------------------------------------------------------------

(fn replace-all [s : Str, from : Str, to : Str] : Str
  ((split s from) ~ join to))

# Never let the API token surface in transcript, logs, events, or errors.
(fn redact [s : Str] : Str
  (if (= auth-token nil)
    s
    (replace-all s auth-token "auth-***REDACTED***")))

(fn guard-enabled? []
  (flag-enabled? guard-flag))

# The workspace root as a real (symlink-resolved, absolute) path; every file
# tool path must resolve inside it.
(var workspace-real (real-path ReadDir workspace-root))

# Confine every file path to the workspace root: reject absolute paths and
# `..` segments up front, then realpath the target so a symlink inside the
# workspace cannot point writes/reads outside it (§8.5).
(fn safe-path [p : Str] : Str
  (if (starts_with? p "/")
    (fail $"unsafe path rejected (absolute): ${p}")
    (if (contains? p "..")
      (fail $"unsafe path rejected (escapes workspace): ${p}")
      (do
        (var rp (real-path ReadDir p))
        (if (|| (= rp workspace-real)
                (starts_with? rp $"${workspace-real}/"))
          p
          (fail $"unsafe path rejected (resolves outside workspace): ${p}"))))))

# --- raw-command classification: normal | destructive | catastrophic ---------
# High-confidence substring/segment heuristics only; parsing arbitrary shell is
# necessarily incomplete and this is not an OS sandbox (§8.5).

(fn rm-recursive? [c : Str]
  (|| (contains? c "rm -rf")
      (|| (contains? c "rm -fr")
          (|| (contains? c "rm -r ") (contains? c "rm -f -r")))))

(var protected-root-tokens ["/" "/*" "~" "~/" "$HOME" "${HOME}" "." ".." ".git" ".git/"])

(fn protected-target? [tok : Str]
  (var hit (cell false))
  ((to_stream protected-root-tokens)
    ~ each (fn [t] (if (= t tok) (Cell/set hit true) nil)))
  (|| (Cell/get hit)
      (|| (= tok workspace-real) (= tok $"${workspace-real}/"))))

# A recursive rm is at least destructive; targeting a protected root or a
# top-level absolute directory (/usr, /etc, ...) is catastrophic.
(fn classify-rm [cmd : Str] : Str
  (var worst (cell "destructive"))
  ((to_stream (split cmd " "))
    ~ each (fn [raw]
        (var tok (trim raw))
        (if (= tok "")
          nil
          (if (protected-target? tok)
            (Cell/set worst "catastrophic")
            (if (&& (starts_with? tok "/")
                    (<= ((split tok "/") ~ size) 2))
              (Cell/set worst "catastrophic")
              nil)))))
  (Cell/get worst))

# Split a command line on `&&`, `;`, and `|` so command-name patterns anchor at
# the start of each simple command instead of matching anywhere (a `grep
# shutdown src/` must stay normal).
(fn command-segments [cmd : Str]
  (var segs (cell []))
  ((to_stream (split cmd "&&"))
    ~ each (fn [a]
        ((to_stream (split a ";"))
          ~ each (fn [b]
              ((to_stream (split b "|"))
                ~ each (fn [c]
                    (segs ~ Cell/set (append (segs ~ Cell/get) (trim c)))))))))
  (Cell/get segs))

(var catastrophic-command-starts
  ["mkfs" "shutdown" "reboot" "poweroff" "halt" "init 0"])

(fn segment-catastrophic? [seg : Str]
  (var s (lower seg))
  (var hit (cell false))
  ((to_stream catastrophic-command-starts)
    ~ each (fn [p] (if (starts_with? s p) (Cell/set hit true) nil)))
  (|| (Cell/get hit)
      (|| (contains? s ":(){")
          (|| (contains? s " of=/dev/") (contains? s "drop database")))))

# A SQL DELETE/UPDATE with no WHERE clause rewrites the whole table.
(fn sql-unbounded? [s : Str]
  (&& (! (contains? s "where"))
      (|| (contains? s "delete from")
          (&& (contains? s "update ") (contains? s " set ")))))

(fn segment-destructive? [seg : Str]
  (var s (lower seg))
  (|| (contains? s "git reset --hard")
      (|| (contains? s "git clean -fd")
          (|| (contains? s "git push --force")
              (|| (contains? s "git push -f")
                  (|| (contains? seg "git branch -D")
                      (|| (contains? s "drop table")
                          (|| (contains? s "truncate table")
                              (|| (contains? s "terraform destroy")
                                  (|| (contains? s "kubectl delete namespace")
                                      (|| (contains? s "kubectl delete ns ")
                                          (|| (contains? s "kubectl delete cluster")
                                              (sql-unbounded? s)))))))))))))

(fn classify-command [cmd : Str] : Str
  (var worst (cell "normal"))
  (fn bump [level : Str]
    (if (= level "catastrophic")
      (Cell/set worst "catastrophic")
      (if (&& (= level "destructive") (! (= (Cell/get worst) "catastrophic")))
        (Cell/set worst "destructive")
        nil)))
  (if (rm-recursive? cmd) (bump (classify-rm cmd)) nil)
  ((to_stream (command-segments cmd))
    ~ each (fn [seg]
        (if (segment-catastrophic? seg)
          (bump "catastrophic")
          (if (segment-destructive? seg) (bump "destructive") nil))))
  (Cell/get worst))

(fn approve? [tool : Str, detail : Str]
  (if (flag-enabled? approve-all)
    true
    (do
      (close-user-input)
      (print $"approve ${tool}: ${(redact detail)}? [y/N] ")
      (var answer (read-line))
      (if (= answer nil)
        false
        (do
          (set answer (lower (trim answer)))
          (|| (= answer "y") (= answer "yes")))))))

# One explicit confirmation for a destructive command. EOF (no stdin, scripted
# runs) denies — a destructive command never auto-approves.
(fn confirm-destructive? [cmd : Str]
  (close-user-input)
  (print $"destructive command: ${(redact cmd)}\nrun it once? [y/N] ")
  (var answer (read-line))
  (if (= answer nil)
    false
    (do
      (set answer (lower (trim answer)))
      (|| (= answer "y") (= answer "yes")))))

# Injectable guard strategy. The CLI's defaults are the stdin confirmation and
# the process-global event log; an embedding host (the gateway) must override
# them — it has no terminal, so a synchronous stdin read would stall the
# scheduler, and its confirmation/audit events belong in the per-session log.
# run-tool-call points guard-emit at the current turn's sink around each
# handler call; the guard runs synchronously before the handler's first await,
# so concurrent session actors cannot interleave between set and use.
(var guard-confirm (cell nil))   # nil -> confirm-destructive? (CLI stdin)
(var guard-emit (cell nil))      # nil -> emit-event! (CLI global log)

(fn set-guard-confirm [f]
  (guard-confirm ~ Cell/set f))

(fn guard-confirmed? [cmd : Str]
  (var f (guard-confirm ~ Cell/get))
  (if (present? f)
    (f cmd)
    (confirm-destructive? cmd)))

(fn guard-emit! [type : Str, props]
  (var f (guard-emit ~ Cell/get))
  (if (present? f)
    (f type props)
    (emit-event! type props)))

# -----------------------------------------------------------------------------
# Authoritative event log (§9.2). Append-only, versioned, redacted at append.
# One vocabulary shared by the transcript, /trace, the /repl session object,
# tests, and the gateway: user-input model-item tool-call tool-result
# agent-text text-delta turn-done tool-registered confirmation memory error.
# -----------------------------------------------------------------------------

(var agent-events (cell []))
(var next-event-v (cell 1))
(var current-turn (cell 0))
(var event-subscriptions (cell []))
(var event-echo (cell nil))     # (fn [line]) hook installed by the REPL loop
# This process-global log is the embedded-CLI surface's own event log. The
# gateway imports run-turn but owns a per-session log in the same vocabulary
# (§12.1/§12.3), so it disables this one to avoid accumulating every session's
# events in a single shared list across concurrent actor turns.
(var events-enabled (cell true))

(fn set-events-enabled [on : Bool]
  (events-enabled ~ Cell/set on))

# Redact recursively through every container an event value can hold — a
# model-item's `content` is a list of maps, so stopping at maps would persist
# a token echoed in assistant content (§8.5).
(fn redact-any [v]
  (match v
    (when (s : Str) (redact s))
    (when (m : Map)
      (do
        (var out {})
        (for [k mv] in m
          (out ~ Map/put! k (redact-any mv)))
        out))
    (when (xs : List)
      ((to_stream xs) ~ map redact-any ; ~ into []))
    (else v)))

(fn first-line [s : Str] : Str
  (var lines (split s "\n"))
  (if (> lines/~size 1) $"${lines/0} ..." lines/0))

(fn event-summary [e] : Str
  (match e/type
    (when "user-input"  (first-line e/text))
    (when "agent-text"  (first-line e/text))
    (when "text-delta"  (first-line e/text))
    (when "turn-done"   (if (present? e/text) (first-line e/text) ""))
    (when "model-item"  (if (present? e/item/type) e/item/type "item"))
    (when "tool-call"   $"${e/name} ${(stringify e/args)}")
    (when "tool-result"
      (do
        (var flag (if (= e/truncated true) " [truncated]" ""))
        $"${e/name}${flag}: ${(first-line e/value)}"))
    (when "confirmation" $"${e/risk} ${e/decision}: ${(first-line e/target)}")
    (when "tool-registered" $"${e/name} (${e/risk})")
    (when "memory"      (first-line e/text))
    (when "error"       (first-line e/text))
    (else "")))

(fn format-event [e] : Str
  $"#${e/v} t${e/turn} ${e/type} ${(event-summary e)}")

(fn subscribed? [type : Str]
  (var hit (cell false))
  ((to_stream (event-subscriptions ~ Cell/get))
    ~ each (fn [t] (if (= t type) (Cell/set hit true) nil)))
  (Cell/get hit))

(fn echo-subscribed [e]
  (if (&& (present? (event-echo ~ Cell/get)) (subscribed? e/type))
    (do
      (var f (event-echo ~ Cell/get))
      (f (format-event e)))
    nil))

(fn emit-event! [type : Str, props]
  (if (! (events-enabled ~ Cell/get))
    nil
    (do
      (var v (next-event-v ~ Cell/get))
      (next-event-v ~ Cell/set (+ v 1))
      (var e {^v v ^turn (current-turn ~ Cell/get) ^type type})
      (for [k pv] in props
        (e ~ Map/put! k (redact-any pv)))
      (agent-events ~ Cell/set (append (agent-events ~ Cell/get) e))
      (echo-subscribed e)
      e)))

(fn begin-turn! []
  (current-turn ~ Cell/set (+ (current-turn ~ Cell/get) 1)))

# --- /trace: filters over the event log (type=, tool=, path=, turn=, from=,
# to=; a bare token is shorthand for type=token) --------------------------------

(fn event-matches? [e, f]
  (var ok (cell true))
  (if (present? f/type)
    (if (= e/type f/type) nil (Cell/set ok false))
    nil)
  (if (present? f/tool)
    (if (= e/name f/tool) nil (Cell/set ok false))
    nil)
  (if (present? f/turn)
    (if (= $"${e/turn}" f/turn) nil (Cell/set ok false))
    nil)
  (if (present? f/from)
    (if (>= e/v (parse_int f/from)) nil (Cell/set ok false))
    nil)
  (if (present? f/to)
    (if (<= e/v (parse_int f/to)) nil (Cell/set ok false))
    nil)
  (if (present? f/path)
    (do
      (var p (cell ""))
      (if (present? e/path) (Cell/set p e/path) nil)
      (if (present? e/args)
        (if (present? e/args/path) (Cell/set p e/args/path) nil)
        nil)
      (if (contains? (Cell/get p) f/path) nil (Cell/set ok false)))
    nil)
  (Cell/get ok))

(fn parse-trace-filters [rest : Str]
  (var f {})
  ((to_stream (split (trim rest) " "))
    ~ each (fn [raw]
        (var tok (trim raw))
        (if (= tok "")
          nil
          (do
            (var kv (split tok "="))
            (if (= kv/~size 2)
              (f ~ Map/put! kv/0 kv/1)
              (f ~ Map/put! "type" tok))))))
  f)

(fn trace-report [rest : Str] : Str
  (var f (parse-trace-filters rest))
  (var lines (cell []))
  ((to_stream (agent-events ~ Cell/get))
    ~ filter (fn [e] (event-matches? e f))
    ; ~ each (fn [e]
        (lines ~ Cell/set (append (lines ~ Cell/get) (format-event e)))))
  (if (empty? (lines ~ Cell/get))
    "no matching events"
    (join (lines ~ Cell/get) "\n")))

# Deny/confirm gate for run_shell and /sh-adjacent tool commands. Returns nil
# when the command may run, or the denial text otherwise. Confirmation and
# audit events go through the injected guard strategy so an embedding host
# (gateway) gets them in its per-session log and never blocks on stdin.
(fn guard-shell [cmd : Str]
  (if (! (guard-enabled?))
    nil
    (match (classify-command cmd)
      (when "catastrophic"
        (do
          (guard-emit! "confirmation"
            {^risk "catastrophic" ^decision "deny" ^target cmd})
          "denied by catastrophe guard (GENE_AGENT_GUARD=0 outside the session overrides)"))
      (when "destructive"
        (if (guard-confirmed? cmd)
          (do
            (guard-emit! "confirmation"
              {^risk "destructive" ^decision "allow" ^target cmd})
            nil)
          (do
            (guard-emit! "confirmation"
              {^risk "destructive" ^decision "deny" ^target cmd})
            "denied: destructive command was not confirmed")))
      (else nil))))

# -----------------------------------------------------------------------------
# Typed tools (§6, slice A). One Tool declaration per tool is the single source
# of truth: the registry entry, the model-facing JSON Schema (both wire
# shapes), argument validation, and the risk class all derive from it. New
# tools register live from /repl via (session ~ add-tool (Tool ...)).
# -----------------------------------------------------------------------------

(fn json-type-ok? [t : Str, v]
  (match t
    (when "string"  (match v (when (s : Str) true) (else false)))
    (when "integer" (match v (when (i : Int) true) (else false)))
    (when "boolean" (match v (when (b : Bool) true) (else false)))
    (else true)))

(type Tool
  ^props {^name Str ^description Str ^risk Str ^params Any ^handler Any}

  # The model-facing schema in the Responses wire shape.
  (message schema [self]
    (var props {})
    (var required (cell []))
    (for p in self/params
      (var spec {^type p/type})
      (if (present? p/doc)
        (spec ~ Map/put! "description" p/doc)
        nil)
      (props ~ Map/put! p/name spec)
      (if (= p/required true)
        (required ~ Cell/set (append (required ~ Cell/get) p/name))
        nil))
    (var parameters {^type "object" ^properties props})
    (if (empty? (required ~ Cell/get))
      nil
      (parameters ~ Map/put! "required" (required ~ Cell/get)))
    {^type "function" ^name self/name
     ^description self/description ^parameters parameters})

  # nil when args satisfy the declaration, else a problem description.
  (message validate-args [self, args]
    (var problems (cell []))
    (for p in self/params
      (var v (args ~ Map/get p/name))
      (if (= v void)
        (if (= p/required true)
          (problems ~ Cell/set (append (problems ~ Cell/get)
            $"missing required argument ${p/name}"))
          nil)
        (if (json-type-ok? p/type v)
          nil
          (problems ~ Cell/set (append (problems ~ Cell/get)
            $"argument ${p/name} must be a ${p/type}")))))
    (if (empty? (problems ~ Cell/get))
      nil
      (join (problems ~ Cell/get) "; "))))

(var tool-registry (cell {}))
(var tool-names (cell []))

(fn find-tool [name : Str]
  ((tool-registry ~ Cell/get) ~ Map/get name))

(fn register-tool! [t]
  (var existing (find-tool t/name))
  ((tool-registry ~ Cell/get) ~ Map/put! t/name t)
  (if (= existing void)
    (tool-names ~ Cell/set (append (tool-names ~ Cell/get) t/name))
    nil)
  (emit-event! "tool-registered" {^name t/name ^risk t/risk})
  t)

# Derived live so tools added/replaced from /repl reach the very next model
# call without re-registration ceremony.
(fn tool-schemas-now []
  ((to_stream (tool-names ~ Cell/get))
    ~ map (fn [n] ((find-tool n) ~ schema))
    ; ~ into []))

# Responses tool schemas are flat; chat nests them under ^function.
(fn chat-tool-schemas-now []
  ((to_stream (tool-schemas-now))
    ~ map (fn [t] {^type "function"
                   ^function {^name t/name
                              ^description t/description
                              ^parameters t/parameters}})
    ; ~ into []))

(register-tool! (Tool
  ^name "read_file"
  ^description "Read a UTF-8 text file inside the workspace."
  ^risk "read"
  ^params [{^name "path" ^type "string" ^required true
            ^doc "workspace-relative file path"}]
  ^handler (fn [args] (read-text ReadDir (safe-path args/path)))))

(register-tool! (Tool
  ^name "write_file"
  ^description "Write a UTF-8 text file inside the workspace."
  ^risk "write"
  ^params [{^name "path" ^type "string" ^required true
            ^doc "workspace-relative file path"}
           {^name "content" ^type "string" ^required true}]
  ^handler (fn [args]
    (if (approve? "write_file" args/path)
      (do
        (write-text WriteDir (safe-path args/path) args/content)
        $"wrote ${args/path}")
      "denied by user policy"))))

(register-tool! (Tool
  ^name "edit_file"
  ^description "Replace one exact text span in a UTF-8 text file inside the workspace."
  ^risk "write"
  ^params [{^name "path" ^type "string" ^required true
            ^doc "workspace-relative file path"}
           {^name "old_text" ^type "string" ^required true
            ^doc "exact text to replace; must match exactly once"}
           {^name "new_text" ^type "string" ^required true}]
  ^handler (fn [args]
    (var path (safe-path args/path))
    (var old-text args/old_text)
    (var new-text args/new_text)
    (if (= old-text "")
      "error: old_text must not be empty"
      (if (approve? "edit_file" args/path)
        (do
          (var text (read-text ReadDir path))
          (var parts (split text old-text))
          (var matches (- parts/~size 1))
          (if (= matches 0)
            "error: old_text not found"
            (if (> matches 1)
              $"error: old_text matched ${matches} times; provide a larger unique old_text"
              (do
                (write-text WriteDir path (join parts new-text))
                $"edited ${args/path}"))))
        "denied by user policy")))))

(register-tool! (Tool
  ^name "list_dir"
  ^description "List directory entries inside the workspace."
  ^risk "read"
  ^params [{^name "path" ^type "string" ^required false
            ^doc "workspace-relative directory; defaults to the workspace root"}]
  ^handler (fn [args]
    (var p (if (= args/path void) "." args/path))
    ((list-dir ReadDir (safe-path p)) ~ join "\n"))))

(register-tool! (Tool
  ^name "run_shell"
  ^description "Run a shell command in the workspace (10s timeout)."
  ^risk "execute"
  ^params [{^name "command" ^type "string" ^required true
            ^doc "command line passed to sh -c"}]
  ^handler (fn [args]
    (var denial (guard-shell args/command))
    (if (present? denial)
      denial
      (if (approve? "run_shell" args/command)
        (do
          (var r (await (exec-async Exec ^cmd "sh" ^args ["-c" args/command]
                            ^dir workspace-root
                            ^timeout-ms 10000 ^max-bytes 65536)))
          (var tail (if r/timed-out "\n[timed out]" ""))
          {^text $"${r/stdout}${r/stderr}${tail}"
           ^truncated (= r/truncated true)})
        "denied by user policy")))))

(register-tool! (Tool
  ^name "grep"
  ^description "Search files in the workspace with grep -rn."
  ^risk "read"
  ^params [{^name "pattern" ^type "string" ^required true}
           {^name "path" ^type "string" ^required false
            ^doc "workspace-relative directory or file; defaults to the workspace root"}]
  ^handler (fn [args]
    (var p (if (= args/path void) "." args/path))
    (var r (await (exec-async Exec ^cmd "grep"
                      ^args ["-rn" args/pattern (safe-path p)]
                      ^dir workspace-root
                      ^timeout-ms 10000 ^max-bytes 65536)))
    (var tail (if r/timed-out "\n[timed out]" ""))
    {^text $"${r/stdout}${r/stderr}${tail}"
     ^truncated (= r/truncated true)})))

# -----------------------------------------------------------------------------
# Responses-API item helpers.
# -----------------------------------------------------------------------------

(fn user-item [text : Str]
  {^role "user" ^content text})

(fn system-item [text : Str]
  {^role "system" ^content text})

(var gene-system-prompt """
You are a coding agent working in the Gene language repository. You can read,
write, and edit files, list directories, grep, and run shell commands after user
approval.

When writing Gene code, use the current repo's language, not generic Lisp:

- Programs are s-expressions. Calls are callable-first: `(f x y)`.
- Top-level forms run in order. `gene run file.gene` calls `(fn main [...])` if
  present; scripts may also do work at top level.
- Comments start with `#`. Modules may start with `(mod name @doc "...")`.
- Imports use namespace/module forms:
  `(import str [join split trim lower])`
  `(import std/stream [to_stream map filter each into])`
  `(import [foo : local] from "./module")`
- Bind with `(var name value)` or `(var name : Type value)`. Reassign existing
  bindings with `(set name value)`. Avoid redeclaring the same local name in a
  loop or branch; allocate mutable loop state once and update it.
- Functions use `(fn name [a : Type, b] : Return body...)`; anonymous functions
  use `(fn [x] body)`. The last expression is returned.
- Basic control forms: `(do ...)`, `(if cond then else)`, `(while cond ...)`,
  `(loop ...)`, `(repeat n ...)`, `(repeat i in n ...)`,
  `(for item in items ...)`, and `match` with `(when pattern ...)` and
  `(else ...)`.
  Boolean operators are `(&& a b)`, `(|| a b)`, and `(! a)`.
- Recoverable errors use `(try body catch (ErrorType ^field name) recovery
  ensure cleanup)`. Use `fail` for recoverable errors and `panic` only for fatal
  bugs.
- Data:
  - Lists: `[a b c]`
  - Maps: `{^key value}`; property access is `m/key`
  - Nodes: `(tag ^prop value child...)`; quasiquote nodes with backtick and
    unquote with `%`, for example `` `(p ^class "x" %text)``.
  - `nil` is absence, `void` means missing selector/omitted storage.
- Selectors and sends:
  - `x/key` is selector/property/index access.
  - `xs/~size` sends the `size` message to `xs`; prefer this over `size xs`
    when modeling receiver behavior.
  - `(x ~ msg arg)` sends a message; `(x ~ Protocol/msg)` disambiguates protocol
    message collisions.
  - Type-direct messages live inside `type`; protocol messages live inside
    `protocol` and are implemented with `impl`.
- Types/protocols:
  `(type T ^props {^name Str} (message label [self] self/name))`
  `(enum Color red green blue)` and `(enum Result (ok Any) (err Str))`
  `(protocol P (message render [self : Self] : Str))`
  `(impl P for T (message render [self] "..."))`
  Single data inheritance is `^is`; behavioral composition is `^inherit`.
- Streams are pull-based and skip `void`. Common shape:
  `((to_stream xs) ~ map (fn [x] ...) ; ~ filter pred ; ~ into [])`.
- Useful stdlib examples:
  - `examples/todo_app.gene` for end-to-end web + sqlite.
  - `examples/web_demo.gene` for nodes, streams, routes, selectors.
  - `examples/protocol_demo.gene` for types, protocols, inheritance, messages.
  - `docs/design.md`, `docs/core.md`, and `docs/stdlib.md` for details.

Before changing Gene code, inspect nearby examples or docs if uncertain. After
writing Gene code, verify with at least `bin/gene parse file.gene` or
`bin/gene compile file.gene`; use `bin/gene run file.gene` when behavior matters.
""")

(enum ResponseItemKind
  assistant_message
  function_call
  other_item)

(enum ResponseContentKind
  output_text
  other_content)

(enum SseEventKind
  output_text_delta
  output_item_done
  output_text_done
  completed
  failed
  incomplete
  other_event)

(fn response-item-kind [item] : ResponseItemKind
  (match item/type
    (when "message"       ResponseItemKind/assistant_message)
    (when "function_call" ResponseItemKind/function_call)
    (else                ResponseItemKind/other_item)))

(fn response-content-kind [part] : ResponseContentKind
  (match part/type
    (when "output_text" ResponseContentKind/output_text)
    (else              ResponseContentKind/other_content)))

(fn sse-event-kind [event] : SseEventKind
  (match event/type
    (when "response.output_text.delta" SseEventKind/output_text_delta)
    (when "response.output_item.done"  SseEventKind/output_item_done)
    (when "response.output_text.done"  SseEventKind/output_text_done)
    (when "response.completed"         SseEventKind/completed)
    (when "response.failed"            SseEventKind/failed)
    (when "response.incomplete"        SseEventKind/incomplete)
    (else                              SseEventKind/other_event)))

# Pull the assistant's text out of a Responses `output` list (message items ->
# content parts of type output_text).
(fn response-output-items [resp]
  (if (= resp/output void)
    []
    (try
      ((to_stream resp/output) ~ into [])
    catch * [])))

# Joined output_text parts of one assistant message item.
(fn message-item-text [item] : Str
  (var acc (cell ""))
  ((to_stream item/content)
    ~ each (fn [part]
        (if (= (response-content-kind part) ResponseContentKind/output_text)
          (Cell/set acc $"${(Cell/get acc)}${part/text}")
          nil)))
  (Cell/get acc))

(fn response-text [resp] : Str
  (if (! (= resp/output_text void))
    resp/output_text
    (do
      (var acc (cell ""))
      ((to_stream (response-output-items resp))
        ~ each (fn [item]
            (if (= (response-item-kind item) ResponseItemKind/assistant_message)
              (Cell/set acc $"${(Cell/get acc)}${(message-item-text item)}")
              nil)))
      (Cell/get acc))))

# function_call items the model emitted this turn.
(fn response-calls [resp]
  ((to_stream (response-output-items resp))
    ~ filter (fn [item] (= (response-item-kind item) ResponseItemKind/function_call))
    ; ~ into []))

# Handlers may return a plain Str or {^text Str ^truncated Bool}; normalize to
# the map shape so truncation always reaches the event log and the model. Any
# other shape (nil, a number, a map without a Str ^text — easy to produce from
# a /repl-registered tool) becomes a tool error instead of escaping into
# redact/selectors and aborting the turn.
(fn normalize-tool-result [res]
  (match res
    (when (s : Str) {^text s ^truncated false})
    (when (m : Map)
      (match m/text
        (when (t : Str) {^text t ^truncated (= m/truncated true)})
        (else {^text "error: tool returned an invalid result shape"
               ^truncated false})))
    (else {^text "error: tool returned an invalid result shape"
           ^truncated false})))

# Execute one function_call item, returning its function_call_output item.
# `emit` is the event sink (§9.2): the CLI passes its process-global logger,
# the gateway passes a per-session sink, so each session owns its own tool
# trail. The declared param schema validates arguments before the handler runs.
(fn run-tool-call [call, emit]
  (var name call/name)
  (var t (find-tool name))
  (var args (cell nil))
  (var parse-err (cell nil))
  (try
    (args ~ Cell/set (parse call/arguments))
  catch (JsonError ^message m) (parse-err ~ Cell/set m))
  (emit "tool-call"
    {^id call/call_id ^name name
     ^args (if (present? (parse-err ~ Cell/get))
             call/arguments
             (args ~ Cell/get))})
  # The guard (called inside handlers) emits confirmation events through this
  # turn's sink. Set synchronously here and cleared after the handler: the
  # guard runs before the handler's first await, so interleaved sessions
  # cannot observe each other's sink.
  (guard-emit ~ Cell/set emit)
  (var result
    (if (= t void)
      {^text $"error: unknown tool ${name}" ^truncated false}
      (if (present? (parse-err ~ Cell/get))
        {^text $"error: bad tool arguments: ${(parse-err ~ Cell/get)}"
         ^truncated false}
        # The model may send valid JSON that is not an object ([], null, "x").
        # Check the top-level kind before field validation, which sends Map/get
        # to the value, so a malformed response is a tool error, not a crash.
        (match (args ~ Cell/get)
          (when (m : Map)
            (do
              (var verr (t ~ validate-args m))
              (if (present? verr)
                {^text $"error: ${verr}" ^truncated false}
                (do
                  (var h t/handler)
                  (try
                    (normalize-tool-result (h m))
                  catch (OsError ^message em)
                    {^text $"error: ${em}" ^truncated false}
                  catch *
                    {^text "error: tool failed" ^truncated false})))))
          (else
            {^text "error: tool arguments must be a JSON object" ^truncated false})))))
  (guard-emit ~ Cell/set nil)
  (var truncated (= result/truncated true))
  # Surface truncation in both the transcript and the model-visible output
  # (§8.5), and redact before the output re-enters the model transcript: a
  # tool like run_shell can echo the environment, and the raw API token must
  # never leak back into the next request.
  (var shown
    (if truncated $"${result/text}\n[output truncated]" result/text))
  (emit "tool-result"
    {^id call/call_id ^name name ^value shown ^truncated truncated})
  {^type "function_call_output" ^call_id call/call_id ^output (redact shown)})

# -----------------------------------------------------------------------------
# Transport. Live mode shells out to curl; demo mode uses a scripted closure.
# Both take a request-body string and return a parsed Responses map.
# curl runs on a dedicated thread (os/exec-stream-async) with stdout lines
# drained from a channel, so the scheduler — other sessions, the gateway's
# HTTP loop — stays live during a model call (docs/ai-agent.md §12.9 gap 1).
# -----------------------------------------------------------------------------

(fn exec-curl-lines [curl-args, timeout-ms, on-line]
  (var ch (channel ^capacity 256))
  (var t (exec-stream-async Exec ^cmd "curl" ^args curl-args
                            ^timeout-ms timeout-ms ^max-bytes 4000000
                            ^stdout-chan ch))
  (var line nil)
  (try
    (loop
      (set line (ch ~ Channel/recv))
      (on-line line))
  catch (ChannelClosed) nil)
  (await t))

(fn api-error-text [resp]
  (var status (if (= resp/status void) "?" resp/status))
  (var message
    (if (= resp/error/message void)
      (if (= resp/detail void) "unknown API error" resp/detail)
      resp/error/message))
  (var code (if (= resp/error/code void) "" $" (${resp/error/code})"))
  $"OpenAI API error ${status}: ${message}${code}")

# Strip one leading "data: " prefix. Rejoin the remaining pieces so a payload
# that itself contains "data: " (e.g. a streamed code snippet) survives intact.
(fn sse-data-payload [line : Str]
  (if (starts_with? line "data: ")
    (do
      (var parts (split line "data: "))
      (var i (cell 0))
      (var acc (cell ""))
      ((to_stream parts)
        ~ each (fn [p]
            (var n (Cell/get i))
            (Cell/set i (+ n 1))
            (if (= n 0)
              nil
              (if (= n 1)
                (Cell/set acc p)
                (Cell/set acc $"${(Cell/get acc)}data: ${p}")))))
      (Cell/get acc))
    nil))

(fn ignore-stream-delta [text]
  nil)

(fn sse-build-response [output, output-text, final]
  (if (= (Cell/get final) nil)
    {^output (Cell/get output) ^output_text (Cell/get output-text)}
    (do
      ((Cell/get final) ~ Map/put! "output" (Cell/get output))
      ((Cell/get final) ~ Map/put! "output_text" (Cell/get output-text))
      (Cell/get final))))

(fn sse-handle-payload [payload : Str, output, output-text, final, render-stream]
  (if (= payload "[DONE]")
    nil
    (try
      (var event (parse payload))
      (match (sse-event-kind event)
        (when SseEventKind/output_text_delta
          (render-stream (redact event/delta))
          (Cell/set output-text $"${(Cell/get output-text)}${event/delta}"))
        (when SseEventKind/output_item_done
          (Cell/set output (append (Cell/get output) event/item))
          nil)
        (when SseEventKind/output_text_done
          (Cell/set output-text event/text))
        (when SseEventKind/completed
          (Cell/set final event/response))
        (when SseEventKind/failed
          (Cell/set final event/response))
        (when SseEventKind/incomplete
          (Cell/set final event/response))
        (when SseEventKind/other_event
          nil))
    catch (JsonError ^message _) nil)))

(fn sse-handle-line [line : Str, output, output-text, final, render-stream]
  (var payload (sse-data-payload line))
  (if (= payload nil)
    nil
    (if (= payload void)
      nil
      (sse-handle-payload payload output output-text final render-stream))))

(fn sse-response [raw : Str]
  (var output (cell []))
  (var output-text (cell ""))
  (var final (cell nil))
  ((to_stream (split raw "\n"))
    ~ each (fn [line]
        (sse-handle-line line output output-text final ignore-stream-delta)))
  (sse-build-response output output-text final))

(fn responses-live-transport [body : Str, render-stream]
  (var output (cell []))
  (var output-text (cell ""))
  (var final (cell nil))
  (var saw-sse (cell false))
  (var curl-args ["-sS" "-N" "-X" "POST" $"${base}/responses"
                  "-H" $"Authorization: Bearer ${auth-token}"
                  "-H" "Content-Type: application/json"
                  "-H" "Accept: text/event-stream"])
  (if (= base codex-base)
    (set curl-args (append-all curl-args
      ["-H" "User-Agent: codex_cli_rs/0.0.0 (Gene AI Agent)"
       "-H" "originator: codex_cli_rs"]))
    nil)
  (set curl-args (append-all curl-args ["-d" body]))
  (var r (exec-curl-lines curl-args 60000
               (fn [line]
                 (if (|| (starts_with? line "event:")
                         (starts_with? line "data:"))
                   (Cell/set saw-sse true)
                   nil)
                 (sse-handle-line line output output-text final render-stream))))
  (if (! (= r/status 0))
    {^agent_error (redact $"curl failed (${r/status}): ${r/stderr}")}
    (do
      (var resp
        (if (Cell/get saw-sse)
          (sse-build-response output output-text final)
          (try
            (parse r/stdout)
          catch (JsonError ^message m)
            {^agent_error (redact $"OpenAI API returned invalid JSON: ${m}")})))
      (if (= resp/error void)
        (if (= resp/status "failed")
          {^agent_error (redact (api-error-text resp))}
          resp)
        (if (= resp/error nil)
          (if (= resp/status "failed")
            {^agent_error (redact (api-error-text resp))}
            resp)
          {^agent_error (redact (api-error-text resp))})))))

# -----------------------------------------------------------------------------
# Chat Completions wire shape, for OpenAI-compatible endpoints (MiniMax,
# DeepSeek, vLLM, api.openai.com, ...). Internally the agent still works on
# Responses-style items; this layer converts on the way out (items -> messages)
# and normalizes on the way in (choices/deltas -> items), so run-turn and the
# tool loop are shared between both flavors.
# -----------------------------------------------------------------------------

# Convert the item transcript into chat messages. A run of assistant text /
# function_call items becomes ONE assistant message (content + tool_calls), so
# every role:"tool" message follows the assistant message that requested it —
# the ordering chat endpoints validate.
(fn items-to-chat-messages [items]
  (var msgs (cell []))
  (var pending-text (cell nil))
  (var pending-calls (cell []))
  (fn flush-assistant []
    (if (|| (present? (Cell/get pending-text))
            (! (empty? (Cell/get pending-calls))))
      (do
        (var m {^role "assistant" ^content (Cell/get pending-text)})
        (if (empty? (Cell/get pending-calls))
          nil
          (m ~ Map/put! "tool_calls" (Cell/get pending-calls)))
        (Cell/set msgs (append (Cell/get msgs) m))
        (Cell/set pending-text nil)
        (Cell/set pending-calls []))
      nil))
  (for item in items
    (if (= item/type void)
      (do
        (flush-assistant)
        (Cell/set msgs (append (Cell/get msgs) item)))
      (match item/type
        (when "message"
          (var sofar (if (present? (Cell/get pending-text)) (Cell/get pending-text) ""))
          (Cell/set pending-text $"${sofar}${(message-item-text item)}"))
        (when "function_call"
          (Cell/set pending-calls (append (Cell/get pending-calls)
            {^id item/call_id ^type "function"
             ^function {^name item/name ^arguments item/arguments}})))
        (when "function_call_output"
          (flush-assistant)
          (Cell/set msgs (append (Cell/get msgs)
            {^role "tool" ^tool_call_id item/call_id ^content item/output})))
        (else nil))))
  (flush-assistant)
  (Cell/get msgs))

(fn chat-api-error [resp]
  (if (present? resp/error)
    (api-error-text resp)
    # MiniMax-style envelope: base_resp/status_code != 0 signals an error.
    (if (&& (present? resp/base_resp/status_code)
            (! (= resp/base_resp/status_code 0)))
      $"API error ${resp/base_resp/status_code}: ${resp/base_resp/status_msg}"
      nil)))

# Streamed tool calls arrive as fragments keyed by ^index: the first carries
# id/name, the rest append argument text. Accumulate into mutable maps.
(fn chat-note-call-frag [calls-map, max-cell, frag]
  (var idx (if (present? frag/index) frag/index 0))
  (var key $"${idx}")
  (var entry (calls-map ~ Map/get key))
  (if (= entry void)
    (do
      (set entry {^id "" ^name "" ^arguments ""})
      (calls-map ~ Map/put! key entry)
      (if (< (Cell/get max-cell) (+ idx 1))
        (Cell/set max-cell (+ idx 1))
        nil))
    nil)
  (if (present? frag/id)
    (entry ~ Map/put! "id" frag/id)
    nil)
  (if (present? frag/function/name)
    (entry ~ Map/put! "name" $"${entry/name}${frag/function/name}")
    nil)
  (if (present? frag/function/arguments)
    (entry ~ Map/put! "arguments" $"${entry/arguments}${frag/function/arguments}")
    nil))

(fn chat-call-items [calls-map, max-cell]
  (var items (cell []))
  (repeat i in (Cell/get max-cell)
    (var entry (calls-map ~ Map/get $"${i}"))
    (if (= entry void)
      nil
      (Cell/set items (append (Cell/get items)
        {^type "function_call" ^name entry/name
         ^call_id entry/id ^arguments entry/arguments}))))
  (Cell/get items))

(fn chat-build-response [text-cell, calls-map, max-cell]
  (var items (cell (chat-call-items calls-map max-cell)))
  (if (= (Cell/get text-cell) "")
    nil
    (Cell/set items
      ((to_stream (Cell/get items))
        ~ into [{^type "message" ^role "assistant"
                 ^content [{^type "output_text" ^text (Cell/get text-cell)}]}])))
  {^output (Cell/get items) ^output_text (Cell/get text-cell)})

(fn chat-handle-payload [payload : Str, text-cell, calls-map, max-cell, err-cell, render-stream]
  (if (= payload "[DONE]")
    nil
    (try
      (var chunk (parse payload))
      (var errtext (chat-api-error chunk))
      (if (present? errtext)
        (Cell/set err-cell errtext)
        (do
          (var delta chunk/choices/0/delta)
          (if (present? delta/content)
            (do
              (render-stream (redact delta/content))
              (Cell/set text-cell $"${(Cell/get text-cell)}${delta/content}"))
            nil)
          (if (present? delta/tool_calls)
            ((to_stream delta/tool_calls)
              ~ each (fn [frag] (chat-note-call-frag calls-map max-cell frag)))
            nil)))
    catch (JsonError ^message _) nil)))

# Non-streaming (or error) chat body: normalize choices/0/message into items.
(fn chat-response-from-json [resp]
  (var errtext (chat-api-error resp))
  (if (present? errtext)
    {^agent_error (redact errtext)}
    (do
      (var message resp/choices/0/message)
      (var text (if (present? message/content) message/content ""))
      (var items (cell []))
      (if (= text "")
        nil
        (Cell/set items (append (Cell/get items)
          {^type "message" ^role "assistant"
           ^content [{^type "output_text" ^text text}]})))
      (if (present? message/tool_calls)
        ((to_stream message/tool_calls)
          ~ each (fn [tc]
              (Cell/set items (append (Cell/get items)
                {^type "function_call" ^name tc/function/name
                 ^call_id tc/id ^arguments tc/function/arguments}))))
        nil)
      {^output (Cell/get items) ^output_text text})))

(fn chat-live-transport [body : Str, render-stream]
  (var text (cell ""))
  (var calls {})
  (var callmax (cell 0))
  (var err (cell nil))
  (var saw-sse (cell false))
  (var r (exec-curl-lines
               ["-sS" "-N" "-X" "POST" $"${base}/chat/completions"
                "-H" $"Authorization: Bearer ${auth-token}"
                "-H" "Content-Type: application/json"
                "-H" "Accept: text/event-stream"
                "-d" body]
               120000
               (fn [line]
                 (if (|| (starts_with? line "event:")
                         (starts_with? line "data:"))
                   (Cell/set saw-sse true)
                   nil)
                 (var payload (sse-data-payload line))
                 (if (|| (= payload nil) (= payload void))
                   nil
                   (chat-handle-payload payload text calls callmax err render-stream)))))
  (if (! (= r/status 0))
    {^agent_error (redact $"curl failed (${r/status}): ${r/stderr}")}
    (if (present? (Cell/get err))
      {^agent_error (redact (Cell/get err))}
      (if (Cell/get saw-sse)
        (chat-build-response text calls callmax)
        (try
          (chat-response-from-json (parse r/stdout))
        catch (JsonError ^message m)
          {^agent_error (redact $"API returned invalid JSON: ${m}")})))))

(var live-transport
  (if (= api-flavor "chat") chat-live-transport responses-live-transport))

(fn call-model [transport, input-items, render-stream]
  (var body
    (if (= api-flavor "chat")
      (stringify {^model model
                  ^messages (items-to-chat-messages input-items)
                  ^tools (chat-tool-schemas-now)
                  ^tool_choice "auto"
                  ^stream true})
      (stringify {^model model
                  ^store false
                  ^stream true
                  ^input input-items
                  ^tools (tool-schemas-now)
                  ^tool_choice "auto"
                  ^parallel_tool_calls true})))
  (transport body render-stream))

(var max-tool-turns 12)

# One turn: call the model; if it asked for tools, run them and recurse with the
# outputs appended, else render the final text. `budget` bounds tool rounds so a
# model that never stops calling tools cannot loop forever. `emit` is the event
# sink (§9.2): CLI passes its global logger, gateway passes a per-session sink.
# `turn-done` fires once, at the outermost completion (each terminal branch
# returns without recursing; the tool-call branch recurses and does not emit it).
(fn run-turn [transport, input-items, render, render-stream, budget, emit]
  (var streamed (cell false))
  (var resp (call-model transport input-items
              (fn [text]
                (Cell/set streamed true)
                # Redact at this choke point (transports also redact — belt
                # and braces for any future transport) and emit the delta
                # through the sink so /trace and subscriptions see text-delta
                # events; the gateway sink skips them to avoid double-logging.
                (var safe (redact text))
                (emit "text-delta" {^text safe})
                (render-stream safe))))
  (if (! (= resp/agent_error void))
    (do
      (emit "error" {^text resp/agent_error})
      (render resp/agent_error)
      (emit "turn-done" {})
      input-items)
    (do
      (each (to_stream (response-output-items resp))
        (fn [item] (emit "model-item" {^item item})))
      (var calls (response-calls resp))
      (if (empty? calls)
        (do
          (emit "agent-text" {^text (response-text resp)})
          (if (Cell/get streamed)
            (render "")
            (render (redact (response-text resp))))
          (emit "turn-done" {^text (response-text resp)})
          # Retain the final assistant message in the conversation so the next
          # turn can see what the agent just said (mirrors the tool-call path,
          # which already appends resp's output items).
          (append-all input-items (response-output-items resp)))
        (if (<= budget 0)
          (do
            (render "[stopped: tool-call budget exhausted]")
            (emit "turn-done" {})
            input-items)
          (do
            (var outputs ((to_stream calls) ~ map (fn [c] (run-tool-call c emit)) ; ~ into []))
            (each (to_stream calls) (fn [c]
              (render $"  · tool ${c/name} ${c/arguments}")))
            (run-turn transport
                      ((to_stream outputs) ~ into (append-all input-items (response-output-items resp)))
                      render
                      render-stream
                      (- budget 1)
                      emit)))))))

# -----------------------------------------------------------------------------
# Optional local persistence. `GENE_AGENT_STATE=<dir>` enables a filesystem
# Store with four data records:
#   config  — non-secret runtime config
#   session — current interactive transcript and Responses-style items
#   memory  — user-managed durable notes included in the system prompt
#   events  — the versioned event log (§9.2) plus its version/turn counters
# -----------------------------------------------------------------------------

(var agent-store (cell nil))

(fn state-enabled? []
  (! (= (trim agent-state-dir) "")))

(fn resume-enabled? []
  (flag-enabled? agent-resume))

(fn init-agent-state []
  (if (|| (! (state-enabled?))
          (! (= (agent-store ~ Cell/get) nil)))
    nil
    (try
      (agent-store ~ Cell/set (store-open ReadWriteDir ^root agent-state-dir))
    catch (StoreError ^message m)
      (println $"agent state disabled: ${m}")
    catch *
      (println "agent state disabled: could not open store"))))

(fn state-put [key : Str, value]
  (if (= (agent-store ~ Cell/get) nil)
    nil
    (try
      ((agent-store ~ Cell/get) ~ put key value)
    catch (StoreError ^message m)
      (println $"agent state save failed (${key}): ${m}")
    catch *
      (println $"agent state save failed (${key})"))))

(fn state-get [key : Str, default]
  (if (= (agent-store ~ Cell/get) nil)
    default
    (try
      ((agent-store ~ Cell/get) ~ get key ^default default)
    catch (StoreError ^message m)
      (do
        (println $"agent state load failed (${key}): ${m}")
        default)
    catch *
      default)))

(fn config-snapshot []
  {^model model
   ^base base
   ^api-flavor api-flavor
   ^workspace-root workspace-root
   ^approve-all approve-all
   ^max-tool-turns max-tool-turns})

(fn save-config []
  (state-put "config" (config-snapshot)))

(fn prompt-with-memory [memory]
  (if (empty? memory)
    gene-system-prompt
    (do
      (var sep "\n")
      $"${gene-system-prompt}\n\nPersistent memory:\n${(join memory sep)}\n")))

(fn initial-items [memory]
  [(system-item (prompt-with-memory memory))])

(fn refresh-system-memory [items, memory]
  (var out (cell []))
  (var i (cell 0))
  (for item in items
    (if (= (i ~ Cell/get) 0)
      (out ~ Cell/set
        (append (out ~ Cell/get) (system-item (prompt-with-memory memory))))
      (out ~ Cell/set (append (out ~ Cell/get) item)))
    (i ~ Cell/set (+ (i ~ Cell/get) 1)))
  (if (= (i ~ Cell/get) 0)
    (initial-items memory)
    (out ~ Cell/get)))

(fn load-memory []
  (state-get "memory" []))

(fn load-session []
  (if (resume-enabled?)
    (state-get "session" nil)
    nil))

(fn save-agent-state [items, transcript, memory]
  (save-config)
  (state-put "memory" memory)
  (state-put "events" {^events (agent-events ~ Cell/get)
                       ^next-v (next-event-v ~ Cell/get)
                       ^turn (current-turn ~ Cell/get)})
  (state-put "session" {^items items ^transcript transcript}))

(fn restore-events []
  (var saved (state-get "events" nil))
  (if (= saved nil)
    nil
    (do
      (agent-events ~ Cell/set saved/events)
      (next-event-v ~ Cell/set saved/next-v)
      (current-turn ~ Cell/set saved/turn))))

(fn after-prefix [s : Str, prefix : Str] : Str
  (var parts (split s prefix))
  (var i (cell 0))
  (var acc (cell ""))
  ((to_stream parts)
    ~ each (fn [p]
        (var n (i ~ Cell/get))
        (i ~ Cell/set (+ n 1))
        (if (= n 0)
          nil
          (if (= n 1)
            (acc ~ Cell/set p)
            (acc ~ Cell/set $"${(acc ~ Cell/get)}${prefix}${p}")))))
  (acc ~ Cell/get))

# -----------------------------------------------------------------------------
# Offline demo transport: turn 1 asks to list the workspace, turn 2 answers.
# Proves the full tool-call loop with no network or key.
# -----------------------------------------------------------------------------

(fn demo-transport-for []
  (var calls (cell 0))
  (fn [body, render-stream]
    (Cell/set calls (+ (Cell/get calls) 1))
    (if (= (Cell/get calls) 1)
      {^output [{^type "function_call" ^name "list_dir"
                 ^call_id "call_1" ^arguments "{\"path\":\".\"}"}]}
      {^output [{^type "message" ^role "assistant"
                 ^content [{^type "output_text"
                            ^text "I listed the workspace via the list_dir tool."}]}]})))

# -----------------------------------------------------------------------------
# Entry point.
# -----------------------------------------------------------------------------

(fn run-demo []
  (println "No OPENAI_AUTH_TOKEN, OPENAI_API_KEY, or CODEX_ACCESS_TOKEN set — running the offline demo.")
  (println "user> what's in this directory?")
  (begin-turn!)
  (emit-event! "user-input" {^text "what's in this directory?"})
  (var items [(system-item gene-system-prompt)
              (user-item "what's in this directory?")])
  (run-turn (demo-transport-for) items
    (fn [text] (println $"agent> ${text}"))
    ignore-stream-delta
    max-tool-turns
    emit-event!)
  (println "Demo complete. Set OPENAI_AUTH_TOKEN, OPENAI_API_KEY, or CODEX_ACCESS_TOKEN to go live."))

(fn run-one-shot [task : Str]
  (init-agent-state)
  (save-config)
  (println $"Gene AI agent - model ${model}")
  (println $"user> ${task}")
  (if (= auth-token nil)
    (println "No OPENAI_AUTH_TOKEN, OPENAI_API_KEY, or CODEX_ACCESS_TOKEN set - using offline demo transport.")
    nil)
  (var streaming (cell false))
  (var transport (if (= auth-token nil) (demo-transport-for) live-transport))
  (var memory (load-memory))
  (begin-turn!)
  (emit-event! "user-input" {^text task})
  (var result-items
    (run-turn transport
              (append (initial-items memory) (user-item task))
              (fn [text]
                (if (Cell/get streaming)
                  (do
                    (println "")
                    (Cell/set streaming false))
                  nil)
                (if (= text "")
                  nil
                  (println $"agent> ${text}")))
              (fn [text]
                (if (= text "")
                  nil
                  (do
                    (if (Cell/get streaming)
                      nil
                      (do
                        (print "agent> ")
                        (Cell/set streaming true)))
                    (print text))))
              max-tool-turns
              emit-event!))
  (save-agent-state result-items $"Gene AI agent - model ${model}\nuser> ${task}\n" memory)
  (if (Cell/get streaming)
    (println "")
    nil))

(fn exit-word? [line]
  (|| (= line "exit") (= line "quit")))

(fn blank-line? [line]
  (= (trim line) ""))

(fn append-transcript [transcript text]
  (Cell/set transcript (join [(Cell/get transcript) text] "")))

(var input-status "Enter sends | /remember note | /memory | /status | /trace | /sh | /repl | /quit")

(fn close-user-input []
  (if (stdin-tty?)
    (close-input)
    nil))

(fn read-user-input [transcript]
  (if (stdin-tty?)
    (read-input ^prompt "" ^multiline true
                ^persistent true
                ^output (Cell/get transcript)
                ^status input-status)
    (do
      (print "you> ")
      (read-line))))

(fn refresh-user-input [transcript]
  (if (stdin-tty?)
    (refresh-input ^prompt "" ^output (Cell/get transcript) ^status input-status)
    nil))

(fn render-agent-delta [transcript streaming text]
  (if (= text "")
    nil
    (do
      (if (Cell/get streaming)
        nil
        (do
          (append-transcript transcript "agent> ")
          (if (stdin-tty?)
            nil
            (print "agent> "))
          (Cell/set streaming true)))
      (append-transcript transcript text)
      (if (stdin-tty?)
        (refresh-user-input transcript)
        (print text)))))

(fn finish-agent-stream [transcript streaming]
  (if (Cell/get streaming)
    (do
      (append-transcript transcript "\n")
      (if (stdin-tty?)
        (refresh-user-input transcript)
        (println ""))
      (Cell/set streaming false))
    nil))

(fn render-agent-text [transcript streaming text]
  (finish-agent-stream transcript streaming)
  (if (= text "")
    nil
    (do
      (append-transcript transcript $"agent> ${text}\n")
      (if (stdin-tty?)
        (refresh-user-input transcript)
        (println $"agent> ${text}")))))

(fn run-shell-session []
  (close-user-input)
  (var shell (get-env Env "SHELL" "sh"))
  (println $"Entering shell (${shell}). Ctrl-C stops the running command or clears the line; exit/quit or Ctrl-D returns.")
  (if (stdin-tty?)
    (do
      # Ctrl-C: the trap marks the interrupt, so a failed read reprompts
      # (cleared line) instead of exiting; a running command just dies and the
      # loop continues. EOF (read fails without the mark) exits the session.
      (var script "intr=0; trap 'intr=1; printf \"\\n\"' INT; while true; do printf 'sh> '; intr=0; IFS= read -r line; rc=$?; if [ $rc -ne 0 ]; then if [ $intr -eq 1 ]; then continue; fi; break; fi; case \"$line\" in exit|quit) break;; *) eval \"$line\";; esac; done")
      (exec-stdio Exec ^cmd shell ^args ["-c" script] ^dir workspace-root)
      (println "")
      nil)
    (do
      # Scripted (piped) /sh: unlike the interactive TTY loop, we read each
      # line in Gene, so route it through the same catastrophe guard as
      # model-issued run_shell (§8.5) before executing.
      (var running (cell true))
      (var line nil)
      (var r nil)
      # Hoisted: re-`var` inside a while body is a duplicate binding on the
      # second iteration, so allocate loop state once and `set` it.
      (var denial nil)
      (while (Cell/get running)
        (print "sh> ")
        (set line (read-line))
        (if (= line nil)
          (Cell/set running false)
          (if (exit-word? line)
            (Cell/set running false)
            (do
              (set denial (guard-shell line))
              (if (present? denial)
                (println denial)
                (do
                  (set r (exec Exec ^cmd shell ^args ["-lc" line] ^dir workspace-root
                             ^timeout-ms 60000 ^max-bytes 400000))
                  (print (redact r/stdout))
                  (print (redact r/stderr))
                  (if r/timed-out
                    (println "[timed out]")
                    nil)))))))
      (println ""))))

# Stable live session object (§9.1). Projections are props holding the live
# cells and registry; mutations go through messages so the session can keep
# invariants (system-prompt memory refresh, persistence) and append an audit
# event. `current-task` and `evidence` projections arrive with slice B.
(type Session
  ^props {^items Any ^transcript Any ^memory Any ^tools Any ^events Any
          ^config Any ^workspace Any ^resume-requested Any}

  # Register (or replace) a typed Tool; it reaches the next model call.
  (message add-tool [self, t]
    (register-tool! t)
    $"tool ${t/name} registered")

  # Durable note: memory list + system prompt + persisted state stay in sync.
  (message remember [self, note : Str]
    (self/memory ~ Cell/set (append (self/memory ~ Cell/get) note))
    (self/items ~ Cell/set
      (refresh-system-memory (self/items ~ Cell/get) (self/memory ~ Cell/get)))
    (emit-event! "memory" {^text note})
    (save-agent-state (self/items ~ Cell/get)
                      (self/transcript ~ Cell/get)
                      (self/memory ~ Cell/get))
    $"remembered: ${note}")

  # Echo future events of this type into the transcript as they are emitted.
  (message subscribe [self, type]
    (var t $"${type}")
    (event-subscriptions ~ Cell/set
      (append (event-subscriptions ~ Cell/get) t))
    $"subscribed to ${t} events")

  # Query the event log with the same filters as /trace.
  (message trace [self, filters : Str]
    (trace-report filters))

  # Ask the agent to run another model turn on the current items (no new user
  # input) right after the REPL exits — the add-a-tool-and-continue flow.
  (message resume [self]
    (self/resume-requested ~ Cell/set true)
    "resume requested: exit the REPL (exit/quit) to continue the current turn"))

# Returns true when the user asked to continue the turn after the REPL.
(fn run-session-repl [items, transcript, memory]
  (close-user-input)
  (var resume-flag (cell false))
  (var session (Session ^items items
                        ^transcript transcript
                        ^memory memory
                        ^tools tool-registry
                        ^events agent-events
                        ^config (config-snapshot)
                        ^workspace workspace-real
                        ^resume-requested resume-flag))
  # classify-command is bound so the guard's classification of dangerous
  # strings can be inspected (and tested) without ever executing them.
  (var repl-env (env ^bindings {^session session ^Tool Tool
                                ^classify-command classify-command}))
  (println "Entering Gene REPL. `session` is bound: session/items session/events (session ~ add-tool (Tool ...)) (session ~ remember \"...\") (session ~ subscribe \"tool-call\") (session ~ trace \"type=tool-call\") (session ~ resume). Ctrl-C stops the running eval or clears the line; exit/quit or Ctrl-D returns.")
  (run-repl-session repl-env ^interactive true)
  (resume-flag ~ Cell/get))

(fn run-repl []
  (init-agent-state)
  (save-config)
  (println $"Gene AI agent - model ${model}. Type /quit to exit.")
  (var memory (cell (load-memory)))
  (var saved (load-session))
  (if (= saved nil)
    nil
    (restore-events))
  (var items
    (cell
      (if (= saved nil)
        (initial-items (memory ~ Cell/get))
        (refresh-system-memory saved/items (memory ~ Cell/get)))))
  (var transcript
    (cell
      (if (= saved nil)
        $"Gene AI agent - model ${model}\n"
        saved/transcript)))
  (var running (cell true))
  (var line nil)
  (var streaming (cell false))
  # Subscribed event types echo into the transcript as they are emitted.
  (event-echo ~ Cell/set
    (fn [text] (render-agent-text transcript streaming $"[event] ${text}")))
  (if (! (= saved nil))
    (do
      (append-transcript transcript $"[restored session from ${agent-state-dir}]\n")
      (refresh-user-input transcript))
    nil)
  (while (Cell/get running)
    (set line (read-user-input transcript))
    (if (= line nil)
      (do
        (close-user-input)
        (save-agent-state (items ~ Cell/get)
                          (transcript ~ Cell/get)
                          (memory ~ Cell/get))
        (Cell/set running false))
      (if (blank-line? line)
        nil
        (do
          # Keep submitted commands in the visible/persisted transcript just
          # like model-bound user input. Slash commands are handled locally,
          # but they are still input from the user.
          (append-transcript transcript $"──────\n${line}\n")
          (refresh-user-input transcript)
          (if (= line "/quit")
            (do
              (close-user-input)
              (save-agent-state (items ~ Cell/get)
                                (transcript ~ Cell/get)
                                (memory ~ Cell/get))
              (Cell/set running false))
            (if (= line "/sh")
              (run-shell-session)
              (if (= line "/repl")
                (if (run-session-repl items transcript memory)
                  (do
                    # (session ~ resume): continue the current turn with the
                    # (possibly reshaped) items — no new user input item.
                    (Cell/set streaming false)
                    (items ~ Cell/set
                      (run-turn live-transport
                                (items ~ Cell/get)
                                (fn [text]
                                  (render-agent-text transcript streaming text))
                                (fn [text]
                                  (render-agent-delta transcript streaming text))
                                max-tool-turns
                                emit-event!))
                    (save-agent-state (items ~ Cell/get)
                                      (transcript ~ Cell/get)
                                      (memory ~ Cell/get)))
                  nil)
                (if (= line "/memory")
                  (do
                    (var sep "\n")
                    (render-agent-text transcript streaming
                      (if (empty? (memory ~ Cell/get))
                        "memory is empty"
                        $"memory:\n${(join (memory ~ Cell/get) sep)}")))
                  (if (= line "/forget-memory")
                    (do
                      (memory ~ Cell/set [])
                      (items ~ Cell/set
                        (refresh-system-memory (items ~ Cell/get)
                                               (memory ~ Cell/get)))
                      (save-agent-state (items ~ Cell/get)
                                        (transcript ~ Cell/get)
                                        (memory ~ Cell/get))
                      (render-agent-text transcript streaming "memory cleared"))
                    (if (starts_with? line "/remember ")
                      (do
                        (var note (trim (after-prefix line "/remember ")))
                        (if (= note "")
                          (render-agent-text transcript streaming
                            "usage: /remember <note>")
                          (do
                            (memory ~ Cell/set (append (memory ~ Cell/get) note))
                            (items ~ Cell/set
                              (refresh-system-memory (items ~ Cell/get)
                                                     (memory ~ Cell/get)))
                            (save-agent-state (items ~ Cell/get)
                                              (transcript ~ Cell/get)
                                              (memory ~ Cell/get))
                            (render-agent-text transcript streaming
                              $"remembered: ${note}"))))
                      (if (= line "/status")
                        (do
                          (var state-label
                            (if (= (agent-store ~ Cell/get) nil)
                              "off"
                              agent-state-dir))
                          (var item-count ((items ~ Cell/get) ~ size))
                          (var memory-count ((memory ~ Cell/get) ~ size))
                          (var event-count ((agent-events ~ Cell/get) ~ size))
                          (var guard-label (if (guard-enabled?) "on" "off"))
                          (render-agent-text transcript streaming
                            $"state: ${state-label}\nmodel: ${model}\napi: ${api-flavor}\nitems: ${item-count}\nmemory: ${memory-count}\nevents: ${event-count}\nguard: ${guard-label}"))
                        (if (|| (= line "/trace") (starts_with? line "/trace "))
                          (render-agent-text transcript streaming
                            (trace-report
                              (if (= line "/trace")
                                ""
                                (after-prefix line "/trace "))))
                          (do
                            (Cell/set streaming false)
                            (begin-turn!)
                            (emit-event! "user-input" {^text line})
                            (Cell/set items
                              (run-turn live-transport
                                        (append (Cell/get items) (user-item line))
                                        (fn [text]
                                          (render-agent-text transcript streaming text))
                                        (fn [text]
                                          (render-agent-delta transcript streaming text))
                                        max-tool-turns
                                        emit-event!))
                            (save-agent-state (items ~ Cell/get)
                                              (transcript ~ Cell/get)
                                              (memory ~ Cell/get))))))))))))))))

# `gene run` auto-invokes a top-level `main` (src/gene.nim), so no explicit call.
(fn main [args]
  (var task args/raw)
  (if (blank-line? task)
    (if (= auth-token nil)
      (run-demo)
      (try
        (run-repl)
        ensure
          (close-user-input)))
    (run-one-shot task)))
