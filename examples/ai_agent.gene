#!/usr/bin/env gene run
# =============================================================================
# Gene AI coding agent — MVP (docs/ai-agent.md milestones 1-4).
#
#   * Talks to Codex's ChatGPT-account Responses backend, streaming.
#   * Transport is `curl` shelled out through os/exec-stream.
#   * Tools: read_file / write_file / edit_file / list_dir / run_shell, each run
#     under the §8.5 safety contract (workspace-root confinement, path
#     normalization, timeout + output caps, secret redaction).
#   * Ncurses-backed prompt on TTY; paste and Shift+Enter/Alt+Enter keep newlines.
#
# Run live:   OPENAI_AUTH_TOKEN=... gene run examples/ai_agent.gene
# Auto-approve tools: GENE_AGENT_APPROVE_ALL=1 (or legacy GENE_AGENT_YOLO=1)
# Run demo:   gene run examples/ai_agent.gene         (no token -> offline demo
#             that drives the same loop with a scripted transport, incl. a
#             tool-call round trip — needs no network)
#
# Auth is a Codex/ChatGPT OAuth bearer token from `OPENAI_AUTH_TOKEN` or
# `CODEX_ACCESS_TOKEN`, sent to chatgpt.com/backend-api/codex.
# =============================================================================

(mod ai-agent
  @doc "a terminal coding agent over the OpenAI Responses API")

(import os [get-env env? exec exec-stream exec-stdio stdin-tty? read-line read-input refresh-input close-input Env Exec OsError])
(import json [parse stringify JsonError])
(import str [join split starts_with? contains? lower trim])
(import std/stream [to_stream map filter into each])
(import Fs [read-text write-text list-dir ReadDir WriteDir])
(import repl [run : run-repl-session])

# -----------------------------------------------------------------------------
# Config (all from the environment; nothing hard-coded).
# -----------------------------------------------------------------------------

(var auth-token (env? Env "OPENAI_AUTH_TOKEN"))
(if (= auth-token nil)
  (set auth-token (env? Env "CODEX_ACCESS_TOKEN")))
(var base    (get-env Env "OPENAI_BASE_URL" "https://chatgpt.com/backend-api/codex"))
(var model   (get-env Env "OPENAI_MODEL" "gpt-5.4-mini"))
(var workspace-root ".")
(var yolo (get-env Env "GENE_AGENT_YOLO" "0"))
(var approve-all (get-env Env "GENE_AGENT_APPROVE_ALL" yolo))

# -----------------------------------------------------------------------------
# §8.5 safety contract.
# -----------------------------------------------------------------------------

(fn replace-all [s : Str, from : Str, to : Str] : Str
  ((split s from) ~ join to))

# Never let the API token surface in transcript, logs, or errors.
(fn redact [s : Str] : Str
  (if (= auth-token nil)
    s
    (replace-all s auth-token "auth-***REDACTED***")))

# Confine every file path to the workspace root. Conservative primitive: reject
# absolute paths and any `..` segment (a production build should realpath and
# prefix-check against the resolved root — see docs/ai-agent.md §8.5).
(fn safe-path [p : Str] : Str
  (if (starts_with? p "/")
    (fail $"unsafe path rejected (absolute): ${p}")
    (if (contains? p "..")
      (fail $"unsafe path rejected (escapes workspace): ${p}")
      p)))

(fn denied-command? [cmd : Str]
  (|| (contains? cmd "rm -rf")
      (contains? cmd "curl ")
      (contains? cmd "wget ")
      (contains? cmd "nc ")))

(fn flag-enabled? [value : Str]
  (var v (lower (trim value)))
  (|| (= v "1")
      (= v "true")
      (= v "yes")
      (= v "on")))

(fn approve? [tool : Str, detail : Str]
  (if (flag-enabled? approve-all)
    true
    (do
      (close-user-input)
      (print $"approve ${tool}: ${(redact detail)}? [y/N] ")
      (var answer (read-line))
      (if (= answer nil)
        false
        (do
          (set answer (lower (trim answer)))
          (|| (= answer "y") (= answer "yes")))))))

# -----------------------------------------------------------------------------
# Tools. Each is fn(args-map) -> Str, described to the model by tool-schemas.
# -----------------------------------------------------------------------------

(fn tool-read-file [args]
  (read-text ReadDir (safe-path args/path)))

(fn tool-write-file [args]
  (if (approve? "write_file" args/path)
    (do
      (write-text WriteDir (safe-path args/path) args/content)
      $"wrote ${args/path}")
    "denied by user policy"))

(fn tool-edit-file [args]
  (var path (safe-path args/path))
  (var old-text args/old_text)
  (var new-text args/new_text)
  (if (= old-text "")
    "error: old_text must not be empty"
    (if (approve? "edit_file" args/path)
      (do
        (var text (read-text ReadDir path))
        (var parts (split text old-text))
        (var matches (- parts/~size 1))
        (if (= matches 0)
          "error: old_text not found"
          (if (> matches 1)
            $"error: old_text matched ${matches} times; provide a larger unique old_text"
            (do
              (write-text WriteDir path (join parts new-text))
              $"edited ${args/path}"))))
      "denied by user policy")))

(fn tool-list-dir [args]
  (var p (if (= args/path void) "." args/path))
  ((list-dir ReadDir (safe-path p)) ~ join "\n"))

(fn tool-run-shell [args]
  (if (denied-command? args/command)
    "denied by command policy"
    (if (approve? "run_shell" args/command)
      (do
        (var r (exec Exec ^cmd "sh" ^args ["-c" args/command] ^dir workspace-root
                     ^timeout-ms 10000 ^max-bytes 65536))
        (var tail (if r/timed-out "\n[timed out]" ""))
        $"${r/stdout}${r/stderr}${tail}")
      "denied by user policy")))

(fn tool-grep [args]
  (var p (if (= args/path void) "." args/path))
  (var r (exec Exec ^cmd "grep"
               ^args ["-rn" args/pattern (safe-path p)]
               ^dir workspace-root
               ^timeout-ms 10000 ^max-bytes 65536))
  (var tail (if r/timed-out "\n[timed out]" ""))
  $"${r/stdout}${r/stderr}${tail}")

(var tools {})
(tools ~ Map/put! "read_file" tool-read-file)
(tools ~ Map/put! "write_file" tool-write-file)
(tools ~ Map/put! "edit_file" tool-edit-file)
(tools ~ Map/put! "list_dir" tool-list-dir)
(tools ~ Map/put! "run_shell" tool-run-shell)
(tools ~ Map/put! "grep" tool-grep)

(var tool-schemas
  [{^type "function" ^name "read_file"
    ^description "Read a UTF-8 text file inside the workspace."
    ^parameters {^type "object"
                 ^properties {^path {^type "string"}}
                 ^required ["path"]}}
   {^type "function" ^name "write_file"
    ^description "Write a UTF-8 text file inside the workspace."
    ^parameters {^type "object"
                 ^properties {^path {^type "string"} ^content {^type "string"}}
                 ^required ["path" "content"]}}
   {^type "function" ^name "edit_file"
    ^description "Replace one exact text span in a UTF-8 text file inside the workspace."
    ^parameters {^type "object"
                 ^properties {^path {^type "string"}
                              ^old_text {^type "string"}
                              ^new_text {^type "string"}}
                 ^required ["path" "old_text" "new_text"]}}
   {^type "function" ^name "list_dir"
    ^description "List directory entries inside the workspace."
    ^parameters {^type "object" ^properties {^path {^type "string"}}}}
   {^type "function" ^name "run_shell"
    ^description "Run a shell command in the workspace (10s timeout)."
    ^parameters {^type "object"
                 ^properties {^command {^type "string"}}
                 ^required ["command"]}}
   {^type "function" ^name "grep"
    ^description "Search files in the workspace with grep -rn."
    ^parameters {^type "object"
                 ^properties {^pattern {^type "string"} ^path {^type "string"}}
                 ^required ["pattern"]}}])

# -----------------------------------------------------------------------------
# Responses-API item helpers.
# -----------------------------------------------------------------------------

(fn user-item [text : Str]
  {^role "user" ^content text})

(fn system-item [text : Str]
  {^role "system" ^content text})

(var gene-system-prompt """
You are a coding agent working in the Gene language repository. You can read,
write, and edit files, list directories, grep, and run shell commands after user
approval.

When writing Gene code, use the current repo's language, not generic Lisp:

- Programs are s-expressions. Calls are callable-first: `(f x y)`.
- Top-level forms run in order. `gene run file.gene` calls `(fn main [...])` if
  present; scripts may also do work at top level.
- Comments start with `#`. Modules may start with `(mod name @doc "...")`.
- Imports use namespace/module forms:
  `(import str [join split trim lower])`
  `(import std/stream [to_stream map filter each into])`
  `(import [foo : local] from "./module")`
- Bind with `(var name value)` or `(var name : Type value)`. Reassign existing
  bindings with `(set name value)`. Avoid redeclaring the same local name in a
  loop or branch; allocate mutable loop state once and update it.
- Functions use `(fn name [a : Type, b] : Return body...)`; anonymous functions
  use `(fn [x] body)`. The last expression is returned.
- Basic control forms: `(do ...)`, `(if cond then else)`, `(while cond ...)`,
  `(loop ...)`, `(repeat n ...)`, `(repeat i in n ...)`,
  `(for item in items ...)`, and `match` with `(when pattern ...)` and
  `(else ...)`.
  Boolean operators are `(&& a b)`, `(|| a b)`, and `(! a)`.
- Recoverable errors use `(try body catch (ErrorType ^field name) recovery
  ensure cleanup)`. Use `fail` for recoverable errors and `panic` only for fatal
  bugs.
- Data:
  - Lists: `[a b c]`
  - Maps: `{^key value}`; property access is `m/key`
  - Nodes: `(tag ^prop value child...)`; quasiquote nodes with backtick and
    unquote with `%`, for example `` `(p ^class "x" %text)``.
  - `nil` is absence, `void` means missing selector/omitted storage.
- Selectors and sends:
  - `x/key` is selector/property/index access.
  - `xs/~size` sends the `size` message to `xs`; prefer this over `size xs`
    when modeling receiver behavior.
  - `(x ~ msg arg)` sends a message; `(x ~ Protocol/msg)` disambiguates protocol
    message collisions.
  - Type-direct messages live inside `type`; protocol messages live inside
    `protocol` and are implemented with `impl`.
- Types/protocols:
  `(type T ^props {^name Str} (message label [self] self/name))`
  `(enum Color red green blue)` and `(enum Result (ok Any) (err Str))`
  `(protocol P (message render [self : Self] : Str))`
  `(impl P T (message render [self] "..."))`
  Single data inheritance is `^is`; behavioral composition is `^inherit`.
- Streams are pull-based and skip `void`. Common shape:
  `((to_stream xs) ~ map (fn [x] ...) ; ~ filter pred ; ~ into [])`.
- Useful stdlib examples:
  - `examples/todo_app.gene` for end-to-end web + sqlite.
  - `examples/web_demo.gene` for nodes, streams, routes, selectors.
  - `examples/protocol_demo.gene` for types, protocols, inheritance, messages.
  - `docs/design.md`, `docs/core.md`, and `docs/stdlib.md` for details.

Before changing Gene code, inspect nearby examples or docs if uncertain. After
writing Gene code, verify with at least `bin/gene parse file.gene` or
`bin/gene compile file.gene`; use `bin/gene run file.gene` when behavior matters.
""")

(enum ResponseItemKind
  assistant_message
  function_call
  other_item)

(enum ResponseContentKind
  output_text
  other_content)

(enum SseEventKind
  output_text_delta
  output_item_done
  output_text_done
  completed
  failed
  incomplete
  other_event)

(fn response-item-kind [item] : ResponseItemKind
  (match item/type
    (when "message"       ResponseItemKind/assistant_message)
    (when "function_call" ResponseItemKind/function_call)
    (else                ResponseItemKind/other_item)))

(fn response-content-kind [part] : ResponseContentKind
  (match part/type
    (when "output_text" ResponseContentKind/output_text)
    (else              ResponseContentKind/other_content)))

(fn sse-event-kind [event] : SseEventKind
  (match event/type
    (when "response.output_text.delta" SseEventKind/output_text_delta)
    (when "response.output_item.done"  SseEventKind/output_item_done)
    (when "response.output_text.done"  SseEventKind/output_text_done)
    (when "response.completed"         SseEventKind/completed)
    (when "response.failed"            SseEventKind/failed)
    (when "response.incomplete"        SseEventKind/incomplete)
    (else                              SseEventKind/other_event)))

# Pull the assistant's text out of a Responses `output` list (message items ->
# content parts of type output_text).
(fn response-output-items [resp]
  (if (= resp/output void)
    []
    (try
      ((to_stream resp/output) ~ into [])
    catch * [])))

(fn response-text [resp] : Str
  (if (! (= resp/output_text void))
    resp/output_text
    (do
      (var acc (cell ""))
      ((to_stream (response-output-items resp))
        ~ each (fn [item]
            (if (= (response-item-kind item) ResponseItemKind/assistant_message)
              ((to_stream item/content)
                ~ each (fn [part]
                    (if (= (response-content-kind part) ResponseContentKind/output_text)
                      (Cell/set acc $"${(Cell/get acc)}${part/text}")
                      nil))))))
      (Cell/get acc))))

# function_call items the model emitted this turn.
(fn response-calls [resp]
  ((to_stream (response-output-items resp))
    ~ filter (fn [item] (= (response-item-kind item) ResponseItemKind/function_call))
    ; ~ into []))

# Execute one function_call item, returning its function_call_output item.
(fn run-tool-call [call]
  (var name call/name)
  (var handler (tools ~ Map/get name))
  (var output
    (if (= handler void)
      $"error: unknown tool ${call/name}"
      (try
        (var args (parse call/arguments))
        (handler args)
      catch (OsError ^message m) $"error: ${m}"
      catch (JsonError ^message m) $"error: bad tool arguments: ${m}"
      catch * "error: tool failed")))
  {^type "function_call_output" ^call_id call/call_id ^output output})

# -----------------------------------------------------------------------------
# Transport. Live mode shells out to curl; demo mode uses a scripted closure.
# Both take a request-body string and return a parsed Responses map.
# -----------------------------------------------------------------------------

(fn api-error-text [resp]
  (var status (if (= resp/status void) "?" resp/status))
  (var message
    (if (= resp/error/message void)
      (if (= resp/detail void) "unknown API error" resp/detail)
      resp/error/message))
  (var code (if (= resp/error/code void) "" $" (${resp/error/code})"))
  $"OpenAI API error ${status}: ${message}${code}")

(fn sse-data-payload [line : Str]
  (if (starts_with? line "data: ")
    (do
      (var parts (split line "data: "))
      parts/1)
    nil))

(fn ignore-stream-delta [text]
  nil)

(fn sse-build-response [output, output-text, final]
  (if (= (Cell/get final) nil)
    {^output (Cell/get output) ^output_text (Cell/get output-text)}
    (do
      ((Cell/get final) ~ Map/put! "output" (Cell/get output))
      ((Cell/get final) ~ Map/put! "output_text" (Cell/get output-text))
      (Cell/get final))))

(fn sse-handle-payload [payload : Str, output, output-text, final, render-stream]
  (if (= payload "[DONE]")
    nil
    (try
      (var event (parse payload))
      (match (sse-event-kind event)
        (when SseEventKind/output_text_delta
          (render-stream (redact event/delta))
          (Cell/set output-text $"${(Cell/get output-text)}${event/delta}"))
        (when SseEventKind/output_item_done
          (Cell/set output (append (Cell/get output) event/item))
          nil)
        (when SseEventKind/output_text_done
          (Cell/set output-text event/text))
        (when SseEventKind/completed
          (Cell/set final event/response))
        (when SseEventKind/failed
          (Cell/set final event/response))
        (when SseEventKind/incomplete
          (Cell/set final event/response))
        (when SseEventKind/other_event
          nil))
    catch (JsonError ^message _) nil)))

(fn sse-handle-line [line : Str, output, output-text, final, render-stream]
  (var payload (sse-data-payload line))
  (if (= payload nil)
    nil
    (if (= payload void)
      nil
      (sse-handle-payload payload output output-text final render-stream))))

(fn sse-response [raw : Str]
  (var output (cell []))
  (var output-text (cell ""))
  (var final (cell nil))
  ((to_stream (split raw "\n"))
    ~ each (fn [line]
        (sse-handle-line line output output-text final ignore-stream-delta)))
  (sse-build-response output output-text final))

(fn live-transport [body : Str, render-stream]
  (var output (cell []))
  (var output-text (cell ""))
  (var final (cell nil))
  (var saw-sse (cell false))
  (var r (exec-stream Exec ^cmd "curl"
               ^args ["-sS" "-N" "-X" "POST" $"${base}/responses"
                      "-H" $"Authorization: Bearer ${auth-token}"
                      "-H" "Content-Type: application/json"
                      "-H" "Accept: text/event-stream"
                      "-H" "User-Agent: codex_cli_rs/0.0.0 (Gene AI Agent)"
                      "-H" "originator: codex_cli_rs"
                      "-d" body]
               ^timeout-ms 60000 ^max-bytes 4000000
               ^stdout-line (fn [line]
                 (if (|| (starts_with? line "event:")
                         (starts_with? line "data:"))
                   (Cell/set saw-sse true)
                   nil)
                 (sse-handle-line line output output-text final render-stream))))
  (if (! (= r/status 0))
    {^agent_error (redact $"curl failed (${r/status}): ${r/stderr}")}
    (do
      (var resp
        (if (Cell/get saw-sse)
          (sse-build-response output output-text final)
          (try
            (parse r/stdout)
          catch (JsonError ^message m)
            {^agent_error (redact $"OpenAI API returned invalid JSON: ${m}")})))
      (if (= resp/error void)
        (if (= resp/status "failed")
          {^agent_error (redact (api-error-text resp))}
          resp)
        (if (= resp/error nil)
          (if (= resp/status "failed")
            {^agent_error (redact (api-error-text resp))}
            resp)
          {^agent_error (redact (api-error-text resp))})))))

(fn call-model [transport, input-items, render-stream]
  (var body (stringify {^model model
                        ^store false
                        ^stream true
                        ^input input-items
                        ^tools tool-schemas
                        ^tool_choice "auto"
                        ^parallel_tool_calls true}))
  (transport body render-stream))

(var max-tool-turns 12)

# One turn: call the model; if it asked for tools, run them and recurse with the
# outputs appended, else render the final text. `budget` bounds tool rounds so a
# model that never stops calling tools cannot loop forever.
(fn run-turn [transport, input-items, render, render-stream, budget]
  (var streamed (cell false))
  (var resp (call-model transport input-items
              (fn [text]
                (Cell/set streamed true)
                (render-stream text))))
  (if (! (= resp/agent_error void))
    (do
      (render resp/agent_error)
      input-items)
    (do
      (var calls (response-calls resp))
      (if (empty? calls)
        (do
          (if (Cell/get streamed)
            (render "")
            (render (redact (response-text resp))))
          input-items)
        (if (<= budget 0)
          (do
            (render "[stopped: tool-call budget exhausted]")
            input-items)
          (do
            (var outputs ((to_stream calls) ~ map run-tool-call ; ~ into []))
            (each (to_stream calls) (fn [c]
              (render $"  · tool ${c/name} ${c/arguments}")))
            (run-turn transport
                      ((to_stream outputs) ~ into (append-all input-items (response-output-items resp)))
                      render
                      render-stream
                      (- budget 1))))))))

(fn append-all [xs, ys]
  ((to_stream ys) ~ into xs))

(fn append [xs, x]
  ((to_stream [x]) ~ into xs))

# -----------------------------------------------------------------------------
# Offline demo transport: turn 1 asks to list the workspace, turn 2 answers.
# Proves the full tool-call loop with no network or key.
# -----------------------------------------------------------------------------

(fn demo-transport-for []
  (var calls (cell 0))
  (fn [body, render-stream]
    (Cell/set calls (+ (Cell/get calls) 1))
    (if (= (Cell/get calls) 1)
      {^output [{^type "function_call" ^name "list_dir"
                 ^call_id "call_1" ^arguments "{\"path\":\".\"}"}]}
      {^output [{^type "message" ^role "assistant"
                 ^content [{^type "output_text"
                            ^text "I listed the workspace via the list_dir tool."}]}]})))

# -----------------------------------------------------------------------------
# Entry point.
# -----------------------------------------------------------------------------

(fn run-demo []
  (println "No OPENAI_AUTH_TOKEN or CODEX_ACCESS_TOKEN set — running the offline demo.")
  (println "user> what's in this directory?")
  (var items [(system-item gene-system-prompt)
              (user-item "what's in this directory?")])
  (run-turn (demo-transport-for) items
    (fn [text] (println $"agent> ${text}"))
    ignore-stream-delta
    max-tool-turns)
  (println "Demo complete. Set OPENAI_AUTH_TOKEN or CODEX_ACCESS_TOKEN to talk to Codex."))

(fn run-one-shot [task : Str]
  (println $"Gene AI agent - model ${model}")
  (println $"user> ${task}")
  (if (= auth-token nil)
    (println "No OPENAI_AUTH_TOKEN or CODEX_ACCESS_TOKEN set - using offline demo transport.")
    nil)
  (var streaming (cell false))
  (var transport (if (= auth-token nil) (demo-transport-for) live-transport))
  (run-turn transport
            [(system-item gene-system-prompt) (user-item task)]
            (fn [text]
              (if (Cell/get streaming)
                (do
                  (println "")
                  (Cell/set streaming false))
                nil)
              (if (= text "")
                nil
                (println $"agent> ${text}")))
            (fn [text]
              (if (= text "")
                nil
                (do
                  (if (Cell/get streaming)
                    nil
                    (do
                      (print "agent> ")
                      (Cell/set streaming true)))
                  (print text))))
            max-tool-turns)
  (if (Cell/get streaming)
    (println "")
    nil))

(fn exit-word? [line]
  (|| (= line "exit") (= line "quit")))

(fn blank-line? [line]
  (= (trim line) ""))

(fn append-transcript [transcript text]
  (Cell/set transcript (join [(Cell/get transcript) text] "")))

(var input-status "Enter sends | Paste/Shift+Enter keep newlines | /sh shell | /repl Gene REPL | /quit exit")

(fn close-user-input []
  (if (stdin-tty?)
    (close-input)
    nil))

(fn read-user-input [transcript]
  (if (stdin-tty?)
    (read-input ^prompt "" ^multiline true
                ^persistent true
                ^output (Cell/get transcript)
                ^status input-status)
    (do
      (print "you> ")
      (read-line))))

(fn refresh-user-input [transcript]
  (if (stdin-tty?)
    (refresh-input ^prompt "" ^output (Cell/get transcript) ^status input-status)
    nil))

(fn render-agent-delta [transcript streaming text]
  (if (= text "")
    nil
    (if (stdin-tty?)
      (do
        (if (Cell/get streaming)
          nil
          (do
            (append-transcript transcript "agent> ")
            (Cell/set streaming true)))
        (append-transcript transcript text)
        (refresh-user-input transcript))
      (do
        (if (Cell/get streaming)
          nil
          (do
            (print "agent> ")
            (Cell/set streaming true)))
        (print text)))))

(fn finish-agent-stream [transcript streaming]
  (if (Cell/get streaming)
    (do
      (if (stdin-tty?)
        (do
          (append-transcript transcript "\n")
          (refresh-user-input transcript))
        (println ""))
      (Cell/set streaming false))
    nil))

(fn render-agent-text [transcript streaming text]
  (finish-agent-stream transcript streaming)
  (if (stdin-tty?)
    (do
      (if (= text "")
        nil
        (do
          (append-transcript transcript $"agent> ${text}\n")
          (refresh-user-input transcript))))
    (if (= text "")
      nil
      (println $"agent> ${text}"))))

(fn run-shell-session []
  (close-user-input)
  (var shell (get-env Env "SHELL" "sh"))
  (println $"Entering shell (${shell}). Type exit/quit or Ctrl-D to return.")
  (if (stdin-tty?)
    (do
      (var script "while true; do printf 'sh> '; IFS= read -r line || break; case \"$line\" in exit|quit) break;; *) eval \"$line\";; esac; done")
      (exec-stdio Exec ^cmd shell ^args ["-c" script] ^dir workspace-root)
      (println "")
      nil)
    (do
      (var running (cell true))
      (var line nil)
      (var r nil)
      (while (Cell/get running)
        (print "sh> ")
        (set line (read-line))
        (if (= line nil)
          (Cell/set running false)
          (if (exit-word? line)
            (Cell/set running false)
            (do
              (set r (exec Exec ^cmd shell ^args ["-lc" line] ^dir workspace-root
                         ^timeout-ms 60000 ^max-bytes 400000))
              (print (redact r/stdout))
              (print (redact r/stderr))
              (if r/timed-out
                (println "[timed out]")
                nil)))))
      (println ""))))

(fn run-session-repl [items]
  (close-user-input)
  (var session {^items items
                ^model model
                ^workspace-root workspace-root
                ^tools tools
                ^tool-schemas tool-schemas})
  (var repl-env (env ^bindings {^session session}))
  (println "Entering Gene REPL. session is available. Type exit/quit or Ctrl-D to return.")
  (run-repl-session repl-env ^interactive true)
  nil)

(fn run-repl []
  (println $"Gene AI agent - model ${model}. Type /quit to exit.")
  (var items (cell [(system-item gene-system-prompt)]))
  (var transcript (cell $"Gene AI agent - model ${model}\n"))
  (var running (cell true))
  (var line nil)
  (var streaming (cell false))
  (while (Cell/get running)
    (set line (read-user-input transcript))
    (if (= line nil)
      (do
        (close-user-input)
        (Cell/set running false))
      (if (= line "/quit")
        (do
          (close-user-input)
          (Cell/set running false))
        (if (= line "/sh")
          (run-shell-session)
          (if (= line "/repl")
            (run-session-repl items)
            (if (blank-line? line)
              nil
              (do
                (append-transcript transcript $"──────\n${line}\n")
                (refresh-user-input transcript)
                (Cell/set streaming false)
                (Cell/set items
                  (run-turn live-transport
                            (append (Cell/get items) (user-item line))
                            (fn [text]
                              (render-agent-text transcript streaming text))
                            (fn [text]
                              (render-agent-delta transcript streaming text))
                            max-tool-turns))))))))))

# `gene run` auto-invokes a top-level `main` (src/gene.nim), so no explicit call.
(fn main [args]
  (var task args/raw)
  (if (blank-line? task)
    (if (= auth-token nil)
      (run-demo)
      (try
        (run-repl)
        ensure
          (close-user-input)))
    (run-one-shot task)))
