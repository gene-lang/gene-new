#!/usr/bin/env bash
set -euo pipefail

# Usage:
#   benchmarks/scripts/bench_call_burst [repeats] [calls_per_repeat]
#
# Environment:
#   GENE_BENCH_MODE=vm     (default: vm)
#   NIM=/path/to/nim       (default: nim, or ~/.nimble/bin/nim)

echo "=== Gene Benchmark ==="
echo "Date: $(date '+%Y-%m-%d %H:%M:%S %A')"
echo "Git commit: $(git rev-parse HEAD)"

NIM_BIN="${NIM:-nim}"
if ! command -v "$NIM_BIN" >/dev/null 2>&1; then
  if [ -x "$HOME/.nimble/bin/nim" ]; then
    NIM_BIN="$HOME/.nimble/bin/nim"
  else
    echo "Error: nim not found. Set NIM=/path/to/nim or add nim to PATH." >&2
    exit 1
  fi
fi

MODE="${GENE_BENCH_MODE:-vm}"
case "$MODE" in
  vm)
    SOURCE="benchmarks/computation/call_burst_vm.nim"
    LABEL="bytecode VM call burst benchmark"
    ;;
  *)
    echo "Error: GENE_BENCH_MODE must be 'vm' in this implementation." >&2
    exit 1
    ;;
esac

echo "Nim version: $("$NIM_BIN" --version 2>&1 | head -1)"
echo "Mode: $MODE"
echo ""

CACHE_DIR="build/nimcache/call-burst-$MODE"
BUILD_LOG="$CACHE_DIR/build.log"
mkdir -p bin "$CACHE_DIR"
rm -f bin/call_burst 2>/dev/null

echo "Compiling $LABEL..."
CMD=("$NIM_BIN" c --hints:off --mm:orc -d:release -d:danger --path:src --nimcache:"$CACHE_DIR" --out:bin/call_burst "$SOURCE")
if ! "${CMD[@]}" >"$BUILD_LOG" 2>&1; then
  grep -v "Warning:" "$BUILD_LOG" | grep -v "ignoring duplicate libraries" || true
  exit 1
fi
grep -v "Warning:" "$BUILD_LOG" | grep -v "ignoring duplicate libraries" || true

if [ ! -x "./bin/call_burst" ]; then
  echo "Error: bin/call_burst was not produced" >&2
  exit 1
fi

echo ""
echo "Running benchmark..."
./bin/call_burst "$@"
